<custom-slider class="template-slider-section color-{{ section.settings.color_scheme }} gradient" data-block-id="{{ section.id }}">
  <div class="slider-wrapper relative-container">
    <div class="swiper-custom-header">
      {%- if section.settings.block_heading != blank -%}
        <h2 class="swiper-custom-heading hero-features__heading {{ section.settings.heading_size }}">
          {{ section.settings.block_heading }}
        </h2>
      {%- endif -%}
    </div>
    
    <swiper-container 
        init="false" 
        class="js-swiper-template"
        data-swiper-config='{
            "autoplay": {{ section.settings.enable_autoplay | default: false }},
            "autoplayInterval": {{ section.settings.autoplay_interval | times: 1000 | default: 3000 }},
            "mobileSlides": {{ section.settings.mobile_slides | default: 2.2 }},
            "mobileSpacing": {{ section.settings.mobile_spacing | default: 16 }},
            "desktopSlides": {{ section.settings.desktop_slides | default: 4 }},
            "tabletSlides": {{ section.settings.tablet_slides | default: 3 }},
            "desktopSpacing": {{ section.settings.desktop_spacing | default: 24 }}
        }'
    >
        {% for product in section.settings.collection.products %}
            <swiper-slide>
                {% content_for 'block', type: '_product-card', id: 'static-product-card', closest.product: product %}
            </swiper-slide>
        {%- endfor -%}
    </swiper-container>

    <div class="swiper-custom-controls">
        <div class="swiper-progress-track
        {% unless section.settings.mobile_progress_bar %}hide-on-mobile{% endunless %} 
        {% unless section.settings.desktop_progress_bar %}hide-on-desktop{% endunless %}">
          <div class="swiper-progress-fill"> </div>
        </div>
        <div class="swiper-custom-controls-nav">
          <div class="swiper-custom-prev swiper-custom-arrow 
            {% unless section.settings.mobile_arrows %}hide-on-mobile{% endunless %} 
            {% unless section.settings.desktop_arrows %}hide-on-desktop{% endunless %}">
             <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          </div>
          <div class="swiper-custom-next swiper-custom-arrow 
            {% unless section.settings.mobile_arrows %}hide-on-mobile{% endunless %} 
            {% unless section.settings.desktop_arrows %}hide-on-desktop{% endunless %}">
             <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </div>
        </div>
    </div>

    <div class="swiper-custom-scrollbar
        {% unless section.settings.mobile_scrollbar %}hide-on-mobile{% endunless %} 
        {% unless section.settings.desktop_scrollbar %}hide-on-desktop{% endunless %}">
    </div>
  </div>
</custom-slider>

<style>
.template-slider-section .swiper-custom-arrow {
    cursor: pointer;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid #E0E0E0;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
    color: #265697;
}
.template-slider-section .swiper-custom-arrow svg{
      width: 20px;
    height: 20px;
    stroke: currentColor;
}
.template-slider-section .relative-container{position:relative;width:100%;}
.template-slider-section swiper-container{width:100%;display:block;}
.template-slider-section .swiper-button-disabled{opacity:0.5;}
.template-slider-section .swiper-custom-scrollbar{display:block;width:100%;height:4px;background:rgba(0,0,0,0.1);margin-top:24px;position:relative;border-radius:2px;overflow:hidden;}
.template-slider-section .swiper-scrollbar-drag{display:block;background:currentColor;height:100%;width:0;position:relative;border-radius:2px;cursor:pointer;}
.template-slider-section .swiper-progress-track{display:block;width:100%;height:3px;background:rgba(0,0,0,0.1);position:relative;overflow:hidden;}
.template-slider-section .swiper-progress-fill{    background: #265697;
    height: 100%;
    display: block;
    transition: transform 300ms;}
@media screen and (max-width:767px){.template-slider-section .hide-on-mobile{display:none !important;}}
@media screen and (min-width:768px){.template-slider-section .hide-on-desktop{display:none !important;}}
</style>

<script>
class CustomSlider extends HTMLElement {
  constructor() {
    super();
  }

  connectedCallback() {
    this.init();
  }

  init() {
    const swiperEl = this.querySelector('swiper-container');
    if (!swiperEl || swiperEl.classList.contains('initialized')) return;

    const config = this.getConfig(swiperEl);
    if (!config) return;

    const params = {
      slidesPerView: config.mobileSlides,
      spaceBetween: config.mobileSpacing,
      loop: false,
      breakpoints: {
        768: {
          slidesPerView: config.tabletSlides,
          spaceBetween: config.desktopSpacing,
        },
        1024: {
          slidesPerView: config.desktopSlides,
          spaceBetween: config.desktopSpacing,
        }
      },
      navigation: {
        nextEl: this.querySelector('.swiper-custom-next'),
        prevEl: this.querySelector('.swiper-custom-prev')
      }
    };

    const scrollbarEl = this.querySelector('.swiper-custom-scrollbar');
    if (scrollbarEl) {
      params.scrollbar = {
        el: scrollbarEl,
        draggable: true,
        hide: false
      };
    }

    if (config.autoplay) {
      params.autoplay = {
        delay: config.autoplayInterval,
        disableOnInteraction: false
      };
    }

    const progressFill = this.querySelector('.swiper-progress-fill');
    if (progressFill) {
      this.attachProgress(swiperEl, progressFill);
    }

    Object.assign(swiperEl, params);
    swiperEl.initialize();
    swiperEl.classList.add('initialized');
  }

  getConfig(el) {
    try {
      return JSON.parse(el.dataset.swiperConfig || '{}');
    } catch (e) {
      console.error(e);
      return null;
    }
  }

  attachProgress(swiperEl, fillEl) {
    const update = (swiper) => {
      const percentage = Math.max(0, Math.min(100, swiper.progress * 100));
      fillEl.style.width = `${percentage}%`;
    };

    swiperEl.addEventListener('swiperprogress', (e) => update(e.detail[0]));
    swiperEl.addEventListener('swiperslidechange', (e) => update(e.detail[0]));
  }
}

customElements.define('custom-slider', CustomSlider);
</script>

{% schema %}
{
  "name": "Slider",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    { "type": "text", "id": "block_heading", "label": "Heading", "default": "Swiper template" },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" },
        { "value": "hxl", "label": "Extra Large" },
        { "value": "hxxl", "label": "Extra Extra Large" }
      ],
      "default": "h1",
      "label": "Heading Size"
    },
    { "type": "header", "content": "⚙️ Configuration" },
    { "type": "checkbox", "id": "enable_autoplay", "label": "Enable Autoplay", "default": false },
    { "type": "range", "id": "autoplay_interval", "min": 2, "max": 10, "step": 1, "unit": "s", "label": "Autoplay Interval", "default": 3 },
    { "type": "header", "content": "💻 Desktop Settings" },
    { "type": "range", "id": "desktop_slides", "min": 1, "max": 6, "step": 0.1, "label": "Slides per view", "default": 4 },
    { "type": "range", "id": "desktop_spacing", "min": 0, "max": 100, "label": "Spacing (px)", "default": 24 },
    { "type": "checkbox", "id": "desktop_arrows", "label": "Show Arrows", "default": true },
    { "type": "checkbox", "id": "desktop_dots", "label": "Show Dots", "default": false },
    { "type": "checkbox", "id": "desktop_scrollbar", "label": "Show Draggable Scrollbar", "default": false },
    { "type": "checkbox", "id": "desktop_progress_bar", "label": "Show Visual Progress Bar", "default": true },
    { "type": "header", "content": "📱 Tablet Settings" },
    { "type": "range", "id": "tablet_slides", "min": 1, "max": 6, "step": 0.1, "label": "Slides per view", "default": 4 },
    { "type": "header", "content": "📱 Mobile Settings" },
    { "type": "range", "id": "mobile_slides", "min": 1, "max": 6, "step": 0.1, "label": "Slides per view", "default": 1.2 },
    { "type": "range", "id": "mobile_spacing", "min": 0, "max": 50, "label": "Spacing (px)", "default": 16 },
    { "type": "checkbox", "id": "mobile_arrows", "label": "Show Arrows", "default": false },
    { "type": "checkbox", "id": "mobile_dots", "label": "Show Dots", "default": true },
    { "type": "checkbox", "id": "mobile_scrollbar", "label": "Show Draggable Scrollbar", "default": false },
    { "type": "checkbox", "id": "mobile_progress_bar", "label": "Show Visual Progress Bar", "default": true }
  ],
  "blocks": [
    {
        "type": "@theme"
    }
  ],
  "presets": [
    {
      "name": "Slider template",
      "category": "Template"
    }
  ]
}
{% endschema %}