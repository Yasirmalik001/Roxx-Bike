{{ 'section-hero-overlay.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .footer-cta-{{ section.id }} {
    position: relative;
    display: flex;
    min-height: {{ section.settings.mobile_height }}px;
    background-color: #000000;
    
    /* Mobile Alignment */
    align-items: {{ section.settings.mobile_align_y }};
    justify-content: {{ section.settings.mobile_align_x }};
  }

  @media screen and (min-width: 750px) {
    .footer-cta-{{ section.id }} {
      min-height: {{ section.settings.desktop_height }}px;
      
      /* Desktop Alignment */
      align-items: {{ section.settings.desktop_align_y }};
      justify-content: {{ section.settings.desktop_align_x }};
    }
  }

  .footer-cta-{{ section.id }} .hero-background-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  /* Different Overlay logic: Top and Bottom Gradients */
  .footer-cta-{{ section.id }} .hero-overlay-top {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: {{ section.settings.top_gradient_height }}%;
    background: linear-gradient(to bottom, #000000 0%, transparent 100%);
    z-index: 2;
  }

  .footer-cta-{{ section.id }} .hero-overlay-bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: {{ section.settings.bottom_gradient_height }}%;
    background: linear-gradient(to top, #000000 0%, transparent 100%);
    z-index: 2;
  }

  .footer-cta-{{ section.id }} .hero-content-wrapper {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    width: 100%;
    color: #ffffff;
    text-align: {{ section.settings.mobile_text_align }};
    align-items: {{ section.settings.mobile_flex_align }};
  }

  @media screen and (min-width: 750px) {
    .footer-cta-{{ section.id }} .hero-content-wrapper {
      /* Desktop Content Alignment */
      text-align: {{ section.settings.desktop_text_align }};
      align-items: {{ section.settings.desktop_flex_align }};
    }
  }
  @media screen and (max-width: 750px) {
      .footer-cta-{{ section.id }} .hero-background-image {
         object-position: 50% 100%;
      }
      .footer-cta-{{ section.id }} .hero-overlay-top {
         height: {{ section.settings.mobile_top_gradient_height }}%;
         background: linear-gradient(to bottom, #000000 0%, #000000 {{ section.settings.mobile_solid_black_top }}%, transparent 100%);
      }
      .footer-cta-{{ section.id }} .hero-overlay-bottom {
         height: {{ section.settings.mobile_bottom_gradient_height }}%;
      }
  }
{%- endstyle -%}

<div class="footer-cta-{{ section.id }} section-{{ section.id }}-padding">
  {%- if section.settings.image != blank -%}
    {{
      section.settings.image
      | image_url: width: 3840
      | image_tag:
        loading: 'lazy',
        class: 'hero-background-image',
        sizes: '100vw',
        widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
    }}
  {%- endif -%}

  <div class="hero-overlay-top"> </div>
  <div class="hero-overlay-bottom"> </div>

  <div class="hero-content-wrapper page-width">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        
        {%- when 'heading' -%}
          <h2 class="hero-block-heading h1" {{ block.shopify_attributes }} style="font-size: {{ block.settings.font_size }}px;">
            {{ block.settings.heading | escape }}
          </h2>

        {%- when 'text' -%}
          <div class="hero-block-text" {{ block.shopify_attributes }} style="font-size: 16px; margin-bottom: 10px;">
            {{ block.settings.text }}
          </div>

        {%- when 'button' -%}
          {%- if block.settings.button_label != blank -%}
            <a href="{{ block.settings.button_link }}" class="hero-block-button-pill-yellow" {{ block.shopify_attributes }}>
              {{ block.settings.button_label | escape }}
              <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-arrow" viewBox="0 0 14 10" style="margin-left: 8px; width: 14px; height: 10px;"><path fill-rule="evenodd" clip-rule="evenodd" d="M8.537.808a.5.5 0 01.817-.162l4 4a.5.5 0 010 .708l-4 4a.5.5 0 11-.708-.708L11.793 5.5H1a.5.5 0 010-1h10.793L8.646 1.354a.5.5 0 01-.109-.546z" fill="currentColor"></path></svg>
            </a>
          {%- endif -%}

      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>

<style>
  /* Base Scoped Styles */
  .footer-cta-{{ section.id }} .hero-content-wrapper * {
    margin: 0
  }
  
  .footer-cta-{{ section.id }} .hero-block-heading {
    line-height: 1.1;
    margin-bottom: 10px;
    font-weight: 800;
    max-width: 600px;
  }
  
  .footer-cta-{{ section.id }} .hero-block-text {
    font-size: 16px;
    line-height: 1.5;
    max-width: 600px;
    font-weight: 400;
  }
  
  .hero-block-button-pill-yellow {
    margin-top: 10px;
    display: inline-flex;
    justify-content: center;
    align-items: center;
    padding: 1.4rem 3.6rem;
    background-color: #ffd800;
    color: #000000;
    border-radius: 50px; 
    font-weight: 800;
    font-size: 14px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    min-width: 250px;
    transition: all 0.3s ease;
  }
  
  .hero-block-button-pill-yellow:hover {
    background-color: #e6c200;
    transform: translateY(-2px);
  }

  @media screen and (max-width: 749px) {
    .footer-cta-{{ section.id }} .hero-block-heading {
      font-size: 24px !important;
    }
    .footer-cta-{{ section.id }} .hero-block-text {
      font-size: 14px !important;
    }
    .hero-block-button-pill-yellow {
      padding: 1.2rem 2.8rem;
      min-width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Footer CTA Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "header",
      "content": "Gradient Overlays (Desktop)"
    },
    {
      "type": "range",
      "id": "top_gradient_height",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Top Gradient Height",
      "default": 30
    },
    {
      "type": "range",
      "id": "bottom_gradient_height",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Bottom Gradient Height",
      "default": 50
    },
    {
      "type": "header",
      "content": "Gradient Overlays (Mobile)"
    },
    {
      "type": "range",
      "id": "mobile_top_gradient_height",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Top Gradient Height",
      "default": 60
    },
    {
      "type": "range",
      "id": "mobile_solid_black_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Solid Black Top Area",
      "default": 30
    },
    {
      "type": "range",
      "id": "mobile_bottom_gradient_height",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Bottom Gradient Height",
      "default": 40
    },
    {
      "type": "header",
      "content": "Desktop Layout"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "min": 400,
      "max": 1000,
      "step": 20,
      "unit": "px",
      "label": "Desktop Height",
      "default": 600
    },
    {
      "type": "select",
      "id": "desktop_align_y",
      "label": "Vertical Alignment",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Middle" },
        { "value": "flex-end", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "desktop_align_x",
      "label": "Horizontal Position",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "desktop_text_align",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "desktop_flex_align",
      "label": "Content Box Alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Mobile Layout"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 300,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Mobile Height",
      "default": 500
    },
    {
      "type": "select",
      "id": "mobile_align_y",
      "label": "Vertical Alignment",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Middle" },
        { "value": "flex-end", "label": "Bottom" }
      ],
      "default": "flex-start"
    },
    {
      "type": "select",
      "id": "mobile_align_x",
      "label": "Horizontal Position",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "mobile_text_align",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "mobile_flex_align",
      "label": "Content Box Alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "READY TO RIDE SMARTER?",
          "label": "Heading"
        },
        {
          "type": "range",
          "id": "font_size",
          "min": 20,
          "max": 80,
          "step": 2,
          "unit": "px",
          "label": "Desktop Font Size",
          "default": 48
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 2,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Upgrade your everyday commute with the Roxx Joleem X.</p>",
          "label": "Description"
        }
      ]
    },
    {
      "type": "button",
      "name": "Primary Button",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label",
          "default": "BOOK A TEST RIDE",
          "label": "Button Label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer CTA Banner",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "text"
        },
        {
          "type": "button"
        }
      ]
    }
  ]
}
{% endschema %}
