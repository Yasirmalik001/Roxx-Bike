<style>
  .custom-showroom-map {
    position: relative;
    width: 100%;
    min-height: 650px;
    display: flex;
    align-items: center;
    overflow: hidden;
    background-color: #E2EFF3; /* Fallback map color */
  }

  .showroom-bg-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .showroom-bg-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  
  .showroom-bg-image svg {
    width: 100%;
    height: 100%;
    background-color: #f3f3f3;
  }

  /* NEW: Embed Map Styling */
  .showroom-embed-map {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .showroom-embed-map iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  /* Map Pin Styling */
  .showroom-map-pin {
    position: absolute;
    z-index: 2;
    transform: translate(-50%, -100%); /* Centers the point of the pin exactly on the coordinates */
    width: 60px; /* Matches your Figma dimensions */
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .showroom-map-pin img, 
  .showroom-map-pin svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .showroom-content-wrapper {
    position: relative;
    z-index: 3;
    width: 100%;
    padding-top: 32px;
    padding-bottom: 32px;
    pointer-events: none; /* Allows interacting with the map behind the wrapper */
  }

  .showroom-card {
    border-radius: 12px;
    padding: 28px 24px;
    max-width: 460px;
    pointer-events: auto; /* Re-enables clicking inside the card */
  }

  .showroom-heading.h2 {
    margin: 0;
  }

  .showroom-address {
    font-size: 16px;
    line-height: 1.5;
    margin-bottom: 24px;
  }

  .showroom-hours {
    font-size: 16px;
    line-height: 1.5;
    margin-bottom: 40px;
  }

  /* Target bold text in rich text to match design */
  .showroom-hours strong {
    font-weight: 700;
  }

  .showroom-buttons {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .showroom-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    font-family: inherit;
    font-weight: 800;
    font-size: 13.6px;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 30px;
    min-width: 160px;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .btn-primary {
    background-color: #FFD100;
    color: #000000;
    border: 1px solid #FFD100;
  }

  .btn-primary:hover {
    background-color: #e6bc00;
    border-color: #e6bc00;
  }

  .btn-secondary {
    background-color: transparent;
    color: currentColor;
    border: 1px solid currentColor;
  }

  .btn-secondary:hover {
    background-color: rgba(var(--color-foreground), 0.05);
  }

  /* Responsive Adjustments */
  @media screen and (max-width: 768px) {
    .custom-showroom-map {
      min-height: 500px;
      align-items: flex-start;
    }
    
    .showroom-content-wrapper {
      padding: 32px;
    }
    
    .showroom-card {
      padding: 32px;
      max-width: 100%;
    }
    
    .showroom-buttons {
      flex-direction: column;
      gap: 16px;
    }
    
    .showroom-btn {
      width: 100%;
    }
    
    .showroom-map-pin {
      transform: translate(-50%, -100%) scale(0.8);
    }
  }
</style>

<section class="custom-showroom-map">
  
  {% if section.settings.map_type == 'image' %}
    <div class="showroom-bg-image">
      {% if section.settings.map_image != blank %}
        {{ section.settings.map_image | image_url: width: 2000 | image_tag: loading: 'lazy', sizes: '100vw' }}
      {% else %}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>

    <div class="showroom-map-pin" style="top: {{ section.settings.pin_top }}%; left: {{ section.settings.pin_left }}%;">
      {% if section.settings.pin_image != blank %}
        {{ section.settings.pin_image | image_url: width: 120 | image_tag: loading: 'lazy' }}
      {% else %}
        <svg width="60" height="89" viewBox="0 0 60 89" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M30 1C14 1 1 14 1 30C1 48 30 87 30 87C30 87 59 48 59 30C59 14 46 1 30 1Z" fill="white" stroke="black" stroke-width="1.5"/>
          <text x="30" y="34" font-family="Arial, sans-serif" font-weight="900" font-style="italic" font-size="14" text-anchor="middle" fill="#FFD100">ROXX</text>
        </svg>
      {% endif %}
    </div>
  {% else %}
    <div class="showroom-embed-map">
      {% if section.settings.embed_html != blank %}
        {{ section.settings.embed_html }}
      {% else %}
        <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: #eee;">
          <p>Please paste your map iframe code in the section settings.</p>
        </div>
      {% endif %}
    </div>
  {% endif %}

  <div class="showroom-content-wrapper page-width">
    <div class="showroom-card color-{{ section.settings.color_scheme }} gradient">
      {% if section.settings.heading != blank %}
        <h2 class="showroom-heading {{ section.settings.heading_size }}">{{ section.settings.heading | escape }}</h2>
      {% endif %}

      {% if section.settings.address != blank %}
        <div class="showroom-address">
          {{ section.settings.address }}
        </div>
      {% endif %}

      {% if section.settings.hours != blank %}
        <div class="showroom-hours">
          {{ section.settings.hours }}
        </div>
      {% endif %}

      <div class="showroom-buttons">
        {% if section.settings.primary_button_label != blank %}
          <a href="{{ section.settings.primary_button_link | default: '#' }}" class="showroom-btn btn-primary">
            {{ section.settings.primary_button_label | escape }}
          </a>
        {% endif %}
        
        {% if section.settings.secondary_button_label != blank %}
          <a href="{{ section.settings.secondary_button_link | default: '#' }}" class="showroom-btn btn-secondary">
            {{ section.settings.secondary_button_label | escape }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Showroom Map",
  "settings": [
    {
      "type": "header",
      "content": "Map Background Settings"
    },
    {
      "type": "select",
      "id": "map_type",
      "label": "Map Display Type",
      "options": [
        { "value": "image", "label": "Image Map with Pin" },
        { "value": "embed", "label": "Embedded HTML Map (e.g. Google Maps)" }
      ],
      "default": "image"
    },
    {
      "type": "html",
      "id": "embed_html",
      "label": "Embed HTML Map",
      "info": "Paste your <iframe> code here (e.g., from Google Maps). It will automatically expand to fill the background."
    },
    {
      "type": "image_picker",
      "id": "map_image",
      "label": "Background Map Image",
      "info": "Only visible if 'Image Map with Pin' is selected."
    },
    {
      "type": "header",
      "content": "Map Pin Settings (Image Type Only)"
    },
    {
      "type": "image_picker",
      "id": "pin_image",
      "label": "Custom Map Pin / Logo",
      "info": "Upload a custom pin (SVG or transparent PNG). If left blank, the default ROXX pin will show."
    },
    {
      "type": "range",
      "id": "pin_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Pin Vertical Position (Top)",
      "default": 35
    },
    {
      "type": "range",
      "id": "pin_left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Pin Horizontal Position (Left)",
      "default": 40
    },
    {
      "type": "header",
      "content": "Card Content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" },
        { "value": "hxl", "label": "Extra Large" },
        { "value": "hxxl", "label": "Extra Extra Large" }
      ],
      "default": "h1",
      "label": "Heading Size"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "THE ROXX BIKE SHOWROOM IN WEESP"
    },
    {
      "type": "richtext",
      "id": "address",
      "label": "Address Text",
      "default": "<p>Pampuslaan 59A<br>1382 JM Weesp</p>"
    },
    {
      "type": "richtext",
      "id": "hours",
      "label": "Operating Hours Text",
      "default": "<p>we are open from <strong>monday to friday 9:00 am to 6:00 pm</strong></p>"
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Primary Button Label",
      "default": "GET DIRECTION"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary Button Label",
      "default": "CALL US"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary Button Link"
    }
  ],
  "presets": [
    {
      "name": "Showroom Map"
    }
  ]
}
{% endschema %}