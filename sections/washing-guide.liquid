{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="sr-wash-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="sr-wash-header">
      <h2 class="sr-wash-title">{{ section.settings.heading }}</h2>
    </div>

    <div class="sr-wash-grid-wrapper">
      <div class="sr-wash-grid">
        {%- for block in section.blocks -%}
          <div class="sr-wash-col" {{ block.shopify_attributes }}>
            <div class="sr-wash-image-wrap">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  alt="{{ block.settings.title | escape }}"
                  loading="lazy"
                  class="sr-wash-img"
                >
              {%- else -%}
                <div class="sr-wash-placeholder">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
              {%- endif -%}
            </div>

            <div class="sr-wash-timeline">
              <div class="sr-wash-line" style="background-color: {{ section.settings.accent_color }};"></div>
              <span class="sr-wash-num" style="background-color: {{ section.settings.accent_color }}; color: #ffffff;">
                {{ forloop.index }}
              </span>
            </div>

            <div class="sr-wash-card color-{{ section.settings.card_color_scheme }} gradient">
              <h3 class="sr-wash-card-title" style="color: {{ section.settings.accent_color }};">
                {{ block.settings.title }}
              </h3>
              <div class="sr-wash-card-text" style="color: {{ section.settings.accent_color }};">
                {{ block.settings.text }}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    {%- if section.settings.note_text != blank -%}
      <div class="sr-wash-note-container">
        <div class="sr-wash-note color-{{ section.settings.card_color_scheme }} gradient">
          <span class="sr-wash-note-text" style="color: {{ section.settings.accent_color }};">
            {{ section.settings.note_text }}
          </span>
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

{% comment %} Styles moved to sereluna.css {% endcomment %}

{% schema %}
{
  "name": "Washing Guide",
  "tag": "section",
  "class": "section",
  "max_blocks": 3,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Main Section Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "card_color_scheme",
      "label": "Card & Note Color Scheme",
      "default": "scheme-2",
      "info": "Use this for the light pink background."
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Text & Line)",
      "default": "#F5F2ED"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How to wash our period pants"
    },
    {
      "type": "textarea",
      "id": "note_text",
      "label": "Bottom Note Text",
      "default": "!Note: Please do not use fabric softener, bleach or any chemical as they can clog the absorbent layers when used regularly and reduce absorbency"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Washing Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Step Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Step Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Washing Guide",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Rinse in cold water",
            "text": "<p>Blood hardens in water warmer than body temperature (37°C). That's why the underwear should always be rinsed thoroughly in cold running water before washing.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Wash in 30-40°C",
            "text": "<p>Wash in the washing machine or by hand at 30-40°C with similar colors. Please use a gentle detergent.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Air dry",
            "text": "<p>Wring out the underwear before drying, as it holds liquid and may take longer to dry. Avoid heaters or direct heat. To speed up drying, you can spin it in the washing machine.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
