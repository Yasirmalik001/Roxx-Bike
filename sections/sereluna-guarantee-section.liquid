{%- style -%}
  #sr-guarantee-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  /* --- Mobile Adjustments --- */
  @media screen and (max-width: 768px) {
    #sr-guarantee-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }

.sereluna-guarantee-section {
    width: 100vw;
    max-width: 100%;
    display: flex;
    justify-content: center;
    padding-left: 20px;
    padding-right: 20px;
    box-sizing: border-box;
    overflow: hidden;
    padding-bottom: 30px;
}

  .sereluna-banner-wrapper {
    position: relative;
    width: 100%;
    max-width: 1150px;
    border-radius: 24px;
    padding: 60px 20px;
    text-align: center;
    overflow: hidden; 
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 250px;
  }

  .sereluna-shape {
    position: absolute;
    z-index: 1;
    object-fit: contain;
  }

  /* Desktop and Mobile Image Visibility Toggles */
  .shape-mobile { display: none; }
  @media (max-width: 768px) {
    .shape-desktop { display: none; }
    .shape-mobile { display: block; }
  }

  .sereluna-content-wrapper {
    position: relative;
    z-index: 2; 
    max-width: 600px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 20px; 
  }

  /* Block Styles */
  .sereluna-block-heading {
    font-size: 32px;
    font-weight: 400;
    margin: 0;
  }

  .sereluna-block-richtext {
    font-size: 14px;
    line-height: 1.6;
    margin: 0;
  }

  .sereluna-block-richtext p {
    margin: 0 0 10px 0; 
  }

  .sereluna-block-richtext p:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .sereluna-banner-wrapper {
      padding: 40px 15px;
    }
    .sereluna-block-heading {
      font-size: 26px;
    }
  }

  /* --- Dynamic Shape Block CSS --- */
  {%- for block in section.blocks -%}
    {%- if block.type == 'shape' -%}
      #sr-guarantee-{{ section.id }} .shape-{{ block.id }} {
        max-width: {{ block.settings.width_desktop }}px;
        width: 100%;
        {{ block.settings.vertical_alignment }}: {{ block.settings.pos_y_desktop }}%;
        {{ block.settings.horizontal_alignment }}: {{ block.settings.pos_x_desktop }}%;
        z-index: {{ block.settings.z_index }};
      }
      
      @media screen and (max-width: 768px) {
        #sr-guarantee-{{ section.id }} .shape-{{ block.id }} {
          max-width: {{ block.settings.width_mobile }}px;
          {{ block.settings.vertical_alignment }}: {{ block.settings.pos_y_mobile }}%;
          {{ block.settings.horizontal_alignment }}: {{ block.settings.pos_x_mobile }}%;
          z-index: {{ block.settings.z_index }};
        }
      }
    {%- endif -%}
  {%- endfor -%}
{%- endstyle -%}

<div id="sr-guarantee-{{ section.id }}" class="sereluna-guarantee-section">
  <div class="sereluna-banner-wrapper color-{{ section.settings.color_scheme }} gradient">
    
   <div class="sereluna-images-wrapper">
      {%- for block in section.blocks -%}
        {%- if block.type == 'shape' -%}
          {%- assign mobile_image = block.settings.image_mobile | default: block.settings.image_desktop -%}
          
          {%- assign desktop_class = 'sereluna-shape shape-desktop shape-' | append: block.id -%}
          {%- assign mobile_class = 'sereluna-shape shape-mobile shape-' | append: block.id -%}
          
          {%- if block.settings.image_desktop != blank -%}
            {{ block.settings.image_desktop | image_url: width: 400 | image_tag: class: desktop_class, loading: 'lazy' }}
          {%- endif -%}
          
          {%- if mobile_image != blank -%}
            {{ mobile_image | image_url: width: 400 | image_tag: class: mobile_class, loading: 'lazy' }}
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
    <div class="sereluna-content-wrapper">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          
          {%- when 'heading' -%}
            {%- if block.settings.title != blank -%}
              <h2 class="sereluna-block-heading" {{ block.shopify_attributes }}>
                {{ block.settings.title }}
              </h2>
            {%- endif -%}

          {%- when 'description' -%}
            {%- if block.settings.text != blank -%}
              <div class="sereluna-block-richtext" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </div>
            {%- endif -%}

        {%- endcase -%}
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Risk Free Banner",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading text",
          "default": "Try Sereluna risk-free"
        }
      ]
    },
    {
      "type": "description",
      "name": "Description text",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Description",
          "default": "<p>Your comfort matters.</p><p>If Sereluna isn't the right fit for you, our 60-day guarantee means you're not taking any risk.</p><p>We're here to help — whether that's a size change, advice, or a refund.</p>"
        }
      ]
    },
    {
      "type": "shape",
      "name": "Decorative Shape",
      "settings": [
        {
          "type": "header",
          "content": "Images"
        },
        {
          "type": "image_picker",
          "id": "image_desktop",
          "label": "Desktop Image"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Mobile Image (optional)",
          "info": "Leave empty to use the desktop image on mobile."
        },
        {
          "type": "header",
          "content": "Size"
        },
        {
          "type": "range",
          "id": "width_desktop",
          "min": 50, "max": 400, "step": 5, "unit": "px",
          "label": "Desktop Width",
          "default": 200
        },
        {
          "type": "range",
          "id": "width_mobile",
          "min": 50, "max": 400, "step": 5, "unit": "px",
          "label": "Mobile Width",
          "default": 150
        },
        {
          "type": "header",
          "content": "Desktop Positioning"
        },
        {
          "type": "select",
          "id": "vertical_alignment",
          "label": "Vertical Alignment",
          "options": [
            {"value": "top", "label": "Top"},
            {"value": "bottom", "label": "Bottom"}
          ],
          "default": "top"
        },
        {
          "type": "range",
          "id": "pos_y_desktop",
          "min": -100, "max": 100, "step": 2, "unit": "%",
          "label": "Vertical Position (Desktop)",
          "default": 0
        },
        {
          "type": "select",
          "id": "horizontal_alignment",
          "label": "Horizontal Alignment",
          "options": [
            {"value": "left", "label": "Left"},
            {"value": "right", "label": "Right"}
          ],
          "default": "left"
        },
        {
          "type": "range",
          "id": "pos_x_desktop",
          "min": -100, "max": 100, "step": 2, "unit": "%",
          "label": "Horizontal Position (Desktop)",
          "default": 0
        },
        {
          "type": "header",
          "content": "Mobile Positioning"
        },
        {
          "type": "range",
          "id": "pos_y_mobile",
          "min": -100, "max": 100, "step": 2, "unit": "%",
          "label": "Vertical Position (Mobile)",
          "default": 0
        },
        {
          "type": "range",
          "id": "pos_x_mobile",
          "min": -100, "max": 100, "step": 2, "unit": "%",
          "label": "Horizontal Position (Mobile)",
          "default": 0
        },
        {
          "type": "range",
          "id": "z_index",
          "min": -5,
          "max": 10,
          "step": 1,
          "label": "Z-Index (Stacking Order)",
          "info": "Higher numbers sit on top of lower numbers.",
          "default": 1
        },
      ]
    }
  ],
  "presets": [
    {
      "name": "Risk Free Banner",
      "blocks": [
        { "type": "heading" },
        { "type": "description" },
        { 
          "type": "shape",
          "settings": {
            "vertical_alignment": "top",
            "horizontal_alignment": "left",
            "pos_y_desktop": -10,
            "pos_y_mobile": -10,
            "width_desktop": 250
          }
        },
        { 
          "type": "shape",
          "settings": {
            "vertical_alignment": "bottom",
            "horizontal_alignment": "left",
            "pos_y_desktop": -10,
            "pos_y_mobile": -10,
            "width_desktop": 180
          }
        },
        { 
          "type": "shape",
          "settings": {
            "vertical_alignment": "top",
            "horizontal_alignment": "right",
            "pos_y_desktop": -10,
            "pos_y_mobile": -10,
            "width_desktop": 160
          }
        },
        { 
          "type": "shape",
          "settings": {
            "vertical_alignment": "bottom",
            "horizontal_alignment": "right",
            "pos_y_desktop": -10,
            "pos_y_mobile": -10,
            "width_desktop": 150
          }
        }
      ]
    }
  ]
}
{% endschema %}