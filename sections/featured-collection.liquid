<custom-slider class="template-slider-section" data-block-id="{{ section.id }}">
  <div class="slider-wrapper relative-container container-x">
      <div class="l-cat-header">
      <div class="l-cat-title-group">
        <h2 class="l-cat-main-title-{{ section.id }}">{{ section.settings.title }}</h2>
        {% if section.settings.view_all_link != blank %}
          <a href="{{ section.settings.view_all_link }}" class="view-all">{{ section.settings.view_all_text }}</a>
        {% endif %}
      </div>
      <div class="swiper-custom-controls-nav">
          <div class="swiper-custom-prev swiper-custom-arrow 
            {% unless section.settings.mobile_arrows %}hide-on-mobile{% endunless %} 
            {% unless section.settings.desktop_arrows %}hide-on-desktop{% endunless %}">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M20 12L4 12M4 12L10 6M4 12L10 18" stroke="#000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
          </div>
          <div class="swiper-custom-next swiper-custom-arrow 
            {% unless section.settings.mobile_arrows %}hide-on-mobile{% endunless %} 
            {% unless section.settings.desktop_arrows %}hide-on-desktop{% endunless %}">
   <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M4 12L20 12M20 12L14 18M20 12L14 6" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
          </div>
        </div>
    </div>

    <swiper-container 
        init="false" 
        class="js-swiper-template"
        data-swiper-config='{
            "autoplay": {{ section.settings.enable_autoplay | default: false }},
            "autoplayInterval": {{ section.settings.autoplay_interval | times: 1000 | default: 3000 }},
            "mobileSlides": {{ section.settings.mobile_slides | default: 1.2 }},
            "mobileSpacing": {{ section.settings.mobile_spacing | default: 16 }},
            "desktopSlides": {{ section.settings.desktop_slides | default: 4 }},
            "tabletSlides": {{ section.settings.tablet_slides | default: 3 }},
            "desktopSpacing": {{ section.settings.desktop_spacing | default: 24 }}
        }'
    >
        {% for product in section.settings.collection.products %}
            <swiper-slide>
                {% render 'card-product',
                    card_product: product,
                    media_aspect_ratio: 'portrait',
                    show_secondary_image: true,
                    show_vendor: false,
                    show_rating: false,
                    lazy_load: true
                  %}
            </swiper-slide>
        {%- endfor -%}
    </swiper-container>

    <div class="swiper-custom-controls">
        <div class="swiper-progress-track
        {% unless section.settings.mobile_progress_bar %}hide-on-mobile{% endunless %} 
        {% unless section.settings.desktop_progress_bar %}hide-on-desktop{% endunless %}">
          <div class="swiper-progress-fill"> </div>
        </div>
    </div>

    <div class="swiper-custom-scrollbar
        {% unless section.settings.mobile_scrollbar %}hide-on-mobile{% endunless %} 
        {% unless section.settings.desktop_scrollbar %}hide-on-desktop{% endunless %}">
    </div>
  </div>
</custom-slider>

<style>
/* Added padding for page-width */
.template-slider-section .page-width {
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    margin: 0 auto;
    max-width: 1200px; /* Adjust based on your theme */
}

.template-slider-section .swiper-custom-header {
    margin-bottom: 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.template-slider-section .l-cat-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 25px;
}

.template-slider-section .swiper-custom-arrow {
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
}

.template-slider-section .relative-container { position:relative; width:100%; margin: 0 auto; padding-top: 40px;
    padding-bottom: 40px;; }
.template-slider-section swiper-container { width:100%; display:block; }
.template-slider-section swiper-slide { height: auto; } /* Ensures cards are same height */

.template-slider-section .swiper-button-disabled { opacity:0.5; cursor: not-allowed; }

.template-slider-section .swiper-custom-scrollbar {
    display:block;
    width:100%;
    height:4px;
    background:rgba(0,0,0,0.1);
    margin-top:24px;
    position:relative;
    border-radius:2px;
    overflow:hidden;
}

.template-slider-section .swiper-progress-track {
    display:block;
    width:100%;
    height:3px;
    background:rgba(0,0,0,0.1);
    position:relative;
    overflow:hidden;
    margin-top: 20px;
}

.template-slider-section .swiper-progress-fill {    
    background: #265697;
    height: 100%;
    display: block;
    width: 0; /* Starts at 0 */
    transition: width 300ms;
}

.swiper-custom-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 15px;
}

.swiper-custom-controls-nav {
    display: flex;
    gap: 15px;
}
.l-cat-main-title-{{ section.id }} {
  font-size: 48px;
  margin: 0;
  font-weight: 400;
  line-height: 1.1;
  text-transform: uppercase;
}

@media screen and (max-width:767px){
    .l-cat-main-title-{{ section.id }} {
    font-size: 28px;
  }
    .template-slider-section .hide-on-mobile{display:none !important;}
}
@media screen and (min-width:768px){
    .template-slider-section .hide-on-desktop{display:none !important;}
    
}
</style>


{% schema %}
{
  "name": "Featured Collection",
  "class": "section",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    { "type": "text", "id": "title", "label": "Heading", "default": "FOLLOW US ON INSTAGRAM" },
    { "type": "url", "id": "view_all_link", "label": "View All Link" },
    { "type": "text", "id": "view_all_text", "label": "View All Link Text", "default": "@luxiaojuneurope" },
    { "type": "header", "content": "⚙️ Configuration" },
    { "type": "checkbox", "id": "enable_autoplay", "label": "Enable Autoplay", "default": false },
    { "type": "range", "id": "autoplay_interval", "min": 2, "max": 10, "step": 1, "unit": "s", "label": "Autoplay Interval", "default": 3 },
    { "type": "header", "content": "💻 Desktop Settings" },
    { "type": "range", "id": "desktop_slides", "min": 1, "max": 6, "step": 0.1, "label": "Slides per view", "default": 4 },
    { "type": "range", "id": "desktop_spacing", "min": 0, "max": 100, "label": "Spacing (px)", "default": 24 },
    { "type": "checkbox", "id": "desktop_arrows", "label": "Show Arrows", "default": true },
    { "type": "checkbox", "id": "desktop_dots", "label": "Show Dots", "default": false },
    { "type": "checkbox", "id": "desktop_scrollbar", "label": "Show Draggable Scrollbar", "default": false },
    { "type": "checkbox", "id": "desktop_progress_bar", "label": "Show Visual Progress Bar", "default": true },
    { "type": "header", "content": "📱 Tablet Settings" },
    { "type": "range", "id": "tablet_slides", "min": 1, "max": 6, "step": 0.1, "label": "Slides per view", "default": 3 },
    { "type": "header", "content": "📱 Mobile Settings" },
    { "type": "range", "id": "mobile_slides", "min": 1, "max": 6, "step": 0.1, "label": "Slides per view", "default": 1.2 },
    { "type": "range", "id": "mobile_spacing", "min": 0, "max": 50, "label": "Spacing (px)", "default": 16 },
    { "type": "checkbox", "id": "mobile_arrows", "label": "Show Arrows", "default": false },
    { "type": "checkbox", "id": "mobile_dots", "label": "Show Dots", "default": true },
    { "type": "checkbox", "id": "mobile_scrollbar", "label": "Show Draggable Scrollbar", "default": false },
    { "type": "checkbox", "id": "mobile_progress_bar", "label": "Show Visual Progress Bar", "default": true }
  ],
  "presets": [
    {
      "name": "Featured Collection",
      "category": "Template"
    }
  ]
}
{% endschema %}