{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ====== Featured Collection Header ====== */
  .fc-{{ section.id }}__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .fc-{{ section.id }}__header-left {
    max-width: 600px;
  }

  .fc-{{ section.id }}__heading {
    font-size: 4.8rem;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: #000000;
    margin: 0 0 1.2rem 0;
  }

  .fc-{{ section.id }}__description {
    font-size: 1.4rem;
    line-height: 1.5;
    color: #555555;
    margin: 0;
    max-width: 500px;
  }

  .fc-{{ section.id }}__discover-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 1.2rem 2.4rem;
    border: 1.5px solid #111111;
    border-radius: 30px;
    background: transparent;
    color: #111111;
    font-size: 1.1rem;
    font-weight: 800;
    text-transform: uppercase;
    text-decoration: none;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.25s ease;
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 0.5rem;
  }

  .fc-{{ section.id }}__discover-btn:hover {
    background: #111111;
    color: #ffffff;
  }

  /* ====== Products Grid / Slider ====== */
  .fc-{{ section.id }}__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: {{ section.settings.gap_desktop }}px;
    width: 100%;
  }

  .fc-{{ section.id }}__grid-item {
    min-width: 0;
  }

  @media screen and (max-width: 989px) {
    .fc-{{ section.id }}__header {
      flex-direction: column;
      gap: 1.5rem;
    }

    .fc-{{ section.id }}__heading {
      font-size: 3.2rem;
    }

    .fc-{{ section.id }}__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
  }

  @media screen and (max-width: 749px) {
    .fc-{{ section.id }}__heading {
      font-size: 2.8rem;
    }

    .fc-{{ section.id }}__grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }

  /* ====== Slider mode styles ====== */
  .fc-{{ section.id }}__slider-wrapper {
    position: relative;
    width: 100%;
  }

  .fc-{{ section.id }}__slider-wrapper .swiper {
    overflow: visible;
  }

  .fc-{{ section.id }}__slider-wrapper .swiper-slide {
    height: auto;
  }

  /* ====== Slider Arrows ====== */
  .fc-{{ section.id }}__arrows {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .fc-{{ section.id }}__arrow {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    border: 1.5px solid #111111;
    background: transparent;
    color: #111111;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.25s ease;
    flex-shrink: 0;
  }

  .fc-{{ section.id }}__arrow:hover {
    background: #111111;
    color: #ffffff;
  }

  .fc-{{ section.id }}__arrow.swiper-button-disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  /* ====== Progress Bar ====== */
  .fc-{{ section.id }}__progress-track {
    width: 100%;
    height: 3px;
    background: rgba(0, 0, 0, 0.08);
    margin-top: 3rem;
    position: relative;
    overflow: hidden;
  }

  .fc-{{ section.id }}__progress-fill {
    height: 100%;
    background: #111111;
    width: 0;
    transition: width 0.3s ease;
  }

  /* ====== Right header group ====== */
  .fc-{{ section.id }}__header-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 1rem;
    flex-shrink: 0;
  }

  @media screen and (max-width: 989px) {
    .fc-{{ section.id }}__header-right {
      align-items: flex-start;
    }
    .fc-{{ section.id }}__arrows {
      display: none;
    }
  }
{%- endstyle -%}

{%- liquid
  assign collection = section.settings.collection
  assign products_to_show = section.settings.products_to_show | default: 8
  assign columns_desktop = section.settings.columns_desktop | default: 3
  assign enable_slider = section.settings.enable_slider | default: false
  assign text_shop_now = section.settings.shop_now_text | default: 'SHOP NOW'
  assign text_test_ride = section.settings.test_ride_text | default: 'BOOK A TEST RIDE'
  assign link_test_ride = section.settings.test_ride_link | default: '/pages/contact'
  assign text_payment = section.settings.payment_text | default: 'Pay in 3 interest-free installments'
-%}

<div class="section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">

    {%- comment -%} ===== Header Row ===== {%- endcomment -%}
    <div class="fc-{{ section.id }}__header">
      <div class="fc-{{ section.id }}__header-left">
        {%- if section.settings.heading != blank -%}
          <h2 class="fc-{{ section.id }}__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="fc-{{ section.id }}__description">{{ section.settings.description | escape }}</p>
        {%- endif -%}
      </div>

      <div class="fc-{{ section.id }}__header-right">
        {%- if section.settings.button_label != blank -%}
          <a
            href="{{ section.settings.button_link | default: '#' }}"
            class="fc-{{ section.id }}__discover-btn"
          >
            {{ section.settings.button_label | escape }} →
          </a>
        {%- endif -%}

        {%- if enable_slider -%}
          <div class="fc-{{ section.id }}__arrows">
            <button type="button" class="fc-{{ section.id }}__arrow js-fc-prev-{{ section.id }}" aria-label="Previous">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 12L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button type="button" class="fc-{{ section.id }}__arrow js-fc-next-{{ section.id }}" aria-label="Next">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} ===== Products ===== {%- endcomment -%}
    {%- if enable_slider -%}
      <slider-container class="fc-{{ section.id }}__slider-wrapper slider-template-section block" data-block-id="{{ section.id }}">
        <div class="slider-template-section__container">
          <div
            class="swiper js-slider-template-swiper slider-template-section__swiper"
            data-swiper-config='
              {
                "enableSliderDesktop": true,
                "enableSliderMobile": true,
                "loop": false,
                "centeredSlides": false,
                "autoplay": {{ section.settings.enable_autoplay | default: false }},
                "autoplayInterval": {{ section.settings.autoplay_interval | times: 1000 | default: 3000 }},
                "mobileSlides": {{ section.settings.mobile_slides | default: 1.3 }},
                "mobileSpacing": 16,
                "desktopSlides": {{ columns_desktop }},
                "desktopSpacing": {{ section.settings.gap_desktop | default: 24 }}
              }
            '
          >
            <div class="swiper-wrapper">
              {%- for product in collection.products limit: products_to_show -%}
                <div class="swiper-slide" style="height: auto;">
                  {% render 'card-product',
                    card_product: product,
                    media_aspect_ratio: section.settings.image_ratio,
                    show_secondary_image: section.settings.show_secondary_image,
                    show_vendor: false,
                    show_rating: false,
                    lazy_load: true,
                    quick_add: section.settings.quick_add,
                    section_id: section.id
                  %}
                </div>
              {%- else -%}
                {%- for i in (1..columns_desktop) -%}
                  <div class="swiper-slide" style="height: auto;">
                    {% render 'card-product',
                      show_vendor: false,
                      show_rating: false
                    %}
                  </div>
                {%- endfor -%}
              {%- endfor -%}
            </div>
          </div>

          {%- comment -%} Navigation is bound by JS via slider-container custom element {%- endcomment -%}
          <button type="button" class="slider-template-section__arrow js-slider-template-prev" aria-label="Previous" style="display: none;">‹</button>
          <button type="button" class="slider-template-section__arrow js-slider-template-next" aria-label="Next" style="display: none;">›</button>
        </div>
      </slider-container>

      {%- if section.settings.show_progress_bar -%}
        <div class="fc-{{ section.id }}__progress-track">
          <div class="fc-{{ section.id }}__progress-fill"></div>
        </div>
      {%- endif -%}

      <script>
        (function() {
          var sectionId = '{{ section.id }}';
          document.addEventListener('DOMContentLoaded', function() {
            var wrapper = document.querySelector('.fc-' + sectionId + '__slider-wrapper');
            if (!wrapper) return;

            var swiperEl = wrapper.querySelector('.swiper');
            if (!swiperEl || !swiperEl.swiper) {
              // Wait for Swiper initialization
              var observer = new MutationObserver(function() {
                if (swiperEl.swiper) {
                  observer.disconnect();
                  bindControls(swiperEl.swiper);
                }
              });
              observer.observe(swiperEl, { childList: true, subtree: true });
              // Also try again after a delay
              setTimeout(function() {
                if (swiperEl.swiper) {
                  observer.disconnect();
                  bindControls(swiperEl.swiper);
                }
              }, 1500);
            } else {
              bindControls(swiperEl.swiper);
            }

            function bindControls(swiper) {
              var prevBtn = document.querySelector('.js-fc-prev-' + sectionId);
              var nextBtn = document.querySelector('.js-fc-next-' + sectionId);
              var progressFill = document.querySelector('.fc-' + sectionId + '__progress-fill');

              if (prevBtn) {
                prevBtn.addEventListener('click', function() { swiper.slidePrev(); });
              }
              if (nextBtn) {
                nextBtn.addEventListener('click', function() { swiper.slideNext(); });
              }

              function updateProgress() {
                if (!progressFill) return;
                var total = swiper.slides.length - Math.floor(swiper.params.slidesPerView);
                if (total <= 0) total = 1;
                var pct = ((swiper.activeIndex) / total) * 100;
                if (pct > 100) pct = 100;
                progressFill.style.width = pct + '%';
              }

              function updateArrows() {
                if (prevBtn) {
                  if (swiper.isBeginning) prevBtn.classList.add('swiper-button-disabled');
                  else prevBtn.classList.remove('swiper-button-disabled');
                }
                if (nextBtn) {
                  if (swiper.isEnd) nextBtn.classList.add('swiper-button-disabled');
                  else nextBtn.classList.remove('swiper-button-disabled');
                }
              }

              swiper.on('slideChange', function() {
                updateProgress();
                updateArrows();
              });
              swiper.on('resize', function() {
                updateProgress();
                updateArrows();
              });

              updateProgress();
              updateArrows();
            }
          });
        })();
      </script>
    {%- else -%}
      <div class="fc-{{ section.id }}__grid">
        {%- for product in collection.products limit: products_to_show -%}
          <div class="fc-{{ section.id }}__grid-item">
            {% render 'card-product',
              card_product: product,
              media_aspect_ratio: section.settings.image_ratio,
              show_secondary_image: section.settings.show_secondary_image,
              show_vendor: false,
              show_rating: false,
              lazy_load: true,
              quick_add: section.settings.quick_add,
              section_id: section.id
            %}
          </div>
        {%- else -%}
          {%- for i in (1..columns_desktop) -%}
            <div class="fc-{{ section.id }}__grid-item">
              {% render 'card-product',
                show_vendor: false,
                show_rating: false
              %}
            </div>
          {%- endfor -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Featured Collection",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 25,
      "step": 1,
      "default": 8,
      "label": "Maximum products to show"
    },
    {
      "type": "header",
      "content": "Header Content"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "E-BIKES",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "default": "Whether you're commuting, exploring, or just escaping traffic, Roxx e-bikes are built to fit seamlessly into your lifestyle.",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "DISCOVER E-BIKES",
      "label": "Button Label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Card Settings"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        { "value": "adapt", "label": "Adapt to image" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "square", "label": "Square" }
      ],
      "default": "portrait",
      "label": "Image ratio"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": true,
      "label": "Show second image on hover"
    },
    {
      "type": "select",
      "id": "quick_add",
      "default": "standard",
      "label": "Quick add button",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "standard", "label": "Standard" }
      ]
    },
    {
      "type": "text",
      "id": "shop_now_text",
      "default": "SHOP NOW",
      "label": "Shop Now Button Text"
    },
    {
      "type": "text",
      "id": "test_ride_text",
      "default": "BOOK A TEST RIDE",
      "label": "Test Ride Button Text"
    },
    {
      "type": "url",
      "id": "test_ride_link",
      "label": "Test Ride Button Link"
    },
    {
      "type": "text",
      "id": "payment_text",
      "default": "Pay in 3 interest-free installments",
      "label": "Payment Strip Text"
    },
    {
      "type": "image_picker",
      "id": "payment_logos_image",
      "label": "Payment Logos Image"
    },
    {
      "type": "header",
      "content": "Layout & Grid"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 3,
      "label": "Columns on desktop"
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 24,
      "label": "Gap between cards (Desktop)"
    },
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_slider",
      "default": true,
      "label": "Enable slider"
    },
    {
      "type": "range",
      "id": "mobile_slides",
      "min": 1,
      "max": 3,
      "step": 0.1,
      "default": 1.3,
      "label": "Slides per view (Mobile)"
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "default": false,
      "label": "Enable autoplay"
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5,
      "label": "Autoplay interval"
    },
    {
      "type": "checkbox",
      "id": "show_progress_bar",
      "default": true,
      "label": "Show progress bar"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Featured Collection",
      "settings": {
        "heading": "E-BIKES",
        "description": "Whether you're commuting, exploring, or just escaping traffic, Roxx e-bikes are built to fit seamlessly into your lifestyle.",
        "button_label": "DISCOVER E-BIKES",
        "columns_desktop": 3,
        "enable_slider": true
      }
    }
  ]
}
{% endschema %}