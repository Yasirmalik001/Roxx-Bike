{%- style -%}
.section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px; padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px; }
.how-to-use-container-{{ section.id }} { padding: {{ section.settings.inner_padding_mobile }}px; gap: {{ section.settings.gap_mobile }}px; }
@media screen and (min-width: 990px) { .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; } .how-to-use-container-{{ section.id }} { padding: {{ section.settings.inner_padding_desktop }}px; gap: {{ section.settings.gap_desktop }}px; } }
.how-to-use-section { position: relative; overflow: hidden; border-radius: 20px; margin-bottom: 50px; width: 100%; box-sizing: border-box; }
.how-to-use-container { display: flex; flex-direction: column-reverse; position: relative; z-index: 1; box-sizing: border-box; width: 100%; }
@media screen and (min-width: 990px) { .how-to-use-container { flex-direction: row; align-items: center; } .how-to-use-container--right { flex-direction: row-reverse; } }
.how-to-use-content { flex: 1; display: flex; flex-direction: column; text-align: center; }
@media screen and (min-width: 990px) { .how-to-use-content { text-align: left; } }
.how-to-use-subheading { font-weight: 400; font-style: normal; font-size: 18px; line-height: 1.3; letter-spacing: 0.02em; margin-top: 0; margin-bottom: 2rem; }
.how-to-use-block { margin-bottom: 2rem; }
.how-to-use-block-title { font-weight: 600; font-style: normal; font-size: 18px; line-height: 1.3; letter-spacing: 0.02em; margin: 0 0 0.5rem 0; }
.how-to-use-text { font-weight: 400; font-style: normal; font-size: 14px; line-height: 1.4; letter-spacing: 0.02em; }
.how-to-use-text p { margin: 0 0 1rem 0; }
.how-to-use-text p:last-child { margin-bottom: 0; }
.how-to-use-content .button--primary {
    max-width: 280px;
    margin: 0 auto;
}
@media screen and (min-width: 990px) {
  .how-to-use-content .button--primary { margin: 0; }
}
.how-to-use-button:hover { opacity: 0.8; }
.how-to-use-image-container { flex: 1; position: relative; z-index: 1; display: flex; justify-content: center; align-items: center; width: 100%; }
.how-to-use-image {
    width: 100%;
    height: auto;
    border-radius: 20px;
    object-fit: cover;
    aspect-ratio: 1 / 1;
    position: relative;
    z-index: 2;
    max-height: 566px;
}
.decorative-shape { position: absolute; z-index: 0; pointer-events: none; object-fit: contain; }
{%- for block in section.blocks -%}
  {%- if block.type == 'shape_top_left' -%}
    .shape-{{ block.id }} { top: {{ block.settings.mobile_top }}%; left: {{ block.settings.mobile_left }}%; width: {{ block.settings.mobile_width }}%; }
    @media screen and (min-width: 990px) { .shape-{{ block.id }} { top: {{ block.settings.desktop_top }}%; left: {{ block.settings.desktop_left }}%; width: {{ block.settings.desktop_width }}%; } }
  {%- elsif block.type == 'shape_bottom_right' -%}
    .shape-{{ block.id }} { bottom: {{ block.settings.mobile_bottom }}%; right: {{ block.settings.mobile_right }}%; width: {{ block.settings.mobile_width }}%; }
    @media screen and (min-width: 990px) { .shape-{{ block.id }} { bottom: {{ block.settings.desktop_bottom }}%; right: {{ block.settings.desktop_right }}%; width: {{ block.settings.desktop_width }}%; } }
  {%- endif -%}
{%- endfor -%}
{%- endstyle -%}

<div class="page-width">
  <div class="how-to-use-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
    <div class="how-to-use-container how-to-use-container-{{ section.id }} {% if section.settings.desktop_content_position == 'right' %}how-to-use-container--right{% endif %}">
      
      <div class="how-to-use-content">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            
            {%- when 'heading' -%}
              {%- if block.settings.title != blank -%}
                <h2 class="h1" {{ block.shopify_attributes }}>{{ block.settings.title }}</h2>
              {%- endif -%}

            {%- when 'subheading' -%}
              {%- if block.settings.text != blank -%}
                <p class="how-to-use-subheading" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
              {%- endif -%}

            {%- when 'content_block' -%}
              {%- if block.settings.title != blank or block.settings.text != blank -%}
                <div class="how-to-use-block" {{ block.shopify_attributes }}>
                  {%- if block.settings.title != blank -%}
                    <h3 class="how-to-use-block-title">{{ block.settings.title }}</h3>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <div class="how-to-use-text">{{ block.settings.text }}</div>
                  {%- endif -%}
                </div>
              {%- endif -%}

            {%- when 'text' -%}
              {%- if block.settings.text != blank -%}
                <div class="how-to-use-block" {{ block.shopify_attributes }}>
                   <div class="how-to-use-text">{{ block.settings.text }}</div>
                </div>
              {%- endif -%}

            {%- when 'button' -%}
              {%- if block.settings.button_label != blank -%}
                <a href="{{ block.settings.button_link }}" class="button button--primary" {{ block.shopify_attributes }}>
                  {{ block.settings.button_label }}
                </a>
              {%- endif -%}

          {%- endcase -%}
        {%- endfor -%}
      </div>

      <div class="how-to-use-image-container">
        {%- for block in section.blocks -%}
          {%- if block.type == 'shape_top_left' or block.type == 'shape_bottom_right' -%}
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 600 }}" alt="" loading="lazy" class="decorative-shape shape-{{ block.id }}" {{ block.shopify_attributes }}>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1500 | image_tag: loading: 'lazy', class: 'how-to-use-image', sizes: '(min-width: 990px) 50vw, 100vw' }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'how-to-use-image placeholder-svg' }}
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "How to Use Section",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Main Layout Settings"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Content Image"
    },
    {
      "type": "select",
      "id": "desktop_content_position",
      "options": [
        { "value": "left", "label": "Text on left, Image on right" },
        { "value": "right", "label": "Text on right, Image on left" }
      ],
      "default": "left",
      "label": "Desktop content position"
    },
    {
      "type": "header",
      "content": "Container Settings (Desktop)"
    },
    {
      "type": "range",
      "id": "inner_padding_desktop",
      "min": 0, "max": 100, "step": 2, "unit": "px",
      "label": "Inner Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "min": 0, "max": 100, "step": 2, "unit": "px",
      "label": "Gap between Text and Image",
      "default": 60
    },
    {
      "type": "header",
      "content": "Container Settings (Mobile)"
    },
    {
      "type": "range",
      "id": "inner_padding_mobile",
      "min": 0, "max": 60, "step": 2, "unit": "px",
      "label": "Inner Padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "min": 0, "max": 60, "step": 2, "unit": "px",
      "label": "Gap between Text and Image",
      "default": 30
    },
    {
      "type": "header",
      "content": "Section Outer Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Main Heading",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "title", "label": "Heading text", "default": "How do you use period panties?" }
      ]
    },
    {
      "type": "subheading",
      "name": "Subheading",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "text", "label": "Subheading text", "default": "It’s simple: wear, wash, and wear again." }
      ]
    },
    {
      "type": "content_block",
      "name": "Step / Info Block",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Step Title" },
        { "type": "richtext", "id": "text", "label": "Description text", "default": "<p>Explain the process here.</p>" }
      ]
    },
    {
      "type": "text",
      "name": "Standard Text",
      "settings": [
        { "type": "richtext", "id": "text", "label": "Text content", "default": "<p>Add additional details or closing remarks here.</p>" }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "button_label", "label": "Button Label", "default": "Shop Period Underwear" },
        { "type": "url", "id": "button_link", "label": "Button Link" }
      ]
    },
    {
      "type": "shape_top_left",
      "name": "Shape (Top Left)",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Shape Image" },
        { "type": "header", "content": "Desktop Settings" },
        { "type": "range", "id": "desktop_width", "min": 10, "max": 100, "step": 1, "unit": "%", "label": "Width", "default": 30 },
        { "type": "range", "id": "desktop_top", "min": -50, "max": 50, "step": 1, "unit": "%", "label": "Top Position", "default": -5 },
        { "type": "range", "id": "desktop_left", "min": -50, "max": 50, "step": 1, "unit": "%", "label": "Left Position", "default": -10 },
        { "type": "header", "content": "Mobile Settings" },
        { "type": "range", "id": "mobile_width", "min": 10, "max": 100, "step": 1, "unit": "%", "label": "Width", "default": 20 },
        { "type": "range", "id": "mobile_top", "min": -50, "max": 50, "step": 1, "unit": "%", "label": "Top Position", "default": -5 },
        { "type": "range", "id": "mobile_left", "min": -50, "max": 50, "step": 1, "unit": "%", "label": "Left Position", "default": -5 }
      ]
    },
    {
      "type": "shape_bottom_right",
      "name": "Shape (Bottom Right)",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Shape Image" },
        { "type": "header", "content": "Desktop Settings" },
        { "type": "range", "id": "desktop_width", "min": 10, "max": 100, "step": 1, "unit": "%", "label": "Width", "default": 40 },
        { "type": "range", "id": "desktop_bottom", "min": -50, "max": 50, "step": 1, "unit": "%", "label": "Bottom Position", "default": -10 },
        { "type": "range", "id": "desktop_right", "min": -50, "max": 50, "step": 1, "unit": "%", "label": "Right Position", "default": -10 },
        { "type": "header", "content": "Mobile Settings" },
        { "type": "range", "id": "mobile_width", "min": 10, "max": 100, "step": 1, "unit": "%", "label": "Width", "default": 30 },
        { "type": "range", "id": "mobile_bottom", "min": -50, "max": 50, "step": 1, "unit": "%", "label": "Bottom Position", "default": -5 },
        { "type": "range", "id": "mobile_right", "min": -50, "max": 50, "step": 1, "unit": "%", "label": "Right Position", "default": -5 }
      ]
    }
  ],
  "presets": [
    {
      "name": "How to Use Section",
      "blocks": [
        { "type": "heading" },
        { "type": "subheading" },
        { 
          "type": "content_block", 
          "settings": { 
            "title": "How to use?", 
            "text": "<p>Period panties can be worn for up to 12 hours...</p>" 
          } 
        },
        { 
          "type": "content_block", 
          "settings": { 
            "title": "How to take care?", 
            "text": "<p>Rinse after use, wash the panties, and let them dry...</p>" 
          } 
        },
        { 
          "type": "text", 
          "settings": { 
            "text": "<p>Period panties have become extremely popular...</p>" 
          } 
        },
        { "type": "button" },
        { "type": "shape_top_left" },
        { "type": "shape_bottom_right" }
      ]
    }
  ]
}
{% endschema %}