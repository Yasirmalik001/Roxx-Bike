{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .hero-slider-wrapper {
    position: relative;
    width: 100%;
    min-height: {{ section.settings.mobile_height }}px;
    background-color: #000;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  @media screen and (min-width: 750px) {
    .hero-slider-wrapper {
      min-height: {{ section.settings.desktop_height }}px;
    }
  }

  /* Swiper Slide Styling */
  .hero-swiper {
    width: 100%;
    height: 100%;
    position: absolute !important;
    top: 0;
    left: 0;
  }

  .hero-slide {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
  }

  .hero-slide__media {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .hero-slide__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-slide__content-container {
    position: relative;
    z-index: 3;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    padding-bottom: 8rem; /* Space for the bottom features */
  }

  .hero-slide__text-box {
    max-width: 500px;
    color: #ffffff;
    padding: 2rem 0;
  }

  .hero-slide__heading {
    color: #ffffff;
    font-weight: 800;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    margin-bottom: 2rem;
    line-height: 1.1;
  }

  .hero-slide__description {
    color: #f3f3f3;
    font-size: 1.6rem;
    line-height: 1.5;
  }

  .hero-slide__description p {
    margin-bottom: 1.5rem;
  }

  /* Persistent Bottom Features Overlay */
  .hero-features-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    z-index: 10;
    background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.4) 60%, transparent 100%);
    padding: 6rem 0 3rem;
  }

  .hero-features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    color: #ffffff;
  }

  @media screen and (min-width: 750px) {
    .hero-features-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 4rem;
    }
  }

  .hero-feature__item {
    display: flex;
    flex-direction: column;
  }

  .hero-feature__title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.8rem;
    color: #ffffff;
  }

  .hero-feature__text {
    font-size: 1.4rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
  }

  /* Swiper Pagination */
  .swiper-pagination-{{ section.id }} {
    position: absolute;
    bottom: 3rem !important;
    left: 0;
    width: 100%;
    display: flex;
    justify-content: center;
    z-index: 20;
  }

  .swiper-pagination-bullet {
    background: #ffffff !important;
    opacity: 0.5;
    width: 8px;
    height: 8px;
    margin: 0 6px !important;
  }

  .swiper-pagination-bullet-active {
    opacity: 1;
    transform: scale(1.2);
  }

  /* ----------------------------------------------------
     CUSTOM MOBILE LAYOUT (Matches Mockup) 
     ---------------------------------------------------- */
  @media screen and (max-width: 749px) {
    .hero-slider-wrapper {
      min-height: auto;
      background-color: #f7f7f7; /* Light background for the whole section */
    }
    
    .hero-swiper {
      position: relative !important;
      height: auto; 
    }
    
    .hero-slide {
      flex-direction: column;
      height: auto;
      align-items: stretch;
    }
    
    .hero-slide__media {
      position: relative;
      height: {{ section.settings.mobile_height }}px;
      width: 100%;
    }
    
    .hero-slide__content-container {
      background: #f7f7f7;
      align-items: flex-start;
    }
    
    .hero-slide__text-box {
      max-width: 100%;
      padding: 0;
    }
    
    .hero-slide__heading {
      color: #000000 !important;
      font-size: 2.8rem !important; 
      margin-bottom: 1.5rem;
    }
    
    .hero-slide__description {
      color: #333333 !important;
      font-size: 1.4rem;
    }
    
    .hero-slide__description p {
      color: #333333 !important;
    }

    .hero-features-overlay {
      position: relative;
      background: #f7f7f7; /* Remove dark gradient, match light bg */
      padding: 0 2rem 4rem;
    }
    
    .hero-features-grid {
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    
    .hero-feature__item {
      padding: 2rem 0;
      border-bottom: 1px solid #dcdcdc; /* Separator lines */
    }
    
    .hero-feature__item:last-child {
      border-bottom: none; /* Hide line on the last item */
    }
    
    .hero-feature__title {
      color: #000000 !important;
      font-size: 1.4rem;
      margin-bottom: 0.5rem;
    }
    
    .hero-feature__text {
      color: #333333 !important;
      font-size: 1.3rem;
    }

    .swiper-pagination-{{ section.id }} {
      bottom: 1.5rem !important;
    }
    
    .swiper-pagination-bullet {
      background: #000000 !important; /* Dark bullets for light bg */
    }
  }
{%- endstyle -%}

{%- capture swiper_config -%}
{
  "enableSliderDesktop": {{ section.settings.enable_slider_desktop | default: true | json }},
  "enableSliderMobile": {{ section.settings.enable_slider_mobile | default: true | json }},
  "desktopSlides": {{ section.settings.desktop_slides | default: 1 }},
  "desktopSpacing": {{ section.settings.desktop_spacing | default: 0 }},
  "mobileSlides": {{ section.settings.mobile_slides | default: 1 }},
  "mobileSpacing": {{ section.settings.mobile_spacing | default: 0 }},
  "loop": {{ section.settings.loop | default: true | json }},
  "centeredSlides": false,
  "autoplay": {{ section.settings.autoplay | default: true | json }},
  "autoplayInterval": {{ section.settings.autoplay_interval | default: 5000 }}
}
{%- endcapture -%}

<div class="hero-slider-wrapper section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient" id="HeroSlider-{{ section.id }}">
  <slider-container style="display: block; width: 100%; height: 100%;">
  <div class="swiper js-slider-template-swiper hero-swiper" id="Swiper-{{ section.id }}" data-swiper-config='{{ swiper_config | escape }}'>
    <div class="swiper-wrapper">
      
      {%- for block in section.blocks -%}
        <div class="swiper-slide hero-slide" {{ block.shopify_attributes }}>
          
          <div class="hero-slide__media">
            {%- if block.settings.image != blank -%}
              {%- liquid
                assign fetch_priority = 'auto'
                assign loading_attr = 'lazy'
                if forloop.first
                  assign fetch_priority = 'high'
                  assign loading_attr = 'eager'
                endif
                assign image_height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio
              -%}
              {{ block.settings.image | image_url: width: 3840 | image_tag:
                loading: loading_attr,
                fetchpriority: fetch_priority,
                width: block.settings.image.width,
                height: image_height,
                sizes: '100vw',
                widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
              }}
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>

          <div class="hero-slide__content-container">
            <div class="hero-slide__text-box">
              {%- if block.settings.heading != blank -%}
                <h2 class="hero-slide__heading {{ block.settings.heading_size }}" {{ block.shopify_attributes }}>
                  {{ block.settings.heading }}
                </h2>
              {%- endif -%}
              
              {%- if block.settings.description != blank -%}
                <div class="hero-slide__description rte">
                  {{ block.settings.description }}
                </div>
              {%- endif -%}
            </div>
          </div>

        </div>
      {%- endfor -%}

    </div>
  </div>

  <div class="hero-features-overlay">
    <div class="page-width">
      <div class="hero-features-grid">
        
        {%- if section.settings.feature_1_title != blank or section.settings.feature_1_text != blank -%}
          <div class="hero-feature__item">
            <h3 class="hero-feature__title">{{ section.settings.feature_1_title }}</h3>
            <p class="hero-feature__text">{{ section.settings.feature_1_text }}</p>
          </div>
        {%- endif -%}

        {%- if section.settings.feature_2_title != blank or section.settings.feature_2_text != blank -%}
          <div class="hero-feature__item">
            <h3 class="hero-feature__title">{{ section.settings.feature_2_title }}</h3>
            <p class="hero-feature__text">{{ section.settings.feature_2_text }}</p>
          </div>
        {%- endif -%}

        {%- if section.settings.feature_3_title != blank or section.settings.feature_3_text != blank -%}
          <div class="hero-feature__item">
            <h3 class="hero-feature__title">{{ section.settings.feature_3_title }}</h3>
            <p class="hero-feature__text">{{ section.settings.feature_3_text }}</p>
          </div>
        {%- endif -%}

      </div>
    </div>
    <div class="swiper-pagination-{{ section.id }} slider-template-pagination"></div>
  </div>
  </slider-container>
</div>



{% schema %}
{
  "name": "Hero Slideshow",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_slider_desktop",
      "label": "Enable Slider on Desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_slider_mobile",
      "label": "Enable Slider on Mobile",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Infinite Loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable Autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "min": 2000,
      "max": 9000,
      "step": 500,
      "unit": "ms",
      "label": "Autoplay Interval",
      "default": 5000
    },
    {
      "type": "range",
      "id": "desktop_slides",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Desktop Slides",
      "default": 1
    },
    {
      "type": "range",
      "id": "desktop_spacing",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Desktop Spacing",
      "default": 0
    },
    {
      "type": "select",
      "id": "mobile_slides",
      "label": "Mobile Slides",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "1.2", "label": "1.2" },
        { "value": "1.5", "label": "1.5" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "mobile_spacing",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Mobile Spacing",
      "default": 0
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Desktop Layout"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "min": 400,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "label": "Desktop Minimum Height",
      "default": 750
    },
    {
      "type": "header",
      "content": "Mobile Layout"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 400,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "label": "Mobile Minimum Height",
      "default": 650
    },
    {
      "type": "header",
      "content": "Persistent Bottom Features"
    },
    {
      "type": "text",
      "id": "feature_1_title",
      "label": "Feature 1 Title",
      "default": "Fold & Go"
    },
    {
      "type": "textarea",
      "id": "feature_1_text",
      "label": "Feature 1 Description",
      "default": "Compact designs that fit your city, your car, your life."
    },
    {
      "type": "text",
      "id": "feature_2_title",
      "label": "Feature 2 Title",
      "default": "Power You Can Feel"
    },
    {
      "type": "textarea",
      "id": "feature_2_text",
      "label": "Feature 2 Description",
      "default": "Fast acceleration and long-range performance for daily freedom."
    },
    {
      "type": "text",
      "id": "feature_3_title",
      "label": "Feature 3 Title",
      "default": "Built for Everyday"
    },
    {
      "type": "textarea",
      "id": "feature_3_text",
      "label": "Feature 3 Description",
      "default": "Reliable, comfortable, and ready for every ride — rain or shine."
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "WHEN E-BIKE MEETS LIFE"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            { "value": "h2", "label": "Small" },
            { "value": "h1", "label": "Medium" },
            { "value": "h0", "label": "Large" },
            { "value": "hxl", "label": "Extra Large" },
            { "value": "hxxl", "label": "Extra Extra Large" }
          ],
          "default": "h0",
          "label": "Heading Size"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Roxx isn't just about getting from A to B. It's about riding smarter, smoother, and with zero compromise.</p><p>Whether you're commuting, exploring, or just escaping traffic Roxx e-bikes are built to fit seamlessly into your lifestyle.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Slideshow",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}