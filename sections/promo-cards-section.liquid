{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .promo-cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media screen and (min-width: 750px) {
    .promo-cards-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  /* --- MOBILE FIRST (Horizontal Layout) --- */
  .promo-card {
    display: flex;
    flex-direction: row;
    background-color: rgb(var(--color-background));
    border: 1px solid rgba(var(--color-foreground), 0.15);
    border-radius: 12px;
    overflow: hidden;
    min-height: 140px;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .promo-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
  }

  .promo-card__image-wrapper {
    position: relative;
    width: 45%;
    flex-shrink: 0;
    overflow: hidden;
  }

  .promo-card__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .promo-card__overlay {
    display: none; /* Hidden on mobile */
  }

  .promo-card__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: 1.5rem;
    width: 55%;
    gap: 1.2rem;
  }

  .promo-card__title {
    margin: 0;
    font-size: 1.3rem;
    font-weight: 800;
    text-transform: uppercase;
    color: rgb(var(--color-foreground));
    line-height: 1.2;
    letter-spacing: 0.02em;
  }

  .promo-card__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.8rem 1.6rem;
    border-radius: 20px;
    font-size: 1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgb(var(--color-foreground));
    background: transparent;
    border: 1.5px solid #ffd000; /* Yellow outline on mobile */
    transition: all 0.2s ease;
  }

  /* --- DESKTOP (Vertical Background Layout) --- */
  @media screen and (min-width: 750px) {
    .promo-card {
      flex-direction: column;
      border: none;
      border-radius: 16px;
      aspect-ratio: 4 / 5;
      position: relative;
      background: transparent;
    }

    .promo-card__image-wrapper {
      width: 100%;
      height: 100%;
      position: absolute;
      inset: 0;
      border-radius: 16px;
    }

    .promo-card__overlay {
      display: block;
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.4) 30%, transparent 60%);
      z-index: 1;
    }

    .promo-card__content {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 100%;
      justify-content: flex-end;
      padding: 2.5rem;
      z-index: 2;
      background: none;
    }

    .promo-card__title {
      color: #ffffff; /* Forced white on desktop over dark gradient */
      font-size: 1.6rem;
    }

    .promo-card__btn {
      background-color: #ffffff; /* Solid white on desktop */
      color: #000000;
      border: none;
      padding: 1.2rem 2.5rem;
      font-size: 1.1rem;
    }

    .promo-card:hover .promo-card__btn {
      background-color: #ffd000; /* Hover effect to yellow */
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding" {{ section.shopify_attributes }}>
  <div class="page-width">
    
    <div class="promo-cards-grid">
      {%- for block in section.blocks -%}
        <a {% if block.settings.link == blank %}role="link" aria-disabled="true"{% else %}href="{{ block.settings.link }}"{% endif %} class="promo-card" {{ block.shopify_attributes }}>
          
          <div class="promo-card__image-wrapper">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: class: 'promo-card__image', loading: 'lazy' }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'promo-card__image placeholder-svg' }}
            {%- endif -%}
            <div class="promo-card__overlay"></div>
          </div>

          <div class="promo-card__content">
            {%- if block.settings.title != blank -%}
              <h3 class="promo-card__title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}
            
            {%- if block.settings.btn_label != blank -%}
              <span class="promo-card__btn">{{ block.settings.btn_label | escape }}</span>
            {%- endif -%}
          </div>

        </a>
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Promotional Cards",
  "tag": "section",
  "class": "section",
  "max_blocks": 3,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1",
      "info": "This applies to the background of the section and the mobile cards."
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Promo Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "VISIT A NEARBY STORE"
        },
        {
          "type": "text",
          "id": "btn_label",
          "label": "Button Label",
          "default": "FIND A STORE"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card Link",
          "info": "The entire card becomes clickable."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promotional Cards",
      "blocks": [
        { "type": "card", "settings": { "title": "VISIT A NEARBY STORE", "btn_label": "FIND A STORE" } },
        { "type": "card", "settings": { "title": "FLEXIBLE PRICING", "btn_label": "PAY IN INSTALLMENT" } },
        { "type": "card", "settings": { "title": "DISCOVER ALL OUR BIKES", "btn_label": "SHOW ALL" } }
      ]
    }
  ]
}
{% endschema %}