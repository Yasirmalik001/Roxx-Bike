

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.background_color }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .quick-features {
    overflow: hidden;
  }

  .quick-features__heading {
    margin: 0 0 3rem 0;
    font-weight: 800;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: {{ section.settings.text_color }};
  }

  /* Card Styling */
  .feature-card {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background-color: #f5f5f5;
    min-height: 400px;
    height: 100%;
    text-decoration: none;
    transform: translateZ(0); /* Fixes Safari overflow bug during hover */
  }

  @media screen and (min-width: 750px) {
    .feature-card {
      min-height: 480px;
    }
  }

  .feature-card__media {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .feature-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .feature-card:hover .feature-card__media img {
    transform: scale(1.05);
  }

  .feature-card__content {
    position: relative;
    z-index: 2;
    background: linear-gradient(to top, rgba(15, 20, 25, 0.95) 0%, rgba(15, 20, 25, 0.7) 70%, transparent 100%);
    padding: 3rem 2rem 2.5rem 2rem;
    color: #ffffff;
    width: 100%;
    margin-top: auto; /* Pushes to bottom */
  }

  .feature-card__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .feature-card__title {
    font-size: 1.4rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin: 0;
    color: #ffffff;
  }

  .feature-card__icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .feature-card:hover .feature-card__icon {
    color: {{ section.settings.accent_color }};
    transform: rotate(90deg);
  }

  .feature-card__icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
  }

  .feature-card__text {
    font-size: 1.3rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Footer Controls Styling */
  .quick-features__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 4rem;
    gap: 2rem;
  }

  /* Custom Swiper Scrollbar */
  .quick-features__scrollbar-container {
    flex-grow: 1;
    max-width: 300px;
    height: 3px;
    background: #e5e5e5;
    border-radius: 4px;
    position: relative;
    overflow: hidden;
  }

  .swiper-scrollbar-{{ section.id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .swiper-scrollbar-{{ section.id }} .swiper-scrollbar-drag {
    background: {{ section.settings.accent_color }};
    border-radius: 4px;
    cursor: pointer;
  }

  /* Custom Navigation Buttons */
  .quick-features__nav {
    display: flex;
    gap: 1.5rem;
  }

  .quick-features__btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: {{ section.settings.accent_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: none;
    transition: transform 0.2s ease, filter 0.2s ease;
  }

  .quick-features__btn:hover {
    transform: scale(1.05);
    filter: brightness(1.05);
  }

  .quick-features__btn.swiper-button-disabled {
    opacity: 0.4;
    cursor: not-allowed;
    transform: none;
  }

  .quick-features__btn svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: #000000;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  @media screen and (max-width: 749px) {
    .quick-features__footer {
      flex-direction: column-reverse;
      gap: 3rem;
    }
    .quick-features__scrollbar-container {
      max-width: 100%;
    }
  }
{%- endstyle -%}

<div class="quick-features section-{{ section.id }}-padding">
  <div class="page-width">
    
    {%- if section.settings.heading != blank -%}
      <h2 class="quick-features__heading {{ section.settings.heading_size }}">
        {{ section.settings.heading | escape }}
      </h2>
    {%- endif -%}

    <div class="swiper" id="Swiper-{{ section.id }}">
      <div class="swiper-wrapper">
        
        {%- for block in section.blocks -%}
          <div class="swiper-slide" {{ block.shopify_attributes }}>
            <a {% if block.settings.link == blank %} role="link" aria-disabled="true"{% else %} href="{{ block.settings.link }}"{% endif %} class="feature-card">
              
              <div class="feature-card__media">
                {%- if block.settings.image != blank -%}
                  {%- liquid
                    assign fetch_priority = 'auto'
                    assign loading_attr = 'lazy'
                    if forloop.index <= 3
                      assign fetch_priority = 'high'
                      assign loading_attr = 'eager'
                    endif
                  -%}
                  {{ block.settings.image | image_url: width: 800 | image_tag: 
                    loading: loading_attr, 
                    fetchpriority: fetch_priority,
                    sizes: '(min-width: 1200px) 25vw, (min-width: 990px) 33vw, (min-width: 750px) 50vw, 100vw',
                    widths: '375, 550, 750, 800'
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>

              <div class="feature-card__content">
                <div class="feature-card__header">
                  <h3 class="feature-card__title">{{ block.settings.title | escape }}</h3>
                  <div class="feature-card__icon">
                    <svg viewBox="0 0 24 24">
                      <circle cx="12" cy="12" r="10"></circle>
                      <line x1="12" y1="8" x2="12" y2="16"></line>
                      <line x1="8" y1="12" x2="16" y2="12"></line>
                    </svg>
                  </div>
                </div>
                
                {%- if block.settings.text != blank -%}
                  <p class="feature-card__text">{{ block.settings.text }}</p>
                {%- endif -%}
              </div>
              
            </a>
          </div>
        {%- endfor -%}

      </div>
    </div>

    <div class="quick-features__footer">
      <div class="quick-features__scrollbar-container">
        <div class="swiper-scrollbar-{{ section.id }}"></div>
      </div>
      
      <div class="quick-features__nav">
        <button class="quick-features__btn swiper-prev-{{ section.id }}" aria-label="Previous slide">
          <svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button class="quick-features__btn swiper-next-{{ section.id }}" aria-label="Next slide">
          <svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </div>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const initQuickFeatures{{ section.id | replace: '-', '_' }} = () => {
      if (typeof Swiper !== 'undefined') {
        new Swiper('#Swiper-{{ section.id }}', {
          slidesPerView: 1.2,
          spaceBetween: 15,
          grabCursor: true,
          navigation: {
            nextEl: '.swiper-next-{{ section.id }}',
            prevEl: '.swiper-prev-{{ section.id }}',
          },
          scrollbar: {
            el: '.swiper-scrollbar-{{ section.id }}',
            draggable: true,
          },
          breakpoints: {
            550: {
              slidesPerView: 2.2,
              spaceBetween: 20
            },
            750: {
              slidesPerView: 2.5,
              spaceBetween: 20
            },
            990: {
              slidesPerView: 3,
              spaceBetween: 24
            },
            1200: {
              slidesPerView: 4,
              spaceBetween: 24
            }
          }
        });
      } else {
        setTimeout(initQuickFeatures{{ section.id | replace: '-', '_' }}, 100);
      }
    };
    
    initQuickFeatures{{ section.id | replace: '-', '_' }}();
  });
</script>

{% schema %}
{
  "name": "Quick Features Slider",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "QUICK FEATURES OF ROXX JX BLACK",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading Size"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Buttons & Bar)",
      "default": "#ffd000"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "default": "LIGHT WEIGHT FRAME",
          "label": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "default": "Lorem ipsum dolor sit amet consectetur. Est in aliquam id feugiat at facilisis sagittis. Viverra ultrices enim arcu curabitur nibh sit tristique massa sit.",
          "label": "Description"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Quick Features Slider",
      "blocks": [
        { "type": "feature", "settings": { "title": "LIGHT WEIGHT FRAME" } },
        { "type": "feature", "settings": { "title": "REMOVABLE BATTERY" } },
        { "type": "feature", "settings": { "title": "ALL IN ONE APP" } },
        { "type": "feature", "settings": { "title": "AESTHETICS" } }
      ]
    }
  ]
}
{% endschema %}