{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .quick-features {
    overflow: hidden;
  }

  .quick-features__heading {
    margin: 0 0 3rem 0;
    font-weight: 800;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: {{ section.settings.text_color }};
  }

  /* Card Styling */
  .feature-card {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background-color: #f5f5f5;
    min-height: 400px;
    height: 100%;
    text-decoration: none;
    transform: translateZ(0); /* Fixes Safari overflow bug during hover */
  }

  @media screen and (min-width: 750px) {
    .feature-card {
      min-height: 480px;
    }
  }

  .feature-card__media {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .feature-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .feature-card:hover .feature-card__media img {
    transform: scale(1.05);
  }

  .feature-card__content {
    position: relative;
    z-index: 2;
    background: linear-gradient(to top, rgba(15, 20, 25, 0.95) 0%, rgba(15, 20, 25, 0.7) 70%, transparent 100%);
    padding: 3rem 2rem 2.5rem 2rem;
    color: #ffffff;
    width: 100%;
    margin-top: auto; /* Pushes to bottom */
  }

  .feature-card__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .feature-card__title {
    font-size: 1.4rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin: 0;
    color: #ffffff;
  }

  .feature-card__icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .feature-card:hover .feature-card__icon {
    color: {{ section.settings.accent_color }};
    transform: rotate(90deg);
  }

  .feature-card__icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
  }

  .feature-card__text {
    font-size: 1.3rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Footer Controls Styling */
  .quick-features__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 4rem;
    gap: 2rem;
  }

  /* Custom Swiper Scrollbar */
  .quick-features__scrollbar-container {
    flex-grow: 1;
    height: 5px;
    background: #e5e5e5;
    border-radius: 4px;
    position: relative;
    overflow: hidden;
  }

  .quick-features__scrollbar-container .slider-template-progress-fill {
    background: {{ section.settings.accent_color }};
    height: 100%;
    display: block;
    width: 0%;
    transition: width 300ms ease;
    border-radius: inherit;
  }

  /* Custom Navigation Buttons */
  .quick-features__nav {
    display: flex;
    gap: 1.5rem;
  }

  .quick-features__btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: {{ section.settings.accent_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: none;
    transition: transform 0.2s ease, filter 0.2s ease;
  }

  .quick-features__btn:hover {
    transform: scale(1.05);
    filter: brightness(1.05);
  }

  .quick-features__btn.swiper-button-disabled {
    opacity: 0.4;
    cursor: not-allowed;
    transform: none;
  }

  .quick-features__btn svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: #000000;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  @media screen and (max-width: 749px) {
    .quick-features__footer {
      flex-direction: column-reverse;
      gap: 3rem;
    }
    .quick-features__scrollbar-container {
      max-width: 100%;
    }
  }
{%- endstyle -%}

<div class="quick-features section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    
    {%- if section.settings.heading != blank -%}
      <h2 class="hero-features__heading {{ section.settings.heading_size }}">
        {{ section.settings.heading | escape }}
      </h2>
    {%- endif -%}

    <slider-container class="slider-template-section block" data-block-id="{{ section.id }}">
      <div class="slider-template-section__container">
        <div class="swiper js-slider-template-swiper slider-template-section__swiper"
          data-swiper-config='
            {
              "enableSliderDesktop": {{ section.settings.enable_slider_desktop }},
              "enableSliderMobile": {{ section.settings.enable_slider_mobile }},
              "loop": {{ section.settings.enable_loop }},
              "centeredSlides": {{ section.settings.enable_centered_slides }},
              "autoplay": {{ section.settings.enable_autoplay }},
              "autoplayInterval": {{ section.settings.autoplay_interval | times: 1000 }},
              "mobileSlides": {{ section.settings.columns_mobile }},
              "mobileSpacing": {{ section.settings.spacing_mobile }},
              "desktopSlides": {{ section.settings.columns_desktop }},
              "desktopSpacing": {{ section.settings.spacing_desktop }}
            }
          '
        >
          <div class="swiper-wrapper">
            
            {%- for block in section.blocks -%}
              <div class="swiper-slide" {{ block.shopify_attributes }}>
                <a {% if block.settings.link == blank %} role="link" aria-disabled="true"{% else %} href="{{ block.settings.link }}"{% endif %} class="feature-card">
                  
                  <div class="feature-card__media">
                    {%- if block.settings.image != blank -%}
                      {%- liquid
                        assign fetch_priority = 'auto'
                        assign loading_attr = 'lazy'
                        if forloop.index <= 3
                          assign fetch_priority = 'high'
                          assign loading_attr = 'eager'
                        endif
                      -%}
                      {{ block.settings.image | image_url: width: 800 | image_tag: 
                        loading: loading_attr, 
                        fetchpriority: fetch_priority,
                        sizes: '(min-width: 1200px) 25vw, (min-width: 990px) 33vw, (min-width: 750px) 50vw, 100vw',
                        widths: '375, 550, 750, 800'
                      }}
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                    {%- endif -%}
                  </div>

                  <div class="feature-card__content">
                    <div class="feature-card__header">
                      <h3 class="feature-card__title">{{ block.settings.title | escape }}</h3>
                      <div class="feature-card__icon">
                        <svg viewBox="0 0 24 24">
                          <circle cx="12" cy="12" r="10"></circle>
                          <line x1="12" y1="8" x2="12" y2="16"></line>
                          <line x1="8" y1="12" x2="16" y2="12"></line>
                        </svg>
                      </div>
                    </div>
                    
                    {%- if block.settings.text != blank -%}
                      <p class="feature-card__text">{{ block.settings.text }}</p>
                    {%- endif -%}
                  </div>
                  
                </a>
              </div>
            {%- endfor -%}

          </div>
        </div>

        <div class="quick-features__footer">
          <div class="quick-features__scrollbar-container">
            <div class="slider-template-progress-fill"></div>
          </div>
          
          <div class="quick-features__nav">
            <button class="quick-features__btn js-slider-template-prev" aria-label="Previous slide">
              <svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
            </button>
            <button class="quick-features__btn js-slider-template-next" aria-label="Next slide">
              <svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
            </button>
          </div>
        </div>
      </div>
    </slider-container>

  </div>
</div>

{% schema %}
{
  "name": "Quick Features Slider",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "QUICK FEATURES OF ROXX JX BLACK",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
            { "value": "h2", "label": "Small" },
            { "value": "h1", "label": "Medium" },
            { "value": "h0", "label": "Large" },
            { "value": "hxl", "label": "Extra Large" },
            { "value": "hxxl", "label": "Extra Extra Large" }
          ],
      "default": "h1",
      "label": "Heading Size"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Buttons & Bar)",
      "default": "#ffd000"
    },
    {
      "type": "header",
      "content": "Slider Configuration"
    },
    {
      "type": "checkbox",
      "id": "enable_slider_desktop",
      "label": "Enable Slider on Desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_slider_mobile",
      "label": "Enable Slider on Mobile",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_loop",
      "label": "Enable Infinite Loop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_centered_slides",
      "label": "Enable Centered Slides",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Enable Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Autoplay Interval",
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 0.1,
      "label": "Slides per view on Desktop",
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 1,
      "max": 3,
      "step": 0.1,
      "label": "Slides per view on Mobile",
      "default": 1.2
    },
    {
      "type": "range",
      "id": "spacing_desktop",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Space between slides on Desktop",
      "default": 24
    },
   {
      "type": "range",
      "id": "spacing_mobile",
      "min": 0,
      "max": 80,
      "step": 1, 
      "unit": "px",
      "label": "Space between slides on Mobile",
      "default": 15
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "default": "LIGHT WEIGHT FRAME",
          "label": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "default": "Lorem ipsum dolor sit amet consectetur. Est in aliquam id feugiat at facilisis sagittis. Viverra ultrices enim arcu curabitur nibh sit tristique massa sit.",
          "label": "Description"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Quick Features Slider",
      "blocks": [
        { "type": "feature", "settings": { "title": "LIGHT WEIGHT FRAME" } },
        { "type": "feature", "settings": { "title": "REMOVABLE BATTERY" } },
        { "type": "feature", "settings": { "title": "ALL IN ONE APP" } },
        { "type": "feature", "settings": { "title": "AESTHETICS" } }
      ]
    }
  ]
}
{% endschema %}