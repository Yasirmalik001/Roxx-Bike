<div class="product-custom-tabs-wrapper color-scheme-1 isolate">
  <div class="product-custom-tabs-sticky-header">
    <div class="page-width">
      <div class="product-custom-tabs-header-inner">
        <!-- Tabs Navigation -->
        <ul class="product-custom-tabs-nav list-unstyled" role="tablist">
          {%- for block in section.blocks -%}
            <li class="product-custom-tab-item" role="presentation">
              <button 
                class="product-custom-tab-button {% if forloop.first %}is-active{% endif %}" 
                role="tab" 
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}" 
                aria-controls="TabPanel-{{ block.id }}" 
                id="Tab-{{ block.id }}"
                data-tab-index="{{ forloop.index0 }}"
              >
                {{ block.settings.tab_title | escape }}
              </button>
            </li>
          {%- endfor -%}
        </ul>

        <!-- Action Buttons -->
        <div class="product-custom-tabs-actions">
          {%- if section.settings.book_ride_text != blank -%}
            <a href="{{ section.settings.book_ride_url | default: '#' }}" class="button button--secondary custom-tabs-btn-outline">
              {{ section.settings.book_ride_text | escape }}
            </a>
          {%- endif -%}
          
          <button type="button" class="button button--primary custom-tabs-btn-solid" onclick="document.querySelector('.product-form__submit').click();">
            {{ 'products.product.add_to_cart' | t | default: 'ADD TO CART' }}
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Tabs Content -->
  <div class="product-custom-tabs-content-container page-width">
    {%- for block in section.blocks -%}
      <div 
        class="product-custom-tab-panel {% if forloop.first %}is-active{% endif %}" 
        role="tabpanel" 
        id="TabPanel-{{ block.id }}" 
        aria-labelledby="Tab-{{ block.id }}"
        {{ block.shopify_attributes }}
      >
        
        {%- if block.type == 'tab_description' -%}
          <div class="tab-description-layout">
            <div class="tab-description-left">
              <div class="rte">
                {{ block.settings.description_text }}
              </div>
            </div>
            <div class="tab-description-right">
              <div class="tab-icon-grid">
                {%- for i in (1..6) -%}
                  {%- assign icon_key = 'icon_' | append: i -%}
                  {%- assign text_key = 'text_' | append: i -%}
                  {%- assign icon_image = block.settings[icon_key] -%}
                  {%- assign icon_text = block.settings[text_key] -%}
                  
                  {%- if icon_image != blank or icon_text != blank -%}
                    <div class="tab-icon-item">
                      <div class="tab-icon-image">
                        {%- if icon_image != blank -%}
                          <img src="{{ icon_image | image_url: width: 60 }}" alt="{{ icon_image.alt | escape }}" loading="lazy" width="30" height="auto">
                        {%- else -%}
                          <!-- Fallback square placeholder if no image picked but text exists -->
                          <div style="width: 30px; height: 30px; background-color: #f4f4f4; border-radius: 4px;"></div>
                        {%- endif -%}
                      </div>
                      <div class="tab-icon-text">
                        {{ icon_text }}
                      </div>
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            </div>
          </div>
        
        {%- elsif block.type == 'tab_generic' -%}
          <div class="tab-generic-layout rte">
            {{ block.settings.content }}
          </div>
        {%- endif -%}
        
      </div>
    {%- endfor -%}
  </div>
</div>

<style>
  .product-custom-tabs-wrapper {
    margin-top: 6rem;
    margin-bottom: 6rem;
  }
  .product-custom-tabs-sticky-header {
    position: sticky;
    top: 0; /* Fallback */
    top: var(--header-height, 70px);
    z-index: 20;
    background-color: #ffffff;
    border-bottom: 1px solid #e5e5e5;
    padding: 15px 0;
  }
  .product-custom-tabs-header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
  }
  .product-custom-tabs-nav {
    display: flex;
    align-items: center;
    gap: 30px;
    margin: 0;
    padding: 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  /* Hide scrollbar for tabs */
  .product-custom-tabs-nav::-webkit-scrollbar {
    display: none;
  }
  .product-custom-tabs-nav {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .product-custom-tab-button {
    background: none;
    border: none;
    padding: 0 0 10px 0;
    font-size: 1.4rem;
    font-weight: 800;
    color: #000000;
    text-transform: uppercase;
    cursor: pointer;
    position: relative;
    white-space: nowrap;
    opacity: 0.6;
    transition: opacity 0.2s ease;
    letter-spacing: 0.5px;
    font-family: inherit;
  }
  .product-custom-tab-button:hover {
    opacity: 1;
  }
  .product-custom-tab-button.is-active {
    opacity: 1;
  }
  .product-custom-tab-button.is-active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: 3px;
    background-color: #FFD000;
  }
  .product-custom-tabs-actions {
    display: flex;
    align-items: center;
    gap: 15px;
  }
  .custom-tabs-btn-outline {
    background-color: #ffffff;
    color: #000000;
    border: 1px solid #FFD000;
    border-radius: 30px;
    font-weight: 800;
    font-size: 1.2rem;
    padding: 12px 28px;
    text-decoration: none;
    letter-spacing: 0.5px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .custom-tabs-btn-solid {
    background-color: #FFD000;
    color: #000000;
    border: none;
    border-radius: 30px;
    font-weight: 800;
    font-size: 1.2rem;
    padding: 12px 32px;
    cursor: pointer;
    letter-spacing: 0.5px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .custom-tabs-btn-outline:hover, .custom-tabs-btn-solid:hover {
    opacity: 0.8;
  }
  .product-custom-tabs-content-container {
    padding-top: 5rem;
  }
  .product-custom-tab-panel {
    display: none;
  }
  .product-custom-tab-panel.is-active {
    display: block;
    animation: fadeInTab 0.3s ease;
  }
  @keyframes fadeInTab {
    from { opacity: 0; transform: translateY(5px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  /* Description Layout */
  .tab-description-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }
  @media screen and (min-width: 990px) {
    .tab-description-layout {
      grid-template-columns: 1fr 1fr;
      gap: 12rem;
    }
  }
  .tab-description-left {
    font-size: 1.4rem;
    line-height: 1.5;
    color: #222222;
  }
  .tab-description-left p {
    margin-bottom: 2.5rem;
  }
  
  /* Icon Grid */
  .tab-icon-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem 2rem;
  }
  .tab-icon-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }
  .tab-icon-image img {
    max-width: 28px;
    height: auto;
    display: block;
  }
  .tab-icon-text {
    font-size: 1.15rem;
    color: #333333;
    line-height: 1.3;
    max-width: 200px;
  }

  @media screen and (max-width: 749px) {
    .product-custom-tabs-header-inner {
      flex-direction: column;
      align-items: flex-start;
    }
    .product-custom-tabs-actions {
      width: 100%;
      justify-content: flex-start;
      flex-wrap: wrap;
    }
    .product-custom-tab-button.is-active::after {
      bottom: -5px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const tabButtons = document.querySelectorAll('.product-custom-tab-button');
    const tabPanels = document.querySelectorAll('.product-custom-tab-panel');

    tabButtons.forEach(button => {
      button.addEventListener('click', function() {
        // Remove active state from all
        tabButtons.forEach(btn => {
          btn.classList.remove('is-active');
          btn.setAttribute('aria-selected', 'false');
        });
        tabPanels.forEach(panel => {
          panel.classList.remove('is-active');
        });

        // Add active state to clicked
        this.classList.add('is-active');
        this.setAttribute('aria-selected', 'true');
        
        const panelId = this.getAttribute('aria-controls');
        const activePanel = document.getElementById(panelId);
        if (activePanel) {
          activePanel.classList.add('is-active');
        }
      });
    });
  });
</script>

