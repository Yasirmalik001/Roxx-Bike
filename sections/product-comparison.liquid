{%- style -%}
.section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px; padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px; }
@media screen and (min-width: 750px) { .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; } }
.compare-section { margin: 0 auto; }
.compare-header { text-align: center; margin-bottom: 2rem; }
.compare-header__subheading { font-size: 1.4rem; margin: 0; }
.compare-table { display: flex; flex-direction: column; }
.compare-row { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; padding: 3rem 0; border-bottom: 1px solid rgba(var(--color-foreground), 0.08); }
@media screen and (min-width: 750px) { .compare-row { gap: 6rem; } }
.compare-row:last-child { border-bottom: none; }
.compare-col { display: flex; flex-direction: column; align-items: center; text-align: center; }
.compare-product__image { width: 100%; max-width: 280px; height: auto; margin-bottom: 2rem; object-fit: contain; }
.compare-product__title-wrapper { position: relative; display: inline-flex; align-items: center; padding: 1.2rem 2.4rem; border: 1px solid rgba(var(--color-foreground), 0.15); border-radius: 50px; margin-bottom: 1.5rem; color: currentColor; background: transparent; }
.compare-product__select { appearance: none; -webkit-appearance: none; background: transparent; border: none; font-size: 1.6rem; font-weight: 800; color: currentColor; font-family: inherit; cursor: pointer; padding-right: 15px; outline: none; text-transform: uppercase; text-align: center; }
.compare-product__chevron { position: absolute; right: 1.2rem; top: 50%; transform: translateY(-50%); pointer-events: none; width: 12px; height: 12px; fill: none; stroke: currentColor; stroke-width: 2; }
.compare-product__desc { font-size: 1.2rem; margin: 0 0 3rem 0; max-width: 220px; opacity: 0.75; }
.compare-product__price { font-size: 1.6rem; font-weight: 600; margin: 0 0 0.5rem 0; }
.compare-product__link { font-size: 1.2rem; color: currentColor; text-decoration: none; font-weight: 500; transition: opacity 0.2s ease; opacity: 0.75; }
.compare-product__link:hover { opacity: 1; }
.compare-feature__icon { width: 32px; height: 32px; margin-bottom: 1.5rem; display: flex; align-items: center; justify-content: center; }
.compare-feature__icon svg, .compare-feature__icon img { width: 100%; height: 100%; object-fit: contain; }
.compare-feature__icon svg { fill: none; stroke: currentColor; stroke-width: 1.2; stroke-linecap: round; stroke-linejoin: round; }
.compare-feature__text { font-size: 1.3rem; line-height: 1.5; margin: 0; max-width: 180px; white-space: pre-wrap; }
{%- endstyle -%}

{%- assign compare_collection = section.settings.compare_collection -%}

<script type="application/json" id="CompareData-{{ section.id }}">
{
  {%- if compare_collection != blank -%}
    {%- for prod in compare_collection.products -%}
      "{{ prod.handle }}": {
        "title": {{ prod.title | json }},
        "url": {{ prod.url | json }},
        "image": {{ prod.featured_image | image_url: width: 600 | json }},
        "price": {{ prod.price | money | json }},
        "features": {
          {%- for block in section.blocks -%}
            {%- assign ns = block.settings.metafield_namespace | default: 'custom' -%}
            {%- assign key = block.settings.metafield_key -%}
            "{{ block.id }}": {{ prod.metafields[ns][key] | json }}{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        }
      }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  {%- endif -%}
}
</script>

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="compare-section page-width page-width--narrow">
  
  <div class="compare-header">
    {%- if section.settings.heading != blank -%}
      <h2 class="hero-features__heading {{ section.settings.heading_size }}">
        {{ section.settings.heading | escape }}
      </h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="compare-header__subheading">{{ section.settings.subheading | escape }}</p>
    {%- endif -%}
  </div>

  <div class="compare-table">
    <div class="compare-row compare-row--header">
      
      <div class="compare-col">
        {%- if compare_collection != blank and compare_collection.products.size > 0 -%}
          <img class="compare-product__image" id="CompareImage1-{{ section.id }}" src="{{ compare_collection.products.first.featured_image | image_url: width: 600 }}" loading="lazy">
          
          <div class="compare-product__title-wrapper">
            <select id="CompareSelect1-{{ section.id }}" class="compare-product__select">
              {%- for prod in compare_collection.products -%}
                <option value="{{ prod.handle }}" {% if prod.handle == product.handle %}selected{% endif %}>{{ prod.title }}</option>
              {%- endfor -%}
            </select>
            <svg class="compare-product__chevron" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </div>
          
          <p class="compare-product__desc">{{ section.settings.desc_1 }}</p>
          <p class="compare-product__price" id="ComparePrice1-{{ section.id }}">{{ compare_collection.products.first.price | money }}</p>
          <a href="{{ compare_collection.products.first.url }}" id="CompareLink1-{{ section.id }}" class="compare-product__link">{{ section.settings.link_label }}</a>
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'compare-product__image placeholder-svg' }}
          <div class="compare-product__title-wrapper">
            <h3 class="compare-product__title">No Collection</h3>
          </div>
        {%- endif -%}
      </div>

      <div class="compare-col">
        {%- if compare_collection != blank and compare_collection.products.size > 0 -%}
          {%- assign second_product = compare_collection.products[1] | default: compare_collection.products.first -%}
          <img class="compare-product__image" id="CompareImage2-{{ section.id }}" src="{{ second_product.featured_image | image_url: width: 600 }}" loading="lazy">
          
          <div class="compare-product__title-wrapper">
            <select id="CompareSelect2-{{ section.id }}" class="compare-product__select">
              {%- for prod in compare_collection.products -%}
                <option value="{{ prod.handle }}" {% if second_product.handle == prod.handle %}selected{% endif %}>{{ prod.title }}</option>
              {%- endfor -%}
            </select>
            <svg class="compare-product__chevron" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </div>
          
          <p class="compare-product__desc">{{ section.settings.desc_2 }}</p>
          <p class="compare-product__price" id="ComparePrice2-{{ section.id }}">{{ second_product.price | money }}</p>
          <a href="{{ second_product.url }}" id="CompareLink2-{{ section.id }}" class="compare-product__link">{{ section.settings.link_label }}</a>
        {%- else -%}
          {{ 'product-2' | placeholder_svg_tag: 'compare-product__image placeholder-svg' }}
          <div class="compare-product__title-wrapper">
            <h3 class="compare-product__title">No Collection</h3>
          </div>
        {%- endif -%}
      </div>

    </div>

    {%- for block in section.blocks -%}
      <div class="compare-row" {{ block.shopify_attributes }}>
        
        <div class="compare-col">
          <div class="compare-feature__icon">
            {%- if block.settings.custom_icon != blank -%}
              <img src="{{ block.settings.custom_icon | image_url: width: 64 }}" alt="{{ block.settings.custom_icon.alt | escape }}" loading="lazy">
            {%- else -%}
              {%- case block.settings.fallback_icon -%}
                {%- when 'rider_height' -%}
                  <svg viewBox="0 0 24 24"><rect x="7" y="4" width="10" height="16" rx="2"></rect><circle cx="12" cy="8" r="2"></circle><path d="M12 11v5"></path><path d="M9 20v2"></path><path d="M15 20v2"></path></svg>
                {%- when 'range_dots' -%}
                  <svg viewBox="0 0 24 24"><circle cx="5" cy="19" r="2"></circle><circle cx="19" cy="5" r="2"></circle><path d="M6.5 17.5c3-3 7-7 11-11" stroke-dasharray="3 3"></path></svg>
                {%- when 'speedometer' -%}
                  <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><path d="M12 12l3-3"></path><path d="M8 12a4 4 0 0 1 8 0"></path></svg>
                {%- when 'gps_pin' -%}
                  <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                {%- when 'drive_belt' -%}
                  <svg viewBox="0 0 24 24"><circle cx="7" cy="12" r="3"></circle><circle cx="17" cy="12" r="3"></circle><path d="M7 9h10"></path><path d="M7 15h10"></path></svg>
              {%- endcase -%}
            {%- endif -%}
          </div>
          <p class="compare-feature__text" id="CompareFeature1-{{ section.id }}-{{ block.id }}"></p>
        </div>

        <div class="compare-col">
          <div class="compare-feature__icon">
            {%- if block.settings.custom_icon != blank -%}
              <img src="{{ block.settings.custom_icon | image_url: width: 64 }}" alt="{{ block.settings.custom_icon.alt | escape }}" loading="lazy">
            {%- else -%}
              {%- case block.settings.fallback_icon -%}
                {%- when 'rider_height' -%}
                  <svg viewBox="0 0 24 24"><rect x="7" y="4" width="10" height="16" rx="2"></rect><circle cx="12" cy="8" r="2"></circle><path d="M12 11v5"></path><path d="M9 20v2"></path><path d="M15 20v2"></path></svg>
                {%- when 'range_dots' -%}
                  <svg viewBox="0 0 24 24"><circle cx="5" cy="19" r="2"></circle><circle cx="19" cy="5" r="2"></circle><path d="M6.5 17.5c3-3 7-7 11-11" stroke-dasharray="3 3"></path></svg>
                {%- when 'speedometer' -%}
                  <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><path d="M12 12l3-3"></path><path d="M8 12a4 4 0 0 1 8 0"></path></svg>
                {%- when 'gps_pin' -%}
                  <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                {%- when 'drive_belt' -%}
                  <svg viewBox="0 0 24 24"><circle cx="7" cy="12" r="3"></circle><circle cx="17" cy="12" r="3"></circle><path d="M7 9h10"></path><path d="M7 15h10"></path></svg>
              {%- endcase -%}
            {%- endif -%}
          </div>
          <p class="compare-feature__text" id="CompareFeature2-{{ section.id }}-{{ block.id }}"></p>
        </div>

      </div>
    {%- endfor -%}

  </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const dataEl = document.getElementById('CompareData-{{ section.id }}');
  if (!dataEl) return;
  
  let productData = {};
  try {
    productData = JSON.parse(dataEl.textContent);
  } catch (e) {
    console.error('Failed to parse compare data', e);
    return;
  }
  
  const select1 = document.getElementById('CompareSelect1-{{ section.id }}');
  const select2 = document.getElementById('CompareSelect2-{{ section.id }}');
  
  function updateCompareColumn(colNum, handle) {
    const data = productData[handle];
    if (!data) return;
    
    const imgEl = document.getElementById(`CompareImage${colNum}-{{ section.id }}`);
    if (imgEl && data.image) imgEl.src = data.image;
    
    const priceEl = document.getElementById(`ComparePrice${colNum}-{{ section.id }}`);
    if (priceEl && data.price) priceEl.innerHTML = data.price;
    
    const linkEl = document.getElementById(`CompareLink${colNum}-{{ section.id }}`);
    if (linkEl && data.url) linkEl.href = data.url;
    
    // Update features
    if (data.features) {
      const featureKeys = Object.keys(data.features);
      featureKeys.forEach(key => {
        const el = document.getElementById(`CompareFeature${colNum}-{{ section.id }}-${key}`);
        if (el) {
          // If value is missing or empty, show a fallback like '-'
          el.innerHTML = data.features[key] || '-';
        }
      });
    }
  }

  if (select1) {
    select1.addEventListener('change', (e) => updateCompareColumn(1, e.target.value));
    updateCompareColumn(1, select1.value);
  }
  
  if (select2) {
    select2.addEventListener('change', (e) => updateCompareColumn(2, e.target.value));
    updateCompareColumn(2, select2.value);
  }
});
</script>

{% schema %}
{
  "name": "Product Comparison",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Header Configuration"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "NOT SURE WHICH BIKE SUITS YOU?",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" },
        { "value": "hxl", "label": "Extra Large" },
        { "value": "hxxl", "label": "Extra Extra Large" }
      ],
      "default": "h1",
      "label": "Heading Size"
    },
    {
      "type": "text",
      "id": "subheading",
      "default": "check out the handy comparison table below.",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Comparison Data"
    },
    {
      "type": "collection",
      "id": "compare_collection",
      "label": "Collection of bikes to compare"
    },
    {
      "type": "text",
      "id": "desc_1",
      "label": "Left Product Subtitle",
      "default": "Lorem ipsum dolor sit amet consectetur."
    },
    {
      "type": "text",
      "id": "desc_2",
      "label": "Right Product Subtitle",
      "default": "Lorem ipsum dolor sit amet consectetur."
    },
    {
      "type": "header",
      "content": "General Text"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link Label underneath price",
      "default": "More info"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "feature_row",
      "name": "Feature Row",
      "settings": [
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Custom Icon Image",
          "info": "Upload an image to override the default SVG icon."
        },
        {
          "type": "select",
          "id": "fallback_icon",
          "label": "Default Icon Fallback",
          "options": [
            { "value": "rider_height", "label": "Rider Height" },
            { "value": "range_dots", "label": "Range Dots" },
            { "value": "speedometer", "label": "Speedometer" },
            { "value": "gps_pin", "label": "GPS Pin" },
            { "value": "drive_belt", "label": "Drive/Belt" }
          ],
          "default": "rider_height"
        },
        {
          "type": "text",
          "id": "metafield_namespace",
          "label": "Metafield Namespace",
          "default": "custom"
        },
        {
          "type": "text",
          "id": "metafield_key",
          "label": "Metafield Key",
          "default": "range"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Comparison",
      "blocks": [
        {
          "type": "feature_row",
          "settings": {
            "fallback_icon": "rider_height",
            "metafield_key": "rider_height"
          }
        },
        {
          "type": "feature_row",
          "settings": {
            "fallback_icon": "range_dots",
            "metafield_key": "range"
          }
        },
        {
          "type": "feature_row",
          "settings": {
            "fallback_icon": "speedometer",
            "metafield_key": "speed"
          }
        },
        {
          "type": "feature_row",
          "settings": {
            "fallback_icon": "gps_pin",
            "metafield_key": "features"
          }
        },
        {
          "type": "feature_row",
          "settings": {
            "fallback_icon": "drive_belt",
            "metafield_key": "drive"
          }
        }
      ]
    }
  ]
}
{% endschema %}