{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .partner-testimonials {
    overflow: hidden;
  }

  .partner-testimonials__heading {
    text-align: center;
    font-weight: 900;
    font-size: clamp(28px, 4vw, 36px);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    margin-top: 0;
    margin-bottom: 48px;
  }

  /* Card Styling */
  .partner-card {
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
    border: none;
  }

  .partner-card__image-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 60%; /* Aspect ratio for the images */
    overflow: hidden;
  }

.partner-card__image-wrapper img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 12px;
}
  .partner-card__content {
    padding: 32px 24px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .partner-card__text {
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 32px;
    opacity: 0.85;
  }

  .partner-card__text p {
    margin: 0;
  }

  .partner-card__author {
    font-weight: 500;
    font-size: 14px;
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 8px;
    opacity: 0.9;
  }

  .partner-card__author::before {
    content: "—";
    display: inline-block;
  }

  /* Swiper Footer Controls */
  .partner-slider-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    min-height: 48px;
    margin-top: 48px;
  }

  .partner-pagination-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* Custom overrides for .slider-template-pagination dots */
  .section-{{ section.id }}-padding .slider-template-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
  }

  .section-{{ section.id }}-padding .slider-template-pagination .swiper-pagination-bullet {
    width: 10px;
    height: 10px;
    background-color: #ffffff !important;
    opacity: 0.3 !important;
    margin: 0 !important;
    transition: all 0.3s ease;
    cursor: pointer;
    border-radius: 50%;
  }

  .section-{{ section.id }}-padding .slider-template-pagination .swiper-pagination-bullet-active {
    background-color: #ffe600 !important;
    opacity: 1 !important;
    transform: scale(1);
  }

  /* Custom styling for progress fill in testimonials */
  .section-{{ section.id }}-padding .slider-template-progress-track {
    background: rgba(var(--color-foreground), 0.08) !important;
  }

  .section-{{ section.id }}-padding .slider-template-progress-fill {
    background: #ffe600 !important;
  }

  /* Custom styling for arrows in testimonials */
  .section-{{ section.id }}-padding .slider-template-arrow {
    background: rgba(var(--color-foreground), 0.05) !important;
    color: currentColor !important;
    border-color: rgba(var(--color-foreground), 0.15) !important;
  }

  .section-{{ section.id }}-padding .slider-template-arrow:hover {
    background: rgba(var(--color-foreground), 0.1) !important;
    border-color: currentColor !important;
  }

  .section-{{ section.id }}-padding .slider-template-arrow.swiper-button-disabled {
    opacity: 0.4 !important;
    pointer-events: none !important;
  }

  /* Button alignment */
  .partner-button-wrapper {
    position: absolute;
    right: 0;
  }

  .partner-button {
    background-color: #ffffff;
    color: #000000;
    border: none;
    border-radius: 50px;
    padding: 12px 32px;
    font-weight: 700;
    font-size: 14px;
    text-decoration: none;
    transition: opacity 0.2s ease;
    display: inline-block;
  }

  .partner-button:hover {
    opacity: 0.85;
  }

  @media screen and (max-width: 989px) {
    .partner-slider-footer {
      flex-direction: column;
      gap: 32px;
    }
    .partner-button-wrapper {
      position: static;
      display: block;
    }
  }
{%- endstyle -%}

<div class="partner-testimonials section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    
    {%- if section.settings.heading != blank -%}
      <h2 class="partner-testimonials__heading {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    <slider-container class="partner-testimonials__slider slider-template-section block" data-block-id="{{ section.id }}">
      <div class="slider-template-section__container">
          
          <div
            class="swiper js-slider-template-swiper slider-template-section__swiper"
            data-swiper-config='
              {
                "enableSliderDesktop": {{ section.settings.enable_slider_desktop }},
                "enableSliderMobile": {{ section.settings.enable_slider_mobile }},
                "loop": {{ section.settings.enable_loop | default: false }},
                "autoplay": {{ section.settings.enable_autoplay | default: false }},
                "autoplayInterval": {{ section.settings.autoplay_interval | times: 1000 | default: 3000 }},
                "mobileSlides": {{ section.settings.columns_mobile | plus: 0.0 }},
                "mobileSpacing": {{ section.settings.spacing | divided_by: 1.5 }},
                "desktopSlides": {{ section.settings.columns_desktop }},
                "desktopSpacing": {{ section.settings.spacing }},
                "centeredSlides": {{ section.settings.center_slides | default: true | json }}
              }
            '
          >
            <div class="swiper-wrapper">
              {%- for block in section.blocks -%}
                <div class="swiper-slide" {{ block.shopify_attributes }}>
                  <div class="partner-card color-{{ section.settings.card_color_scheme }} gradient">
                    <div class="partner-card__image-wrapper">
                      {%- if block.settings.image != blank -%}
                        {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400, 600, 800' }}
                      {%- else -%}
                        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                      {%- endif -%}
                    </div>
                    <div class="partner-card__content">
                      <div class="partner-card__text rte">
                        {{ block.settings.text }}
                      </div>
                      <div class="partner-card__author">
                        {{ block.settings.author }}
                      </div>
                    </div>
                  </div>
                </div>
              {%- endfor -%}
            </div>
          </div>

          <div class="partner-slider-footer">
            <div class="slider-template-controls slider-template-controls--{{ section.settings.controls_position }}">
              {%- if section.settings.controls_position == 'bottom' -%}
                <div class="slider-template-progress-track">
                  <div class="slider-template-progress-fill"></div>
                </div>
              {%- endif -%}
              
              {%- if section.settings.controls_position == 'dots' -%}
                <div class="slider-template-pagination partner-pagination-wrapper"></div>
              {%- endif -%}

              {%- if section.settings.controls_position == 'middle' -%}
                <div class="slider-template-controls-nav">
                  <button type="button" class="slider-template-arrow js-slider-template-prev" aria-label="{{ 'general.slider.previous_slide' | t }}">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M10 12L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                  <button type="button" class="slider-template-arrow js-slider-template-next" aria-label="{{ 'general.slider.next_slide' | t }}">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                </div>
              {%- endif -%}
            </div>

            {%- if section.settings.button_label != blank -%}
              <div class="partner-button-wrapper">
                <a {% if section.settings.button_link == blank %} role="link" aria-disabled="true"{% else %} href="{{ section.settings.button_link }}"{% endif %} 
                   class="partner-button">
                  {{ section.settings.button_label | escape }}
                </a>
              </div>
            {%- endif -%}
          </div>

      </div>
    </slider-container>
  </div>
</div>

{% schema %}
{
  "name": "Partner Slider",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "card_color_scheme",
      "label": "Card Color Scheme",
      "default": "scheme-2"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "WHAT OUR PARTNER SAYS!",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
            { "value": "h2", "label": "Small" },
            { "value": "h1", "label": "Medium" },
            { "value": "h0", "label": "Large" },
            { "value": "hxl", "label": "Extra Large" },
            { "value": "hxxl", "label": "Extra Extra Large" }
          ],
      "default": "h1",
      "label": "Heading Size"
    },
    {
      "type": "header",
      "content": "Footer Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "View all",
      "label": "Button Label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Carousel Controls"
    },
    {
      "type": "checkbox",
      "id": "enable_slider_desktop",
      "label": "Enable slider on desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_slider_mobile",
      "label": "Enable slider on mobile",
      "default": true
    },
    {
      "type": "select",
      "id": "controls_position",
      "label": "Slider controls type",
      "options": [
        { "value": "bottom", "label": "Progress bar" },
        { "value": "middle", "label": "Arrows only" },
        { "value": "dots", "label": "Dots" }
      ],
      "default": "dots"
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Enable autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "min": 2,
      "max": 8,
      "step": 1,
      "unit": "s",
      "label": "Autoplay interval",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "enable_loop",
      "label": "Enable infinite loop",
      "default": true
    },
    {
      "type": "header",
      "content": "Columns and spacing"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "Number of columns on desktop"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "1.2",
      "label": "Number of columns on mobile",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "1.2", "label": "1.2 columns" },
        { "value": "1.5", "label": "1.5 columns" },
        { "value": "2", "label": "2 columns" }
      ]
    },
    {
      "type": "checkbox",
      "id": "center_slides",
      "label": "Center slides",
      "default": true
    },
    {
      "type": "range",
      "id": "spacing",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Space between cards",
      "default": 30
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Partner Image"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Lorem ipsum dolor sit amet consectetur. Non sed nec massa semper in nec amet tristique. Volutpat consectetur ultrices leo turpis nunc neque ullamcorper tristique venenatis. Commodo arcu hac ullamcorper praesent hendrerit ac ut donec consectetur.</p>",
          "label": "Testimonial Text"
        },
        {
          "type": "text",
          "id": "author",
          "default": "Partner Name",
          "label": "Author Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Partner Slider",
      "blocks": [
        { "type": "testimonial", "settings": { "author": "Hardwell" } },
        { "type": "testimonial", "settings": { "author": "John Heitinga" } },
        { "type": "testimonial", "settings": { "author": "Doutzen Kroes" } }
      ]
    }
  ]
}
{% endschema %}