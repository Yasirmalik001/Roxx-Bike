{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .partner-testimonials {
    overflow: hidden;
  }

  /* --- Slider & Grid Setup --- */
  .partner-testimonials__slider .swiper-slide {
    height: auto;
  }

  @media screen and (min-width: 990px) {
    .slider-template-section__swiper:not(.swiper-initialized) .swiper-wrapper {
      display: flex;
      justify-content: flex-start;
      gap: {{ section.settings.spacing }}px;
    }
    .slider-template-section__swiper:not(.swiper-initialized) .swiper-slide {
      width: calc((100% - ({{ section.settings.spacing }}px * {{ section.settings.columns_desktop | minus: 1 }})) / {{ section.settings.columns_desktop }});
    }
  }

  /* --- Card Styling --- */
  .partner-card {
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
    border: none;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }

.partner-card__image-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 58%;
    overflow: hidden;
    border-radius: 12px;
}
  .partner-card__image-wrapper img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .partner-card__content {
    padding:  4rem 2.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .partner-card__text {
    font-size: 1.3rem;
    line-height: 1.6;
    margin-bottom: 2.5rem;
    color: rgba(var(--color-foreground), 0.8);
  }

  .partner-card__text p {
    margin: 0;
  }

  .partner-card__author {
    font-weight: 600;
    font-size: 1.3rem;
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 8px;
    color: rgb(var(--color-foreground));
  }

  .partner-card__author::before {
    content: "—";
    display: inline-block;
    color: rgba(var(--color-foreground), 0.5);
  }

  /* --- Footer Area (Dots & Button) --- */
  .partner-slider-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    width: 100%;
    min-height: 48px;
    margin-top: 4rem;
  }

  .partner-pagination-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* Swiper Dots Overrides */
  .section-{{ section.id }}-padding .slider-template-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
  }

  .section-{{ section.id }}-padding .slider-template-pagination .swiper-pagination-bullet {
    width: 12px;
    height: 12px;
    background-color: #FFD100 !important;
    opacity: 0.3 !important;
    margin: 0 !important;
    transition: all 0.3s ease;
    cursor: pointer;
    border-radius: 50%;
  }

  .section-{{ section.id }}-padding .slider-template-pagination .swiper-pagination-bullet-active {
    opacity: 1 !important;
    transform: scale(1.1);
  }

  /* Button alignment */
  .partner-button-wrapper {
    position: absolute;
    right: 0;
  }

  @media screen and (max-width: 989px) {
    .partner-slider-footer {
      flex-direction: column;
      gap: 3rem;
    }
    .partner-button-wrapper {
      position: static;
      display: block;
    }
  }
{%- endstyle -%}

<div class="partner-testimonials color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    
    {%- if section.settings.heading != blank -%}
      <h2 class="partner-testimonials__heading {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    <slider-container class="partner-testimonials__slider slider-template-section block" data-block-id="{{ section.id }}">
      <div class="slider-template-section__container">
          
          <div
            class="swiper js-slider-template-swiper slider-template-section__swiper"
            data-swiper-config='
              {
                "enableSliderDesktop": {{ section.settings.enable_slider_desktop }},
                "enableSliderMobile": {{ section.settings.enable_slider_mobile }},
                "loop": {{ section.settings.enable_loop | default: false }},
                "autoplay": {{ section.settings.enable_autoplay | default: false }},
                "autoplayInterval": {{ section.settings.autoplay_interval | times: 1000 | default: 3000 }},
                "mobileSlides": {{ section.settings.columns_mobile | plus: 0.0 }},
                "mobileSpacing": {{ section.settings.spacing | divided_by: 1.5 }},
                "desktopSlides": {{ section.settings.columns_desktop }},
                "desktopSpacing": {{ section.settings.spacing }},
                "centeredSlides": {{ section.settings.center_slides | default: false | json }},
                "initialSlide": {% if section.settings.center_slides and section.blocks.size >= 3 %}1{% else %}0{% endif %}
              }
            '
          >
            <div class="swiper-wrapper">
              {%- for block in section.blocks -%}
                <div class="swiper-slide" {{ block.shopify_attributes }}>
                  <div class="partner-card color-{{ block.settings.color_scheme }} gradient">
                    <div class="partner-card__image-wrapper">
                      {%- if block.settings.image != blank -%}
                        {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400, 600, 800' }}
                      {%- else -%}
                        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                      {%- endif -%}
                    </div>
                    <div class="partner-card__content">
                      <div class="partner-card__text rte">
                        {{ block.settings.text }}
                      </div>
                      <div class="partner-card__author">
                        {{ block.settings.author }}
                      </div>
                    </div>
                  </div>
                </div>
              {%- endfor -%}
            </div>
          </div>

          <div class="partner-slider-footer">
            <div class="slider-template-controls slider-template-controls--{{ section.settings.controls_position }}">
              
              {%- if section.settings.controls_position == 'dots' -%}
                <div class="slider-template-pagination partner-pagination-wrapper"></div>
              {%- endif -%}

            </div>

            {%- if section.settings.button_label != blank -%}
              <div class="partner-button-wrapper">
                <a {% if section.settings.button_link == blank %} role="link" aria-disabled="true"{% else %} href="{{ section.settings.button_link }}"{% endif %} 
                   class="button button--secondary partner-button">
                  {{ section.settings.button_label | escape }}
                </a>
              </div>
            {%- endif -%}
          </div>

      </div>
    </slider-container>
  </div>
</div>

{% schema %}
{
  "name": "Partner Slider",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "WHAT OUR PARTNER SAYS!",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" },
        { "value": "hxl", "label": "Extra Large" },
        { "value": "hxxl", "label": "Extra Extra Large" }
      ],
      "default": "h1",
      "label": "Heading Size"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Footer Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "View all",
      "label": "Button Label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Carousel Controls"
    },
    {
      "type": "checkbox",
      "id": "enable_slider_desktop",
      "label": "Enable slider on desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_slider_mobile",
      "label": "Enable slider on mobile",
      "default": true
    },
    {
      "type": "select",
      "id": "controls_position",
      "label": "Slider controls type",
      "options": [
        { "value": "dots", "label": "Dots" }
      ],
      "default": "dots"
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Enable autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "min": 2,
      "max": 8,
      "step": 1,
      "unit": "s",
      "label": "Autoplay interval",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "enable_loop",
      "label": "Enable infinite loop",
      "default": true
    },
    {
      "type": "header",
      "content": "Columns and spacing"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "Number of columns on desktop"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "1.2",
      "label": "Number of columns on mobile",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "1.2", "label": "1.2 columns" },
        { "value": "1.5", "label": "1.5 columns" },
        { "value": "2", "label": "2 columns" }
      ]
    },
    {
      "type": "checkbox",
      "id": "center_slides",
      "label": "Center slides",
      "default": false
    },
    {
      "type": "range",
      "id": "spacing",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Space between cards",
      "default": 30
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "label": "t:sections.all.colors.label",
          "default": "scheme-2"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Partner Image"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Lorem ipsum dolor sit amet consectetur. Non sed nec massa semper in nec amet tristique. Volutpat consectetur ultrices leo turpis nunc neque ullamcorper tristique venenatis. Commodo arcu hac ullamcorper praesent hendrerit ac ut donec consectetur.</p>",
          "label": "Testimonial Text"
        },
        {
          "type": "text",
          "id": "author",
          "default": "Partner Name",
          "label": "Author Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Partner Slider",
      "blocks": [
        { "type": "testimonial", "settings": { "author": "Hardwell" } },
        { "type": "testimonial", "settings": { "author": "John Heitinga" } },
        { "type": "testimonial", "settings": { "author": "Doutzen Kroes" } }
      ]
    }
  ]
}
{% endschema %}