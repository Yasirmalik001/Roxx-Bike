    },
    {
      "type": "text",
      "id": "tier_2_discount_text",
      "label": "Discount Text",
      "default": "10% OFF"
    },
    {
      "type": "header",
      "content": "Tier 3"
    },
    {
      "type": "text",
      "id": "tier_3_qty_text",
