      "label": "t:sections.main-collection-product-grid.settings.filter_type.label"
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "default": true,
      "label": "t:sections.main-collection-product-grid.settings.enable_sorting.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
  "type": "block",
  "name": "Tab",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Tab label"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Show tab",
      "default": true
    }
  ]
},
{
  "type": "bmsm_promo",
  "name": "Buy More, Save More Promo",
  "settings": [
    {
      "type": "number",
      "id": "insert_after",
      "label": "Insert after product #",
      "default": 8
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Main Background Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "card_color_scheme",
      "label": "Offer Card Color Scheme",
      "default": "scheme-2"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Card Heading",
      "default": "Buy More, Save More"
    },
    {
      "type": "image_picker",
      "id": "image",
