    },
    {
      "type": "range",
      "id": "shape_desktop_width",
      "min": 10,
      "max": 150,
      "step": 2,
      "unit": "%",
      "label": "Desktop Width",
      "default": 40
    },
    {
      "type": "range",
      "id": "shape_desktop_top",
      "min": -50,
      "max": 100,
      "step": 2,
      "unit": "%",
      "label": "Desktop Top Position",
      "default": 10
    },
    {
      "type": "range",
      "id": "shape_desktop_left",
