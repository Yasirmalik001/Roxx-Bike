{{ 'component-collection-hero.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Breadcrumbs */
  .custom-collection-hero__breadcrumbs {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 1.2rem;
    color: rgba(var(--color-foreground), 0.6);
    margin-bottom: 4rem;
    text-decoration: none;
  }
  
  .custom-collection-hero__breadcrumbs a {
    color: rgba(var(--color-foreground), 0.6);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .custom-collection-hero__breadcrumbs a:hover {
    color: rgb(var(--color-foreground));
  }

  .custom-collection-hero__breadcrumbs svg {
    width: 10px;
    height: 10px;
    opacity: 0.5;
  }

  /* Main Content Container */
  .custom-collection-hero__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
    gap: 1.6rem;
  }

  /* Reviews Block */
  .custom-collection-hero__reviews {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 0.5rem;
  }

  .custom-collection-hero__stars {
    display: flex;
    gap: 2px;
  }

  .custom-collection-hero__star-box {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    background-color: {{ section.settings.stars_color }};
  }

  .custom-collection-hero__star-box svg {
    width: 12px;
    height: 12px;
    fill: #ffffff;
  }

  .custom-collection-hero__reviews-text {
    font-size: 1.2rem;
    font-weight: 500;
    color: rgb(var(--color-foreground));
    margin: 0;
  }

  /* Text Elements */
  .custom-collection-hero__title {
    margin: 0;
    font-weight: 800;
    font-size: 3.6rem;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground));
    line-height: 1.1;
  }

  .custom-collection-hero__description {
    font-size: 1.4rem;
    color: rgba(var(--color-foreground), 0.8);
    line-height: 1.5;
    margin: 0;
  }

  /* Button */
  .custom-collection-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 1rem;
    padding: 12px 28px;
    border: 1px solid rgb(var(--color-foreground));
    border-radius: 50px;
    background-color: transparent;
    color: rgb(var(--color-foreground));
    font-size: 1.3rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .custom-collection-hero__btn:hover {
    background-color: rgba(var(--color-foreground), 0.05);
  }

  .custom-collection-hero__btn svg {
    width: 14px;
    height: 14px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  @media screen and (max-width: 749px) {
    .custom-collection-hero__title {
      font-size: 2.8rem;
    }
    .custom-collection-hero__description {
      font-size: 1.3rem;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.main_color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    
    {%- if section.settings.show_breadcrumbs -%}
      {%- assign promo_title = collection.title | default: page.title | default: section.settings.title -%}
      {% render 'breadcrumbs', class: 'custom-collection-hero__breadcrumbs', use_svg_separator: true, current_title: promo_title %}
    {%- endif -%}

    <div class="custom-collection-hero__content">
      
      {%- if section.settings.show_reviews -%}
        <div class="custom-collection-hero__reviews">
          <div class="custom-collection-hero__stars">
            {%- for i in (1..5) -%}
              <div class="custom-collection-hero__star-box">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279-7.416-3.967-7.417 3.967 1.481-8.279-6.064-5.828 8.332-1.151z"/>
                </svg>
              </div>
            {%- endfor -%}
          </div>
          {%- if section.settings.reviews_text != blank -%}
            <span class="custom-collection-hero__reviews-text">{{ section.settings.reviews_text }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      <h1 class="custom-collection-hero__title {{ section.settings.heading_size }}">
        {%- if section.settings.title != blank -%}
          {{ section.settings.title | escape }}
        {%- elsif collection.title != blank -%}
          {{ collection.title | escape }}
        {%- else -%}
          SHOP ALL BIKES
        {%- endif -%}
      </h1>
      
      {%- if section.settings.description != blank or collection.description != blank -%}
        <div class="custom-collection-hero__description rte">
          {%- if section.settings.description != blank -%}
            {{ section.settings.description }}
          {%- else -%}
            {{ collection.description }}
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: '#' }}" class="custom-collection-hero__btn">
          {{ section.settings.button_label }}
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
      {%- endif -%}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection Hero Clean",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Main Settings"
    },
    {
      "type": "color_scheme",
      "id": "main_color_scheme",
      "label": "Section Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "default": true,
      "label": "Show breadcrumbs"
    },
    {
      "type": "header",
      "content": "Reviews Badge"
    },
    {
      "type": "checkbox",
      "id": "show_reviews",
      "default": true,
      "label": "Show Reviews Badge"
    },
    {
      "type": "color",
      "id": "stars_color",
      "label": "Star Box Color",
      "default": "#00B67A",
      "info": "Default is Trustpilot Green"
    },
    {
      "type": "text",
      "id": "reviews_text",
      "label": "Reviews Text",
      "default": "4.4 / 5 (based on 200+)"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "SHOP ALL BIKES",
      "info": "Leave blank to use the Collection or Page title automatically."
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Explore the complete Roxx collection — from smart urban e-bikes to powerful fat bikes and everyday commuters. Designed for performance, comfort, and modern mobility.</p>",
      "info": "Leave blank to use the Collection description automatically."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Compare Models"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Collection Hero Clean"
    }
  ]
}
{% endschema %}