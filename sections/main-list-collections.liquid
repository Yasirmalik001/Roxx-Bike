{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .custom-category-header {
    background-color: #222222;
    color: #FFFFFF;
    text-align: center;
    padding: 12px 20px;
    font-size: 1.4rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 40px 0 24px 0;
  }

  /* Remove top margin for the very first header */
  .custom-category-header:first-of-type {
    margin-top: 0;
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    
    {%- for block in section.blocks -%}
      {%- if block.settings.title != blank -%}
        <div class="custom-category-header" {{ block.shopify_attributes }}>
          {{ block.settings.title }}
        </div>
      {%- endif -%}

      <ul class="grid product-grid grid--1-col grid--2-col-tablet grid--3-col-desktop">
        {%- assign collection = block.settings.collection -%}
        
        {%- if collection != blank and collection.products_count > 0 -%}
          {%- for product in collection.products limit: block.settings.products_to_show -%}
            <li class="grid__item">
              {% render 'card-product',
                card_product: product,
                media_aspect_ratio: section.settings.image_ratio,
                show_secondary_image: section.settings.show_secondary_image,
                show_vendor: section.settings.show_vendor,
                show_rating: section.settings.show_rating
              %}
            </li>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..3) -%}
            <li class="grid__item">
              <div class="placeholder-background" style="padding-bottom: 100%; position: relative; background: #f3f3f3;">
                {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            </li>
          {%- endfor -%}
        {%- endif -%}
      </ul>
      
    {%- endfor -%}

  </div>
</div>

{% schema %}
{
  "name": "Categorized Product Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Product Card Settings"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        { "value": "adapt", "label": "Adapt to image" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "square", "label": "Square" }
      ],
      "default": "adapt",
      "label": "Image ratio"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "Show second image on hover"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Show vendor"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": false,
      "label": "Show product rating"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Category Header Title",
          "default": "CITY BIKES"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection to Display"
        },
        {
          "type": "range",
          "id": "products_to_show",
          "min": 2,
          "max": 12,
          "step": 1,
          "default": 3,
          "label": "Maximum products to show in this category"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Categorized Product Grid",
      "blocks": [
        { "type": "category", "settings": { "title": "CITY BIKES" } },
        { "type": "category", "settings": { "title": "FAT BIKES" } }
      ]
    }
  ]
}
{% endschema %}