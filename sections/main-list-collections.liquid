{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'section-collection-list.css' | asset_url | stylesheet_tag }}

<style>
  /* Global Header Styles */
  .bikes-header {
    text-align: center;
    padding: 4rem 2rem;
    max-width: 800px;
    margin: 0 auto;
  }
  .bikes-header__reviews {
    color: #00b67a;
    font-size: 1.2rem;
    font-weight: bold;
    margin-bottom: 1rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
  }
  .bikes-header__title {
    font-size: 4rem;
    font-weight: 900;
    text-transform: uppercase;
    margin: 0 0 1rem 0;
    letter-spacing: -0.02em;
  }
  .bikes-header__desc {
    font-size: 1.4rem;
    color: #555;
    margin-bottom: 2rem;
    line-height: 1.5;
  }
  .btn-outline {
    display: inline-block;
    padding: 1rem 2rem;
    border: 1px solid #111;
    border-radius: 50px;
    text-decoration: none;
    color: #111;
    font-weight: 600;
    font-size: 1.2rem;
    transition: all 0.3s ease;
  }
  .btn-outline:hover {
    background: #111;
    color: #fff;
  }
  
  /* Category Banner Divider */
  .category-banner {
    background-color: #1a1a1a;
    color: #ffffff;
    text-align: center;
    padding: 1.5rem 0;
    margin: 4rem 0 3rem 0;
    text-transform: uppercase;
    font-weight: 800;
    font-size: 1.8rem;
    letter-spacing: 0.05em;
  }
</style>

<div class="bikes-page">
  <div class="bikes-header{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    <div class="bikes-header__reviews">
      <span class="stars">★★★★★</span> {{ section.settings.review_text }}
    </div>
    <h1 class="bikes-header__title">{{ section.settings.title }}</h1>
    <p class="bikes-header__desc">{{ section.settings.description }}</p>
    {% if section.settings.button_label != blank %}
      <a href="{{ section.settings.button_link }}" class="btn-outline">{{ section.settings.button_label }}</a>
    {% endif %}
  </div>

  {%- liquid
    case section.settings.sort
      when 'products_high', 'products_low'
        assign sorted_collections = collections | sort: 'all_products_count'
      when 'date', 'date_reversed'
        assign sorted_collections = collections | sort: 'published_at'
      else
        assign sorted_collections = collections | sort: 'title'
    endcase

    if section.settings.sort == 'products_high' or section.settings.sort == 'date_reversed' or section.settings.sort == 'alphabetical_reversed'
      assign sorted_collections = sorted_collections | reverse
    endif
  -%}

  {%- for collection in sorted_collections -%}
    {%- if collection.all_products_count > 0 -%}
      <div class="category-section{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
           {% if settings.animations_reveal_on_scroll %}data-cascade style="--animation-order: {{ forloop.index }};"{% endif %}>
        
        <div class="category-banner">
          {{ collection.title }}
        </div>

        <div class="page-width">
          <ul class="grid grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down" role="list">
            
            {%- for product in collection.products limit: section.settings.products_per_collection -%}
              <li class="grid__item">
                {% render 'card-product',
                  card_product: product,
                  media_aspect_ratio: section.settings.image_ratio,
                  show_secondary_image: section.settings.show_secondary_image,
                  show_vendor: section.settings.show_vendor,
                  show_rating: section.settings.show_rating
                %}
              </li>
            {%- endfor -%}
            
          </ul>
        </div>
      </div>
    {%- endif -%}
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "Categorized Bikes Grid",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Page Header Content"
    },
    {
      "type": "text",
      "id": "review_text",
      "label": "Review Text",
      "default": "5.0 / 5.0 (Based on 200+)"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "SHOP ALL BIKES"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Explore the complete bike collection — from smart urban e-bikes to powerful fat bikes and everyday commuters."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Compare Models ➔"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Grid Settings"
    },
    {
      "type": "range",
      "id": "products_per_collection",
      "min": 3,
      "max": 12,
      "step": 3,
      "default": 3,
      "label": "Products to show per category"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "Columns on desktop"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        {
          "value": "1",
          "label": "1 column"
        },
        {
          "value": "2",
          "label": "2 columns"
        }
      ],
      "default": "1",
      "label": "Columns on mobile"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt to image"
        },
        {
          "value": "portrait",
          "label": "Portrait"
        },
        {
          "value": "square",
          "label": "Square"
        }
      ],
      "default": "adapt",
      "label": "Image ratio"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "Show second image on hover"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Show vendor"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": false,
      "label": "Show product rating"
    }
  ]
}
{% endschema %}