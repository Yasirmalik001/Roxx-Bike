{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .app-intro-section {
    overflow: hidden;
    background-color: transparent;
  }

  /* --- Header Styles --- */
  .app-intro-header {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 6rem auto;
  }

  .app-intro-heading {
    margin: 0 0 1.5rem 0;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0em;
    color: rgb(var(--color-foreground));
  }

  .app-intro-description {
    font-size: 1.5rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.75);
    margin: 0 auto;
    max-width: 650px;
  }

  /* --- Main Grid Layout --- */
  .app-intro-grid {
    display: flex;
    flex-direction: column;
    gap: 5rem;
  }

  @media screen and (min-width: 990px) {
    .app-intro-grid {
      flex-direction: row;
      align-items: center;
      gap: 4rem;
    }
    .app-image-col {
      width: 55%;
    }
    .app-card-col {
      width: 45%;
    }
  }

  /* --- Left Column: 3 Images Composition --- */
  .app-image-col {
    position: relative;
    display: flex;
    align-items: center;
    /* Extra padding bottom to allow devices to hang down slightly without clipping */
    padding-bottom: 3rem; 
  }

  .layer-bike {
    width: 78%; /* Bike takes up left 78% */
    height: auto;
    object-fit: contain;
    position: relative;
    z-index: 1;
    display: block;
  }

  .layer-device-1 {
    position: absolute;
    width: 25%; /* Tablet/Phone 1 size */
    bottom: 5%;
    right: 18%; /* Positioned slightly behind Device 2 */
    z-index: 2;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(-10px 15px 25px rgba(0, 0, 0, 0.15));
  }

  .layer-device-2 {
    position: absolute;
    width: 22%; /* Mobile size */
    bottom: 0%;
    right: 2%; /* Positioned on the far right */
    z-index: 3;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(-15px 20px 30px rgba(0, 0, 0, 0.2));
  }

  /* --- Right Column: Feature Card (1:1 White Box) --- */
  .app-card-col {
    display: flex;
    justify-content: center;
  }

  .app-feature-card {
    background-color: #ffffff; /* Forced white to match screenshot */
    border-radius: 16px;
    padding: 6rem 5rem;
    width: 100%;
    max-width: 550px;
    box-shadow: 0 15px 50px rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(0, 0, 0, 0.02);
  }

  .app-features-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 3rem;
    row-gap: 5rem;
  }

  /* --- Individual Feature Block --- */
  .app-feature-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.8rem;
  }

  .app-feature-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background-color: #d8d8d8; /* Solid gray placeholder circle from image */
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .app-feature-icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .app-feature-title {
    font-size: 1.3rem;
    font-weight: 500;
    line-height: 1.4;
    color: #333333;
    margin: 0;
    max-width: 160px;
  }

  /* Mobile Adjustments */
  @media screen and (max-width: 749px) {
    .app-intro-header {
      margin-bottom: 4rem;
    }
    .layer-bike { width: 85%; }
    .layer-device-1 { width: 30%; right: 12%; }
    .layer-device-2 { width: 26%; right: 0%; }
    
    .app-feature-card {
      padding: 4rem 2rem;
    }
    .app-features-wrapper {
      column-gap: 2rem;
      row-gap: 4rem;
    }
  }
{%- endstyle -%}

<div class="app-intro-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding" {{ section.shopify_attributes }}>
  <div class="page-width">
    
    <div class="app-intro-header">
      {%- if section.settings.title != blank -%}
        <h2 class="app-intro-heading h1 {{ section.settings.heading_size }}">{{ section.settings.title | escape }}</h2>
      {%- endif -%}
      
      {%- if section.settings.description != blank -%}
        <div class="app-intro-description rte">
          {{ section.settings.description }}
        </div>
      {%- endif -%}
    </div>

    <div class="app-intro-grid">
      
      <div class="app-image-col">
        {%- if section.settings.image_bike != blank -%}
          {{ section.settings.image_bike | image_url: width: 1000 | image_tag: class: 'layer-bike', loading: 'lazy' }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'layer-bike placeholder-svg' }}
        {%- endif -%}

        {%- if section.settings.image_device_1 != blank -%}
          {{ section.settings.image_device_1 | image_url: width: 400 | image_tag: class: 'layer-device-1', loading: 'lazy' }}
        {%- endif -%}

        {%- if section.settings.image_device_2 != blank -%}
          {{ section.settings.image_device_2 | image_url: width: 300 | image_tag: class: 'layer-device-2', loading: 'lazy' }}
        {%- endif -%}
      </div>

      <div class="app-card-col">
        <div class="app-feature-card">
          
          {%- if section.blocks.size > 0 -%}
            <div class="app-features-wrapper">
              {%- for block in section.blocks -%}
                <div class="app-feature-item" {{ block.shopify_attributes }}>
                  
                  <div class="app-feature-icon">
                    {%- if block.settings.icon != blank -%}
                      {{ block.settings.icon | image_url: width: 100 | image_tag: loading: 'lazy' }}
                    {%- endif -%}
                  </div>

                  {%- if block.settings.title != blank -%}
                    <h3 class="app-feature-title">{{ block.settings.title | escape }}</h3>
                  {%- endif -%}
                  
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}

        </div>
      </div>

    </div>

  </div>
</div>

{% schema %}
{
  "name": "App Features Intro",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section Background Color Scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Header Settings"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "INTRODUCING OUR ALL IN ONE APP"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h0", "label": "t:sections.all.heading_size.options__3.label" },
        { "value": "hxl", "label": "Extra Large" }
      ],
      "default": "h0",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>The Roxx JX electric bike works with an app specifically designed for this model and an advanced all-in-one system.</p>"
    },
    {
      "type": "header",
      "content": "Visuals (Left Column Composition)"
    },
    {
      "type": "image_picker",
      "id": "image_bike",
      "label": "1. Base Image (Bike)",
      "info": "This image sits in the background on the left."
    },
    {
      "type": "image_picker",
      "id": "image_device_1",
      "label": "2. Middle Device (Tablet/Phone 1)",
      "info": "Overlaps the bike on the right side."
    },
    {
      "type": "image_picker",
      "id": "image_device_2",
      "label": "3. Front Device (Mobile/Phone 2)",
      "info": "Overlaps Device 1 and sits in the foreground."
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "App Feature",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Upload Icon Image",
          "info": "If left blank, a solid gray circle will appear."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Feature Title",
          "default": "4G remote communication"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "App Features Intro",
      "blocks": [
        { "type": "feature", "settings": { "title": "4G remote communication" } },
        { "type": "feature", "settings": { "title": "Cycling track" } },
        { "type": "feature", "settings": { "title": "Bluetooth near field communication" } },
        { "type": "feature", "settings": { "title": "Multiple alarm modes" } },
        { "type": "feature", "settings": { "title": "Multiple unlocking methods" } },
        { "type": "feature", "settings": { "title": "Geo-fence" } }
      ]
    }
  ]
}
{% endschema %}