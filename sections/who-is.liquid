{%- style -%}
/* ==================================
   1. MOBILE & BASE STYLES
================================== */
.section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px; padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px; }
.who-is-section { position: relative; overflow: hidden; border-radius: 24px; padding: 3rem; }
.who-is-container { display: flex; flex-direction: column; gap: 3rem; position: relative; z-index: 1; }
.who-is-image-container { flex: 1; position: relative; z-index: 1; width: 100%; }
.who-is-main-image { width: 100%; height: auto; border-radius: 20px; object-fit: cover; aspect-ratio: 4 / 5; position: relative; z-index: 2; display: block; }
.who-is-shape { position: absolute; z-index: 0; pointer-events: none; object-fit: contain; }
.who-is-content { flex: 1; display: flex; flex-direction: column; align-items: center; text-align: center; }
.who-is-intro { font-size: 15px; line-height: 1.6; margin-bottom: 2rem; color: inherit; opacity: 0.9; }
.who-is-intro p { margin: 0 0 1rem 0; }
.who-is-intro p:last-child { margin-bottom: 0; }
.who-is-subheading { font-size: 18px; color: inherit; margin: 0 0 1.5rem 0; font-weight: 600; }
.who-is-features { display: grid; grid-template-columns: 1fr; gap: 2rem; margin-bottom: 2.5rem; width: 100%; }
.who-is-feature { display: flex; flex-direction: column; gap: 12px; align-items: center; text-align: center; }
.who-is-feature-icon.who-is-feature-icon {
    display: flex;
    justify-content: center;
    color: inherit;
    border-radius: 50%;
    border: 1px solid #2B2B2B;
}
.who-is-feature-icon img { display: block; box-sizing: border-box; padding: 8px;width: 56px; height: 56px; object-fit: contain; }
.who-is-feature-title {  font-weight: 500; font-size: 16px; line-height: 1.3; letter-spacing: 0.02em; color: inherit; margin: 0; }
.who-is-feature-text {  font-weight: 400; font-size: 14px; line-height: 1.3; letter-spacing: 0.02em; margin: 0; text-align: center; max-width: 228px;}
.who-is-feature-text p { margin: 0; }
/* .who-is-button { background-color: #F5F2ED; color: white; padding: 14px 32px; border-radius: 50px; text-decoration: none; font-weight: 600; font-size: 15px; display: inline-flex; transition: opacity 0.3s ease; align-self: center; }/ */

/* ==================================
   2. TABLET STYLES
================================== */
@media screen and (min-width: 750px) { 
  .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; } 
  .who-is-features { grid-template-columns: 1fr 1fr; gap: 2.5rem 2rem; }
  .who-is-feature { align-items: flex-start; text-align: left; }
  .who-is-feature-text { text-align: left; }
}

/* ==================================
   3. DESKTOP STYLES
================================== */
@media screen and (min-width: 990px) { 
  .who-is-section { padding: 4rem; } 
  .who-is-container { flex-direction: row; align-items: center; gap: 5rem; } 
  .who-is-container--right { flex-direction: row-reverse; } 
  .who-is-content { align-items: flex-start; text-align: left; } 
  .who-is-button { align-self: flex-start; } 
}

/* ==================================
   4. DYNAMIC DECORATIVE SHAPES
================================== */
{%- for block in section.blocks -%}
  {%- if block.type == 'shape' -%}
    .shape-{{ block.id }} { top: {{ block.settings.mobile_top }}%; left: {{ block.settings.mobile_left }}%; width: {{ block.settings.mobile_width }}%; }
    @media screen and (min-width: 990px) { .shape-{{ block.id }} { top: {{ block.settings.desktop_top }}%; left: {{ block.settings.desktop_left }}%; width: {{ block.settings.desktop_width }}%; } }
  {%- endif -%}
{%- endfor -%}
{%- endstyle -%}
<div class="page-width section-{{ section.id }}-padding">
  <div class="who-is-section color-{{ section.settings.color_scheme }} gradient">
    <div class="who-is-container {% if section.settings.desktop_image_position == 'right' %}who-is-container--right{% endif %}">
      
      <div class="who-is-image-container">
        {%- for block in section.blocks -%}
          {%- if block.type == 'shape' and block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 600 }}" alt="" loading="lazy" class="who-is-shape shape-{{ block.id }}" {{ block.shopify_attributes }}>
          {%- endif -%}
        {%- endfor -%}

        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'who-is-main-image', sizes: '(min-width: 990px) 50vw, 100vw' }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'who-is-main-image placeholder-svg' }}
        {%- endif -%}
      </div>

      <div class="who-is-content">
        {%- assign in_feature_grid = false -%}
        
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            {%- if in_feature_grid == false -%}
              <div class="who-is-features">
              {%- assign in_feature_grid = true -%}
            {%- endif -%}
            
            <div class="who-is-feature" {{ block.shopify_attributes }}>
              {%- if block.settings.icon_image != blank -%}
                <div class="who-is-feature-icon">
                  {{ block.settings.icon_image | image_url: width: 100 | image_tag: loading: 'lazy', alt: block.settings.title }}
                </div>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <div class="who-is-feature-title">{{ block.settings.title }}</div>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="who-is-feature-text">{{ block.settings.text }}</div>
              {%- endif -%}
            </div>
            
          {%- else -%}
            {%- if in_feature_grid -%}
              </div>
              {%- assign in_feature_grid = false -%}
            {%- endif -%}

            {%- case block.type -%}
              {%- when 'heading' -%}
                {%- if block.settings.heading != blank -%}
                  <h2 class="who-is-heading h1" {{ block.shopify_attributes }}>{{ block.settings.heading }}</h2>
                {%- endif -%}
                
              {%- when 'text' -%}
                {%- if block.settings.text != blank -%}
                  <div class="who-is-intro" {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
                {%- endif -%}
                
              {%- when 'subheading' -%}
                {%- if block.settings.subheading != blank -%}
                  <div class="who-is-subheading" {{ block.shopify_attributes }}>{{ block.settings.subheading }}</div>
                {%- endif -%}
                
              {%- when 'button' -%}
                {%- if block.settings.button_label != blank and block.settings.button_link != blank -%}
                  <a href="{{ block.settings.button_link }}" class="button button--primary" {{ block.shopify_attributes }}>
                    {{ block.settings.button_label }}
                  </a>
                {%- endif -%}
            {%- endcase -%}
            
          {%- endif -%}
        {%- endfor -%}
        
        {%- if in_feature_grid -%}
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Who is Sereluna",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Main Layout"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image"
    },
    {
      "type": "select",
      "id": "desktop_image_position",
      "options": [
        { "value": "left", "label": "Image on Left, Text on Right" },
        { "value": "right", "label": "Image on Right, Text on Left" }
      ],
      "default": "left",
      "label": "Desktop Image Position"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Who is sereluna?" }
      ]
    },
    {
      "type": "text",
      "name": "Intro Text",
      "limit": 1,
      "settings": [
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Sereluna is a family-owned company founded in 2022 by me, Charlotte (that's me in the photo). We've helped thousands of women have a better and more comfortable experience during their period.</p>" }
      ]
    },
    {
      "type": "subheading",
      "name": "Subheading",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "subheading", "label": "Subheading", "default": "What makes us best" }
      ]
    },
    {
      "type": "feature",
      "name": "Icon Feature",
      "limit": 4,
      "settings": [
        { "type": "image_picker", "id": "icon_image", "label": "Icon Image" },
        { "type": "text", "id": "title", "label": "Feature Title", "default": "Fast delivery" },
        { "type": "richtext", "id": "text", "label": "Feature Text", "default": "<p>We ship directly from our warehouse just outside Oslo — delivery takes around 2 days.</p>" }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "button_label", "label": "Button Label", "default": "Learn More" },
        { "type": "url", "id": "button_link", "label": "Button Link" }
      ]
    },
    {
      "type": "shape",
      "name": "Decorative Shape",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Shape Image (PNG)" },
        { "type": "header", "content": "Desktop Settings" },
        { "type": "range", "id": "desktop_width", "min": 10, "max": 150, "step": 2, "unit": "%", "label": "Width", "default": 30 },
        { "type": "range", "id": "desktop_top", "min": -50, "max": 100, "step": 2, "unit": "%", "label": "Top Position", "default": -10 },
        { "type": "range", "id": "desktop_left", "min": -50, "max": 100, "step": 2, "unit": "%", "label": "Left Position", "default": -10 },
        { "type": "header", "content": "Mobile Settings" },
        { "type": "range", "id": "mobile_width", "min": 10, "max": 150, "step": 2, "unit": "%", "label": "Width", "default": 20 },
        { "type": "range", "id": "mobile_top", "min": -50, "max": 100, "step": 2, "unit": "%", "label": "Top Position", "default": -10 },
        { "type": "range", "id": "mobile_left", "min": -50, "max": 100, "step": 2, "unit": "%", "label": "Left Position", "default": -10 }
      ]
    }
  ],
  "presets": [
    {
      "name": "Who is Sereluna",
      "blocks": [
        { "type": "shape" },
        { "type": "shape" },
        { "type": "heading" },
        { "type": "text" },
        { "type": "subheading" },
        { "type": "feature", "settings": { "title": "Fast delivery", "text": "<p>We ship directly from our warehouse just outside Oslo.</p>" } },
        { "type": "feature", "settings": { "title": "Easy payment", "text": "<p>Shop safely with Vipps or Klarna — receive your products first and pay later.</p>" } },
        { "type": "feature", "settings": { "title": "Personal customer service", "text": "<p>We offer top-quality customer support and are happy to help if you need to change size.</p>" } },
        { "type": "feature", "settings": { "title": "Trust & quality", "text": "<p>We are a Norwegian company and naturally follow Norwegian consumer protection laws.</p>" } },
        { "type": "button", "settings": { "button_label": "Learn More", "button_link": "/" } }
      ]
    }
  ]
}
{% endschema %}