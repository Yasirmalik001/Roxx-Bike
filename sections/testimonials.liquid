<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.background_color }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .customer-reviews {
    overflow: hidden;
  }

  /* Header Bar */
  .customer-reviews__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 4rem;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .customer-reviews__heading {
    margin: 0;
    font-weight: 800;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: #000000;
  }

  .customer-reviews__brand-logo img {
    height: 30px;
    width: auto;
    object-fit: contain;
  }

  /* Main Layout */
  .customer-reviews__layout {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  @media screen and (min-width: 990px) {
    .customer-reviews__layout {
      flex-direction: row;
      align-items: stretch;
      gap: 5rem;
    }
  }

  /* Left Summary Card */
  .customer-reviews__summary-card {
    background-color: #ffffff;
    border: 1px solid #e5e5e5;
    border-radius: 12px;
    padding: 4rem 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    width: 100%;
    box-shadow: 0 4px 15px rgba(0,0,0,0.02);
  }

  @media screen and (min-width: 990px) {
    .customer-reviews__summary-card {
      width: 320px;
      flex-shrink: 0;
    }
  }

  .customer-reviews__summary-stars {
    margin-bottom: 1.5rem;
  }

  .customer-reviews__summary-stars img,
  .customer-reviews__summary-stars svg {
    height: 24px;
    width: auto;
  }

  .customer-reviews__summary-rating {
    font-size: 1.6rem;
    font-weight: 700;
    color: #000000;
    margin: 0 0 0.5rem 0;
  }

  .customer-reviews__summary-count {
    font-size: 1.3rem;
    color: #666666;
    margin: 0 0 4rem 0;
  }

  /* Custom Navigation Buttons */
  .customer-reviews__nav-buttons {
    display: flex;
    gap: 1.5rem;
    margin-top: auto;
  }

  .customer-reviews__btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: #ffd000;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: none;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .customer-reviews__btn:hover {
    transform: scale(1.05);
  }

  .customer-reviews__btn.swiper-button-disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  .customer-reviews__btn svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: #ffffff;
    stroke-width: 2.5;
  }

  /* Right Slider Area */
  .customer-reviews__slider-wrapper {
    flex-grow: 1;
    min-width: 0; /* Prevents Swiper from breaking flex container */
    position: relative;
  }

  /* Track background line */
  .customer-reviews__slider-wrapper::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: #eeeeee;
    z-index: 1;
  }

  /* Individual Slide Card */
  .review-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding-bottom: 3rem;
    position: relative;
  }

  .review-card__stars {
    margin-bottom: 1.5rem;
  }

  .review-card__stars img,
  .review-card__stars svg {
    height: 20px;
    width: auto;
  }

  .review-card__text {
    font-size: 1.4rem;
    line-height: 1.6;
    color: #333333;
    margin-bottom: 2rem;
    flex-grow: 1;
  }

  .review-card__author {
    font-size: 1.4rem;
    font-weight: 600;
    color: #000000;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Active line indicator for slides */
  .swiper-slide {
    position: relative;
    z-index: 2;
  }

  .swiper-slide::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: transparent;
    transition: background-color 0.3s ease;
  }

  .swiper-slide-active::after {
    background-color: #ffd000;
    z-index: 3;
  }
{%- endstyle -%}

<div class="customer-reviews section-{{ section.id }}-padding">
  <div class="page-width">
    
    <div class="customer-reviews__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="customer-reviews__heading {{ section.settings.heading_size }}">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if section.settings.brand_logo != blank -%}
        <div class="customer-reviews__brand-logo">
          {{ section.settings.brand_logo | image_url: width: 300 | image_tag: loading: 'lazy' }}
        </div>
      {%- endif -%}
    </div>

    <div class="customer-reviews__layout">
      
      <div class="customer-reviews__summary-card">
        <div class="customer-reviews__summary-stars">
          {%- if section.settings.summary_stars_image != blank -%}
            {{ section.settings.summary_stars_image | image_url: width: 150 | image_tag: loading: 'lazy' }}
          {%- else -%}
            <svg viewBox="0 0 120 24" fill="#00B67A" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
              <path d="M36 17.27L42.18 21l-1.64-7.03L46 9.24l-7.19-.61L36 2 33.19 8.63 26 9.24l5.46 4.73L29.82 21z"/>
              <path d="M60 17.27L66.18 21l-1.64-7.03L70 9.24l-7.19-.61L60 2 57.19 8.63 50 9.24l5.46 4.73L53.82 21z"/>
              <path d="M84 17.27L90.18 21l-1.64-7.03L94 9.24l-7.19-.61L84 2 81.19 8.63 74 9.24l5.46 4.73L77.82 21z"/>
              <path d="M108 17.27L114.18 21l-1.64-7.03L118 9.24l-7.19-.61L108 2 105.19 8.63 98 9.24l5.46 4.73L101.82 21z"/>
            </svg>
          {%- endif -%}
        </div>
        
        <p class="customer-reviews__summary-rating">{{ section.settings.summary_rating_text }}</p>
        <p class="customer-reviews__summary-count">{{ section.settings.summary_count_text }}</p>

        <div class="customer-reviews__nav-buttons">
          <button class="customer-reviews__btn swiper-prev-{{ section.id }}" aria-label="Previous slide">
            <svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <button class="customer-reviews__btn swiper-next-{{ section.id }}" aria-label="Next slide">
            <svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        </div>
      </div>

      <div class="customer-reviews__slider-wrapper">
        <div class="swiper" id="Swiper-{{ section.id }}">
          <div class="swiper-wrapper">
            
            {%- for block in section.blocks -%}
              <div class="swiper-slide" {{ block.shopify_attributes }}>
                <div class="review-card">
                  <div class="review-card__stars">
                    {%- if block.settings.stars_image != blank -%}
                      {{ block.settings.stars_image | image_url: width: 150 | image_tag: loading: 'lazy' }}
                    {%- else -%}
                       <svg viewBox="0 0 120 24" fill="#00B67A" xmlns="http://www.w3.org/2000/svg">
                          <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                          <path d="M36 17.27L42.18 21l-1.64-7.03L46 9.24l-7.19-.61L36 2 33.19 8.63 26 9.24l5.46 4.73L29.82 21z"/>
                          <path d="M60 17.27L66.18 21l-1.64-7.03L70 9.24l-7.19-.61L60 2 57.19 8.63 50 9.24l5.46 4.73L53.82 21z"/>
                          <path d="M84 17.27L90.18 21l-1.64-7.03L94 9.24l-7.19-.61L84 2 81.19 8.63 74 9.24l5.46 4.73L77.82 21z"/>
                          <path d="M108 17.27L114.18 21l-1.64-7.03L118 9.24l-7.19-.61L108 2 105.19 8.63 98 9.24l5.46 4.73L101.82 21z"/>
                        </svg>
                    {%- endif -%}
                  </div>
                  <div class="review-card__text rte">
                    {{ block.settings.text }}
                  </div>
                  <div class="review-card__author">
                    &mdash; {{ block.settings.author }}
                  </div>
                </div>
              </div>
            {%- endfor -%}

          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const initReviewSwiper{{ section.id | replace: '-', '_' }} = () => {
      if (typeof Swiper !== 'undefined') {
        new Swiper('#Swiper-{{ section.id }}', {
          slidesPerView: 1,
          spaceBetween: 30,
          grabCursor: true,
          navigation: {
            nextEl: '.swiper-next-{{ section.id }}',
            prevEl: '.swiper-prev-{{ section.id }}',
          },
          breakpoints: {
            750: {
              slidesPerView: 2,
              spaceBetween: 40
            },
            1200: {
              slidesPerView: 3,
              spaceBetween: 50
            }
          }
        });
      } else {
        setTimeout(initReviewSwiper{{ section.id | replace: '-', '_' }}, 100);
      }
    };
    
    initReviewSwiper{{ section.id | replace: '-', '_' }}();
  });
</script>

{% schema %}
{
  "name": "Customer Reviews Slider",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Header Layout"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "OUR CUSTOMER SAY!",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h0",
      "label": "Heading Size"
    },
    {
      "type": "image_picker",
      "id": "brand_logo",
      "label": "Brand Logo (e.g. Trustpilot)"
    },
    {
      "type": "header",
      "content": "Summary Card (Left)"
    },
    {
      "type": "image_picker",
      "id": "summary_stars_image",
      "label": "Summary Stars Image (Manual Override)"
    },
    {
      "type": "text",
      "id": "summary_rating_text",
      "label": "Rating Text",
      "default": "4.2 stars / 5"
    },
    {
      "type": "text",
      "id": "summary_count_text",
      "label": "Review Count Text",
      "default": "(Based on 200+ reviews)"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "image_picker",
          "id": "stars_image",
          "label": "Custom Stars Image (Manual Override)"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Lorem ipsum dolor sit amet consectetur. Massa enim ut risus leo scelerisque semper. Lacus feugiat tellus eget hendrerit phasellus et platea arcu. Sollicitudin tempor egestas orci cursus eu purus. Praesent pretium dui aliquam feugiat a et. Mauris non auctor eget tortor.</p>",
          "label": "Review Text"
        },
        {
          "type": "text",
          "id": "author",
          "default": "Lena . J",
          "label": "Author Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer Reviews Slider",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}