{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .customer-reviews {
    overflow: hidden;
  }

  /* Header Bar */
  .customer-reviews__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 4rem;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .customer-reviews__heading {
    margin: 0;
    font-weight: 800;
    letter-spacing: -0.03em;
    text-transform: uppercase;
  }

  .customer-reviews__header-right {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  .customer-reviews__brand-logo img {
    height: 30px;
    width: auto;
    object-fit: contain;
  }

  /* Main Layout */
  .customer-reviews__layout {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    width: 100%;
  }

  .customer-reviews__layout--with-summary {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  @media screen and (min-width: 990px) {
    .customer-reviews__layout--with-summary {
      flex-direction: row;
      align-items: stretch;
      gap: 5rem;
    }
  }

  /* Left Summary Card */
  .customer-reviews__summary-card {
    background-color: rgba(var(--color-foreground), 0.03);
    border: 1px solid rgba(var(--color-foreground), 0.08);
    border-radius: 12px;
    padding: 4rem 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    width: 100%;
    box-shadow: 0 4px 15px rgba(0,0,0,0.02);
  }

  @media screen and (min-width: 990px) {
    .customer-reviews__summary-card {
      width: 320px;
      flex-shrink: 0;
    }
  }

  .customer-reviews__summary-stars {
    margin-bottom: 1.5rem;
  }

  .customer-reviews__summary-stars img,
  .customer-reviews__summary-stars svg {
    height: 24px;
    width: auto;
  }

  .customer-reviews__summary-rating {
    font-size: 1.6rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0;
  }

  .customer-reviews__summary-count {
    font-size: 1.3rem;
    opacity: 0.75;
    margin: 0 0 4rem 0;
  }

  /* Custom Navigation Buttons */
  .customer-reviews__nav-buttons {
    display: flex;
    gap: 1.5rem;
    margin-top: auto;
  }

  .customer-reviews__btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: transparent !important;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: 1px solid rgba(var(--color-foreground), 0.15) !important;
    color: currentColor !important;
    transition: all 0.2s ease;
  }

  .customer-reviews__btn:hover {
    background-color: rgba(var(--color-foreground), 0.05) !important;
    border-color: rgba(var(--color-foreground), 0.8) !important;
  }

  .customer-reviews__btn.swiper-button-disabled {
    opacity: 0.3 !important;
    cursor: not-allowed !important;
    border-color: rgba(var(--color-foreground), 0.08) !important;
  }

  .customer-reviews__btn svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: currentColor !important;
    stroke-width: 2.5;
  }

  /* Right Slider Area */
  .customer-reviews__slider-wrapper {
    flex-grow: 1;
    min-width: 0; /* Prevents Swiper from breaking flex container */
    position: relative;
  }


  /* Individual Slide Card */
  .review-card {
    background-color: rgba(var(--color-foreground), 0.03);
    border: 1px solid rgba(var(--color-foreground), 0.08);
    border-radius: 12px;
    padding: 3rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    box-sizing: border-box;
    transition: box-shadow 0.3s ease;
  }

  .review-card:hover {
    box-shadow: 0 4px 15px rgba(var(--color-foreground), 0.03);
  }

  .review-card__stars {
    margin-bottom: 2rem;
  }

  .review-card__stars img,
  .review-card__stars svg {
    height: 20px;
    width: auto;
  }

  .review-card__text {
    font-size: 1.4rem;
    line-height: 1.6;
    opacity: 0.85;
    margin-bottom: 2.5rem;
    flex-grow: 1;
  }

  .review-card__author {
    font-size: 1.4rem;
    font-weight: 600;
    color: currentColor;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Custom overrides for .slider-template-pagination dots */
  .section-{{ section.id }}-padding .slider-template-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.2rem;
    margin-top: 3rem;
  }

  .section-{{ section.id }}-padding .slider-template-pagination .swiper-pagination-bullet {
    width: 1rem;
    height: 1rem;
    background-color: currentColor !important;
    opacity: 0.2 !important;
    margin: 0 !important;
    transition: all 0.3s ease;
    cursor: pointer;
    border-radius: 50%;
  }

  .section-{{ section.id }}-padding .slider-template-pagination .swiper-pagination-bullet-active {
    background-color: #00b67a !important;
    opacity: 1 !important;
    transform: scale(1.1);
  }

  /* Custom styling for progress fill in reviews */
  .section-{{ section.id }}-padding .slider-template-progress-track {
    background: rgba(var(--color-foreground), 0.08) !important;
    margin-top: 3rem;
  }

  .section-{{ section.id }}-padding .slider-template-progress-fill {
    background: #00b67a !important;
  }
{%- endstyle -%}

<slider-container class="customer-reviews block" data-block-id="{{ section.id }}">
  <div class="customer-reviews section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
    <div class="page-width">
      
      <div class="customer-reviews__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="hero-features__heading {{ section.settings.heading_size }}">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}

        <div class="customer-reviews__header-right">
          {%- if section.settings.brand_logo != blank -%}
            <div class="customer-reviews__brand-logo">
              {{ section.settings.brand_logo | image_url: width: 300 | image_tag: loading: 'lazy' }}
            </div>
          {%- endif -%}

          {%- unless section.settings.show_summary_card -%}
            <div class="customer-reviews__nav-buttons">
              <button class="customer-reviews__btn js-slider-template-prev" aria-label="Previous slide">
                <svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
              </button>
              <button class="customer-reviews__btn js-slider-template-next" aria-label="Next slide">
                <svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
              </button>
            </div>
          {%- endunless -%}
        </div>
      </div>

      <div class="{% if section.settings.show_summary_card %}customer-reviews__layout--with-summary{% else %}customer-reviews__layout{% endif %}">
        
        {%- if section.settings.show_summary_card -%}
          <div class="customer-reviews__summary-card">
            <div class="customer-reviews__summary-stars">
              {%- if section.settings.summary_stars_image != blank -%}
                {{ section.settings.summary_stars_image | image_url: width: 150 | image_tag: loading: 'lazy' }}
              {%- else -%}
                <svg viewBox="0 0 124 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="display: block; width: 124px; height: 24px; margin: 0 auto;">
                  <g>
                    <rect width="24" height="24" rx="2" fill="#00B67A"/>
                    <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" fill="white" transform="scale(0.8) translate(3, 3)"/>
                  </g>
                  <g transform="translate(25, 0)">
                    <rect width="24" height="24" rx="2" fill="#00B67A"/>
                    <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" fill="white" transform="scale(0.8) translate(3, 3)"/>
                  </g>
                  <g transform="translate(50, 0)">
                    <rect width="24" height="24" rx="2" fill="#00B67A"/>
                    <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" fill="white" transform="scale(0.8) translate(3, 3)"/>
                  </g>
                  <g transform="translate(75, 0)">
                    <rect width="24" height="24" rx="2" fill="#00B67A"/>
                    <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" fill="white" transform="scale(0.8) translate(3, 3)"/>
                  </g>
                  <g transform="translate(100, 0)">
                    <rect width="24" height="24" rx="2" fill="#00B67A"/>
                    <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" fill="white" transform="scale(0.8) translate(3, 3)"/>
                  </g>
                </svg>
              {%- endif -%}
            </div>
            
            <p class="customer-reviews__summary-rating">{{ section.settings.summary_rating_text }}</p>
            <p class="customer-reviews__summary-count">{{ section.settings.summary_count_text }}</p>

            <div class="customer-reviews__nav-buttons">
              <button class="customer-reviews__btn js-slider-template-prev" aria-label="Previous slide">
                <svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
              </button>
              <button class="customer-reviews__btn js-slider-template-next" aria-label="Next slide">
                <svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
              </button>
            </div>
          </div>
        {%- endif -%}

        <div class="customer-reviews__slider-wrapper">
          <div
            class="swiper js-slider-template-swiper slider-template-section__swiper"
            data-swiper-config='
              {
                "enableSliderDesktop": {{ section.settings.enable_slider_desktop }},
                "enableSliderMobile": {{ section.settings.enable_slider_mobile }},
                "loop": {{ section.settings.enable_loop | default: false }},
                "autoplay": {{ section.settings.enable_autoplay | default: false }},
                "autoplayInterval": {{ section.settings.autoplay_interval | times: 1000 | default: 3000 }},
                "mobileSlides": {{ section.settings.columns_mobile | plus: 0.0 }},
                "mobileSpacing": {{ section.settings.spacing | divided_by: 1.5 }},
                "desktopSlides": {{ section.settings.columns_desktop }},
                "desktopSpacing": {{ section.settings.spacing }}
              }
            '
          >
            <div class="swiper-wrapper">
              
              {%- for block in section.blocks -%}
                <div class="swiper-slide" {{ block.shopify_attributes }}>
                  <div class="review-card">
                    <div class="review-card__stars">
                      {%- if block.settings.stars_image != blank -%}
                        {{ block.settings.stars_image | image_url: width: 150 | image_tag: loading: 'lazy' }}
                      {%- else -%}
                         <svg viewBox="0 0 124 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="display: block; width: 124px; height: 24px;">
                            <g>
                              <rect width="24" height="24" rx="2" fill="#00B67A"/>
                              <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" fill="white" transform="scale(0.8) translate(3, 3)"/>
                            </g>
                            <g transform="translate(25, 0)">
                              <rect width="24" height="24" rx="2" fill="#00B67A"/>
                              <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" fill="white" transform="scale(0.8) translate(3, 3)"/>
                            </g>
                            <g transform="translate(50, 0)">
                              <rect width="24" height="24" rx="2" fill="#00B67A"/>
                              <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" fill="white" transform="scale(0.8) translate(3, 3)"/>
                            </g>
                            <g transform="translate(75, 0)">
                              <rect width="24" height="24" rx="2" fill="#00B67A"/>
                              <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" fill="white" transform="scale(0.8) translate(3, 3)"/>
                            </g>
                            <g transform="translate(100, 0)">
                              <rect width="24" height="24" rx="2" fill="#00B67A"/>
                              <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" fill="white" transform="scale(0.8) translate(3, 3)"/>
                            </g>
                          </svg>
                      {%- endif -%}
                    </div>
                    <div class="review-card__text rte">
                      {{ block.settings.text }}
                    </div>
                    <div class="review-card__author">
                      &mdash; {{ block.settings.author }}
                    </div>
                  </div>
                </div>
              {%- endfor -%}

            </div>
          </div>

          {%- comment -%} Optional slider template pagination indicators {%- endcomment -%}
          <div class="slider-template-controls slider-template-controls--{{ section.settings.controls_position }}">
            {%- if section.settings.controls_position == 'bottom' -%}
              <div class="slider-template-progress-track">
                <div class="slider-template-progress-fill"></div>
              </div>
            {%- endif -%}
            
            {%- if section.settings.controls_position == 'dots' -%}
              <div class="slider-template-pagination"></div>
            {%- endif -%}
          </div>
        </div>

      </div>

    </div>
  </div>
</slider-container>

{% schema %}
{
  "name": "Customer Reviews Slider",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    
    {
      "type": "header",
      "content": "Header Layout"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "OUR CUSTOMER SAY!",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
            { "value": "h2", "label": "Small" },
            { "value": "h1", "label": "Medium" },
            { "value": "h0", "label": "Large" },
            { "value": "hxl", "label": "Extra Large" },
            { "value": "hxxl", "label": "Extra Extra Large" }
          ],
      "default": "h0",
      "label": "Heading Size"
    },
    {
      "type": "image_picker",
      "id": "brand_logo",
      "label": "Brand Logo (e.g. Trustpilot)"
    },
    {
      "type": "header",
      "content": "Summary Card (Left)"
    },
    {
      "type": "checkbox",
      "id": "show_summary_card",
      "label": "Show summary card on left",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "summary_stars_image",
      "label": "Summary Stars Image (Manual Override)"
    },
    {
      "type": "text",
      "id": "summary_rating_text",
      "label": "Rating Text",
      "default": "4.2 stars / 5"
    },
    {
      "type": "text",
      "id": "summary_count_text",
      "label": "Review Count Text",
      "default": "(Based on 200+ reviews)"
    },
    {
      "type": "header",
      "content": "Carousel Controls"
    },
    {
      "type": "checkbox",
      "id": "enable_slider_desktop",
      "label": "Enable slider on desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_slider_mobile",
      "label": "Enable slider on mobile",
      "default": true
    },
    {
      "type": "select",
      "id": "controls_position",
      "label": "Slider controls type",
      "options": [
        { "value": "none", "label": "None (Arrows only)" },
        { "value": "bottom", "label": "Progress bar" },
        { "value": "dots", "label": "Dots" }
      ],
      "default": "none"
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Enable autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "min": 2,
      "max": 8,
      "step": 1,
      "unit": "s",
      "label": "Autoplay interval",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "enable_loop",
      "label": "Enable infinite loop",
      "default": false
    },
    {
      "type": "header",
      "content": "Columns and spacing"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "Number of columns on desktop"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "1",
      "label": "Number of columns on mobile",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ]
    },
    {
      "type": "range",
      "id": "spacing",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Space between cards",
      "default": 30
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "image_picker",
          "id": "stars_image",
          "label": "Custom Stars Image (Manual Override)"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Lorem ipsum dolor sit amet consectetur. Non sed nec massa semper in nec amet tristique. Volutpat consectetur ultrices leo turpis nunc neque ullamcorper tristique venenatis. Commodo arcu hac ullamcorper praesent hendrerit ac ut donec consectetur.</p>",
          "label": "Review Text"
        },
        {
          "type": "text",
          "id": "author",
          "default": "Lena . J",
          "label": "Author Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer Reviews Slider",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}