{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .roxx-masonry-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .roxx-masonry-heading {
    margin: 0 0 1rem 0;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.5px;
  }

  .roxx-masonry-subheading {
    font-size: clamp(13px, 1.5vw, 15px);
    font-weight: 500;
    margin: 0;
    opacity: 0.8; /* Inherits Dawn color scheme naturally */
  }

  /* Core layout flows top to bottom, 2 items per column */
  .roxx-masonry-grid {
    column-count: 2;
    column-gap: 16px;
    width: 100%;
  }

  @media screen and (min-width: 768px) {
    .roxx-masonry-grid {
      column-count: 3;
    }
  }

  @media screen and (min-width: 1024px) {
    .roxx-masonry-grid {
      column-count: 5;
      column-gap: 20px;
    }
  }

  .roxx-masonry-item {
    break-inside: avoid;
    border-radius: 16px;
    overflow: hidden;
    transform: translateZ(0);
    display: inline-block;
    width: 100%;
  }

  .roxx-masonry-image {
    width: 100%;
    display: block;
    border-radius: 16px;
    object-fit: cover;
  }

  /* Applies your exact manual margin settings to each specific block */
  {%- for block in section.blocks -%}
    #roxx-block-{{ block.id }} {
      margin-top: {{ block.settings.margin_top }}px;
      margin-bottom: {{ block.settings.margin_bottom }}px;
    }
  {%- endfor -%}

  /* Aspect Ratio Modifiers */
  .ratio-adapt { height: auto; }
  .ratio-square { aspect-ratio: 1 / 1; }
  .ratio-portrait { aspect-ratio: 3 / 4; }
  .ratio-tall { aspect-ratio: 2 / 3; }
  .ratio-landscape { aspect-ratio: 4 / 3; }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding">
    <div class="page-width">
      <div class="roxx-masonry-header">
        {%- if section.settings.heading != blank -%}
          <h2 class="roxx-masonry-heading h1">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="roxx-masonry-subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>

      <div class="roxx-masonry-grid">
        {%- for block in section.blocks -%}
          <div class="roxx-masonry-item" id="roxx-block-{{ block.id }}" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.image.alt | escape }}"
                class="roxx-masonry-image ratio-{{ block.settings.image_ratio }}"
                loading="lazy"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
              >
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'roxx-masonry-image placeholder-svg ratio-square' }}
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Masonry Gallery",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "JOIN OUR ROXX FAMILY"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "with thousands who've upgraded their everyday ride."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "background-1",
      "info": "Uses your theme's default color settings."
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "image_ratio",
          "label": "Aspect Ratio",
          "options": [
            { "value": "adapt", "label": "Adapt to image" },
            { "value": "square", "label": "Square (1:1)" },
            { "value": "portrait", "label": "Portrait (3:4)" },
            { "value": "tall", "label": "Tall Portrait (2:3)" },
            { "value": "landscape", "label": "Landscape (4:3)" }
          ],
          "default": "adapt"
        },
        {
          "type": "header",
          "content": "Manual Layout Control"
        },
        {
          "type": "range",
          "id": "margin_top",
          "min": 0,
          "max": 120,
          "step": 4,
          "unit": "px",
          "label": "Margin Top",
          "info": "Increase this on top-row images to push an entire column down.",
          "default": 0
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "min": 0,
          "max": 120,
          "step": 4,
          "unit": "px",
          "label": "Margin Bottom",
          "info": "Controls the spacing below this specific image.",
          "default": 20
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Masonry Gallery",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}