{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .roxx-masonry-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  @media screen and (min-width: 768px) {
    .roxx-masonry-header {
      margin-bottom: 3rem;
    }
  }

  .roxx-masonry-heading {
    margin: 0 0 0.5rem 0;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.5px;
    font-size: clamp(20px, 4vw, 32px);
  }

  .roxx-masonry-subheading {
    font-size: clamp(12px, 1.5vw, 15px);
    font-weight: 500;
    margin: 0;
    opacity: 0.8;
  }

  /* 
   * DYNAMIC MASONRY CSS 
   * 3 columns on Mobile, 5 on Desktop. 
   * Blocks wrap automatically to fill the columns.
   */
  .roxx-masonry-grid {
    column-count: 3;
    column-gap: 8px; /* Tight gaps for mobile */
    width: 100%;
  }

  @media screen and (min-width: 1024px) {
    .roxx-masonry-grid {
      column-count: 5;
      column-gap: 20px; /* Wider gaps for desktop */
    }
  }

  /* Keep the block together so top/bottom images don't split across columns */
  .roxx-column-block {
    display: inline-block;
    width: 100%;
    break-inside: avoid;
    margin-bottom: 8px; /* Vertical space between stacked blocks on mobile */
  }

  @media screen and (min-width: 1024px) {
    .roxx-column-block {
      margin-bottom: 0; /* Desktop doesn't stack blocks vertically */
    }
  }

  .roxx-column-block-inner {
    display: flex;
    flex-direction: column;
    gap: 8px; /* Space between Top and Bottom image on mobile */
  }

  @media screen and (min-width: 1024px) {
    .roxx-column-block-inner {
      gap: 20px; /* Space between Top and Bottom image on desktop */
    }
  }

  .roxx-masonry-image {
    width: 100%;
    display: block;
    border-radius: 8px; /* Slightly smaller radius for mobile */
    object-fit: cover;
  }

  @media screen and (min-width: 768px) {
    .roxx-masonry-image {
      border-radius: 16px;
    }
  }

  /* Apply exact Customizer height & margin settings per block */
  {%- for block in section.blocks -%}
    /* Mobile Settings */
    #roxx-column-{{ block.id }} {
      margin-top: {{ block.settings.margin_top_mobile }}px;
    }
    #roxx-column-{{ block.id }} .roxx-top-img {
      height: {{ block.settings.height_top_mobile }}px;
    }
    #roxx-column-{{ block.id }} .roxx-bottom-img {
      height: {{ block.settings.height_bottom_mobile }}px;
    }

    /* Desktop Settings */
    @media screen and (min-width: 1024px) {
      #roxx-column-{{ block.id }} {
        margin-top: {{ block.settings.margin_top }}px;
      }
      #roxx-column-{{ block.id }} .roxx-top-img {
        height: {{ block.settings.height_top }}px;
      }
      #roxx-column-{{ block.id }} .roxx-bottom-img {
        height: {{ block.settings.height_bottom }}px;
      }
    }
  {%- endfor -%}
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding">
    <div class="page-width">
      
      <div class="roxx-masonry-header">
        {%- if section.settings.heading != blank -%}
          <h2 class="roxx-masonry-heading h1">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="roxx-masonry-subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>

      <div class="roxx-masonry-grid">
        {%- for block in section.blocks -%}
          <div class="roxx-column-block" id="roxx-column-{{ block.id }}" {{ block.shopify_attributes }}>
            <div class="roxx-column-block-inner">
              
              <!-- TOP IMAGE -->
              {%- if block.settings.image_top != blank -%}
                <img
                  src="{{ block.settings.image_top | image_url: width: 600 }}"
                  alt="{{ block.settings.image_top.alt | escape }}"
                  class="roxx-masonry-image roxx-top-img"
                  loading="lazy"
                  width="{{ block.settings.image_top.width }}"
                  height="{{ block.settings.image_top.height }}"
                >
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'roxx-masonry-image placeholder-svg roxx-top-img' }}
              {%- endif -%}

              <!-- BOTTOM IMAGE -->
              {%- if block.settings.image_bottom != blank -%}
                <img
                  src="{{ block.settings.image_bottom | image_url: width: 600 }}"
                  alt="{{ block.settings.image_bottom.alt | escape }}"
                  class="roxx-masonry-image roxx-bottom-img"
                  loading="lazy"
                  width="{{ block.settings.image_bottom.width }}"
                  height="{{ block.settings.image_bottom.height }}"
                >
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'roxx-masonry-image placeholder-svg roxx-bottom-img' }}
              {%- endif -%}

            </div>
          </div>
        {%- endfor -%}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Masonry Gallery",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "JOIN OUR ROXX FAMILY"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "with thousands who've upgraded their everyday ride."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column (2 Images)",
      "limit": 5,
      "settings": [
        {
          "type": "header",
          "content": "Desktop Settings"
        },
        {
          "type": "range",
          "id": "margin_top",
          "min": 0,
          "max": 150,
          "step": 5,
          "unit": "px",
          "label": "Push Column Down",
          "default": 0
        },
        {
          "type": "range",
          "id": "height_top",
          "min": 100,
          "max": 600,
          "step": 10,
          "unit": "px",
          "label": "Top Image Height",
          "default": 350
        },
        {
          "type": "range",
          "id": "height_bottom",
          "min": 100,
          "max": 600,
          "step": 10,
          "unit": "px",
          "label": "Bottom Image Height",
          "default": 250
        },
        {
          "type": "header",
          "content": "Mobile Settings"
        },
        {
          "type": "range",
          "id": "margin_top_mobile",
          "min": 0,
          "max": 100,
          "step": 2,
          "unit": "px",
          "label": "Push Column Down (Mobile)",
          "default": 0
        },
        {
          "type": "range",
          "id": "height_top_mobile",
          "min": 80,
          "max": 400,
          "step": 5,
          "unit": "px",
          "label": "Top Image Height (Mobile)",
          "default": 180
        },
        {
          "type": "range",
          "id": "height_bottom_mobile",
          "min": 80,
          "max": 400,
          "step": 5,
          "unit": "px",
          "label": "Bottom Image Height (Mobile)",
          "default": 130
        },
        {
          "type": "header",
          "content": "Images"
        },
        {
          "type": "image_picker",
          "id": "image_top",
          "label": "Top Image"
        },
        {
          "type": "image_picker",
          "id": "image_bottom",
          "label": "Bottom Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Masonry Gallery",
      "blocks": [
        { "type": "column", "settings": { "margin_top": 0, "height_top": 350, "height_bottom": 250, "margin_top_mobile": 0, "height_top_mobile": 180, "height_bottom_mobile": 130 } },
        { "type": "column", "settings": { "margin_top": 40, "height_top": 250, "height_bottom": 350, "margin_top_mobile": 24, "height_top_mobile": 130, "height_bottom_mobile": 180 } },
        { "type": "column", "settings": { "margin_top": 0, "height_top": 350, "height_bottom": 250, "margin_top_mobile": 0, "height_top_mobile": 180, "height_bottom_mobile": 130 } },
        { "type": "column", "settings": { "margin_top": 40, "height_top": 250, "height_bottom": 350, "margin_top_mobile": 0, "height_top_mobile": 130, "height_bottom_mobile": 180 } },
        { "type": "column", "settings": { "margin_top": 0, "height_top": 350, "height_bottom": 250, "margin_top_mobile": 0, "height_top_mobile": 180, "height_bottom_mobile": 130 } }
      ]
    }
  ]
}
{% endschema %}