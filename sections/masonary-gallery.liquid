{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .roxx-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .roxx-heading {
    font-family: inherit;
    font-size: clamp(24px, 4vw, 32px);
    font-weight: 900;
    text-transform: uppercase;
    margin: 0 0 0.5rem 0;
    color: #000;
  }

  .roxx-subheading {
    font-size: clamp(13px, 1.5vw, 15px);
    font-weight: 500;
    color: #333;
    margin: 0;
  }

  /* 
   * COLCADE.JS CSS SETUP
   * Exact flexbox structure from the tutorial 
   */
  .roxx-grid {
    display: flex;
    /* Offset the column padding */
    margin-left: -10px;
    margin-right: -10px;
  }

  .roxx-grid-col {
    flex: 1;
    padding: 0 10px; /* Controls the horizontal gap */
  }

  /* Hide extra columns on mobile, show 2 */
  .roxx-grid-col--3,
  .roxx-grid-col--4,
  .roxx-grid-col--5 {
    display: none;
  }

  /* Show 3 columns on tablet */
  @media (min-width: 768px) {
    .roxx-grid-col--3 { display: block; }
  }

  /* Show 5 columns on desktop */
  @media (min-width: 1024px) {
    .roxx-grid-col--4,
    .roxx-grid-col--5 { display: block; }
  }

  /* The actual image cards */
  .roxx-grid-item {
    margin-bottom: 20px; /* Controls the vertical gap */
    border-radius: 16px;
    overflow: hidden;
    position: relative;
  }

  .roxx-grid-item img {
    width: 100%;
    display: block;
    border-radius: 16px;
    height: auto;
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  <div class="roxx-container page-width">
    <div class="roxx-header">
      {%- if section.settings.heading != blank -%}
        <h2 class="roxx-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="roxx-subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <!-- 
      COLCADE HTML STRUCTURE 
      The script requires empty columns first, followed by the items. 
    -->
    <div class="roxx-grid" id="colcade-grid-{{ section.id }}">
      
      <!-- 1. The Empty Columns for Colcade to sort into -->
      <div class="roxx-grid-col roxx-grid-col--1"></div>
      <div class="roxx-grid-col roxx-grid-col--2"></div>
      <div class="roxx-grid-col roxx-grid-col--3"></div>
      <div class="roxx-grid-col roxx-grid-col--4"></div>
      <div class="roxx-grid-col roxx-grid-col--5"></div>

      <!-- 2. The Grid Items (Your Shopify Blocks) -->
      {%- for block in section.blocks -%}
        <div class="roxx-grid-item" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 800 }}"
              alt="{{ block.settings.image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      {%- endfor -%}
      
    </div>
  </div>
</div>

<!-- 3. The Colcade.js Script from the tutorial -->
<script src="https://unpkg.com/colcade@0/colcade.js" defer></script>

<script>
  function initColcade() {
    // Wait for the script to load from unpkg
    if (typeof Colcade !== 'undefined') {
      var colc = new Colcade('#colcade-grid-{{ section.id }}', {
        columns: '.roxx-grid-col',
        items: '.roxx-grid-item'
      });
    } else {
      setTimeout(initColcade, 100);
    }
  }

  document.addEventListener('DOMContentLoaded', initColcade);

  // Ensures it re-loads perfectly inside the Shopify Customizer if you add/remove a block
  document.addEventListener('shopify:section:load', function(event) {
    if (event.detail.sectionId === '{{ section.id }}') {
      initColcade();
    }
  });
</script>

{% schema %}
{
  "name": "Masonry Gallery",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "JOIN OUR ROXX FAMILY"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "with thousands who've upgraded their everyday ride."
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Masonry Gallery",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}