{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .roxx-masonry-wrapper {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .roxx-masonry-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .roxx-masonry-heading {
    font-family: inherit;
    font-size: clamp(24px, 4vw, 32px);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.5px;
    margin: 0 0 0.5rem 0;
    color: #000;
  }

  .roxx-masonry-subheading {
    font-size: clamp(13px, 1.5vw, 15px);
    font-weight: 500;
    color: #333;
    margin: 0;
  }

  /* 
   * NATIVE CSS MASONRY
   * This cannot be broken by Shopify's JS iframe 
   */
  .roxx-masonry-grid {
    column-count: 2;
    column-gap: 16px;
    width: 100%;
  }

  @media screen and (min-width: 768px) {
    .roxx-masonry-grid {
      column-count: 3;
    }
  }

  @media screen and (min-width: 1024px) {
    .roxx-masonry-grid {
      column-count: 5;
      column-gap: 20px;
    }
  }

  .roxx-masonry-item {
    break-inside: avoid; /* Forces items not to split across columns */
    margin-bottom: 16px;
    border-radius: 16px;
    overflow: hidden;
    transform: translateZ(0);
  }

  @media screen and (min-width: 1024px) {
    .roxx-masonry-item {
      margin-bottom: 20px;
    }
  }

  .roxx-masonry-image {
    width: 100%;
    display: block;
    border-radius: 16px;
    object-fit: cover;
  }

  /* Aspect Ratio Modifiers to force the stagger */
  .ratio-adapt { height: auto; }
  .ratio-square { aspect-ratio: 1 / 1; }
  .ratio-portrait { aspect-ratio: 3 / 4; }
  .ratio-tall { aspect-ratio: 2 / 3; }
  .ratio-landscape { aspect-ratio: 4 / 3; }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  <div class="roxx-masonry-wrapper">
    <div class="roxx-masonry-header">
      {%- if section.settings.heading != blank -%}
        <h2 class="roxx-masonry-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="roxx-masonry-subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="roxx-masonry-grid">
      {%- for block in section.blocks -%}
        <div class="roxx-masonry-item" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 800 }}"
              alt="{{ block.settings.image.alt | escape }}"
              class="roxx-masonry-image ratio-{{ block.settings.image_ratio }}"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'roxx-masonry-image placeholder-svg ratio-square' }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Masonry Gallery",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "JOIN OUR ROXX FAMILY"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "with thousands who've upgraded their everyday ride."
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "image_ratio",
          "label": "Aspect Ratio",
          "info": "Mix these up to create the staggered masonry effect.",
          "options": [
            { "value": "adapt", "label": "Adapt to image" },
            { "value": "square", "label": "Square (1:1)" },
            { "value": "portrait", "label": "Portrait (3:4)" },
            { "value": "tall", "label": "Tall Portrait (2:3)" },
            { "value": "landscape", "label": "Landscape (4:3)" }
          ],
          "default": "adapt"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Masonry Gallery",
      "blocks": [
        { "type": "image", "settings": { "image_ratio": "tall" } },
        { "type": "image", "settings": { "image_ratio": "square" } },
        { "type": "image", "settings": { "image_ratio": "portrait" } },
        { "type": "image", "settings": { "image_ratio": "tall" } },
        { "type": "image", "settings": { "image_ratio": "portrait" } },
        { "type": "image", "settings": { "image_ratio": "square" } },
        { "type": "image", "settings": { "image_ratio": "tall" } },
        { "type": "image", "settings": { "image_ratio": "portrait" } },
        { "type": "image", "settings": { "image_ratio": "tall" } },
        { "type": "image", "settings": { "image_ratio": "square" } }
      ]
    }
  ]
}
{% endschema %}