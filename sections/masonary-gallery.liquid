{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .roxx-masonry-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .roxx-masonry-heading {
    margin: 0 0 1rem 0;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.5px;
  }

  .roxx-masonry-subheading {
    font-size: clamp(13px, 1.5vw, 15px);
    font-weight: 500;
    margin: 0;
    opacity: 0.8;
  }

  .roxx-masonry-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    align-items: start;
  }

  @media screen and (min-width: 768px) {
    .roxx-masonry-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (min-width: 1024px) {
    .roxx-masonry-grid {
      grid-template-columns: repeat(5, 1fr);
      gap: 20px;
    }
  }

  .roxx-column-block {
    display: flex;
    flex-direction: column;
    gap: 20px;
    width: 100%;
  }

  .roxx-masonry-image {
    width: 100%;
    display: block;
    border-radius: 16px;
    object-fit: cover;
  }

  /* Applies manual margin and exact height controls to each specific block */
  {%- for block in section.blocks -%}
    #roxx-column-{{ block.id }} {
      margin-top: {{ block.settings.margin_top }}px;
    }
    #roxx-column-{{ block.id }} .roxx-top-img {
      height: {{ block.settings.height_top }}px;
    }
    #roxx-column-{{ block.id }} .roxx-bottom-img {
      height: {{ block.settings.height_bottom }}px;
    }
  {%- endfor -%}
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding">
    <div class="page-width">
      
      <div class="roxx-masonry-header">
        {%- if section.settings.heading != blank -%}
          <h2 class="roxx-masonry-heading h1">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="roxx-masonry-subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>

      <div class="roxx-masonry-grid">
        {%- for block in section.blocks -%}
          <div class="roxx-column-block" id="roxx-column-{{ block.id }}" {{ block.shopify_attributes }}>
            
            <!-- TOP IMAGE -->
            {%- if block.settings.image_top != blank -%}
              <img
                src="{{ block.settings.image_top | image_url: width: 600 }}"
                alt="{{ block.settings.image_top.alt | escape }}"
                class="roxx-masonry-image roxx-top-img"
                loading="lazy"
                width="{{ block.settings.image_top.width }}"
                height="{{ block.settings.image_top.height }}"
              >
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'roxx-masonry-image placeholder-svg roxx-top-img' }}
            {%- endif -%}

            <!-- BOTTOM IMAGE -->
            {%- if block.settings.image_bottom != blank -%}
              <img
                src="{{ block.settings.image_bottom | image_url: width: 600 }}"
                alt="{{ block.settings.image_bottom.alt | escape }}"
                class="roxx-masonry-image roxx-bottom-img"
                loading="lazy"
                width="{{ block.settings.image_bottom.width }}"
                height="{{ block.settings.image_bottom.height }}"
              >
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'roxx-masonry-image placeholder-svg roxx-bottom-img' }}
            {%- endif -%}

          </div>
        {%- endfor -%}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Masonry Gallery",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "JOIN OUR ROXX FAMILY"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "with thousands who've upgraded their everyday ride."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column (2 Images)",
      "limit": 5,
      "settings": [
        {
          "type": "header",
          "content": "Stagger Control"
        },
        {
          "type": "range",
          "id": "margin_top",
          "min": 0,
          "max": 150,
          "step": 5,
          "unit": "px",
          "label": "Push Column Down",
          "info": "Increase this to stagger this column lower than the others.",
          "default": 0
        },
        {
          "type": "header",
          "content": "Top Image"
        },
        {
          "type": "image_picker",
          "id": "image_top",
          "label": "Image"
        },
        {
          "type": "range",
          "id": "height_top",
          "min": 100,
          "max": 400,
          "step": 10,
          "unit": "px",
          "label": "Height",
          "default": 300
        },
        {
          "type": "header",
          "content": "Bottom Image"
        },
        {
          "type": "image_picker",
          "id": "image_bottom",
          "label": "Image"
        },
        {
          "type": "range",
          "id": "height_bottom",
          "min": 100,
          "max": 400,
          "step": 10,
          "unit": "px",
          "label": "Height",
          "default": 250
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Masonry Gallery",
      "blocks": [
        { "type": "column", "settings": { "margin_top": 0, "height_top": 350, "height_bottom": 250 } },
        { "type": "column", "settings": { "margin_top": 40, "height_top": 250, "height_bottom": 350 } },
        { "type": "column", "settings": { "margin_top": 0, "height_top": 350, "height_bottom": 250 } },
        { "type": "column", "settings": { "margin_top": 40, "height_top": 250, "height_bottom": 350 } },
        { "type": "column", "settings": { "margin_top": 0, "height_top": 350, "height_bottom": 250 } }
      ]
    }
  ]
}
{% endschema %}