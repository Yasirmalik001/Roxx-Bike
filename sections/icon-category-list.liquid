{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .icon-category-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem 1rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .icon-category-item {
    /* Mobile: 2 items per row, odd items center automatically via flexbox */
    width: calc(50% - 0.5rem); 
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .icon-category-item__link {
    display: block;
    text-decoration: none;
    color: rgb(var(--color-foreground));
    width: 100%;
    transition: transform 0.3s ease;
  }

  .icon-category-item__link:hover .icon-category-item__image {
    transform: scale(1.04);
  }

  .icon-category-item__image-wrapper {
    position: relative;
    width: 100%;
    /* Creates a consistent aspect ratio container */
    padding-bottom: 75%; 
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon-category-item__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain; /* Ensures the whole sofa/icon is visible */
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .icon-category-item__title {
    margin: 0;
    font-size: 1.4rem;
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: 0.04rem;
  }

  /* Desktop Layout */
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .icon-category-list {
      gap: 2rem;
      /* Adjusts nicely depending on block count, max 5-6 per row looks best */
      justify-content: center; 
    }

    .icon-category-item {
      /* Flex basis allows them to sit inline on desktop (e.g., 5 columns) */
      width: calc(20% - 1.6rem); 
      max-width: 22rem;
    }

    .icon-category-item__title {
      font-size: 1.5rem;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    
    {%- if section.settings.title != blank -%}
      <div class="title-wrapper-with-link title-wrapper--self-padded-mobile title-wrapper--no-top-margin center">
        <h2 class="title {{ section.settings.heading_size }}">
          {{ section.settings.title }}
        </h2>
      </div>
    {%- endif -%}

    <ul class="icon-category-list" role="list">
      {%- for block in section.blocks -%}
        <li class="icon-category-item" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.link | default: '#' }}" 
             class="icon-category-item__link" 
             aria-label="{{ block.settings.title | escape }}">
            
            <div class="icon-category-item__image-wrapper">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 600 | image_tag: 
                  loading: 'lazy', 
                  class: 'icon-category-item__image',
                  sizes: '(min-width: 750px) 20vw, 50vw',
                  widths: '150, 300, 450, 600'
                }}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'icon-category-item__image placeholder-svg' }}
              {%- endif -%}
            </div>

            {%- if block.settings.title != blank -%}
              <p class="icon-category-item__title">{{ block.settings.title }}</p>
            {%- endif -%}
            
          </a>
        </li>
      {%- endfor -%}
    </ul>
    
  </div>
</div>

{% schema %}
{
  "name": "Icon Category Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Sofas for every <em>space</em>",
      "label": "t:sections.all.heading.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
            { "value": "h2", "label": "Small" },
            { "value": "h1", "label": "Medium" },
            { "value": "h0", "label": "Large" },
            { "value": "hxl", "label": "Extra Large" },
            { "value": "hxxl", "label": "Extra Extra Large" }
          ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "limit": 10,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Use images with transparent backgrounds for best results."
        },
        {
          "type": "text",
          "id": "title",
          "default": "Category Name",
          "label": "Category Title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Icon Category Grid",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "2 Seater Sofas"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "3 Seater Sofas"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "4 Seater Sofas"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Corner Sofas"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Swivel Chairs"
          }
        }
      ]
    }
  ]
}
{% endschema %}