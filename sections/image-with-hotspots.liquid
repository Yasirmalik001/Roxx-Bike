{{ 'component-image-with-text.css' | asset_url | stylesheet_tag }}

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .hotspot-container {
    text-align: center;
  }

  /* --- Header Styling --- */
  .hotspot-header {
    max-width: 800px;
    margin: 0 auto 5rem auto;
    padding: 0 2rem;
  }

  .hotspot-header h2 {
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.5px;
    margin-bottom: 1.5rem;
  }

  .hotspot-header .rte {
    font-size: 1.4rem;
    color: #555555;
    line-height: 1.6;
    max-width: 650px;
    margin: 0 auto;
  }

  /* --- Image Wrapper --- */
  .hotspot-image-wrapper {
    position: relative;
    margin: 0 auto;
    display: inline-block;
    max-width: 100%;
  }

  .hotspot-image-wrapper img, 
  .hotspot-image-wrapper svg {
    width: 100%;
    height: auto;
    max-height: 700px;
    min-height: 700px;
    display: block;
    border-radius: {{ section.settings.image_radius }}px;
  }

  /* --- Hotspot Points & Glow --- */
  .hotspot-point {
    position: absolute;
    transform: translate(-50%, -50%);
    z-index: 2;
  }

  .hotspot-wrapper {
    position: relative;
    z-index: 3;
  }

  /* Base Glow State */
  .hotspot-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.8);
    width: 85px;
    height: 85px;
    background: radial-gradient(circle, rgba(255, 209, 0, 0.6) 0%, rgba(255, 209, 0, 0) 65%);
    border-radius: 50%;
    pointer-events: none;
    z-index: 1;
    opacity: 0;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.4s ease;
  }

  /* Smooth reveal classes handled by JS */
  .hotspot-point:hover .hotspot-glow,
  .hotspot-wrapper.is-open ~ .hotspot-glow {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.2);
  }

  .hotspot-btn {
    width: 40px;
    height: 40px;
    background-color: #FFD100;
    border: none;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    list-style: none;
    transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
    color: #111111;
    position: relative;
    z-index: 2;
    padding: 0;
  }

  .hotspot-btn:hover, 
  .hotspot-wrapper.is-open .hotspot-btn {
    transform: scale(1.15);
  }

  .hotspot-btn svg {
    width: 14px;
    height: 14px;
    stroke: currentColor;
    stroke-width: 2px;
    transition: transform 0.35s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .hotspot-wrapper.is-open .hotspot-btn svg {
    transform: rotate(45deg);
  }

  /* --- Tooltip Box --- */
  .hotspot-tooltip {
    position: absolute;
    background: #ffffff;
    padding: 2.5rem;
    border-radius: 12px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
    width: max-content;
    max-width: 320px;
    z-index: 10;
    text-align: left;
    border: 1px solid rgba(0,0,0,0.04);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s cubic-bezier(0.25, 1, 0.5, 1), transform 0.3s cubic-bezier(0.25, 1, 0.5, 1), visibility 0.3s;
    pointer-events: none;
  }

  /* High performance hardware acceleration transitions */
  .hotspot-wrapper.is-open .hotspot-tooltip {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .hotspot-tooltip__header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 1.2rem;
  }

  .hotspot-tooltip__header img {
    width: 20px;
    height: 20px;
    object-fit: contain;
  }

  .hotspot-tooltip__header h4 {
    margin: 0;
    font-size: 1.4rem;
    font-weight: 700;
    color: #111111;
  }

  .hotspot-tooltip__subtitle {
    font-size: 1.35rem;
    font-weight: 600;
    color: #333333;
    line-height: 1.4;
    margin: 0 0 0.8rem 0;
  }

  .hotspot-tooltip .rte {
    font-size: 1.25rem;
    line-height: 1.5;
    color: #777777;
    margin: 0;
  }

  .hotspot-tooltip .rte p {
    margin: 0;
  }

  /* --- Tooltip Positions (Desktop Animations) --- */
  
  /* Right */
  .hotspot-tooltip--right {
    top: 50%;
    left: calc(100% + 35px);
    transform: translateY(-50%) translateX(-15px);
  }
  .hotspot-wrapper.is-open .hotspot-tooltip--right { transform: translateY(-50%) translateX(0); }
  .hotspot-tooltip--right::before {
    content: ''; position: absolute;
    top: 50%; right: 100%; transform: translateY(-50%);
    border-width: 8px 12px 8px 0; border-style: solid; border-color: transparent #fff transparent transparent;
  }

  /* Left */
  .hotspot-tooltip--left {
    top: 50%;
    right: calc(100% + 35px);
    transform: translateY(-50%) translateX(15px);
  }
  .hotspot-wrapper.is-open .hotspot-tooltip--left { transform: translateY(-50%) translateX(0); }
  .hotspot-tooltip--left::before {
    content: ''; position: absolute;
    top: 50%; left: 100%; transform: translateY(-50%);
    border-width: 8px 0 8px 12px; border-style: solid; border-color: transparent transparent transparent #fff;
  }

  /* Top */
  .hotspot-tooltip--top {
    bottom: calc(100% + 35px);
    left: 50%;
    transform: translateX(-50%) translateY(15px);
  }
  .hotspot-wrapper.is-open .hotspot-tooltip--top { transform: translateX(-50%) translateY(0); }
  .hotspot-tooltip--top::before {
    content: ''; position: absolute;
    top: 100%; left: 50%; transform: translateX(-50%);
    border-width: 12px 8px 0 8px; border-style: solid; border-color: #fff transparent transparent transparent;
  }

  /* Bottom */
  .hotspot-tooltip--bottom {
    top: calc(100% + 35px);
    left: 50%;
    transform: translateX(-50%) translateY(-15px);
  }
  .hotspot-wrapper.is-open .hotspot-tooltip--bottom { transform: translateX(-50%) translateY(0); }
  .hotspot-tooltip--bottom::before {
    content: ''; position: absolute;
    bottom: 100%; left: 50%; transform: translateX(-50%);
    border-width: 0 8px 12px 8px; border-style: solid; border-color: transparent transparent #fff transparent;
  }

  /* --- Mobile Tooltip Override --- */
  @media screen and (max-width: 749px) {
    .hotspot-tooltip {
      position: fixed;
      bottom: 2rem;
      left: 50%;
      width: calc(100% - 4rem);
      max-width: none;
      top: auto !important;
      right: auto !important;
      transform: translateX(-50%) translateY(30px) !important;
      padding: 2rem;
    }
    .hotspot-wrapper.is-open .hotspot-tooltip {
      transform: translateX(-50%) translateY(0) !important;
    }
    .hotspot-tooltip::before {
      display: none !important;
    }
  }
</style>

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width hotspot-container">
    
    <div class="hotspot-header">
      {%- if section.settings.heading != blank -%}
        <h2 class="h1">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="rte">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    <div class="hotspot-image-wrapper">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 5000 | image_tag: loading: 'lazy', widths: '550, 720, 990, 1500, 5000' }}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}

      {%- for block in section.blocks -%}
        <div class="hotspot-point" style="top: {{ block.settings.pos_y }}%; left: {{ block.settings.pos_x }}%;" {{ block.shopify_attributes }}>
          
          <div class="hotspot-wrapper" data-hotspot>
            <button class="hotspot-btn" type="button" aria-expanded="false" aria-controls="tooltip-{{ block.id }}">
              <span class="visually-hidden">View details for {{ block.settings.title }}</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
        <circle cx="12" cy="12" r="9" stroke="#333333" stroke-width="2"/>
        <path d="M12 15L12 9" stroke="#333333" stroke-width="2" stroke-linecap="square"/>
        <path d="M15 12L9 12" stroke="#333333" stroke-width="2" stroke-linecap="square"/>
        </svg>
            </button>
            
            <div id="tooltip-{{ block.id }}" class="hotspot-tooltip hotspot-tooltip--{{ block.settings.tooltip_position }}">
              <div class="hotspot-tooltip__header">
                {%- if block.settings.icon != blank -%}
                  {{ block.settings.icon | image_url: width: 40 | image_tag: loading: 'lazy' }}
                {%- endif -%}
                {%- if block.settings.title != blank -%}
                  <h4>{{ block.settings.title }}</h4>
                {%- endif -%}
              </div>
              
              {%- if block.settings.subtitle != blank -%}
                <p class="hotspot-tooltip__subtitle">{{ block.settings.subtitle }}</p>
              {%- endif -%}
              
              {%- if block.settings.content != blank -%}
                <div class="rte">{{ block.settings.content }}</div>
              {%- endif -%}
            </div>
          </div>
          
          <div class="hotspot-glow"> </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const hotspots = document.querySelectorAll('[data-hotspot]');
    
    hotspots.forEach((hotspot) => {
      const btn = hotspot.querySelector('.hotspot-btn');
      
      btn.addEventListener('click', (e) => {
        // Prevent event from bubbling up to document
        e.stopPropagation();
        
        const isOpen = hotspot.classList.contains('is-open');
        
        // Accordion behavior: Close all other hotspots
        hotspots.forEach((otherHotspot) => {
          otherHotspot.classList.remove('is-open');
          otherHotspot.querySelector('.hotspot-btn').setAttribute('aria-expanded', 'false');
        });

        // Toggle clicked hotspot
        if (!isOpen) {
          hotspot.classList.add('is-open');
          btn.setAttribute('aria-expanded', 'true');
        }
      });
      
      // Stop clicks inside the tooltip from closing it
      const tooltip = hotspot.querySelector('.hotspot-tooltip');
      if(tooltip) {
        tooltip.addEventListener('click', (e) => {
          e.stopPropagation();
        });
      }
    });

    // Close smooth dismissals when clicking outside hotspots
    document.addEventListener('click', () => {
      hotspots.forEach((hotspot) => {
        hotspot.classList.remove('is-open');
        hotspot.querySelector('.hotspot-btn').setAttribute('aria-expanded', 'false');
      });
    });
  });
</script>

{% schema %}
{
  "name": "Image with Hotspots",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "MINIMAL DESIGN. MAXIMUM IMPACT."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>A sleek, integrated frame that turns heads — without compromising function. Built with precision and high-quality materials, the Joieem X blends aesthetics with durability, making it as stylish as it is reliable.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image"
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Image corner radius",
      "default": 0
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "Hotspot Point",
      "settings": [
        {
          "type": "range",
          "id": "pos_x",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Horizontal Position (Left to Right)",
          "default": 50
        },
        {
          "type": "range",
          "id": "pos_y",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Vertical Position (Top to Bottom)",
          "default": 50
        },
        {
          "type": "select",
          "id": "tooltip_position",
          "label": "Tooltip Popup Direction (Desktop)",
          "options": [
            { "value": "top", "label": "Top" },
            { "value": "bottom", "label": "Bottom" },
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "right"
        },
        {
          "type": "header",
          "content": "Tooltip Content"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Small Icon Image (Optional)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Tyres"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Bold Subtitle",
          "default": "28 inch Cst Fly safely through the road bends"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Description",
          "default": "<p>Lorem ipsum dolor sit amet consectetur. Et sed tempor odio felis diam. Mattis at sollicitudin id nec tincidunt</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image with Hotspots",
      "blocks": [
        {
          "type": "hotspot",
          "settings": {
            "pos_x": 30,
            "pos_y": 74,
            "tooltip_position": "top"
          }
        },
        {
          "type": "hotspot",
          "settings": {
            "pos_x": 42,
            "pos_y": 48,
            "tooltip_position": "bottom"
          }
        },
        {
          "type": "hotspot",
          "settings": {
            "pos_x": 46,
            "pos_y": 74,
            "tooltip_position": "right"
          }
        },
        {
          "type": "hotspot",
          "settings": {
            "pos_x": 63,
            "pos_y": 33,
            "tooltip_position": "left"
          }
        },
        {
          "type": "hotspot",
          "settings": {
            "pos_x": 75,
            "pos_y": 62,
            "tooltip_position": "right"
          }
        }
      ]
    }
  ]
}
{% endschema %}