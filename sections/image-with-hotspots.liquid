{{ 'component-image-with-text.css' | asset_url | stylesheet_tag }}

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .hotspot-container { text-align: center; }

  /* --- Image Wrapper --- */
  .hotspot-image-wrapper { position: relative; margin: 0 auto; display: inline-block; max-width: 100%; }
  .hotspot-image-wrapper img, .hotspot-image-wrapper svg { width: 100%; height: auto; max-height: 700px; display: block; border-radius: {{ section.settings.image_radius }}px; }

  /* --- Hotspot Points --- */
  .hotspot-point { position: absolute; transform: translate(-50%, -50%); z-index: 2; }
  
  .hotspot-btn {
    width: 26px; height: 26px;
    background-color: #FFD100;
    border: 1.5px solid #111111;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: transform 0.3s ease;
    color: #111111;
    position: relative;
    z-index: 3;
    padding: 0;
  }

  /* The Glow Effect - Placed outside details so it doesn't get hidden */
  .hotspot-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 85px;
    height: 85px;
    background: radial-gradient(circle, rgba(255, 209, 0, 0.6) 0%, rgba(255, 209, 0, 0) 65%);
    border-radius: 50%;
    pointer-events: none;
    z-index: 1;
    transition: transform 0.3s ease;
  }

  /* Trigger glow expansion when button is hovered or details is open */
  .hotspot-btn:hover + .hotspot-glow, 
  details[open] + .hotspot-glow {
    transform: translate(-50%, -50%) scale(1.2);
  }

  .hotspot-btn svg { width: 14px; height: 14px; stroke: currentColor; stroke-width: 2px; }
  details[open] .hotspot-btn svg { transform: rotate(45deg); }

  /* --- Tooltip Box --- */
  .hotspot-tooltip {
    position: absolute; background: #ffffff; padding: 2.5rem; border-radius: 12px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.08); width: max-content; max-width: 320px;
    z-index: 10; text-align: left; border: 1px solid rgba(0,0,0,0.04);
    opacity: 0; visibility: hidden; transition: opacity 0.25s ease;
  }
  details[open] .hotspot-tooltip { opacity: 1; visibility: visible; }
  
  /* Positions */
  .hotspot-tooltip--right { top: 50%; left: calc(100% + 20px); transform: translateY(-50%); }
  .hotspot-tooltip--left { top: 50%; right: calc(100% + 20px); transform: translateY(-50%); }
  .hotspot-tooltip--top { bottom: calc(100% + 20px); left: 50%; transform: translateX(-50%); }
  .hotspot-tooltip--bottom { top: calc(100% + 20px); left: 50%; transform: translateX(-50%); }
</style>

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width hotspot-container">
    <div class="hotspot-image-wrapper">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 5000 | image_tag }}
      {%- endif -%}

      {%- for block in section.blocks -%}
        <div class="hotspot-point" style="top: {{ block.settings.pos_y }}%; left: {{ block.settings.pos_x }}%;" {{ block.shopify_attributes }}>
          <details data-hotspot>
            <summary class="hotspot-btn">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14m-7-7h14"/></svg>
            </summary>
            <div class="hotspot-tooltip hotspot-tooltip--{{ block.settings.tooltip_position }}">
              <h4>{{ block.settings.title }}</h4>
              <div class="rte">{{ block.settings.content }}</div>
            </div>
          </details>
          <div class="hotspot-glow"></div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>