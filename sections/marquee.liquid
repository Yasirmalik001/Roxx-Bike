{% schema %}
{
  "name": "Scrolling Banner",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-4"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "min": 10,
      "max": 60,
      "step": 2,
      "unit": "s",
      "label": "Scroll Speed",
      "default": 30,
      "info": "Lower is faster, higher is slower."
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text Size",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 36,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 36,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "text_block",
      "name": "Text Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Add your banner text here"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scrolling Banner",
      "blocks": [
        { "type": "text_block", "settings": { "text": "60-day satisfaction guarantee" } },
        { "type": "text_block", "settings": { "text": "Delivery in 2-3 days within Norway" } },
        { "type": "text_block", "settings": { "text": "High-quality customer service" } },
        { "type": "text_block", "settings": { "text": "Free shipping above NOK 800" } }
      ]
    }
  ]
}
{% endschema %}

<div class="sr-marquee-section color-{{ section.settings.color_scheme }} gradient" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  
  <div class="sr-marquee-container" style="--marquee-speed: {{ section.settings.scroll_speed }}s; --marquee-font-size: {{ section.settings.font_size }}px;">
    
    {%- capture marquee_content -%}
      {%- for block in section.blocks -%}
        <div class="sr-marquee-item" {{ block.shopify_attributes }}>
          <span class="sr-marquee-text">{{ block.settings.text }}</span>
          <span class="sr-marquee-dot"></span>
        </div>
      {%- endfor -%}
    {%- endcapture -%}

    <div class="sr-marquee-track">
      <div class="sr-marquee-content">
        {{ marquee_content }}
      </div>
      <div class="sr-marquee-content" aria-hidden="true">
        {{ marquee_content }}
      </div>
      <div class="sr-marquee-content" aria-hidden="true">
        {{ marquee_content }}
      </div>
      <div class="sr-marquee-content" aria-hidden="true">
        {{ marquee_content }}
      </div>
    </div>

  </div>
</div>

{% comment %} Styles moved to sereluna.css {% endcomment %}