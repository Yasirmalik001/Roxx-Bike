{{ 'section-main-product-custom.css' | asset_url | stylesheet_tag }}
{{ 'component-product-card-custom.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-custom.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="product-custom page-width section-{{ section.id }}-padding" style="--bg-color: {{ section.settings.bg_color }}; --container-width: {{ section.settings.container_width }}px;">
  <div class="product-custom__container">
    
    <!-- LEFT SIDE: Gallery and Specs -->
    <div class="product-custom__media-wrapper">
      {% render 'product-gallery-custom', section: section, product: product %}
      
      {% if section.settings.enable_specs %}
        {% render 'product-specs', blocks: section.blocks %}
      {% endif %}
    </div>

    <!-- RIGHT SIDE: Sticky Info Card -->
    <div class="product-custom__info-wrapper {% if section.settings.enable_sticky_info %}product-custom__info-sticky{% endif %}">
      {% render 'product-info-card', section: section, product: product, blocks: section.blocks %}
    </div>
    
  </div>
</div>

{% schema %}
{
  "name": "Custom Product Info",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 1000,
      "max": 1600,
      "step": 50,
      "default": 1400,
      "label": "Container Width"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_info",
      "default": true,
      "label": "Enable Sticky Info Card"
    },
    {
      "type": "checkbox",
      "id": "enable_specs",
      "default": true,
      "label": "Enable Specs (under gallery)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "Title",
      "limit": 1
    },
    {
      "type": "price",
      "name": "Price",
      "limit": 1
    },
    {
      "type": "installment",
      "name": "Installment Row",
      "limit": 1
    },
    {
      "type": "description",
      "name": "Short Description",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>A fully connected e-bike built for modern life — powerful, intelligent, and effortlessly smooth.</p>"
        }
      ]
    },
    {
      "type": "inventory",
      "name": "Inventory Status",
      "limit": 1
    },
    {
      "type": "buy_buttons",
      "name": "Buy Buttons",
      "limit": 1
    },
    {
      "type": "payment_icons",
      "name": "Payment Icons",
      "limit": 1
    },
    {
      "type": "accessory",
      "name": "Accessory Upsell",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Accessory Product"
        }
      ]
    },
    {
      "type": "insurance",
      "name": "Insurance Upsell",
      "limit": 1,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Insurance Product"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Roxx insurance"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description"
        }
      ]
    },
    {
      "type": "review_avatars",
      "name": "Review Avatars",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Real people reviews"
        },
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "Avatar 1"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Avatar 2"
        },
        {
          "type": "image_picker",
          "id": "image_3",
          "label": "Avatar 3"
        },
        {
          "type": "image_picker",
          "id": "image_4",
          "label": "Avatar 4"
        }
      ]
    },
    {
      "type": "feature_icons",
      "name": "Feature Icons Row",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title_1",
          "label": "Title 1",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "sub_1",
          "label": "Subtitle 1",
          "default": "from $79.95"
        },
        {
          "type": "text",
          "id": "title_2",
          "label": "Title 2",
          "default": "2-Year Warranty"
        },
        {
          "type": "text",
          "id": "title_3",
          "label": "Title 3",
          "default": "14 days money"
        },
        {
          "type": "text",
          "id": "sub_3",
          "label": "Subtitle 3",
          "default": "back guarantee"
        }
      ]
    },
    {
      "type": "spec",
      "name": "Spec Item",
      "settings": [
        {
          "type": "text",
          "id": "icon_svg",
          "label": "Icon SVG (Raw)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Battery"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "Samsung lithium, 48V"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Product Info",
      "blocks": [
        { "type": "title" },
        { "type": "price" },
        { "type": "installment" },
        { "type": "description" },
        { "type": "inventory" },
        { "type": "buy_buttons" },
        { "type": "payment_icons" },
        { "type": "accessory" },
        { "type": "insurance" },
        { "type": "review_avatars" },
        { "type": "feature_icons" }
      ]
    }
  ]
}
{% endschema %}
