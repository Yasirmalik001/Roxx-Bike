{{ 'section-main-product.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}
{{ 'section-main-product-custom.css' | asset_url | stylesheet_tag }}
{{ 'component-product-card-custom.css' | asset_url | stylesheet_tag }}

{%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}
{%- if first_3d_model -%}
  {{ 'component-product-model.css' | asset_url | stylesheet_tag }}
{%- endif -%}

<script src="{{ 'product-custom.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
{% if section.settings.image_zoom == 'hover' %}
  <script id="EnableZoomOnHover-main" src="{{ 'magnify.js' | asset_url }}" defer="defer"></script>
{% endif %}
{%- if product.media.size > 0 -%}
  <script src="{{ 'product-modal.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'media-gallery.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<product-info
  id="MainProduct-{{ section.id }}"
  class="product-custom page-width section-{{ section.id }}-padding"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-update-url="true"
  data-url="{{ product.url }}"
  {% if section.settings.image_zoom == 'hover' %}
    data-zoom-on-hover
  {% endif %}
  style="--bg-color: {{ section.settings.bg_color }}; --container-width: {{ section.settings.container_width }}px; display: block;"
>
  <div class="product-custom__container product product--large product--left product--thumbnail_left product--mobile-show grid grid--1-col {% if product.media.size > 0 %}grid--2-col-tablet{% else %}product--no-media{% endif %}">
    
    <!-- LEFT SIDE: Gallery and Specs -->
    <div class="product-custom__media-wrapper grid__item product__media-wrapper" style="width: 100%; max-width: 100%;">
      <div style="position: relative;">
        <div class="product-custom__gallery-badges" style="position: absolute; top: 1.5rem; left: 1.5rem; z-index: 2; display: flex; flex-direction: column; gap: 1rem;">
          {% render 'product-badges', product: product %}
          {% render 'product-rating', product: product %}
        </div>
        {% assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src' %}
        {% render 'product-media-gallery', variant_images: variant_images %}
      </div>
      
      {% if section.settings.enable_specs %}
        {% render 'product-specs', blocks: section.blocks %}
      {% endif %}
    </div>

    <!-- RIGHT SIDE: Sticky Info Card -->
    <div class="product-custom__info-wrapper {% if section.settings.enable_sticky_info %}product-custom__info-sticky{% endif %}">
      {% render 'product-info-card', section: section, product: product, blocks: section.blocks %}
    </div>
    
  </div>
  
  {% render 'product-media-modal', variant_images: variant_images %}
</product-info>

{% schema %}
{
  "name": "Custom Product Info",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 1000,
      "max": 1600,
      "step": 50,
      "default": 1400,
      "label": "Container Width"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_info",
      "default": true,
      "label": "Enable Sticky Info Card"
    },
    {
      "type": "checkbox",
      "id": "enable_specs",
      "default": true,
      "label": "Enable Specs (under gallery)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "Title",
      "limit": 1
    },
    {
      "type": "price",
      "name": "Price",
      "limit": 1
    },
    {
      "type": "installment",
      "name": "Installment Row",
      "limit": 1
    },
    {
      "type": "description",
      "name": "Short Description",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>A fully connected e-bike built for modern life — powerful, intelligent, and effortlessly smooth.</p>"
        }
      ]
    },
    {
      "type": "inventory",
      "name": "Inventory Status",
      "limit": 1
    },
    {
      "type": "buy_buttons",
      "name": "Buy Buttons",
      "limit": 1
    },
    {
      "type": "payment_icons",
      "name": "Payment Icons",
      "limit": 1
    },
    {
      "type": "accessory",
      "name": "Accessory Upsell",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Accessory Product"
        }
      ]
    },
    {
      "type": "insurance",
      "name": "Insurance Upsell",
      "limit": 1,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Insurance Product"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Roxx insurance"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description"
        }
      ]
    },
    {
      "type": "review_avatars",
      "name": "Review Avatars",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Real people reviews"
        },
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "Avatar 1"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Avatar 2"
        },
        {
          "type": "image_picker",
          "id": "image_3",
          "label": "Avatar 3"
        },
        {
          "type": "image_picker",
          "id": "image_4",
          "label": "Avatar 4"
        }
      ]
    },
    {
      "type": "feature_icons",
      "name": "Feature Icons Row",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title_1",
          "label": "Title 1",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "sub_1",
          "label": "Subtitle 1",
          "default": "from $79.95"
        },
        {
          "type": "text",
          "id": "title_2",
          "label": "Title 2",
          "default": "2-Year Warranty"
        },
        {
          "type": "text",
          "id": "title_3",
          "label": "Title 3",
          "default": "14 days money"
        },
        {
          "type": "text",
          "id": "sub_3",
          "label": "Subtitle 3",
          "default": "back guarantee"
        }
      ]
    },
    {
      "type": "spec",
      "name": "Spec Item",
      "settings": [
        {
          "type": "text",
          "id": "icon_svg",
          "label": "Icon SVG (Raw)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Battery"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "Samsung lithium, 48V"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Product Info",
      "blocks": [
        { "type": "title" },
        { "type": "price" },
        { "type": "installment" },
        { "type": "description" },
        { "type": "inventory" },
        { "type": "buy_buttons" },
        { "type": "payment_icons" },
        { "type": "accessory" },
        { "type": "insurance" },
        { "type": "review_avatars" },
        { "type": "feature_icons" }
      ]
    }
  ]
}
{% endschema %}
