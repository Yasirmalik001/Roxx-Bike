{%- style -%}
#custom-banner-{{ section.id }} {
  position: relative;
  width: 100%;
  overflow: hidden;
}

#custom-banner-{{ section.id }} .banner-image-wrapper {
  position: relative;
  width: 100%;
  display: block;
  {% if section.settings.adapt_height_desktop %}
    height: auto;
  {% else %}
    height: {{ section.settings.min_height_desktop }}px;
  {% endif %}
}

/* Dark Overlay */
#custom-banner-{{ section.id }} .banner-image-wrapper::after {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0,0,0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
  z-index: 1;
}

#custom-banner-{{ section.id }} .banner-image,
#custom-banner-{{ section.id }} .hp-hero__video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

#custom-banner-{{ section.id }} .banner-content {
  position: absolute;
  top: {{ section.settings.text_position_top }}%;
  left: {{ section.settings.text_position_left }}%;
  transform: translate(-{{ section.settings.text_position_left }}%, -{{ section.settings.text_position_top }}%);
  z-index: 2;
  text-align: {{ section.settings.text_alignment }};
  max-width: {{ section.settings.content_width }}px;
  width: 100%;
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 15px; /* Clean spacing between all blocks */
  align-items: {% if section.settings.text_alignment == 'left' %}flex-start{% elsif section.settings.text_alignment == 'right' %}flex-end{% else %}center{% endif %};
}

/* BLOCK: HEADING */
#custom-banner-{{ section.id }} .banner-heading {
  font-size: {{ section.settings.heading_size_desktop }}px;
  line-height: 1.1;
  margin: 0;
  font-weight: 400;
  margin: 0;
  color: inherit;
}

/* BLOCK: SUBHEADING */
#custom-banner-{{ section.id }} .banner-subheading {
  font-size: {{ section.settings.subheading_size_desktop }}px;
font-weight: 500;
line-height: 120%;

}
#custom-banner-{{ section.id }} .banner-subheading p {
margin: 0;
}

#custom-banner-{{ section.id }} .banner-review-block {
  display: inline-flex;
  align-items: center;
  gap: 8px;
font-weight: 500;
font-style: Medium;
font-size: 14px;
  
line-height: 100%;
 
  margin-bottom: 0;
}
.banner-review-stars {
  display: flex;
  color: #fb499b; /* Bright pink for stars, or change to match your brand */
  font-size: 14px;
}
.banner-review-custom-svg {
  display: flex;
  align-items: center;
  width: 80px; /* Adjust if your SVG is wider */
}
.banner-review-custom-svg svg {
  width: 100%;
  height: auto;
}

/* BLOCK: BUTTONS */
#custom-banner-{{ section.id }} .btn-custom-banner {
  display: flex;
  gap: 15px;
  z-index: 3;
  justify-content: {% if section.settings.text_alignment == 'left' %}flex-start{% elsif section.settings.text_alignment == 'right' %}flex-end{% else %}center{% endif %};
}

/* Rounded Pill Button Style */
#custom-banner-{{ section.id }} .btn-style-pill {
  border-radius: 50px !important;
  padding: 12px 30px;
  font-weight: 600;
}

@media (max-width: 800px) {
  #custom-banner-{{ section.id }} .banner-image-wrapper {
    {% if section.settings.adapt_height_mobile %}
      height: auto;
    {% else %}
      height: {{ section.settings.min_height_mobile }}px;
    {% endif %}
  }

  {% if section.settings.show_mobile_content_below %}
    #custom-banner-{{ section.id }} .banner-content.mobile-stacked {
      position: relative;
      top: 0;
      left: 0;
      transform: none;
      padding: 40px 20px;
      display: flex !important;
    }
    #custom-banner-{{ section.id }} .banner-image-wrapper::after { display: none; }
    #custom-banner-{{ section.id }} .banner-image-wrapper .banner-content { display: none; }
  {% else %}
     #custom-banner-{{ section.id }} .banner-content.mobile-stacked { display: none; }
  {% endif %}

  #custom-banner-{{ section.id }} .banner-heading {
    font-size: {{ section.settings.heading_size_mobile }}px;
    margin-bottom: 0;
  }
  #custom-banner-{{ section.id }} .banner-content {
    text-align: center;
    max-width: 650px;
    align-items: center;
    gap: 15px;
  }
}

@media (min-width: 800px) {
  .mobile-stacked { display: none !important; }
}
{%- endstyle -%}

<div id="custom-banner-{{ section.id }}" class="custom-banner-section color-{{ section.settings.color_scheme }} gradient">
  
  <div class="banner-image-wrapper">
    {%- if section.settings.media_type == 'video' and section.settings.video != blank -%}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true, class: 'hp-hero__video' }}
    {%- elsif section.settings.image != blank -%}
      <picture>
        {% if section.settings.mobile_image != blank %}
          <source media="(max-width: 800px)" srcset="{{ section.settings.mobile_image | image_url: width: 800 }}">
        {% endif %}
        <img src="{{ section.settings.image | image_url: width: 4000 }}" alt="{{ section.settings.image.alt }}" class="banner-image" loading="eager" width="4000" height="auto">
      </picture>
    {%- endif -%}

    <div class="banner-content">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          
          {%- when 'review_badge' -%}
            <div class="banner-review-block" {{ block.shopify_attributes }}>
              {%- if block.settings.custom_svg != blank -%}
                <div class="banner-review-custom-svg">{{ block.settings.custom_svg }}</div>
              {%- else -%}
                <div class="banner-review-stars">★★★★★</div>
              {%- endif -%}
              <span>{{ block.settings.review_text }}</span>
            </div>

          {%- when 'heading' -%}
            <h2 class="hero-features__heading {{ block.settings.heading_size }}" {{ block.shopify_attributes }}>
              {{ block.settings.heading | newline_to_br }}
            </h2>

          {%- when 'subheading' -%}
            <div class="banner-subheading" {{ block.shopify_attributes }}>
              {{ block.settings.subheading }}
            </div>

          {%- when 'buttons' -%}
            <div class="btn-custom-banner" {{ block.shopify_attributes }}>
              {% if block.settings.button_text != blank %}
                <a href="{{ block.settings.button_link }}" class="button button--primary">{{ block.settings.button_text }} {% render 'shop-arrow' %}</a>
              {% endif %}
              {% if block.settings.button_text2 != blank %}
                <a href="{{ block.settings.button_link2 }}" class="button button--secondary">{{ block.settings.button_text2 }}{% render 'shop-arrow' %}</a>
              {% endif %}
            </div>

        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>


  <div class="banner-content mobile-stacked"> 
    {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'review_badge' -%}
            <div class="banner-review-block">
              {%- if block.settings.custom_svg != blank -%}
                <div class="banner-review-custom-svg">{{ block.settings.custom_svg }}</div>
              {%- else -%}
                <div class="banner-review-stars">★★★★★</div>
              {%- endif -%}
              <span>{{ block.settings.review_text }}</span>
            </div>
          {%- when 'heading' -%}
            <h2 class="hero-features__heading {{ block.settings.heading_size }}">{{ block.settings.heading | newline_to_br }}</h2>
          {%- when 'subheading' -%}
            <div class="banner-subheading">{{ block.settings.subheading }}</div>
          {%- when 'buttons' -%}
            <div class="btn-custom-banner">
              {% if block.settings.button_text != blank %}
                <a href="{{ block.settings.button_link }}" class="button button--primary btn-style-pill">{{ block.settings.button_text }}</a>
              {% endif %}
              {% if block.settings.button_text2 != blank %}
                <a href="{{ block.settings.button_link2 }}" class="button button--secondary btn-style-pill">{{ block.settings.button_text2 }}</a>
              {% endif %}
            </div>
        {%- endcase -%}
      {%- endfor -%}
  </div>

</div>

{% schema %}
{
  "name": "Image Custom Banner",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1",
      "info": "Applies to text overlay on desktop, and the stacked background on mobile."
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Media Type",
      "options": [
        { "value": "image", "label": "Static Image" },
        { "value": "video", "label": "Background Video" }
      ],
      "default": "image"
    },
    { "type": "video", "id": "video", "label": "Banner Video" },
    { "type": "image_picker", "id": "image", "label": "Desktop Image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile Image" },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 90, "step": 5, "unit": "%", "label": "Overlay Opacity", "default": 20 },
    {
      "type": "header",
      "content": "Desktop Sizing"
    },
    { "type": "range", "id": "heading_size_desktop", "min": 20, "max": 100, "step": 2, "unit": "px", "label": "Heading Size", "default": 48 },
    { "type": "range", "id": "subheading_size_desktop", "min": 12, "max": 40, "step": 1, "unit": "px", "label": "Subheading Size", "default": 16 },
    { "type": "range", "id": "content_width", "min": 400, "max": 1200, "step": 50, "unit": "px", "label": "Max Content Width", "default": 650 },
    { "type": "range", "id": "min_height_desktop", "min": 300, "max": 1000, "step": 50, "unit": "px", "label": "Banner Height", "default": 600 },
    { "type": "checkbox", "id": "adapt_height_desktop", "label": "Adapt to Image Height", "default": false },
    {
      "type": "header",
      "content": "Mobile Sizing"
    },
    { "type": "range", "id": "heading_size_mobile", "min": 18, "max": 60, "step": 2, "unit": "px", "label": "Heading Size", "default": 36 },
    { "type": "range", "id": "min_height_mobile", "min": 200, "max": 800, "step": 50, "unit": "px", "label": "Mobile Height", "default": 400 },
    { "type": "checkbox", "id": "adapt_height_mobile", "label": "Adapt Height (Mobile)", "default": false },
    { "type": "checkbox", "id": "show_mobile_content_below", "label": "Stack Content Below Image", "default": true },
    {
      "type": "header",
      "content": "Content Positioning"
    },
    { "type": "range", "id": "text_position_top", "min": 0, "max": 100, "default": 50, "unit": "%", "label": "Vertical Position" },
    { "type": "range", "id": "text_position_left", "min": 0, "max": 100, "default": 50, "unit": "%", "label": "Horizontal Position" },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    }
  ],
  "blocks": [
    {
      "type": "review_badge",
      "name": "Review / Trust Badge",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "review_text",
          "label": "Badge Text",
        },
        {
          "type": "html",
          "id": "custom_svg",
          "label": "Custom SVG (Overrides default stars)",
          "info": "Paste SVG code here if you want to use a specific logo/stars."
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "heading",
          "label": "Heading Text"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            { "value": "h2", "label": "Small" },
            { "value": "h1", "label": "Medium" },
            { "value": "h0", "label": "Large" },
            { "value": "hxl", "label": "Extra Large" },
            { "value": "hxxl", "label": "Extra Extra Large" }
          ],
          "default": "h0",
          "label": "Heading Size"
        }
      ]
    },
    {
      "type": "subheading",
      "name": "Subheading",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "subheading",
          "label": "Subheading Text",
        }
      ]
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "button_text", "label": "Button 1 Label" },
        { "type": "url", "id": "button_link", "label": "Button 1 Link" },
        { "type": "text", "id": "button_text2", "label": "Button 2 Label" },
        { "type": "url", "id": "button_link2", "label": "Button 2 Link" }
      ]
    }
  ],
  "presets": [
    { 
      "name": "Image Custom Banner",
      "blocks": [
        { "type": "review_badge" },
        { "type": "heading" },
        { "type": "subheading" },
        { "type": "buttons" }
      ]
    }
  ]
}
{% endschema %}