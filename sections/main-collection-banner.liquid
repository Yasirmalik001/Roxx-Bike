{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{{ 'component-collection-hero.css' | asset_url | stylesheet_tag }}

<style>
  .custom-collection-hero {
    position: relative;
    width: 100%;
    min-height: {{ section.settings.desktop_height }}px;
    display: flex; /* Flex container */
    background-color: #111111;
    overflow: hidden;
  }

  .custom-hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .custom-hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .custom-hero-bg svg {
    width: 100%;
    height: 100%;
    background-color: #333333;
    fill: #555555;
  }

  .custom-hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: #000000;
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 2;
  }

  /* Combined page-width and content wrapper */
  .custom-hero-content {
    position: relative;
    z-index: 3;
    width: 100%; /* Ensures page-width spans full available width */
    display: flex;
    flex-direction: column;
    flex-grow: 1; /* Stretches to fill the min-height of the parent */
    padding-top: 3rem;
    padding-bottom: 2rem;
  }

  .custom-hero-center {
    flex-grow: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .custom-hero-title {
    font-family: inherit;
    font-size: 4.5rem;
    font-weight: 800;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0;
    letter-spacing: -0.02em;
    text-align: center;
  }

  .custom-hero-bottom {
    width: 100%;
    display: flex;
    justify-content: flex-start;
    margin-top: auto; /* Pushes to the bottom */
  }

  .custom-breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-size: 1.2rem;
    color: #ffffff;
    font-weight: 500;
  }

  .custom-breadcrumbs a {
    color: #ffffff;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .custom-breadcrumbs a:hover {
    opacity: 0.7;
  }

  .breadcrumb-separator {
    font-size: 1rem;
    opacity: 0.8;
  }

  @media screen and (max-width: 749px) {
    .custom-collection-hero {
      min-height: {{ section.settings.mobile_height }}px;
    }
    .custom-hero-content {
      padding-top: 2rem;
      padding-bottom: 1.5rem;
    }
    .custom-hero-title {
      font-size: 2.8rem;
    }
  }
</style>

<div class="custom-collection-hero">
  <div class="custom-hero-bg">
    {%- if section.settings.show_collection_image and collection.image -%}
      <img
        srcset="
          {%- if collection.image.width >= 360 -%}{{ collection.image | image_url: width: 360 }} 360w,{%- endif -%}
          {%- if collection.image.width >= 750 -%}{{ collection.image | image_url: width: 750 }} 750w,{%- endif -%}
          {%- if collection.image.width >= 1100 -%}{{ collection.image | image_url: width: 1100 }} 1100w,{%- endif -%}
          {%- if collection.image.width >= 1500 -%}{{ collection.image | image_url: width: 1500 }} 1500w,{%- endif -%}
          {%- if collection.image.width >= 2000 -%}{{ collection.image | image_url: width: 2000 }} 2000w,{%- endif -%}
          {{ collection.image | image_url }} {{ collection.image.width }}w
        "
        src="{{ collection.image | image_url: width: 1500 }}"
        sizes="100vw"
        alt="{{ collection.image.alt | escape }}"
        width="{{ collection.image.width }}"
        height="{{ collection.image.height }}"
        fetchpriority="high"
      >
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>

  <div class="custom-hero-overlay"></div>

  <div class="page-width custom-hero-content">
    <div class="custom-hero-center">
      <h1 class="custom-hero-title">
        <span class="visually-hidden">Collection: </span>
        {{- collection.title | escape -}}
      </h1>
    </div>
    
    {% if section.settings.show_breadcrumbs %}
      <div class="custom-hero-bottom">
        {% render 'breadcrumbs', class: 'custom-breadcrumbs' %}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Collection Banner Custom",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Displays a full-width collection banner with centered title and breadcrumbs."
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "default": true,
      "label": "Show collection image"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "default": true,
      "label": "Show breadcrumbs"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Image overlay opacity",
      "default": 30
    },
    {
      "type": "range",
      "id": "desktop_height",
      "min": 200,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "Desktop height",
      "default": 450
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 200,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Mobile height",
      "default": 300
    }
  ]
}
{% endschema %}