{%- style -%}
.section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px; padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px; }
@media screen and (min-width: 750px) { .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; } }
.specs-container { display: grid; grid-template-columns: 1fr; gap: 4rem; }
@media screen and (min-width: 990px) { .specs-container { grid-template-columns: 1fr 1fr; gap: 8rem; align-items: flex-start; } }
.specs-left-col { display: flex; flex-direction: column; gap: 3rem; }
.specs-heading { color: rgb(var(--color-foreground)); }
@media screen and (min-width: 990px) { .specs-image-wrap { width: 145%; margin-left: -45%; max-width: none; display: flex; justify-content: flex-end; margin-top: 4rem; } }
.specs-image { width: 100%; height: auto; object-fit: contain; display: block; }
.specs-right-col { display: flex; flex-direction: column; gap: 4rem; padding-top: 1rem; }
.spec-category { display: flex; flex-direction: column; gap: 1.5rem; }
.spec-category-title { font-family: "Suisse Int'l Trial", sans-serif; font-weight: 400; font-size: 20px; line-height: 100%; color: rgb(var(--color-foreground)); margin: 0; }
.spec-table { display: flex; flex-direction: column; width: 100%; }
.spec-row { display: flex; align-items: flex-start; padding: 1.4rem 1.5rem; font-size: 1.3rem; line-height: 1.4; }
.spec-row:nth-child(odd) { background-color: rgba(var(--color-foreground), 0.04); }
.spec-label { flex: 0 0 35%; padding-right: 1.5rem; color: rgba(var(--color-foreground), 0.6); font-weight: 400; }
.spec-value { flex: 1; color: rgb(var(--color-foreground)); font-weight: 500; }

@media screen and (max-width: 989px) {
  .specs-image-wrap { display: none; }
}

@media screen and (max-width: 749px) {
  .spec-row { flex-direction: row; gap: 1rem; padding: 1.2rem 1rem; }
  .spec-label { flex: 0 0 40%; padding-right: 0; }
  .spec-value { flex: 1; }
}
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding" {{ section.shopify_attributes }}>
  <div class="page-width">
    <div class="specs-container">
      
      <div class="specs-left-col">
        {%- if section.settings.title != blank -%}
          <h2 class="{{ section.settings.heading_size }} specs-heading">{{ section.settings.title | escape }}</h2>
        {%- endif -%}

        <div class="specs-image-wrap">
          {%- if section.settings.image != blank -%}
            {{ section.settings.image | image_url: width: 1500 | image_tag: class: 'specs-image', loading: 'lazy' }}
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'specs-image placeholder-svg' }}
          {%- endif -%}
        </div>
      </div>

      <div class="specs-right-col">
        {%- assign first_category = true -%}

        {%- for block in section.blocks -%}

          {%- if block.type == 'category' -%}
            {%- unless first_category -%}
              </div> </div> {%- endunless -%}
            
            <div class="spec-category" {{ block.shopify_attributes }}>
              <h3 class="spec-category-title">{{ block.settings.title | escape }}</h3>
              <div class="spec-table">
            
            {%- assign first_category = false -%}

          {%- elsif block.type == 'spec' -%}
            
            {%- if first_category -%}
              <div class="spec-category">
                <div class="spec-table">
              {%- assign first_category = false -%}
            {%- endif -%}

            <div class="spec-row" {{ block.shopify_attributes }}>
              <div class="spec-label">{{ block.settings.label | escape }}</div>
              <div class="spec-value">{{ block.settings.value | escape }}</div>
            </div>

          {%- endif -%}

        {%- endfor -%}

        {%- unless first_category -%}
            </div> </div> {%- endunless -%}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Specifications Table",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Left Column Settings"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "SPECIFICATIONS"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h0", "label": "t:sections.all.heading_size.options__3.label" }
      ],
      "default": "h0",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product Image"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Header",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Category Title",
          "default": "Performance & Power",
          "info": "This groups the specification rows below it."
        }
      ]
    },
    {
      "type": "spec",
      "name": "Specification Row",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Motor"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "250W Mivice rear hub motor"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Specifications Table",
      "blocks": [
        { "type": "category", "settings": { "title": "Performance & Power" } },
        { "type": "spec", "settings": { "label": "Motor", "value": "250W Mivice rear hub motor" } },
        { "type": "spec", "settings": { "label": "Top Speed", "value": "Up to 25 km/h" } },
        { "type": "spec", "settings": { "label": "Torque Sensor", "value": "Responsive, natural riding feel" } },
        { "type": "spec", "settings": { "label": "Range", "value": "Up to ~80 km per charge" } },
        { "type": "category", "settings": { "title": "Battery" } },
        { "type": "spec", "settings": { "label": "Battery Type", "value": "Samsung lithium" } },
        { "type": "spec", "settings": { "label": "Capacity", "value": "10Ah / 48V" } },
        { "type": "spec", "settings": { "label": "Charging", "value": "Fast and efficient for daily use" } },
        { "type": "spec", "settings": { "label": "Warranty", "value": "2 years" } },
        { "type": "category", "settings": { "title": "Ride & Build" } },
        { "type": "spec", "settings": { "label": "Drive System", "value": "Carbon belt drive (clean, silent, low maintenance)" } },
        { "type": "spec", "settings": { "label": "Frame", "value": "Lightweight aluminium" } },
        { "type": "spec", "settings": { "label": "Wheel Size", "value": "28\" CST tires" } },
        { "type": "spec", "settings": { "label": "Brakes", "value": "Mechanical disc brakes" } }
      ]
    }
  ]
}
{% endschema %}