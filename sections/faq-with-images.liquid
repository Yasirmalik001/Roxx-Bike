{%- style -%}
  .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px; padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px; }
  @media screen and (min-width: 750px) { .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; } }
{%- endstyle -%}

<div class="sr-faq-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    
    <div class="sr-faq-header">
      <h2 class="sr-faq-title h1">{{ section.settings.heading }}</h2>
    </div>

    <div class="sr-faq-layout">
      
      <div class="sr-faq-images sr-faq-images-left">
        {%- if section.settings.image_l1 != blank -%}
          <img src="{{ section.settings.image_l1 | image_url: width: 400 }}" class="sr-img-item sr-img-l1" loading="lazy" alt="FAQ Image">
        {%- else -%}
          <div class="sr-img-item sr-img-l1 placeholder">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
        {%- endif -%}

        {%- if section.settings.image_l2 != blank -%}
          <img src="{{ section.settings.image_l2 | image_url: width: 400 }}" class="sr-img-item sr-img-l2" loading="lazy" alt="FAQ Image">
        {%- else -%}
          <div class="sr-img-item sr-img-l2 placeholder">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
        {%- endif -%}

        {%- if section.settings.image_l3 != blank -%}
          <img src="{{ section.settings.image_l3 | image_url: width: 400 }}" class="sr-img-item sr-img-l3" loading="lazy" alt="FAQ Image">
        {%- else -%}
          <div class="sr-img-item sr-img-l3 placeholder">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
        {%- endif -%}
      </div>

      <div class="sr-faq-accordion-wrapper">
        {%- for block in section.blocks -%}
          <details class="sr-faq-item" {{ block.shopify_attributes }}>
            <summary class="sr-faq-summary" style="background-color: {{ section.settings.accordion_bg }}; color: {{ section.settings.accordion_text }};">
              <span class="sr-faq-question">{{ block.settings.question }}</span>
              <span class="sr-faq-icon">
                <svg class="icon-plus" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                <svg class="icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
              </span>
            </summary>
            <div class="sr-faq-answer" style="background-color: {{ section.settings.accordion_bg }}; color: {{ section.settings.accordion_text }};">
              <div class="sr-faq-answer-content">
                {{ block.settings.answer }}
              </div>
            </div>
          </details>
        {%- endfor -%}
      </div>

      <div class="sr-faq-images sr-faq-images-right">
        {%- if section.settings.image_r1 != blank -%}
          <img src="{{ section.settings.image_r1 | image_url: width: 400 }}" class="sr-img-item sr-img-r1" loading="lazy" alt="FAQ Image">
        {%- else -%}
          <div class="sr-img-item sr-img-r1 placeholder">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
        {%- endif -%}

        {%- if section.settings.image_r2 != blank -%}
          <img src="{{ section.settings.image_r2 | image_url: width: 400 }}" class="sr-img-item sr-img-r2" loading="lazy" alt="FAQ Image">
        {%- else -%}
          <div class="sr-img-item sr-img-r2 placeholder">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
        {%- endif -%}

        {%- if section.settings.image_r3 != blank -%}
          <img src="{{ section.settings.image_r3 | image_url: width: 400 }}" class="sr-img-item sr-img-r3" loading="lazy" alt="FAQ Image">
        {%- else -%}
          <div class="sr-img-item sr-img-r3 placeholder">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% comment %} Styles moved to sereluna.css {% endcomment %}

{% schema %}
{
  "name": "FAQ with Images",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently asked questions"
    },
    {
      "type": "header",
      "content": "Accordion Styling"
    },
    {
      "type": "color",
      "id": "accordion_bg",
      "label": "Pill Background Color",
      "default": "#F5F2ED"
    },
    {
      "type": "color",
      "id": "accordion_text",
      "label": "Pill Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Left Side Images"
    },
    {
      "type": "image_picker",
      "id": "image_l1",
      "label": "Left Image 1 (Top)"
    },
    {
      "type": "image_picker",
      "id": "image_l2",
      "label": "Left Image 2 (Middle)"
    },
    {
      "type": "image_picker",
      "id": "image_l3",
      "label": "Left Image 3 (Bottom)"
    },
    {
      "type": "header",
      "content": "Right Side Images"
    },
    {
      "type": "image_picker",
      "id": "image_r1",
      "label": "Right Image 1 (Top)"
    },
    {
      "type": "image_picker",
      "id": "image_r2",
      "label": "Right Image 2 (Middle)"
    },
    {
      "type": "image_picker",
      "id": "image_r3",
      "label": "Right Image 3 (Bottom)"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What are period panties?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Period panties look like regular underwear but have built-in absorbent protection that safely absorbs menstrual flow. They can replace pads and tampons.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ with Images",
      "blocks": [
        { "type": "faq_item" },
        { "type": "faq_item" },
        { "type": "faq_item" },
        { "type": "faq_item" }
      ]
    }
  ]
}
{% endschema %}