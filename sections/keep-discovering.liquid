{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .keep-discovering-wrapper {
    position: relative;
    width: 100%;
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background-color: #000;
  }

  .keep-discovering-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .kd-desktop-image, .kd-mobile-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    position: absolute;
    top: 0;
    left: 0;
  }

  .kd-desktop-image { display: none; }
  .kd-mobile-image { display: block; }

  @media screen and (min-width: 750px) {
    .kd-desktop-image { display: block; }
    .kd-mobile-image { display: none; }
  }

  /* Linear gradient overlay with schema-controlled color and opacity */
  {%- assign overlay_alpha = section.settings.overlay_opacity | divided_by: 100.0 -%}
  {%- assign overlay_mid_alpha = overlay_alpha | times: 0.6 -%}
  .keep-discovering-bg::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, 
      {{ section.settings.overlay_color | color_modify: 'alpha', overlay_alpha }} 0%, 
      {{ section.settings.overlay_color | color_modify: 'alpha', overlay_mid_alpha }} 40%, 
      {{ section.settings.overlay_color | color_modify: 'alpha', 0.0 }} 100%);
    z-index: 2;
    pointer-events: none;
  }

  .keep-discovering-content {
    position: relative;
    z-index: 3;
    padding-top: 5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .keep-discovering-heading {
    color: #ffffff;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 3.5rem;
    text-align: center;
  }

  .kd-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.5rem;
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .kd-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Frosted glass / Dark card styling */
  .kd-card {
border: 1px solid #FFFFFF1F;
backdrop-filter: blur(4px);
    border-radius: 10px;
    padding: 1.5rem 1.2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    aspect-ratio: 16 / 9;
    text-decoration: none;
    transition: transform 0.3s ease, background 0.3s ease;
  }

  .kd-card:hover {
    background: rgba(45, 45, 45, 0.85);
    transform: translateY(-4px);
  }

  .kd-card__title {
    font-size: 1.3rem;
    font-weight: 700;
    text-transform: uppercase;
    margin: 0;
    color: #ffffff;
    letter-spacing: 0.05em;
  }

  .kd-card__icon-wrapper {
    display: flex;
    justify-content: flex-start;
    margin-top: auto;
  }

  .kd-card__icon-external svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: #ffffff;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
{%- endstyle -%}

<div class="keep-discovering-wrapper section-{{ section.id }}-padding">
  <div class="keep-discovering-bg">
    {%- if section.settings.image != blank -%}
      {%- assign mobile_image = section.settings.mobile_image | default: section.settings.image -%}
      
      {{ section.settings.image | image_url: width: 3000 | image_tag: class: 'kd-desktop-image', loading: 'lazy', sizes: '100vw', widths: '750, 1100, 1500, 1780, 2000, 3000' }}
      
      {{ mobile_image | image_url: width: 1500 | image_tag: class: 'kd-mobile-image', loading: 'lazy', sizes: '100vw', widths: '375, 550, 750' }}
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>

  <div class="keep-discovering-content page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="keep-discovering-heading {{ section.settings.heading_size }}">
        {{ section.settings.heading | escape }}
      </h2>
    {%- endif -%}

    <div class="kd-grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" class="kd-card" {{ block.shopify_attributes }}>
          <h3 class="kd-card__title">{{ block.settings.title | escape }}</h3>

          {%- if block.type == 'external_link' -%}
            <div class="kd-card__icon-wrapper">
              <span class="kd-card__icon-external">
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                  <polyline points="15 3 21 3 21 9"></polyline>
                  <line x1="10" y1="14" x2="21" y2="3"></line>
                </svg>
              </span>
            </div>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Keep Discovering Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Background Images"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop background image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile background image",
      "info": "Optional. Defaults to desktop image if left blank."
    },
    {
      "type": "header",
      "content": "Linear Gradient Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay maximum opacity",
      "default": 80
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "KEEP DISCOVERING",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "standard_card",
      "name": "Standard Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "default": "SHOP BIKES",
          "label": "Card Heading"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        }
      ]
    },
    {
      "type": "external_link",
      "name": "External Link Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "default": "BOOK TEST DRIVE",
          "label": "Card Heading"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Keep Discovering Hero",
      "blocks": [
        {
          "type": "external_link",
          "settings": {
            "title": "BOOK TEST DRIVE"
          }
        },
        {
          "type": "standard_card",
          "settings": {
            "title": "ACCESSORIES"
          }
        },
        {
          "type": "standard_card",
          "settings": {
            "title": "SHOP BIKES"
          }
        },
        {
          "type": "standard_card",
          "settings": {
            "title": "SUPPORT"
          }
        }
      ]
    }
  ]
}
{% endschema %}