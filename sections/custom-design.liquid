{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 990px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .custom-production-container {
    border-radius: {{ section.settings.container_radius }}px;
    position: relative;
    padding: 3rem 2.5rem;
  }

  @media screen and (min-width: 990px) {
    .custom-production-container {
      padding: 6rem;
    }
  }

  .custom-production-grid {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  @media screen and (min-width: 990px) {
    .custom-production-grid {
      flex-direction: {% if section.settings.layout == 'text_first' %}row-reverse{% else %}row{% endif %};
      align-items: center;
      gap: 6rem;
    }
  }

  .custom-production-media-wrapper {
    flex: 1;
    position: relative;
    width: 100%;
  }

  .custom-production-media {
    position: relative;
    z-index: 2;
    border-radius: {{ section.settings.image_radius }}px;
    overflow: hidden;
  }

.custom-production-media img, .custom-production-media svg {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    max-height: 736px;
}
  .custom-production-shape {
    position: absolute;
    z-index: 1;
  }

  .custom-production-content-wrapper {
    flex: 1.5;
    display: flex;
    flex-direction: column;
    justify-content: center;
    text-align: center;
  }

  @media screen and (min-width: 990px) {
    .custom-production-content-wrapper {
      text-align: left;
    }
  }

  .custom-production-content {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .custom-production-heading {
    margin: 0;
    margin-bottom: 0.5rem;
  }

.custom-production-body {
    margin: 0;
    line-height: 130%;
}
  .custom-production-feature {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: center;
  }

  @media screen and (min-width: 990px) {
    .custom-production-feature {
      align-items: flex-start;
    }
  }

.custom-production-feature-title {
    margin: 0;
    font-weight: 600;
    font-size: 18px;
}

  .custom-production-feature-text {
    margin: 0;
    font-size: 1.4rem;
    line-height: 1.5;
    opacity: 0.9;
  }
  
  .custom-production-feature-text p {
    margin: 0;
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="custom-production-container color-{{ section.settings.color_scheme }} gradient">
      <div class="custom-production-grid">

        <div class="custom-production-media-wrapper">
          <div class="custom-production-media">
            {%- if section.settings.image != blank -%}
              {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
            {%- else -%}
              {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>

          {%- for block in section.blocks -%}
            {%- if block.type == 'shape' -%}
              {%- style -%}
                .shape-block-{{ block.id }} {
                  width: {{ block.settings.shape_width }}%;
                  {%- if block.settings.position == 'top_left' -%}
                    top: {{ block.settings.offset_y }}%; left: {{ block.settings.offset_x }}%;
                  {%- elsif block.settings.position == 'top_right' -%}
                    top: {{ block.settings.offset_y }}%; right: {{ block.settings.offset_x }}%;
                  {%- elsif block.settings.position == 'bottom_left' -%}
                    bottom: {{ block.settings.offset_y }}%; left: {{ block.settings.offset_x }}%;
                  {%- elsif block.settings.position == 'bottom_right' -%}
                    bottom: {{ block.settings.offset_y }}%; right: {{ block.settings.offset_x }}%;
                  {%- endif -%}
                }
              {%- endstyle -%}
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 300 }}"
                     alt="{{ block.settings.image.alt | escape }}"
                     class="custom-production-shape shape-block-{{ block.id }}"
                     loading="lazy"
                     {{ block.shopify_attributes }}>
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg custom-production-shape shape-block-' | append: block.id }}
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>

        <div class="custom-production-content-wrapper">
          <div class="custom-production-content">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'heading' -%}
                  <h2 class="hero-features__heading {{ block.settings.heading_size }}" {{ block.shopify_attributes }}>
  {{ block.settings.heading }}
</h2>
                {%- when 'text' -%}
                  <div class="custom-production-body rte {{ block.settings.text_style }}" {{ block.shopify_attributes }}>
                    {{ block.settings.text }}
                  </div>
                {%- when 'feature' -%}
                  <div class="custom-production-feature" {{ block.shopify_attributes }}>
                    <div class="custom-production-feature-title">
                      {{ block.settings.title }}
                    </div>
                    <div class="custom-production-feature-text rte">
                      {{ block.settings.text }}
                    </div>
                  </div>
              {%- endcase -%}
            {%- endfor -%}
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom Production",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image"
    },
    {
      "type": "select",
      "id": "layout",
      "options": [
        {
          "value": "image_first",
          "label": "Image first"
        },
        {
          "value": "text_first",
          "label": "Text first"
        }
      ],
      "default": "image_first",
      "label": "Desktop image placement"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "container_radius",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Container Border Radius",
      "default": 32
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Image Border Radius",
      "default": 24
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "shape",
      "name": "Shape Image",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Shape Image"
        },
        {
          "type": "select",
          "id": "position",
          "label": "Anchor Position",
          "options": [
            { "value": "top_left", "label": "Top Left" },
            { "value": "top_right", "label": "Top Right" },
            { "value": "bottom_left", "label": "Bottom Left" },
            { "value": "bottom_right", "label": "Bottom Right" }
          ],
          "default": "bottom_left"
        },
        {
          "type": "range",
          "id": "offset_x",
          "min": -50,
          "max": 50,
          "step": 1,
          "unit": "%",
          "label": "Offset X",
          "default": -10
        },
        {
          "type": "range",
          "id": "offset_y",
          "min": -50,
          "max": 50,
          "step": 1,
          "unit": "%",
          "label": "Offset Y",
          "default": -10
        },
        {
          "type": "range",
          "id": "shape_width",
          "min": 10,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Shape Width (Relative to Image)",
          "default": 30
        }
      ]
    },
    {
      "type": "heading",
      "name": "t:sections.image-with-text.blocks.heading.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Image with text",
          "label": "t:sections.image-with-text.blocks.heading.settings.heading.label"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            {
              "value": "h2",
              "label": "t:sections.all.heading_size.options__1.label"
            },
            {
              "value": "h1",
              "label": "t:sections.all.heading_size.options__2.label"
            },
            {
              "value": "h0",
              "label": "t:sections.all.heading_size.options__3.label"
            }
          ],
          "default": "h1",
          "label": "t:sections.all.heading_size.label"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.image-with-text.blocks.text.name",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post.</p>",
          "label": "t:sections.image-with-text.blocks.text.settings.text.label"
        },
        {
          "type": "select",
          "id": "text_style",
          "options": [
            {
              "value": "body",
              "label": "t:sections.image-with-text.blocks.text.settings.text_style.options__1.label"
            },
            {
              "value": "subtitle",
              "label": "t:sections.image-with-text.blocks.text.settings.text_style.options__2.label"
            }
          ],
          "default": "body",
          "label": "t:sections.image-with-text.blocks.text.settings.text_style.label"
        }
      ]
    },
    {
      "type": "feature",
      "name": "Feature List Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "default": "Feature Title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Explain the feature details here.</p>",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Production",
      "blocks": [
        { "type": "shape", "settings": { "position": "top_right", "offset_x": -10, "offset_y": -10 } },
        { "type": "shape", "settings": { "position": "bottom_left", "offset_x": -10, "offset_y": -10 } },
        { "type": "heading", "settings": { "heading": "Design, production, and testing" } },
        { "type": "text", "settings": { "text": "<p>Sereluna respects women's bodies and the environment. Our products are innovative, durable, and ethically made.</p>" } },
        { "type": "feature", "settings": { "title": "Design and sourcing", "text": "<p>We design our period panties ourselves. All our designs are original and unique.</p>" } },
        { "type": "feature", "settings": { "title": "Manufacturing", "text": "<p>Period panties are technically advanced and cannot be mass-produced by machines.</p>" } },
        { "type": "feature", "settings": { "title": "Testing", "text": "<p>We do not use harmful chemicals such as nanosilver or PFAS in our period panties.</p>" } }
      ]
    }
  ]
}
{% endschema %}
