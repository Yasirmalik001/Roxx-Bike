{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Central Wave Positioning */
  .sr-wave-bg {
    position: absolute;
    top: {{ section.settings.wave_top_pos }}%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    z-index: -1;
    opacity: {{ section.settings.wave_opacity }}%;
    pointer-events: none;
  }

  {%- for block in section.blocks -%}
    {%- if block.type == 'feature' -%}
      .block-{{ block.id }} .sr-unique-icon {
        width: {{ block.settings.icon_width }}px;
      }
    {%- endif -%}
  {%- endfor -%}
{%- endstyle -%}

<div class="sr-unique-section section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient" style="position: relative; overflow: hidden;">
  
  {%- if section.settings.wave_image -%}
    <img src="{{ section.settings.wave_image | image_url: width: 2000 }}" 
         class="sr-wave-bg" 
         alt="" 
         loading="lazy">
  {%- endif -%}

  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="sr-unique-heading h1 center">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="sr-unique-container">
      {%- comment -%} Left Column {%- endcomment -%}
      <div class="sr-unique-column sr-unique-col-left">
        {% assign feature_blocks = section.blocks | where: "type", "feature" %}
        {% for block in feature_blocks limit: 3 %}
          <div class="sr-unique-item block-{{ block.id }}" {{ block.shopify_attributes }}>
            <div class="sr-unique-text-wrap">
              <div class="sr-unique-title">{{ block.settings.title }}</div>
              <p class="sr-unique-desc">{{ block.settings.text }}</p>
            </div>
            {% if block.settings.icon %}
              <div class="sr-unique-icon-wrap">
                <img src="{{ block.settings.icon | image_url: width: 200 }}" alt="" class="sr-unique-icon" loading="lazy">
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>

      <div class="sr-unique-center-wrap">
        {% if section.settings.center_image %}
          <img src="{{ section.settings.center_image | image_url: width: 800 }}" alt="Feature" class="sr-unique-center-img" loading="lazy">
        {% endif %}
      </div>

      {%- comment -%} Right Column {%- endcomment -%}
      <div class="sr-unique-column sr-unique-col-right">
        {% for block in feature_blocks offset: 3 limit: 3 %}
          <div class="sr-unique-item block-{{ block.id }}" {{ block.shopify_attributes }}>
            {% if block.settings.icon %}
              <div class="sr-unique-icon-wrap">
                <img src="{{ block.settings.icon | image_url: width: 200 }}" alt="" class="sr-unique-icon" loading="lazy">
              </div>
            {% endif %}
            <div class="sr-unique-text-wrap">
              <div class="sr-unique-title">{{ block.settings.title }}</div>
              <p class="sr-unique-desc">{{ block.settings.text }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    {%- comment -%} Separate Button Block {%- endcomment -%}
    <div class="sr-unique-btn-wrap center">
      {%- for block in section.blocks -%}
        {%- if block.type == 'button' -%}
          <a {% if block.settings.button_link == blank %} role="link" aria-disabled="true"{% else %} href="{{ block.settings.button_link }}"{% endif %} 
            class="button{% if block.settings.button_style_secondary %} button--secondary{% else %} button--primary{% endif %}" {{ block.shopify_attributes }}>
            {{ block.settings.button_label | escape }}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .sr-unique-section { z-index: 1; }
  .sr-unique-heading { margin-bottom: 50px; } /* Color inherited from scheme */
  .sr-unique-container { display: flex; align-items: center; justify-content: center; gap: 40px; }
  .sr-unique-column { flex: 1; display: flex; flex-direction: column; gap: 120px; }
  
  .sr-unique-item { display: flex; align-items: start; gap: 20px; }
  .sr-unique-col-left .sr-unique-item { text-align: right; justify-content: flex-end; }
  .sr-unique-col-right .sr-unique-item { text-align: left; justify-content: flex-start; }

.sr-unique-title {
    font-size: 1.8rem;
    margin: 0 0 0.5rem;
    font-weight: 600;
    line-height: 140%;
}
  .sr-unique-desc { font-size: 1.4rem; line-height: 1.4; margin: 0; }
  
  .sr-unique-icon-wrap { flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
  .sr-unique-icon { height: auto; object-fit: contain; }

  .sr-unique-center-wrap {display: flex; justify-content: center; z-index: 2; }
  .sr-unique-center-img {
      width: 100%;
      max-width: 500px;
      height: auto;
      border-radius: 15px;
      max-height: 600px;
  }

  .sr-unique-btn-wrap { 
    margin-top: 60px;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  
  @media (max-width: 1290px) {
    .sr-unique-column { gap: 60px; }
  }
  @media (max-width: 1190px) {
    .sr-unique-container { flex-direction: column; gap: 10px; }
    .sr-unique-center-wrap { order: -1; margin-bottom: 20px; }
    .sr-unique-col-left .sr-unique-item { flex-direction: row-reverse; text-align: left; }
    .sr-unique-column { gap: 30px; }
    .sr-wave-bg { width: 200%; }
    .sr-unique-center-img {
    max-width: 307px;
}
  }
</style>

{% schema %}
{
  "name": "Unique Features",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Why our period pants are unique"
    },
    {
      "type": "header",
      "content": "Wave Background Settings"
    },
    {
      "type": "image_picker",
      "id": "wave_image",
      "label": "Wave Overlay Image"
    },
    {
      "type": "range",
      "id": "wave_top_pos",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Wave Vertical Position",
      "default": 50
    },
    {
      "type": "range",
      "id": "wave_opacity",
      "min": 10,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "Wave Opacity",
      "default": 100
    },
    {
      "type": "header",
      "content": "Central Image"
    },
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "Central Image"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "range",
          "id": "icon_width",
          "min": 20,
          "max": 150,
          "step": 5,
          "unit": "px",
          "label": "Icon Width",
          "default": 50
        },
        {
          "type": "text",
          "id": "title",
          "label": "Feature Title",
          "default": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Feature Description",
          "default": "Feature description goes here."
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 2,
      "settings": [
        {
          "type": "text",
          "id": "button_label",
          "default": "Button label",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "checkbox",
          "id": "button_style_secondary",
          "default": false,
          "label": "Use secondary button style"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Unique Features",
      "blocks": [
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}
