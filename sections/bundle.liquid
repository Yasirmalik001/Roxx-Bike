                      <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    </svg>
                    <svg data-tier-icon-applied="" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                    <span data-tier-status-text="">Køb {{ block.settings.min_qty }}+</span>
                  </span>
                  <span class="bb-tier-label">{{ block.settings.label | escape }}</span>
                  <span class="bb-tier-sub">{{ block.settings.sub_label | escape }}</span>
