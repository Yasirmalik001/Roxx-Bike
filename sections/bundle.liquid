
<style>
  #shopify-section-{{ section.id }} .bundle-builder {
    --bg: rgb(var(--background-primary));
    --text: rgb(var(--text-primary));
    --muted: rgb(var(--text-primary) / 0.7);
    --accent: rgb(var(--accent));
    --accent-hover: rgb(var(--accent) / 0.85);
    --accent-soft: rgb(var(--accent) / 0.1);
    --accent-text: rgb(var(--button-text-primary));
    --highlight: {% if section.settings.highlight_color != blank %}rgb({{ section.settings.highlight_color.rgb }}){% else %}#f5e97b{% endif %};
    --gift-badge: {% if section.settings.gift_badge_color != blank %}rgb({{ section.settings.gift_badge_color.rgb }}){% else %}#bef264{% endif %};
    --card-bg: {% if section.settings.card_bg_color != blank %}rgb({{ section.settings.card_bg_color.rgb }}){% else %}rgb(var(--product-card-background, var(--background-primary))){% endif %};
    --border: rgb(var(--border-color));
    --radius: var(--rounded-block);

    width: 100%;
    background: var(--bg);
    color: var(--text);
    padding: var(--section-outer-spacing-block) 0;
    font-family: var(--text-font-family);
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .bundle-builder *,
  #shopify-section-{{ section.id }} .bundle-builder *::before,
  #shopify-section-{{ section.id }} .bundle-builder *::after {
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-inner {
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: 0 var(--container-gutter);
  }

  /* ---------- Header ---------- */
  #shopify-section-{{ section.id }} .bundle-builder .bb-header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 36px;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-eyebrow {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 14px;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-heading {
    font-family: var(--heading-font-family);
    font-size: clamp(28px, 4vw, 44px);
    line-height: 1.1;
    font-weight: var(--heading-font-weight);
    margin: 0 0 14px;
    letter-spacing: var(--heading-letter-spacing);
    text-transform: var(--heading-text-transform);
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-subheading {
    font-size: 17px;
    line-height: 1.5;
    margin: 0;
    color: var(--muted);
  }

  /* ---------- Tier strip ---------- */
  #shopify-section-{{ section.id }} .bundle-builder .bb-tiers {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px;
    margin-bottom: 32px;
    padding: 20px;
    background: var(--text);
    border-radius: var(--radius);
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-tier {
    background: var(--bg);
    border-radius: var(--rounded-xs);
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
    position: relative;
    transition: all 0.25s ease;
    border: 2px solid transparent;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-tier--applied {
    background: var(--highlight);
    color: var(--text);
    border-color: var(--highlight);
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-tier-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 600;
    color: var(--muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-tier--applied .bb-tier-status {
    color: var(--accent);
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-tier-status svg {
    width: 14px;
    height: 14px;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-tier-label {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-tier-sub {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.3;
  }

  /* ---------- Main layout ---------- */
  #shopify-section-{{ section.id }} .bundle-builder .bb-layout {
    display: grid !important;
    grid-template-columns: 1fr 380px !important;
    gap: 32px !important;
    align-items: flex-start !important;
  }

  /* ---------- Products grid ---------- */
  #shopify-section-{{ section.id }} .bundle-builder .bb-products {
    display: grid !important;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)) !important;
    gap: 16px !important;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-product {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px;
    display: flex !important;
    flex-direction: column !important;
    gap: 12px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    position: relative;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-product--active {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent);
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-product--unavailable {
    opacity: 0.5;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-product-image {
    width: 100%;
    padding-top: 100%; /* Enforce strict 1:1 aspect ratio */
    position: relative;
    border-radius: var(--rounded-xs);
    overflow: hidden;
    background: rgb(var(--text-primary) / 0.04);
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-product-image img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    padding: 8px;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-product-image-placeholder {
    opacity: 0.3;
    color: var(--muted);
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-product-image-placeholder svg {
    width: 48px;
    height: 48px;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-product-title {
    font-family: var(--heading-font-family);
    font-size: 15px;
    font-weight: 500;
    line-height: 1.3;
    margin: 0;
    color: var(--text);
    flex: 1;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-product-price {
    font-size: 14px;
    color: var(--muted);
    margin: 0;
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-product-sold-out {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: var(--border);
    color: var(--muted);
    padding: 4px 10px;
    border-radius: 999px;
  }

  /* ---------- Quantity selector ---------- */
  #shopify-section-{{ section.id }} .bundle-builder .bb-qty {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--highlight);
    border-radius: var(--rounded-button);
    padding: 4px;
    margin-top: auto;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-qty-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    background: transparent;
    color: var(--text);
    font-size: 18px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-qty-btn:hover:not(:disabled) {
    background: rgba(0,0,0,0.08);
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-qty-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-qty-btn svg {
    width: 16px;
    height: 16px;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-qty-value {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
    min-width: 24px;
    text-align: center;
  }

  /* ---------- Bundle cart (desktop sidebar) ---------- */
  #shopify-section-{{ section.id }} .bundle-builder .bb-cart {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-cart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-cart-title {
    font-family: var(--heading-font-family);
    font-size: 16px;
    font-weight: 600;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 10px;
    letter-spacing: 0.02em;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-count {
    background: var(--accent);
    color: var(--accent-text);
    font-size: 13px;
    font-weight: 700;
    min-width: 26px;
    height: 26px;
    padding: 0 8px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-clear {
    background: none;
    border: none;
    color: var(--muted);
    font-size: 13px;
    cursor: pointer;
    padding: 4px 8px;
    text-decoration: underline;
    transition: color 0.2s ease;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-clear:hover {
    color: var(--text);
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-clear[hidden] {
    display: none;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-items {
    margin: 0 -8px 16px;
    padding: 0 8px;
    list-style: none;
    flex: 0 0 auto;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-empty {
    padding: 32px 16px;
    text-align: center;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.5;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-empty svg {
    width: 40px;
    height: 40px;
    margin: 0 auto 12px;
    display: block;
    opacity: 0.4;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-item {
    display: grid;
    grid-template-columns: 40px 1fr auto;
    gap: 12px;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-item:last-child {
    border-bottom: none;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-item-img {
    width: 40px;
    height: 40px;
    border-radius: 6px;
    background: rgb(var(--text-primary) / 0.04);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-item-img img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-item-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
    margin: 0 0 2px;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-item-price {
    font-size: 12px;
    color: var(--muted);
    margin: 0;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-item-qty {
    font-size: 13px;
    color: var(--text);
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  /* ---------- Totals ---------- */
  #shopify-section-{{ section.id }} .bundle-builder .bb-totals {
    padding: 16px 0;
    border-top: 1px solid var(--border);
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 14px;
    margin-bottom: 8px;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-row:last-child {
    margin-bottom: 0;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-row--savings {
    color: var(--accent);
    font-weight: 600;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-row--savings[hidden] {
    display: none;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-savings-amount {
    background: var(--accent);
    color: var(--accent-text);
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 700;
  }

  /* ---------- Submit button ---------- */
  #shopify-section-{{ section.id }} .bundle-builder .bb-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    background: rgb(var(--button-background-primary));
    color: rgb(var(--button-text-primary));
    border: none;
    border-radius: var(--rounded-button);
    padding: 18px 24px;
    font-family: var(--heading-font-family);
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
    margin-top: 16px;
    letter-spacing: 0.01em;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-submit:hover:not(:disabled) {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-submit-loader {
    display: none;
    width: 16px;
    height: 16px;
    border: 2px solid currentColor;
    border-top-color: transparent;
    border-radius: 50%;
    animation: bb-spin 0.7s linear infinite;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-submit--loading .bb-submit-loader {
    display: inline-block;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-submit--loading .bb-submit-text {
    display: none;
  }

  @keyframes bb-spin {
    to { transform: rotate(360deg); }
  }

  /* ---------- Benefits row ---------- */
  #shopify-section-{{ section.id }} .bundle-builder .bb-benefits {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 16px;
    justify-content: center;
    margin-top: 12px;
    font-size: 12px;
    color: var(--muted);
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-benefit {
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-benefit svg {
    width: 13px;
    height: 13px;
    color: var(--accent);
  }

  /* ---------- Mobile bottom bar ---------- */
  #shopify-section-{{ section.id }} .bundle-builder .bb-mobile-bar {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--text);
    color: var(--bg);
    padding: 12px 18px;
    z-index: 100;
    box-shadow: 0 -8px 32px rgba(0,0,0,0.2);
    cursor: pointer;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-mobile-bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-mobile-bar-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-mobile-bar-count {
    background: var(--accent);
    color: var(--accent-text);
    font-size: 12px;
    font-weight: 700;
    min-width: 24px;
    height: 24px;
    padding: 0 7px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-mobile-bar-total {
    font-size: 14px;
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-mobile-bar-cta {
    background: var(--accent);
    color: var(--accent-text);
    padding: 10px 20px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 700;
    border: none;
    cursor: pointer;
  }

  /* ---------- Gifts (inside cart) ---------- */
  #shopify-section-{{ section.id }} .bundle-builder .bb-gifts {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-gifts-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 6px;
    gap: 8px;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-gifts-title {
    font-family: var(--heading-font-family);
    font-size: 13px;
    font-weight: 700;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 8px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--text);
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-gifts-count {
    background: var(--gift-badge);
    color: var(--text);
    font-size: 11px;
    font-weight: 800;
    min-width: 20px;
    height: 20px;
    padding: 0 6px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-gifts-progress {
    font-size: 12px;
    color: var(--muted);
    margin: 0 0 12px;
    line-height: 1.4;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-gifts-progress:empty {
    display: none;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-gifts-progress strong {
    color: var(--accent);
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-gifts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-gift {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 10px 12px;
    display: flex;
    flex-direction: column;
    gap: 3px;
    position: relative;
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    opacity: 0.5;
    filter: grayscale(0.6);
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-gift--unlocked {
    opacity: 1;
    filter: none;
    border-color: var(--accent);
    box-shadow: 0 4px 12px -6px rgba(0,0,0,0.15);
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-gift-badge {
    position: absolute;
    top: 6px;
    left: 6px;
    background: var(--gift-badge);
    color: var(--text);
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 2px 6px;
    border-radius: 4px;
    z-index: 2;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-gift-image {
    width: 100%;
    aspect-ratio: 1 / 1;
    background: rgb(var(--text-primary) / 0.04);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    margin-bottom: 6px;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-gift-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 6px;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-gift-placeholder {
    color: var(--muted);
    opacity: 0.4;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-gift-placeholder svg {
    width: 26px;
    height: 26px;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-gift-title {
    font-family: var(--heading-font-family);
    font-size: 12px;
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
    color: var(--text);
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-gift-orig {
    font-size: 11px;
    color: var(--muted);
    text-decoration: line-through;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-gift-condition {
    font-size: 11px;
    font-weight: 700;
    color: var(--muted);
    margin: 3px 0 0;
    letter-spacing: 0.02em;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-gift--unlocked .bb-gift-condition {
    color: var(--accent);
  }

  /* Gift line items in items-list (when unlocked, displays as FREE) */
  #shopify-section-{{ section.id }} .bundle-builder .bb-item--gift .bb-item-name::after {
    content: " · GAVE";
    color: var(--accent);
    font-weight: 800;
    font-size: 10px;
    letter-spacing: 0.08em;
  }

  #shopify-section-{{ section.id }} .bundle-builder .bb-item--gift .bb-item-qty span {
    color: var(--accent);
  }

  /* ---------- Mobile drawer overlay ---------- */
  #shopify-section-{{ section.id }} .bundle-builder .bb-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 200;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  #shopify-section-{{ section.id }} .bundle-builder.bb--drawer-open .bb-overlay {
    display: block;
    opacity: 1;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 1024px) {
    #shopify-section-{{ section.id }} .bundle-builder .bb-layout {
      grid-template-columns: 1fr !important;
    }

    #shopify-section-{{ section.id }} .bundle-builder .bb-cart {
      position: fixed;
      top: auto;
      bottom: 0;
      left: 0;
      right: 0;
      max-height: 85vh;
      overflow-y: auto;
      border-radius: 20px 20px 0 0;
      border: none;
      box-shadow: 0 -8px 32px rgba(0,0,0,0.18);
      transform: translateY(100%);
      transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
      z-index: 300;
      background: rgb(var(--dialog-background, var(--background-primary)));
    }

    #shopify-section-{{ section.id }} .bundle-builder.bb--drawer-open .bb-cart {
      transform: translateY(0);
    }

    #shopify-section-{{ section.id }} .bundle-builder .bb-cart-header {
      position: relative;
      gap: 8px;
    }

    #shopify-section-{{ section.id }} .bundle-builder .bb-cart-title {
      flex: 1;
      min-width: 0;
    }

    #shopify-section-{{ section.id }} .bundle-builder .bb-clear {
      flex-shrink: 0;
      padding: 6px 10px;
    }

    #shopify-section-{{ section.id }} .bundle-builder .bb-cart-close {
      display: flex;
      position: static;
      flex-shrink: 0;
      width: 36px;
      height: 36px;
      align-items: center;
      justify-content: center;
      background: var(--border);
      border-radius: 50%;
      border: none;
      cursor: pointer;
      color: var(--text);
    }

    #shopify-section-{{ section.id }} .bundle-builder .bb-cart-close svg {
      width: 16px;
      height: 16px;
    }

    #shopify-section-{{ section.id }} .bundle-builder .bb-mobile-bar {
      display: block;
    }

    #shopify-section-{{ section.id }} .bundle-builder .bb-mobile-bar[hidden] {
      display: none;
    }

    #shopify-section-{{ section.id }} .bundle-builder .bb-products {
      padding-bottom: 80px; /* space for bottom bar */
    }
  }

  @media (min-width: 1025px) {
    #shopify-section-{{ section.id }} .bundle-builder .bb-cart-close {
      display: none;
    }
  }

  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .bundle-builder {
      padding: var(--section-outer-spacing-block) 0;
    }
    #shopify-section-{{ section.id }} .bundle-builder .bb-inner {
      padding: 0 16px;
    }
    #shopify-section-{{ section.id }} .bundle-builder .bb-tiers {
      grid-template-columns: 1fr;
      gap: 8px;
      padding: 14px;
    }
    #shopify-section-{{ section.id }} .bundle-builder .bb-tier {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      padding: 12px 16px;
      gap: 12px;
    }
    #shopify-section-{{ section.id }} .bundle-builder .bb-tier-label {
      font-size: 14px;
    }
    #shopify-section-{{ section.id }} .bundle-builder .bb-products {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 10px !important;
    }
    #shopify-section-{{ section.id }} .bundle-builder .bb-product {
      padding: 10px;
      gap: 8px;
    }
    #shopify-section-{{ section.id }} .bundle-builder .bb-product-title {
      font-size: 13px;
    }
    #shopify-section-{{ section.id }} .bundle-builder .bb-qty-btn {
      width: 30px;
      height: 30px;
    }
    #shopify-section-{{ section.id }} .bundle-builder .bb-qty-value {
      font-size: 14px;
    }
  }
</style>

