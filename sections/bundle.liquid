<div {% render 'section-properties' %}>
  <div class="section-stack section-stack--center">
    
    {%- capture heading_content -%}
      {%- if section.settings.subheading != blank -%}
        <p class="subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h2 class="h2">{{ section.settings.title | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.content != blank -%}
        <div class="prose">{{ section.settings.content }}</div>
      {%- endif -%}
    {%- endcapture -%}

    {%- if heading_content != blank -%}
      <div class="section-stack__intro">
        <div class="prose text-center">
          {{ heading_content }}
        </div>
      </div>
    {%- endif -%}

    <div class="section-stack__main w-full">
      
      <div class="bundle-builder" data-bundle-builder="" id="bundle-builder-{{ section.id }}">
        
        {%- assign label_submit_default = section.settings.label_submit_default | default: "Vælg dine produkter" -%}
        {%- assign label_submit_with_total = section.settings.label_submit_with_total | default: "Til kassen • {total}" -%}
        {%- assign label_sold_out = section.settings.label_sold_out | default: "Udsolgt" -%}
        {%- assign label_error_generic = section.settings.label_error_generic | default: "Noget gik galt. Prøv igen." -%}

        <script type="application/json" data-bundle-config="">
          {
            "tiers": [
              {%- assign first_tier = true -%}
              {%- assign tier_blocks = section.blocks | where: 'type', 'tier' -%}
              {%- for block in tier_blocks -%}
                {%- unless first_tier -%},{%- endunless -%}
                {
                  "minQty": {{ block.settings.min_qty | default: 0 }},
                  "discount": {{ block.settings.discount | default: 0 }},
                  "code": {{ block.settings.code | json }},
                  "label": {{ block.settings.label | json }}
                }
                {%- assign first_tier = false -%}
              {%- endfor -%}
            ],
            "gifts": [
              {%- assign first_gift = true -%}
              {%- assign gift_blocks = section.blocks | where: 'type', 'gift' -%}
              {%- for block in gift_blocks -%}
                {%- assign gift_product = block.settings.product -%}
                {%- if gift_product != blank -%}
                  {%- assign gift_variant = gift_product.selected_or_first_available_variant -%}
                  {%- unless first_gift -%},{%- endunless -%}
                  {
                    "threshold": {{ block.settings.threshold | times: 100 }},
                    "variantId": {{ gift_variant.id }},
                    "title": {{ block.settings.title | default: gift_product.title | json }},
                    "image": {{ block.settings.image | default: gift_product.featured_image | image_url: width: 200 | json }}
                  }
                  {%- assign first_gift = false -%}
                {%- endif -%}
              {%- endfor -%}
            ],
            "giftBasis": {{ section.settings.gift_basis | json }},
            "currency": {{ cart.currency.iso_code | json }},
            "locale": {{ request.locale.iso_code | json }},
            "maxItems": {{ section.settings.max_items | default: 50 }},
            "checkoutBehavior": {{ section.settings.checkout_behavior | json }},
            "labels": {
              "submitDefault": {{ label_submit_default | json }},
              "submitWithTotal": {{ label_submit_with_total | json }},
              "soldOut": {{ label_sold_out | json }},
              "errorGeneric": {{ label_error_generic | json }}
            }
          }
        </script>

        <div class="bb-inner">
          
          {%- comment -%} Discount Tier Strip {%- endcomment -%}
          {%- if tier_blocks.size > 0 -%}
            <div class="bb-tiers" data-tier-strip="">
              {%- for block in tier_blocks -%}
                <div class="bb-tier" data-tier="" data-tier-min="{{ block.settings.min_qty }}">
                  <span class="bb-tier-status" data-tier-status="">
                    <svg data-tier-icon-locked="" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
