<script>
(function() {
  'use strict';

  class HorizonBundleBuilder {
    constructor(root) {
      this.root = root;
      this.config = JSON.parse(root.querySelector('[data-bundle-config]').textContent);
      this.storageKey = 'horizon-bundle-' + root.id;

      this.state = { items: {} };
      this.elements = this.cacheElements();

      this.loadFromStorage();
      this.bindEvents();
      this.render();
    }

    cacheElements() {
      return {
        productCards: this.root.querySelectorAll('[data-product-card]'),
        tierStrip: this.root.querySelector('[data-tier-strip]'),
        tiers: this.root.querySelectorAll('[data-tier]'),
        cart: this.root.querySelector('[data-bundle-cart]'),
        items: this.root.querySelector('[data-bundle-items]'),
        empty: this.root.querySelector('[data-bundle-empty]'),
        count: this.root.querySelector('[data-bundle-count]'),
        clear: this.root.querySelector('[data-bundle-clear]'),
        subtotal: this.root.querySelector('[data-subtotal]'),
        savingsRow: this.root.querySelector('[data-savings-row]'),
        savings: this.root.querySelector('[data-savings]'),
        total: this.root.querySelector('[data-total]'),
        submit: this.root.querySelector('[data-bundle-submit]'),
        submitText: this.root.querySelector('[data-submit-text]'),
        mobileBar: this.root.querySelector('[data-mobile-bar]'),
        mobileCount: this.root.querySelector('[data-mobile-count]'),
        mobileTotal: this.root.querySelector('[data-mobile-total]'),
        cartClose: this.root.querySelector('[data-cart-close]'),
        overlay: this.root.querySelector('[data-cart-overlay]'),
        gifts: this.root.querySelectorAll('[data-gift]'),
        giftsCount: this.root.querySelector('[data-gifts-count]'),
        giftsProgress: this.root.querySelector('[data-gifts-progress]')
      };
    }

    bindEvents() {
      this.elements.productCards.forEach(card => {
        const inc = card.querySelector('[data-increment]');
        const dec = card.querySelector('[data-decrement]');
        if (inc) inc.addEventListener('click', () => this.increment(card));
        if (dec) dec.addEventListener('click', () => this.decrement(card));
      });

      if (this.elements.clear) {
        this.elements.clear.addEventListener('click', () => this.clear());
      }
      if (this.elements.submit) {
        this.elements.submit.addEventListener('click', () => this.submit());
      }
      if (this.elements.mobileBar) {
        this.elements.mobileBar.addEventListener('click', () => this.openDrawer());
      }
      if (this.elements.cartClose) {
        this.elements.cartClose.addEventListener('click', () => this.closeDrawer());
      }
      if (this.elements.overlay) {
        this.elements.overlay.addEventListener('click', () => this.closeDrawer());
      }
    }

    increment(card) {
      const variantId = card.dataset.variantId;
      if (this.getTotalQty() >= this.config.maxItems) {
        return;
      }
      if (!this.state.items[variantId]) {
        this.state.items[variantId] = {
          qty: 0,
          title: card.dataset.productTitle,
          image: card.dataset.productImage,
          price: parseInt(card.dataset.productPrice, 10),
          url: card.dataset.productUrl
        };
      }
      this.state.items[variantId].qty++;
      this.persist();
      this.render();
    }

    decrement(card) {
      const variantId = card.dataset.variantId;
      if (!this.state.items[variantId]) return;
      this.state.items[variantId].qty--;
      if (this.state.items[variantId].qty <= 0) {
        delete this.state.items[variantId];
      }
      this.persist();
      this.render();
    }

    clear() {
      this.state.items = {};
      this.persist();
      this.render();
    }

    getTotalQty() {
      return Object.values(this.state.items).reduce((sum, i) => sum + i.qty, 0);
    }

    getSubtotal() {
      return Object.values(this.state.items).reduce((sum, i) => sum + (i.qty * i.price), 0);
    }

    getActiveTier() {
      const qty = this.getTotalQty();
      const eligible = this.config.tiers.filter(t => qty >= t.minQty);
      if (!eligible.length) return null;
      return eligible.reduce((max, t) => t.minQty > max.minQty ? t : max, eligible[0]);
    }

    getDiscountAmount() {
      const tier = this.getActiveTier();
      if (!tier) return 0;
      return Math.round(this.getSubtotal() * tier.discount / 100);
    }

    getFinalTotal() {
      return this.getSubtotal() - this.getDiscountAmount();
    }

    getGiftBasis() {
      return this.config.giftBasis === 'final' ? this.getFinalTotal() : this.getSubtotal();
    }

    getUnlockedGifts() {
      if (!this.config.gifts || !this.config.gifts.length) return [];
      const basis = this.getGiftBasis();
      return this.config.gifts.filter(g => basis >= g.threshold);
    }

    getNextLockedGift() {
      if (!this.config.gifts || !this.config.gifts.length) return null;
      const basis = this.getGiftBasis();
      const locked = this.config.gifts.filter(g => basis < g.threshold);
      if (!locked.length) return null;
      return locked.reduce((min, g) => g.threshold < min.threshold ? g : min, locked[0]);
    }

    formatMoney(cents) {
      try {
        return (cents / 100).toLocaleString(this.config.locale, {
          style: 'currency',
          currency: this.config.currency,
          minimumFractionDigits: 2
        });
      } catch (e) {
        return (cents / 100).toFixed(2) + ' ' + this.config.currency;
      }
    }

    render() {
      const totalQty = this.getTotalQty();
      const subtotal = this.getSubtotal();
      const discount = this.getDiscountAmount();
      const total = this.getFinalTotal();

      // Product cards
      this.elements.productCards.forEach(card => {
        const variantId = card.dataset.variantId;
        const item = this.state.items[variantId];
        const qty = item ? item.qty : 0;
        const display = card.querySelector('[data-qty-display]');
        const dec = card.querySelector('[data-decrement]');
        if (display) display.textContent = qty;
        if (dec) dec.disabled = qty === 0;
        card.classList.toggle('bb-product--active', qty > 0);
        const inc = card.querySelector('[data-increment]');
        if (inc) inc.disabled = totalQty >= this.config.maxItems;
      });

      // Tier strip
      this.elements.tiers.forEach(tierEl => {
        const min = parseInt(tierEl.dataset.tierMin, 10);
        const applied = totalQty >= min;
        tierEl.classList.toggle('bb-tier--applied', applied);
        const lockedIcon = tierEl.querySelector('[data-tier-icon-locked]');
        const appliedIcon = tierEl.querySelector('[data-tier-icon-applied]');
        const statusText = tierEl.querySelector('[data-tier-status-text]');
        if (lockedIcon) lockedIcon.style.display = applied ? 'none' : '';
        if (appliedIcon) appliedIcon.style.display = applied ? '' : 'none';
        if (statusText) statusText.textContent = applied ? 'Aktiveret' : 'Køb ' + min + '+';
      });

      // Cart count
      this.elements.count.textContent = totalQty;
      if (this.elements.mobileCount) this.elements.mobileCount.textContent = totalQty;

      // Clear button
      if (this.elements.clear) this.elements.clear.hidden = totalQty === 0;

      // Items list
      this.renderItems();

      // Totals
      this.elements.subtotal.textContent = this.formatMoney(subtotal);
      this.elements.total.textContent = this.formatMoney(total);
      if (this.elements.mobileTotal) this.elements.mobileTotal.textContent = this.formatMoney(total);

      if (discount > 0) {
        this.elements.savingsRow.hidden = false;
        this.elements.savings.textContent = '−' + this.formatMoney(discount);
      } else {
        this.elements.savingsRow.hidden = true;
      }

      // Submit button
      this.elements.submit.disabled = totalQty === 0;
      if (totalQty === 0) {
        this.elements.submitText.textContent = this.config.labels.submitDefault;
      } else {
        this.elements.submitText.textContent =
          this.config.labels.submitWithTotal.replace('{total}', this.formatMoney(total));
      }

      // Mobile bar visibility
      if (this.elements.mobileBar) {
        this.elements.mobileBar.hidden = totalQty === 0;
      }

      // Show cart close button on mobile when items exist
      if (this.elements.cartClose) {
        if (window.matchMedia('(max-width: 1024px)').matches) {
          this.elements.cartClose.style.display = 'flex';
        }
      }

      // Gifts strip
      this.renderGifts();
    }

    renderGifts() {
      if (!this.elements.gifts || !this.elements.gifts.length) return;

      const basis = this.getGiftBasis();
      const unlocked = this.getUnlockedGifts();

      this.elements.gifts.forEach(giftEl => {
        const threshold = parseInt(giftEl.dataset.giftThreshold, 10);
        giftEl.classList.toggle('bb-gift--unlocked', basis >= threshold);
      });

      if (this.elements.giftsCount) {
        this.elements.giftsCount.textContent = unlocked.length;
      }

      if (this.elements.giftsProgress) {
        const next = this.getNextLockedGift();
        if (next) {
          const remaining = next.threshold - basis;
          this.elements.giftsProgress.innerHTML =
            'Tilføj for <strong>' + this.formatMoney(remaining) + '</strong> til næste gave';
        } else if (unlocked.length > 0) {
          this.elements.giftsProgress.innerHTML = '🎉 <strong>Alle gaver låst op!</strong>';
        } else {
          this.elements.giftsProgress.textContent = '';
        }
      }
    }

    renderItems() {
      const items = Object.entries(this.state.items);
      const unlockedGifts = this.getUnlockedGifts();

      if (items.length === 0 && unlockedGifts.length === 0) {
        // Show empty state
        this.elements.items.innerHTML = '';
        this.elements.items.appendChild(this.elements.empty);
        return;
      }

      const itemsHtml = items.map(([variantId, item]) => {
        const lineTotal = this.formatMoney(item.qty * item.price);
        const safeTitle = item.title.replace(/</g, '&lt;');
        return (
          '<li class="bb-item">' +
            '<div class="bb-item-img">' +
              (item.image ? '<img src="' + item.image + '" alt="" loading="lazy">' : '') +
            '</div>' +
            '<div>' +
              '<p class="bb-item-name">' + safeTitle + '</p>' +
              '<p class="bb-item-price">' + this.formatMoney(item.price) + ' / stk</p>' +
            '</div>' +
            '<div class="bb-item-qty">' + item.qty + '× <span>' + lineTotal + '</span></div>' +
          '</li>'
        );
      }).join('');

      const giftsHtml = unlockedGifts.map(gift => {
        const safeTitle = (gift.title || '').replace(/</g, '&lt;');
        return (
          '<li class="bb-item bb-item--gift">' +
            '<div class="bb-item-img">' +
              (gift.image ? '<img src="' + gift.image + '" alt="" loading="lazy">' : '') +
            '</div>' +
            '<div>' +
              '<p class="bb-item-name">' + safeTitle + '</p>' +
              '<p class="bb-item-price">Gratis bonus</p>' +
            '</div>' +
            '<div class="bb-item-qty">1× <span>GRATIS</span></div>' +
          '</li>'
        );
      }).join('');

      this.elements.items.innerHTML = itemsHtml + giftsHtml;
    }

    persist() {
      try {
        localStorage.setItem(this.storageKey, JSON.stringify(this.state));
      } catch (e) {}
    }

    loadFromStorage() {
      try {
        const raw = localStorage.getItem(this.storageKey);
        if (raw) {
          const parsed = JSON.parse(raw);
          if (parsed && typeof parsed === 'object' && parsed.items) {
            this.state = parsed;
          }
        }
      } catch (e) {}
    }

    openDrawer() {
      this.root.classList.add('bb--drawer-open');
      document.body.style.overflow = 'hidden';
    }

    closeDrawer() {
      this.root.classList.remove('bb--drawer-open');
      document.body.style.overflow = '';
    }

    async submit() {
      const items = Object.entries(this.state.items).map(([variantId, item]) => ({
        id: parseInt(variantId, 10),
        quantity: item.qty
      }));

      if (items.length === 0) return;

      // Add unlocked gifts to checkout payload
      const unlockedGifts = this.getUnlockedGifts();
      unlockedGifts.forEach(gift => {
        items.push({
          id: gift.variantId,
          quantity: 1,
          properties: { '_gift': 'true' }
        });
      });

      const btn = this.elements.submit;
      btn.classList.add('bb-submit--loading');
      btn.disabled = true;

      try {
        const res = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ items: items })
        });

        if (!res.ok) {
          const errData = await res.json().catch(() => ({}));
          throw new Error(errData.description || 'Cart add failed');
        }

        // Clear local storage state
        this.state.items = {};
        this.persist();

        // Determine redirect destination
        const tier = this.getActiveTier();
        const destination = this.config.checkoutBehavior === 'checkout' ? '/checkout' : '/cart';

        if (tier && tier.code) {
          window.location.href = '/discount/' + encodeURIComponent(tier.code) + '?redirect=' + destination;
        } else {
          window.location.href = destination;
        }
      } catch (err) {
        console.error('[Horizon Bundle Builder]', err);
        btn.classList.remove('bb-submit--loading');
        btn.disabled = false;
        alert(this.config.labels.errorGeneric);
      }
    }
  }

  function initAll() {
    document.querySelectorAll('[data-bundle-builder]').forEach(el => {
      if (!el.dataset.bbInitialized) {
        new HorizonBundleBuilder(el);
        el.dataset.bbInitialized = '1';
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAll);
  } else {
    initAll();
  }

  // Support section loading inside theme editor
  document.addEventListener('shopify:section:load', function(e) {
    if (e.target.querySelector('[data-bundle-builder]')) initAll();
  });
})();
</script>

