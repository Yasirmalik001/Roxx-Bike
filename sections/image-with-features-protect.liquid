{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .app-section {
    overflow: hidden;
    background-color: #ffffff; /* Clean white background */
  }

  /* --- HEADER (TOP) --- */
  .app-header-wrap {
    text-align: center;
    margin-bottom: 5rem;
    padding: 0 2rem;
  }

  .app-heading {
    margin: 0 0 1.5rem 0;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    font-size: clamp(2.8rem, 4vw, 4rem);
    line-height: 1.1;
    color: #111111;
  }

  .app-subtitle {
    font-size: 1.4rem;
    line-height: 1.6;
    color: #444444;
    max-width: 650px;
    margin: 0 auto;
  }

  /* --- MAIN GRID --- */
  .app-grid {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  @media screen and (min-width: 990px) {
    .app-grid {
      flex-direction: row;
      align-items: center;
      gap: 6rem;
    }
    .app-visual-col, .app-content-col {
      width: 50%;
    }
  }

  /* --- VISUAL COLUMN (LEFT) --- */
  .app-visual-col {
    display: flex;
    justify-content: center;
    align-items: center; 
  }

  .app-main-image {
    width: 100%;
    max-width: 600px;
    height: auto;
    object-fit: contain;
    display: block;
  }

  /* --- CONTENT COLUMN (RIGHT / CARD) --- */
  .app-content-col {
    display: flex;
    justify-content: center;
  }

  .app-features-card {
    background: #ffffff;
    border-radius: 24px;
    padding: 5rem 4rem;
    box-shadow: 0 10px 40px rgba(0,0,0,0.04);
    width: 100%;
    max-width: 500px;
  }

  .app-features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 5rem 2rem;
  }

  .app-feature-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
  }

  .app-feature-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background-color: #d1d5db; /* Grey placeholder circle matching the image */
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .app-feature-icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .app-feature-title {
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 1.4;
    color: #333333;
    max-width: 140px;
  }

  @media screen and (max-width: 480px) {
    .app-features-card {
      padding: 3rem 2rem;
    }
    .app-features-grid {
      gap: 4rem 1.5rem;
    }
  }
{%- endstyle -%}

<div class="app-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding" {{ section.shopify_attributes }}>
  <div class="page-width">
    
    <!-- Top Header Area -->
    <div class="app-header-wrap">
      {%- if section.settings.title != blank -%}
        <h2 class="app-heading">{{ section.settings.title | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="app-subtitle rte">
          {{ section.settings.text }}
        </div>
      {%- endif -%}
    </div>

    <!-- Main Grid (Image Left, Card Right) -->
    <div class="app-grid">
      
      <!-- Visual Column -->
      <div class="app-visual-col">
        {%- if section.settings.main_image != blank -%}
          {{ section.settings.main_image | image_url: width: 1200 | image_tag: class: 'app-main-image', loading: 'lazy' }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'app-main-image placeholder-svg' }}
        {%- endif -%}
      </div>

      <!-- Content Column (Features Card) -->
      <div class="app-content-col">
        <div class="app-features-card">
          {%- if section.blocks.size > 0 -%}
            <div class="app-features-grid">
              {%- for block in section.blocks -%}
                <div class="app-feature-block" {{ block.shopify_attributes }}>
                  <div class="app-feature-icon">
                    {%- if block.settings.icon_image != blank -%}
                      {{ block.settings.icon_image | image_url: width: 120 | image_tag: loading: 'lazy' }}
                    {%- endif -%}
                  </div>
                  {%- if block.settings.title != blank -%}
                    <span class="app-feature-title">{{ block.settings.title | escape }}</span>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>
      
    </div>
  </div>
</div>

{% schema %}
{
  "name": "App Features Intro",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Header Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "INTRODUCING OUR ALL IN ONE APP"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Subtitle text",
      "default": "<p>The Roxx JX electric bike works with an app specifically designed for this model and an advanced all-in-one system.</p>"
    },
    {
      "type": "header",
      "content": "Main Visual"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Image (Bike + Phones)"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Block",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Upload Icon",
          "info": "Leaves a grey circle if empty, matching the design."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Feature Text",
          "default": "Feature Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "App Features Intro",
      "blocks": [
        { "type": "feature", "settings": { "title": "4G remote communication" } },
        { "type": "feature", "settings": { "title": "Cycling track" } },
        { "type": "feature", "settings": { "title": "Bluetooth near field communication" } },
        { "type": "feature", "settings": { "title": "Multiple alarm modes" } },
        { "type": "feature", "settings": { "title": "Multiple unlocking methods" } },
        { "type": "feature", "settings": { "title": "Geo-fence" } }
      ]
    }
  ]
}
{% endschema %}