{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .vt-gallery-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3rem;
    gap: 2rem;
  }

  .vt-gallery-rating-wrapper {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.6rem;
    padding-bottom: 0.5rem;
  }

  .vt-gallery-stars {
    display: flex;
    gap: 2px;
  }

  .vt-gallery-star-box {
    background-color: #00b67a;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 1px;
  }

  .vt-gallery-star-box svg {
    width: 12px;
    height: 12px;
    fill: #ffffff;
  }

  .vt-gallery-rating-text {
    font-size: 1.2rem;
    font-weight: 500;
    color: rgb(var(--color-foreground));
    white-space: nowrap;
  }

  /* Slider/Grid Wrapper */
  .vt-gallery-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    gap: {{ section.settings.column_gap }}rem;
  }

  @media screen and (max-width: 749px) {
    .vt-gallery-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .vt-gallery-rating-wrapper {
      align-items: flex-start;
    }
    
    .vt-gallery-grid {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      padding-left: 1.5rem;
      padding-right: 1.5rem;
      margin-left: -1.5rem;
      margin-right: -1.5rem;
      gap: 1.5rem;
    }

    .vt-gallery-grid::-webkit-scrollbar {
      display: none;
    }

    .vt-gallery-item {
      flex: 0 0 75%;
      scroll-snap-align: start;
    }
  }

  /* Card and Height Styling */
  .vt-gallery-item {
    position: relative;
    border-radius: {{ section.settings.card_corner_radius }}px;
    overflow: hidden;
    background-color: rgba(var(--color-foreground), 0.05);
  }

  .vt-gallery-media-wrap {
    position: relative;
    width: 100%;
    display: block;
    height: {{ section.settings.card_height_desktop }}px;
    cursor: pointer; /* Indicates it can be clicked */
  }

  @media screen and (max-width: 749px) {
    .vt-gallery-media-wrap {
      height: {{ section.settings.card_height_mobile }}px;
    }
  }

  .vt-gallery-media-wrap img,
  .vt-gallery-media-wrap video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Play Button Overlay */
  .vt-gallery-play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    border: none;
    z-index: 3;
    transition: opacity 0.3s ease, transform 0.2s ease;
    background: #FFFFFF54;
    pointer-events: none; /* Lets clicks pass through to the wrapper */
  }

  /* Hide button state */
  .vt-gallery-play-btn.is-hidden {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.9);
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    
    <div class="vt-gallery-header">
      {%- if section.settings.title != blank -%}
        <h2 class="{{ section.settings.heading_size }}">{{ section.settings.title | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.show_rating -%}
        <div class="vt-gallery-rating-wrapper">
          <div class="vt-gallery-stars">
            {%- for i in (1..5) -%}
              <div class="vt-gallery-star-box">
                <svg viewBox="0 0 24 24">
                  <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                </svg>
              </div>
            {%- endfor -%}
          </div>
          <span class="vt-gallery-rating-text">{{ section.settings.rating_text | escape }}</span>
        </div>
      {%- endif -%}
    </div>

    <div class="vt-gallery-grid">
      {%- for block in section.blocks -%}
        <div class="vt-gallery-item" {{ block.shopify_attributes }}>
          <div class="vt-gallery-media-wrap">
            
            {%- if block.settings.video != blank -%}
              {{ block.settings.video | video_tag: image_size: '800s', autoplay: false, loop: true, controls: false, preload: 'metadata' }}
              
              <button type="button" class="vt-gallery-play-btn" aria-label="Play video">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="20" viewBox="0 0 18 20" fill="none">
                  <path d="M16.0002 6.51413C18.5988 8.06616 18.5988 11.8303 16.0002 13.3824L6.05105 19.3246C3.38483 20.917 9.00512e-07 18.996 1.03054e-06 15.8905L1.52812e-06 4.00602C1.65814e-06 0.90045 3.38483 -1.02052 6.05106 0.571909L16.0002 6.51413Z" fill="white"/>
                </svg>
              </button>

            {%- elsif block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}

          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Select all the media wrappers inside this section
    const wrappers = document.querySelectorAll('.vt-gallery-media-wrap');
    
    wrappers.forEach(wrap => {
      const video = wrap.querySelector('video');
      const playBtn = wrap.querySelector('.vt-gallery-play-btn');
      
      // If the block has a video, add the click functionality
      if (video && playBtn) {
        wrap.addEventListener('click', function() {
          if (video.paused) {
            video.play();
            playBtn.classList.add('is-hidden');
          } else {
            video.pause();
            playBtn.classList.remove('is-hidden');
          }
        });
      }
    });
  });
</script>

{% schema %}
{
  "name": "Video Review Gallery",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Trusted by thousands of riders"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h0", "label": "t:sections.all.heading_size.options__3.label" }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "header",
      "content": "Ratings Settings"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show Rating Text & Stars",
      "default": true
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating label text",
      "default": "4.4 / 5 (based on 200+)"
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "label": "Number of columns on desktop",
      "default": 4
    },
    {
      "type": "range",
      "id": "column_gap",
      "min": 1,
      "max": 5,
      "step": 0.5,
      "unit": "rem",
      "label": "Desktop Gap size",
      "default": 2.5
    },
    {
      "type": "range",
      "id": "card_height_desktop",
      "min": 200,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "Desktop Card Height",
      "default": 550
    },
    {
      "type": "range",
      "id": "card_height_mobile",
      "min": 200,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "Mobile Card Height",
      "default": 450
    },
    {
      "type": "range",
      "id": "card_corner_radius",
      "min": 0,
      "max": 32,
      "step": 4,
      "unit": "px",
      "label": "Card Corner Radius",
      "default": 16
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "video_item",
      "name": "Video / Image Card",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Card Native Video"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Fallback Cover Image",
          "info": "Used if no native video is uploaded."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Review Gallery",
      "blocks": [
        { "type": "video_item" },
        { "type": "video_item" },
        { "type": "video_item" },
        { "type": "video_item" }
      ]
    }
  ]
}
{% endschema %}