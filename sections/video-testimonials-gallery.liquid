{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .vt-gallery-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3rem;
    gap: 2rem;
  }

  .vt-gallery-heading {
    margin: 0;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .vt-gallery-rating {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-size: 1.3rem;
    font-weight: 600;
    color: rgb(var(--color-foreground));
    white-space: nowrap;
    padding-bottom: 0.5rem;
  }

  .vt-gallery-stars {
    display: flex;
    gap: 0.2rem;
    color: #00b67a; /* Trustpilot green or customize */
  }

  .vt-gallery-stars svg {
    width: 14px;
    height: 14px;
    fill: currentColor;
  }

  /* Slider/Grid Wrapper */
  .vt-gallery-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    gap: {{ section.settings.column_gap }}rem;
  }

  /* Responsive Mobile Layout mimicking image_0ac10a.jpg */
  @media screen and (max-width: 749px) {
    .vt-gallery-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
      margin-bottom: 2rem;
    }
    
    .vt-gallery-grid {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      padding-left: 1.5rem;
      padding-right: 1.5rem;
      margin-left: -1.5rem;
      margin-right: -1.5rem;
      gap: 1.5rem;
    }

    .vt-gallery-grid::-webkit-scrollbar {
      display: none;
    }

    .vt-gallery-item {
      flex: 0 0 75%; /* Allows the next item to peak through on mobile */
      scroll-snap-align: start;
    }
  }

  /* Card and Aspect Ratio Styling */
  .vt-gallery-item {
    position: relative;
    border-radius: {{ section.settings.card_corner_radius }}px;
    overflow: hidden;
    background-color: rgba(var(--color-foreground), 0.05);
  }

  .vt-gallery-media-wrap {
    position: relative;
    width: 100%;
    display: block;
    /* Aspect Ratio handling */
    aspect-ratio: {{ section.settings.aspect_ratio_desktop }};
  }

  @media screen and (max-width: 749px) {
    .vt-gallery-media-wrap {
      aspect-ratio: {{ section.settings.aspect_ratio_mobile }};
    }
  }

  .vt-gallery-media-wrap img,
  .vt-gallery-media-wrap video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Play Button Overlay */
  .vt-gallery-play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 54px;
    height: 54px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.25);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    border: none;
    cursor: pointer;
    z-index: 3;
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .vt-gallery-item:hover .vt-gallery-play-btn {
    transform: translate(-50%, -50%) scale(1.1);
    background-color: rgba(255, 255, 255, 0.4);
  }

  .vt-gallery-play-btn svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
    margin-left: 2px; /* Visual centering adjustment for play triangle */
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    
    <!-- Top Header Bar -->
    <div class="vt-gallery-header">
      {%- if section.settings.title != blank -%}
        <h2 class="vt-gallery-heading {{ section.settings.heading_size }}">{{ section.settings.title | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.show_rating -%}
        <div class="vt-gallery-rating">
          <span>{{ section.settings.rating_text | escape }}</span>
          <div class="vt-gallery-stars">
            {%- for i in (1..5) -%}
              <svg viewBox="0 0 24 24">
                <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
              </svg>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    </div>

    <!-- Video Grid Components -->
    <div class="vt-gallery-grid">
      {%- for block in section.blocks -%}
        <div class="vt-gallery-item" {{ block.shopify_attributes }}>
          <div class="vt-gallery-media-wrap">
            
            {%- if block.settings.video != blank -%}
              {{ block.settings.video | video_tag: image_size: '800s', autoplay: false, loop: true, controls: false, preload: 'metadata' }}
            {%- elsif block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}

            <button type="button" class="vt-gallery-play-btn" aria-label="Play video">
              <svg viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </button>

          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Video Review Gallery",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Trusted by thousands of riders"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h0", "label": "t:sections.all.heading_size.options__3.label" }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "header",
      "content": "Ratings Settings"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show Rating Text & Stars",
      "default": true
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating label text",
      "default": "4.4 / 5 (based on 200+)"
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "label": "Number of columns on desktop",
      "default": 4
    },
    {
      "type": "range",
      "id": "column_gap",
      "min": 1,
      "max": 5,
      "step": 0.5,
      "unit": "rem",
      "label": "Desktop Gap size",
      "default": 2.5
    },
    {
      "type": "text",
      "id": "aspect_ratio_desktop",
      "label": "Desktop Aspect Ratio",
      "default": "1 / 1.3",
      "info": "Width / Height format. Use '1 / 1.3' for portrait cards shown in image_0ac108.png"
    },
    {
      "type": "text",
      "id": "aspect_ratio_mobile",
      "label": "Mobile Aspect Ratio",
      "default": "1 / 1.3",
      "info": "Width / Height format."
    },
    {
      "type": "range",
      "id": "card_corner_radius",
      "min": 0,
      "max": 32,
      "step": 4,
      "unit": "px",
      "label": "Card Corner Radius",
      "default": 16
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "video_item",
      "name": "Video / Image Card",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Card Native Video"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Fallback Cover Image",
          "info": "Used if no native video is uploaded."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Review Gallery",
      "blocks": [
        { "type": "video_item" },
        { "type": "video_item" },
        { "type": "video_item" },
        { "type": "video_item" }
      ]
    }
  ]
}
{% endschema %}