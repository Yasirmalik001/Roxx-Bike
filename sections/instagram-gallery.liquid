{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .roxx-masonry-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .roxx-masonry-heading {
    font-family: inherit;
    font-size: clamp(24px, 4vw, 32px);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.5px;
    margin: 0 0 0.5rem 0;
    color: #000;
  }

  .roxx-masonry-subheading {
    font-size: clamp(13px, 1.5vw, 15px);
    font-weight: 500;
    color: #333;
    margin: 0;
  }

  /* CSS Multi-column layout for native Masonry */
  .roxx-masonry-grid {
    column-count: 2;
    column-gap: 16px;
    width: 100%;
  }

  @media screen and (min-width: 768px) {
    .roxx-masonry-grid {
      column-count: 3;
    }
  }

  @media screen and (min-width: 1024px) {
    .roxx-masonry-grid {
      column-count: 5;
      column-gap: 20px;
    }
  }

  .roxx-masonry-item {
    break-inside: avoid; /* Prevents images from splitting across columns */
    margin-bottom: 16px;
    border-radius: 16px;
    overflow: hidden;
    transform: translateZ(0); /* Forces hardware acceleration for crisp borders */
  }

  @media screen and (min-width: 1024px) {
    .roxx-masonry-item {
      margin-bottom: 20px;
    }
  }

  .roxx-masonry-image {
    width: 100%;
    display: block;
    border-radius: 16px;
    object-fit: cover;
    height: auto;
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  <div class="roxx-masonry-wrapper">
    <div class="roxx-masonry-header">
      {%- if section.settings.heading != blank -%}
        <h2 class="roxx-masonry-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="roxx-masonry-subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="roxx-masonry-grid">
      {%- for block in section.blocks -%}
        <div class="roxx-masonry-item" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 800 }}"
              alt="{{ block.settings.image.alt | escape }}"
              class="roxx-masonry-image"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'roxx-masonry-image placeholder-svg' }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Masonry Gallery",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "JOIN OUR ROXX FAMILY"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "with thousands who've upgraded their everyday ride."
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Masonry Gallery",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}