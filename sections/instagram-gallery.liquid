                        {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
                      {%- endif -%}

                      {%- if block.settings.show_comment -%}
                        <button type="button" class="comment-hotspot-pill" data-popup-id="Popup-{{ block.id }}-{{ i }}" style="position: absolute; top: {{ block.settings.hotspot_y }}%; left: {{ block.settings.hotspot_x }}%;">
                          <span class="comment-hotspot-avatar comment-hotspot-avatar--1">J</span>
                          <span class="comment-hotspot-avatar comment-hotspot-avatar--2">
                            {%- if block.settings.reply_avatar != blank -%}
                              <img src="{{ block.settings.reply_avatar | image_url: width: 40 }}" alt="">
                            {%- else -%}
                              L
                            {%- endif -%}
                          </span>
                        </button>
                        
                        <div class="comment-popup-box" id="Popup-{{ block.id }}-{{ i }}" style="display: none;">
                          <div class="comment-popup-header">
                            <span class="comment-popup-title">Comment</span>
                            <div class="comment-popup-header-actions">
                              <button type="button" class="comment-popup-more" aria-label="More options">
                                <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M6 10c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm12 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm-6 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/></svg>
                              </button>
                              <button type="button" class="comment-popup-close" aria-label="Close comments">
                                <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none"><path d="M18 6L6 18M6 6l12 12"/></svg>
                              </button>
                            </div>
                          </div>
                          <div class="comment-popup-body">
                            <div class="comment-row">
                              <div class="comment-avatar">J</div>
                              <div class="comment-content-wrap">
                                <div class="comment-meta">
                                  <span class="comment-author">{{ block.settings.comment_author_1 | default: 'jay' }}</span>
                                  <span class="comment-time">{{ block.settings.comment_time_1 | default: '12 days ago' }}</span>
                                </div>
                                <div class="comment-text">{{ block.settings.comment_text_1 | default: 'You make it adjustable?' }}</div>
                              </div>
                            </div>
                            {%- if block.settings.comment_text_2 != blank -%}
                              <div class="comment-row comment-row--reply">
                                <div class="comment-avatar">
                                  {%- if block.settings.reply_avatar != blank -%}
                                    <img src="{{ block.settings.reply_avatar | image_url: width: 40 }}" alt="">
                                  {%- else -%}
                                    L
                                  {%- endif -%}
                                </div>
                                <div class="comment-content-wrap">
                                  <div class="comment-meta">
                                    <span class="comment-author">{{ block.settings.comment_author_2 | default: 'Lucineh' }}</span>
                                    <span class="comment-time">{{ block.settings.comment_time_2 | default: '12 days ago' }}</span>
                                  </div>
                                  <div class="comment-text">
                                    {%- if block.settings.comment_text_2 contains 'jay' -%}
                                      {{ block.settings.comment_text_2 | replace: 'jay', '<span class="comment-mention">jay</span>' }}
                                    {%- else -%}
                                      {{ block.settings.comment_text_2 }}
                                    {%- endif -%}
                                  </div>
                                </div>
                              </div>
                            {%- endif -%}
                          </div>
                          <div class="comment-popup-footer">
                            <div class="comment-footer-avatar">Y</div>
