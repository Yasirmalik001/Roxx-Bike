{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.background_color }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .scrolling-gallery__header {
    text-align: center;
    margin-bottom: 5rem;
  }

  .scrolling-gallery__heading {
    margin: 0 0 1rem 0;
    font-weight: 800;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: #000000;
  }

  .scrolling-gallery__description {
    font-size: 1.5rem;
    color: #555555;
    margin: 0;
  }

  /* Horizontal Scrolling Flex Layout */
  .scrolling-gallery__grid {
    display: flex;
    gap: 1.5rem;
    width: 100%;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE/Edge */
    padding-bottom: 1rem;
    
    /* Creates the fade effect on the left and right edges */
    -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
    mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
  }

  .scrolling-gallery__grid::-webkit-scrollbar {
    display: none; /* Hide scrollbar for Chrome, Safari and Opera */
  }

  @media screen and (min-width: 750px) {
    .scrolling-gallery__grid {
      gap: 2rem;
    }
  }

  .scrolling-gallery__item {
    flex: 0 0 auto;
    width: 70vw; /* Mobile width */
    aspect-ratio: 1 / 1; /* Forces the 1:1 square ratio */
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    scroll-snap-align: center;
    transform: translateZ(0); 
  }

  @media screen and (min-width: 750px) {
    .scrolling-gallery__item {
      width: 35vw;
    }
  }

  @media screen and (min-width: 990px) {
    .scrolling-gallery__item {
      width: 22vw; /* Adjust width to show partial next/prev slides */
    }
  }

  .scrolling-gallery__image-wrapper {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
  }

  .scrolling-gallery__image-wrapper img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  /* Hover Effect */
  .scrolling-gallery__item:hover .scrolling-gallery__image-wrapper img {
    transform: scale(1.03);
  }
  
  /* Instagram overlay styling */
  .scrolling-gallery__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.2);
    opacity: 0;
    transition: opacity 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }
  
  .scrolling-gallery__item:hover .scrolling-gallery__overlay {
    opacity: 1;
  }
  
  .scrolling-gallery__overlay svg {
    width: 32px;
    height: 32px;
    fill: #ffffff;
  }
{%- endstyle -%}

<div class="scrolling-gallery section-{{ section.id }}-padding">
  <!-- Removed page-width wrapper from the grid so the slider spans edge-to-edge -->
  <div class="page-width">
    <div class="scrolling-gallery__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="scrolling-gallery__heading {{ section.settings.heading_size }}">
          {{ section.settings.heading | escape }}
        </h2>
      {%- endif -%}
      
      {%- if section.settings.description != blank -%}
        <p class="scrolling-gallery__description">{{ section.settings.description | escape }}</p>
      {%- endif -%}
    </div>
  </div>

  <div class="scrolling-gallery__grid">
    {%- for block in section.blocks -%}
      <div class="scrolling-gallery__item" {{ block.shopify_attributes }}>
        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}" class="scrolling-gallery__image-wrapper">
        {%- else -%}
          <div class="scrolling-gallery__image-wrapper">
        {%- endif -%}

          {%- if block.settings.image != blank -%}
            {%- liquid
              assign fetch_priority = 'auto'
              assign loading_attr = 'lazy'
              
              if section.settings.lazy_load == false and forloop.index <= 5
                assign fetch_priority = 'high'
                assign loading_attr = 'eager'
              endif
            -%}
            {{ block.settings.image | image_url: width: 800 | image_tag:
              loading: loading_attr,
              fetchpriority: fetch_priority,
              widths: '300, 400, 600, 800',
              sizes: '(min-width: 990px) 22vw, (min-width: 750px) 35vw, 70vw'
            }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
          
          {%- if block.settings.show_icon_on_hover -%}
            <div class="scrolling-gallery__overlay">
               <svg viewBox="0 0 24 24">
                 <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
               </svg>
            </div>
          {%- endif -%}

        {%- if block.settings.link != blank -%}
          </a>
        {%- else -%}
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Scrolling Gallery",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Header Layout"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "JOIN OUR ROXX FAMILY",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h0",
      "label": "Heading Size"
    },
    {
      "type": "text",
      "id": "description",
      "default": "with thousands who've upgraded their everyday ride.",
      "label": "Description"
    },
    {
      "type": "checkbox",
      "id": "lazy_load",
      "default": true,
      "label": "Lazy load images",
      "info": "Disable if this section is the first thing users see."
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Image Link (Optional)"
        },
        {
          "type": "checkbox",
          "id": "show_icon_on_hover",
          "label": "Show Instagram icon on hover",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scrolling Gallery",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}