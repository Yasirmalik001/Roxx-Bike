                                    <span class="comment-author">{{ block.settings.comment_author_2 | default: 'Lucineh' }}</span>
                                    <span class="comment-time">{{ block.settings.comment_time_2 | default: '12 days ago' }}</span>
                                  </div>
                                  <div class="comment-text">
