                      <div class="comment-avatar">
                        {%- if block.settings.reply_avatar != blank -%}
                          <img src="{{ block.settings.reply_avatar | image_url: width: 40 }}" alt="">
                        {%- else -%}
                          L
                        {%- endif -%}
                      </div>
                      <div class="comment-content-wrap">
                        <div class="comment-meta">
                          <span class="comment-author">{{ block.settings.comment_author_2 | default: 'Lucineh' }}</span>
                          <span class="comment-time">{{ block.settings.comment_time_2 | default: '12 days ago' }}</span>
                        </div>
                        <div class="comment-text">
                          {%- if block.settings.comment_text_2 contains 'jay' -%}
                            {{ block.settings.comment_text_2 | replace: 'jay', '<span class="comment-mention">jay</span>' }}
                          {%- else -%}
                            {{ block.settings.comment_text_2 }}
                          {%- endif -%}
                        </div>
                      </div>
                    </div>
                  {%- endif -%}
                </div>
                <div class="comment-popup-footer">
                  <div class="comment-footer-avatar">Y</div>
                  <div class="comment-input-wrap">
                    <input type="text" placeholder="Reply" class="comment-input" readonly>
                    <button type="button" class="comment-submit-btn" aria-label="Send reply">
                      <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
                    </button>
                  </div>
                </div>
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('.section-{{ section.id }}-padding');
    if (!section) return;

    // Create popup portal container
    const portal = document.createElement('div');
    portal.className = 'instagram-popups-portal';
    section.appendChild(portal);

    // Move all popup boxes inside blocks to portal container to avoid marquee overflow clipping
    const popups = section.querySelectorAll('.comment-popup-box');
    popups.forEach(popup => portal.appendChild(popup));

    const hotspots = section.querySelectorAll('.comment-hotspot-pill');
    let activePopup = null;

    function pauseMarquees() {
      const tracks = section.querySelectorAll('.marquee-gallery__track');
      tracks.forEach(track => {
        track.style.animationPlayState = 'paused';
      });
    }

    function resumeMarquees() {
      const tracks = section.querySelectorAll('.marquee-gallery__track');
      tracks.forEach(track => {
        track.style.animationPlayState = 'running';
      });
    }

    hotspots.forEach(hotspot => {
      hotspot.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();

        const popupId = this.getAttribute('data-popup-id');
        const popup = document.getElementById(popupId);
        if (!popup) return;

        // Close current active popup
        if (activePopup) {
          activePopup.style.display = 'none';
        }

        // Pause marquee
        pauseMarquees();

        // Position popup relative to section container
        const rect = this.getBoundingClientRect();
        const secRect = section.getBoundingClientRect();

        let top = rect.bottom - secRect.top;
        let left = rect.left - secRect.left + (rect.width / 2) - 160; // Center popup (width: 320px)

        // Keep popup inside section container bounds horizontally
        if (left < 10) left = 10;
        if (left + 330 > secRect.width) {
          left = secRect.width - 330;
        }

        popup.style.top = `${top + 10}px`;
        popup.style.left = `${left}px`;
        popup.style.display = 'flex';
        activePopup = popup;
      });
    });

    // Close buttons inside popups
    const closeBtns = section.querySelectorAll('.comment-popup-close');
    closeBtns.forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        if (activePopup) {
          activePopup.style.display = 'none';
          activePopup = null;
        }
        resumeMarquees();
      });
    });

    // Close when clicking outside of the popup
    document.addEventListener('click', function(e) {
      if (activePopup && !activePopup.contains(e.target) && !e.target.closest('.comment-hotspot-pill')) {
        activePopup.style.display = 'none';
        activePopup = null;
        resumeMarquees();
      }
    });
  });
</script>

