<style>
  .custom-alternating-section {
    display: flex;
    flex-direction: column;
    width: 100%;
    overflow: hidden;
    background-color: #ffffff;
  }
  
  .alternating-row {
    display: flex;
    flex-wrap: wrap;
    width: 100%;
    align-items: center;
  }
  
  .alternating-row.layout-right {
    flex-direction: row-reverse;
  }
  
  .alternating-image {
    width: 50%;
    font-size: 0;
    position: relative;
  }
  
  .alternating-image img {
    width: 100%;
    height: 100%;
    min-height: 550px;
    object-fit: cover;
    display: block;
  }

  .alternating-image svg {
    width: 100%;
    height: 100%;
    min-height: 550px;
    background-color: #f3f3f3;
  }
  
  .alternating-content {
    width: 50%;
    padding: 6% 8%;
    box-sizing: border-box;
  }
  
  .alternating-heading {
    font-family: inherit;
    font-size: 2.2rem;
    font-weight: 900;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #111111;
  }
  
  /* Timeline Component Styles */
  .alternating-timeline {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .timeline-item {
    position: relative;
    padding-left: 2.5rem;
    padding-bottom: 3rem;
    font-size: 1.05rem;
    line-height: 1.6;
    color: #333333;
  }
  
  .timeline-item:last-child {
    padding-bottom: 0;
  }
  
  .timeline-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.4rem;
    width: 14px;
    height: 14px;
    background-color: #FFD100;
    border-radius: 50%;
    z-index: 2;
  }
  
  .timeline-item:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 6px;
    top: 1.4rem;
    bottom: -0.2rem;
    width: 2px;
    background-color: #E5E7EB;
    z-index: 1;
  }
  
  /* Standard Paragraph Styles */
  .alternating-text {
    font-size: 0.95rem;
    line-height: 1.6;
    color: #333333;
    margin-bottom: 1.5rem;
  }

  /* --- NEW: Feature Block Styles (Checkmarks & Buttons) --- */
  .feature-list-wrapper {
    margin-bottom: 2rem;
  }
  
  .list-heading {
    font-size: 0.95rem;
    font-weight: 600;
    color: #111;
    margin-bottom: 0.8rem;
  }

  .check-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .check-list-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.95rem;
    color: #333;
    margin-bottom: 0.8rem;
    line-height: 1.4;
  }

  .check-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    margin-top: 2px;
  }

  .feature-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #FFD100;
    color: #000000;
    padding: 14px 28px;
    border-radius: 30px;
    font-size: 0.85rem;
    font-weight: 800;
    text-transform: uppercase;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .feature-btn:hover {
    opacity: 0.85;
  }
  
  /* Responsive Breakpoints */
  @media screen and (max-width: 990px) {
    .alternating-image, .alternating-content {
      width: 100%;
    }
    
    .alternating-image img, .alternating-image svg {
      min-height: 400px;
    }
    
    .alternating-content {
      padding: 3rem 2rem;
    }
  }
</style>

<section class="custom-alternating-section">
  {% for block in section.blocks %}
    <div class="alternating-row {% if block.settings.layout == 'right' %}layout-right{% endif %}" {{ block.shopify_attributes }}>
      
      <div class="alternating-image">
        {% if block.settings.image != blank %}
          {{ block.settings.image | image_url: width: 1500 | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 50vw, 100vw' }}
        {% else %}
          {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>

      <div class="alternating-content">
        {% if block.settings.heading != blank %}
          <h2 class="alternating-heading">{{ block.settings.heading | escape }}</h2>
        {% endif %}

        {% if block.type == 'timeline_row' %}
          <ul class="alternating-timeline">
            {% if block.settings.bullet_1 != blank %}
              <li class="timeline-item">{{ block.settings.bullet_1 }}</li>
            {% endif %}
            {% if block.settings.bullet_2 != blank %}
              <li class="timeline-item">{{ block.settings.bullet_2 }}</li>
            {% endif %}
          </ul>

        {% elsif block.type == 'text_row' %}
          {% if block.settings.text != blank %}
            <div class="alternating-text">
              {{ block.settings.text }}
            </div>
          {% endif %}

        {% elsif block.type == 'feature_block' %}
          {% if block.settings.text != blank %}
            <div class="alternating-text">
              {{ block.settings.text }}
            </div>
          {% endif %}

          {% if block.settings.list_item_1 != blank or block.settings.list_item_2 != blank or block.settings.list_item_3 != blank or block.settings.list_item_4 != blank %}
            <div class="feature-list-wrapper">
              {% if block.settings.list_heading != blank %}
                <div class="list-heading">{{ block.settings.list_heading }}</div>
              {% endif %}
              
              <ul class="check-list">
                {% for i in (1..4) %}
                  {% capture list_item_key %}list_item_{{ i }}{% endcapture %}
                  {% assign list_item = block.settings[list_item_key] %}
                  
                  {% if list_item != blank %}
                    <li class="check-list-item">
                      <svg class="check-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/0000/svg">
                        <circle cx="12" cy="12" r="11" stroke="#111" stroke-width="1.5"/>
                        <path d="M8 12L11 15L16 9" stroke="#111" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      {{ list_item }}
                    </li>
                  {% endif %}
                {% endfor %}
              </ul>
            </div>
          {% endif %}

          {% if block.settings.button_label != blank %}
            <a href="{{ block.settings.button_link }}" class="feature-btn">
              {{ block.settings.button_label }}
            </a>
          {% endif %}
        {% endif %}
      </div>
      
    </div>
  {% endfor %}
</section>

{% schema %}
{
  "name": "Alternating Features",
  "settings": [],
  "blocks": [
    {
      "type": "timeline_row",
      "name": "Timeline Row",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "layout",
          "label": "Image Placement",
          "options": [
            { "value": "left", "label": "Image on Left" },
            { "value": "right", "label": "Image on Right" }
          ],
          "default": "left"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "FROM A SMALL IDEA TO A GROWING E-BIKE BRAND"
        },
        {
          "type": "textarea",
          "id": "bullet_1",
          "label": "First Bullet Text",
          "default": "Lorem ipsum dolor sit amet consectetur. Velit eu justo adipiscing nec nam nibh turpis et consectetur."
        },
        {
          "type": "textarea",
          "id": "bullet_2",
          "label": "Second Bullet Text",
          "default": "Lorem ipsum dolor sit amet consectetur. Et facilisi quis consequat nulla nibh amet mi est proin."
        }
      ]
    },
    {
      "type": "text_row",
      "name": "Text Row",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "layout",
          "label": "Image Placement",
          "options": [
            { "value": "left", "label": "Image on Left" },
            { "value": "right", "label": "Image on Right" }
          ],
          "default": "right"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "BUILT FOR EVERYDAY RIDERS"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>From city commuting to weekend adventures, our bikes are designed to make every ride feel effortless.</p>"
        }
      ]
    },
    {
      "type": "feature_block",
      "name": "Rich Feature Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "layout",
          "label": "Image Placement",
          "options": [
            { "value": "left", "label": "Image on Left" },
            { "value": "right", "label": "Image on Right" }
          ],
          "default": "left"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "SMART PROTECTION FOR A SMARTER RIDE."
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Paragraph Text",
          "default": "<p>Your bike is more than just a ride — it's part of your everyday life. With Roxx insurance, you're protected against the unexpected.</p>"
        },
        {
          "type": "header",
          "content": "Checkmark List"
        },
        {
          "type": "text",
          "id": "list_heading",
          "label": "List Title",
          "default": "What's covered:"
        },
        {
          "type": "text",
          "id": "list_item_1",
          "label": "List Item 1",
          "default": "Theft protection"
        },
        {
          "type": "text",
          "id": "list_item_2",
          "label": "List Item 2",
          "default": "Damage & accident coverage"
        },
        {
          "type": "text",
          "id": "list_item_3",
          "label": "List Item 3",
          "default": "Peace of mind, wherever you park"
        },
        {
          "type": "text",
          "id": "list_item_4",
          "label": "List Item 4 (Optional)"
        },
        {
          "type": "header",
          "content": "Button"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "EXPLORE INSURANCE"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Alternating Features",
      "blocks": [
        { "type": "feature_block" },
        { "type": "feature_block", "settings": { "layout": "right", "heading": "KEEP YOUR RIDE PERFORMING LIKE NEW" } }
      ]
    }
  ]
}
{% endschema %}