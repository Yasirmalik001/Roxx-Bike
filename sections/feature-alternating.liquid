{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .custom-alternating-section {
    display: flex;
    flex-direction: column;
    width: 100%;
    overflow: hidden;
  }
  
  .alternating-row {
    display: flex;
    flex-wrap: wrap;
    width: 100%;
    align-items: center;
  }
  
  .alternating-row.layout-right {
    flex-direction: row-reverse;
  }
  
  .alternating-image {
    width: 50%;
    font-size: 0;
    position: relative;
  }
  
  .alternating-image img {
    width: 100%;
    height: 100%;
    aspect-ratio: 1 / 1; /* Forces the exact same height and width */
    object-fit: cover;
    display: block;
  }

  .alternating-image svg {
    width: 100%;
    height: 100%;
    aspect-ratio: 1 / 1; /* Forces the exact same height and width */
    background-color: rgba(var(--color-foreground), 0.05);
  }
  
  .alternating-content {
    width: 50%;
    padding: 50px 100px;
    box-sizing: border-box;
  }
  
  .alternating-heading {
    font-family: inherit;
    font-size: 35.2px; /* 2.2rem */
    font-weight: 900;
    text-transform: uppercase;
    margin-bottom: 24px; /* 1.5rem */
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
  
  /* Timeline Component Styles */
  .alternating-timeline {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .timeline-item {
    position: relative;
    padding-left: 40px; /* 2.5rem */
    padding-bottom: 48px; /* 3rem */
    font-size: 16.8px; /* 1.05rem */
    line-height: 1.6;
    color: currentColor;
    opacity: 0.85;
  }
  
  .timeline-item:last-child {
    padding-bottom: 0;
  }
  
  .timeline-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 6.4px; /* 0.4rem */
    width: 14px;
    height: 14px;
    background-color: #FFD100;
    border-radius: 50%;
    z-index: 2;
  }
  
  .timeline-item:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 6px;
    top: 22.4px; /* 1.4rem */
    bottom: -3.2px; /* -0.2rem */
    width: 2px;
    background-color: rgba(var(--color-foreground), 0.15);
    z-index: 1;
  }
  
  /* Standard Paragraph Styles */
  .alternating-text {
    font-weight: 400;
    font-style: Regular;
    font-size: 16px;
    leading-trim: NONE;
    line-height: 100%;
    max-width: 500px;
  }

  /* --- NEW: Feature Block Styles (Checkmarks & Buttons) --- */
  .feature-list-wrapper {
    margin-bottom: 32px; /* 2rem */
  }
  
  .list-heading {
    font-size: 15.2px; /* 0.95rem */
    font-weight: 600;
    color: currentColor;
    margin-bottom: 12.8px; /* 0.8rem */
  }

  .check-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .check-list-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 15.2px; /* 0.95rem */
    color: currentColor;
    opacity: 0.85;
    margin-bottom: 12.8px; /* 0.8rem */
    line-height: 1.4;
  }

  .check-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    margin-top: 2px;
  }

  .feature-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #FFD100;
    color: #000000;
    padding: 14px 28px;
    border-radius: 30px;
    font-size: 13.6px; /* 0.85rem */
    font-weight: 800;
    text-transform: uppercase;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .feature-btn:hover {
    opacity: 0.85;
  }
  
  /* Responsive Breakpoints */
  @media screen and (max-width: 990px) {
    .timeline-item{
      font-size: 14px;
    }
    .alternating-row {
      flex-direction: column !important; /* Force image on top for ALL layouts on mobile */
      margin-bottom: 32px; /* 2rem */
    }
    
    .alternating-image, .alternating-content {
      width: 100%;
    }
    
    .alternating-content {
      padding: 32px 24px; /* 2rem 1.5rem */
      background-color: #F8F9FA; /* Light gray background matching screenshot */
    }

    .alternating-heading {
      font-size: 25.6px; /* 1.6rem */
      margin-bottom: 16px; /* 1rem */
    }

    .alternating-text {
      font-size: 13.6px; /* 0.85rem */
      margin-bottom: 19.2px; /* 1.2rem */
    }

    .check-list-item {
      font-size: 13.6px; /* 0.85rem */
      gap: 8px;
    }

    .custom-alternating-section {
      padding-inline: 32px; /* 2rem */
    }

    .custom-alternating-section  .hero-features__heading{
      text-align: left;
    }

    .check-icon {
      width: 16px;
      height: 16px;
    }

    .feature-btn {
      width: 100%; /* Full width button on mobile */
      padding: 12px 20px;
      font-size: 12.8px; /* 0.8rem */
    }
  }
{%- endstyle -%}

<section class="custom-alternating-section section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  {% for block in section.blocks %}
    <div class="alternating-row color-{{ block.settings.color_scheme }} gradient {% if block.settings.layout == 'right' %}layout-right{% endif %}" {{ block.shopify_attributes }}>
      
      <div class="alternating-image">
        {% if block.settings.image != blank %}
          {{ block.settings.image | image_url: width: 1500 | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 50vw, 100vw' }}
        {% else %}
          {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>

      <div class="alternating-content">
        {% if block.settings.heading != blank %}
          <h2 class="hero-features__heading {{ block.settings.heading_size }}" {{ block.shopify_attributes }}>{{ block.settings.heading | escape }}</h2>
        {% endif %}

        {% if block.type == 'timeline_row' %}
          <ul class="alternating-timeline">
            {% if block.settings.bullet_1 != blank %}
              <li class="timeline-item">{{ block.settings.bullet_1 }}</li>
            {% endif %}
            {% if block.settings.bullet_2 != blank %}
              <li class="timeline-item">{{ block.settings.bullet_2 }}</li>
            {% endif %}
          </ul>

        {% elsif block.type == 'text_row' %}
          {% if block.settings.text != blank %}
            <div class="alternating-text">
              {{ block.settings.text }}
            </div>
          {% endif %}

        {% elsif block.type == 'feature_block' %}
          {% if block.settings.text != blank %}
            <div class="alternating-text">
              {{ block.settings.text }}
            </div>
          {% endif %}

          {% if block.settings.list_item_1 != blank or block.settings.list_item_2 != blank or block.settings.list_item_3 != blank or block.settings.list_item_4 != blank %}
            <div class="feature-list-wrapper">
              {% if block.settings.list_heading != blank %}
                <div class="list-heading">{{ block.settings.list_heading }}</div>
              {% endif %}
              
              <ul class="check-list">
                {% for i in (1..4) %}
                  {% capture list_item_key %}list_item_{{ i }}{% endcapture %}
                  {% assign list_item = block.settings[list_item_key] %}
                  
                  {% if list_item != blank %}
                    <li class="check-list-item">
                      <svg class="check-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="12" cy="12" r="11" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M8 12L11 15L16 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      {{ list_item }}
                    </li>
                  {% endif %}
                {% endfor %}
              </ul>
            </div>
          {% endif %}

          {% if block.settings.button_label != blank %}
            <a href="{{ block.settings.button_link }}" class="feature-btn">
              {{ block.settings.button_label }}
            </a>
          {% endif %}
        {% endif %}
      </div>
      
    </div>
  {% endfor %}
</section>

{% schema %}
