{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .custom-alternating-section {
    display: flex;
    flex-direction: column;
    width: 100%;
    overflow: hidden;
  }
  
  .alternating-row {
    display: flex;
    flex-wrap: wrap;
    width: 100%;
    align-items: center;
  }
  
  .alternating-row.layout-right {
    flex-direction: row-reverse;
  }
  
  .alternating-image {
    width: 50%;
    font-size: 0;
    position: relative;
  }
  
  .alternating-image img {
    width: 100%;
    height: 100%;
    min-height: 550px;
    object-fit: cover;
    display: block;
  }

  .alternating-image svg {
    width: 100%;
    height: 100%;
    min-height: 550px;
    background-color: rgba(var(--color-foreground), 0.05);
  }
  
  .alternating-content {
    width: 50%;
    padding: 6% 8%;
    box-sizing: border-box;
  }
  
  .alternating-heading {
    font-family: inherit;
    font-size: 2.2rem;
    font-weight: 900;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
  
  /* Timeline Component Styles */
  .alternating-timeline {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .timeline-item {
    position: relative;
    padding-left: 2.5rem;
    padding-bottom: 3rem;
    font-size: 1.05rem;
    line-height: 1.6;
    color: currentColor;
    opacity: 0.85;
  }
  
  .timeline-item:last-child {
    padding-bottom: 0;
  }
  
  .timeline-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.4rem;
    width: 14px;
    height: 14px;
    background-color: #FFD100;
    border-radius: 50%;
    z-index: 2;
  }
  
  .timeline-item:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 6px;
    top: 1.4rem;
    bottom: -0.2rem;
    width: 2px;
    background-color: rgba(var(--color-foreground), 0.15);
    z-index: 1;
  }
  
  /* Standard Paragraph Styles */
  .alternating-text {
    font-size: 0.95rem;
    line-height: 1.6;
    color: currentColor;
    opacity: 0.85;
    margin-bottom: 1.5rem;
  }

  /* --- NEW: Feature Block Styles (Checkmarks & Buttons) --- */
  .feature-list-wrapper {
    margin-bottom: 2rem;
  }
  
  .list-heading {
    font-size: 0.95rem;
    font-weight: 600;
    color: currentColor;
    margin-bottom: 0.8rem;
  }

  .check-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .check-list-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.95rem;
    color: currentColor;
    opacity: 0.85;
    margin-bottom: 0.8rem;
    line-height: 1.4;
  }

  .check-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    margin-top: 2px;
  }

  .feature-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #FFD100;
    color: #000000;
    padding: 14px 28px;
    border-radius: 30px;
    font-size: 0.85rem;
    font-weight: 800;
    text-transform: uppercase;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .feature-btn:hover {
    opacity: 0.85;
  }
  
  /* Responsive Breakpoints */
  @media screen and (max-width: 990px) {
    .alternating-row {
      flex-direction: column !important; /* Force image on top for ALL layouts on mobile */
      margin-bottom: 2rem;
    }
    
    .alternating-image, .alternating-content {
      width: 100%;
    }
    
    .alternating-image img, .alternating-image svg {
      min-height: 250px; /* Reduced height for mobile */
      max-height: 300px;
    }
    
    .alternating-content {
      padding: 2rem 1.5rem;
      background-color: #F8F9FA; /* Light gray background matching screenshot */
    }

    .alternating-heading {
      font-size: 1.6rem; /* Scaled down heading */
      margin-bottom: 1rem;
    }

    .alternating-text {
      font-size: 0.85rem;
      margin-bottom: 1.2rem;
    }

    .check-list-item {
      font-size: 0.85rem;
      gap: 8px;
    }

    .check-icon {
      width: 16px;
      height: 16px;
    }

    .feature-btn {
      width: 100%; /* Full width button on mobile */
      padding: 12px 20px;
      font-size: 0.8rem;
    }
  }
{%- endstyle -%}