{%- liquid
  assign current_language = request.locale.iso_code | downcase
  assign active_block = blank
  assign default_block = blank

  for block in section.blocks
    assign block_langs = block.settings.language_code | downcase
    if block_langs contains current_language
      assign active_block = block
      break
    endif
    
    if block.settings.is_default
      assign default_block = block
    endif
  endfor

  if active_block == blank
    assign active_block = default_block | default: section.blocks.first
  endif
-%}

<div class="lang-banner-wrapper">
  {% if active_block != blank %}
    <div class="lang-banner-content" {{ active_block.shopify_attributes }}>
      
      {% if active_block.settings.image != blank %}
        {{ active_block.settings.image | image_url: width: 2000 | image_tag: class: 'lang-banner-img', loading: 'lazy' }}
      {% else %}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}

      {% if active_block.settings.heading != blank %}
        <div class="lang-banner-text">
          <h2>{{ active_block.settings.heading }}</h2>
        </div>
      {% endif %}
      
    </div>
  {% endif %}
</div>

<style>
  .lang-banner-wrapper {
    display: flex;
    flex-direction: column;
    width: 100%;
    position: relative;
    background-color: #f4f4f4;
  }
  
  .lang-banner-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
  }
  
  .lang-banner-img {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
  }
  
  .lang-banner-text {
    position: absolute;
    text-align: center;
    color: #ffffff;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
</style>

{% schema %}
{
  "name": "Language Specific Banner",
  "settings": [],
  "blocks": [
    {
      "type": "language_banner",
      "name": "Language Banner",
      "settings": [
        {
          "type": "checkbox",
          "id": "is_default",
          "label": "Set as Default Banner",
          "default": false
        },
        {
          "type": "text",
          "id": "language_code",
          "label": "Language ISO Code",
          "info": "Enter the 2-letter language code (e.g., en, fr, da)."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Banner Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Welcome"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Language Specific Banner",
      "blocks": [
        {
          "type": "language_banner",
          "settings": {
            "is_default": true,
            "heading": "Global Store"
          }
        }
      ]
    }
  ]
}
{% endschema %}