<style>
  @media screen and (max-width: 749px) {
    .mobile-utility-wrapper {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
      padding: 1rem 1.5rem;
      gap: 1rem;
    }
    .mobile-announcement-row {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      column-gap: 0.8rem;
      row-gap: 0.5rem;
      width: 100%;
    }
    .mobile-announcement-item {
      display: flex;
      align-items: center;
      font-size: 1.1rem;
      line-height: 1.2;
      text-align: center;
    }
    .mobile-announcement-item svg {
      width: 1.4rem;
      height: 1.4rem;
      margin-right: 0.4rem;
    }
    .mobile-announcement-divider {
      opacity: 0.4;
      font-size: 1.2rem;
    }
    .mobile-store-location {
      display: inline-flex; 
      align-items: center; 
      gap: 0.4rem; 
      text-decoration: none; 
      font-size: 1.2rem;
    }
  }
</style>

<div class="utility-bar color-{{ section.settings.color_scheme }} gradient large-up-hide">
  <div class="mobile-utility-wrapper">
    
    {%- if section.settings.show_social and social_icons -%}
      {%- render 'social-icons' -%}
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="mobile-announcement-row">
        {%- for block in section.blocks -%}
          <div class="mobile-announcement-item" {{ block.shopify_attributes }}>
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="link link--text" style="display: flex; align-items: center; text-decoration: none;">
            {%- endif -%}
            
            {%- if block.settings.icon != 'none' -%}
              {%- case block.settings.icon -%}
                {%- when 'shipping' -%}
                  <svg class="icon icon-shipping" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="2" y1="8" x2="6" y2="8"></line><line x1="1" y1="12" x2="5" y2="12"></line><line x1="3" y1="16" x2="7" y2="16"></line><path d="M12 2L20 6.5V15.5L12 20L4 15.5V6.5L12 2Z"></path><path d="M12 20V11"></path><path d="M12 11L20 6.5"></path><path d="M12 11L4 6.5"></path></svg>
                {%- when 'payment' -%}
                  <svg class="icon icon-payment" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2" ry="2"></rect><line x1="2" y1="10" x2="22" y2="10"></line><path d="M16 14l2 2 4-4"></path></svg>
                {%- when 'warranty' -%}
                  <svg class="icon icon-warranty" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="M9 11l2 2 4-4"></path></svg>
              {%- endcase -%}
            {%- endif -%}
            
            <span>{{ block.settings.text | escape }}</span>
            
            {%- if block.settings.link != blank -%}
              </a>
            {%- endif -%}
          </div>
          
          {%- unless forloop.last -%}
            <span class="mobile-announcement-divider">|</span>
          {%- endunless -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div style="display: flex; gap: 1.5rem; align-items: center; justify-content: center;">
      {%- if section.settings.enable_country_selector and localization.available_countries.size >= 1 -%}
        <localization-form>
          {%- form 'localization', id: 'AnnouncementCountryFormMobile', class: 'localization-form' -%}
            <div>
              <h2 class="visually-hidden" id="AnnouncementCountryLabelMobile">{{ 'localization.country_label' | t }}</h2>
              {%- render 'country-localization', localPosition: 'AnnouncementCountry' -%}
            </div>
          {%- endform -%}
        </localization-form>
      {% endif %}

      {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
        <localization-form>
          {%- form 'localization', id: 'AnnouncementLanguageFormMobile', class: 'localization-form' -%}
            <div>
              <h2 class="visually-hidden" id="AnnouncementLanguageLabelMobile">{{ 'localization.language_label' | t }}</h2>
              {%- render 'language-localization', localPosition: 'AnnouncementLanguage' -%}
            </div>
          {%- endform -%}
        </localization-form>
      {%- endif -%}

      {%- if section.settings.store_location_label != blank -%}
        <a {% if section.settings.store_location_link != blank %}href="{{ section.settings.store_location_link }}"{% else %}href="#"{% endif %} class="link link--text mobile-store-location">
          <svg class="icon icon-map-pin" viewBox="0 0 20 20" fill="currentColor" style="width: 1.4rem; height: 1.4rem;"><path fill-rule="evenodd" d="m9.91 18.59 5.036-8.78c2.228-3.886-.525-8.777-4.942-8.777-4.385 0-7.147 4.822-4.992 8.713zM10.004 0C4.845 0 1.593 5.673 4.13 10.255l5.212 9.41a.64.64 0 0 0 1.12.009l5.358-9.342C18.445 5.755 15.202 0 10.004 0"/><path d="M13 6.796c0 1.76-1.399 3.187-3.124 3.187S6.752 8.556 6.752 6.796s1.399-3.187 3.124-3.187S13 5.036 13 6.796M9.876 8.949c1.166 0 2.11-.964 2.11-2.153s-.944-2.153-2.11-2.153-2.11.964-2.11 2.153.944 2.153 2.11 2.153"/></svg>
          <span>{{ section.settings.store_location_label | escape }}</span>
        </a>
      {%- endif -%}
    </div>

  </div>
</div>