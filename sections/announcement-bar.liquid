{%- style -%}
  .custom-announcement-bar {
    padding: 0.8rem 0;
    font-size: 1.2rem;
    border-bottom: 1px solid rgba(255,255,255,0.1); /* Optional subtle separator */
  }

  .custom-announcement-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .custom-announcement-group {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    flex-wrap: wrap;
  }

  .custom-announcement-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: inherit;
    line-height: 1.2;
  }

  .custom-announcement-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .custom-announcement-icon svg {
    width: 1.6rem;
    height: 1.6rem;
    display: block;
  }

  .custom-announcement-separator {
    opacity: 0.4;
    font-size: 1.2rem;
    user-select: none;
  }

  .custom-announcement-right {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  /* Target Dawn's native localization dropdowns so they sit inline */
  .custom-announcement-right .localization-form {
    margin: 0;
    padding: 0;
  }
  .custom-announcement-right .disclosure__button {
    font-size: 1.2rem;
  }

  /* ----------------------------------------------------
     MOBILE LAYOUT (Matches Figma precisely) 
     ---------------------------------------------------- */
  @media screen and (max-width: 800px) {
    .custom-announcement-bar {
      padding: 0.8rem 1rem;
    }
    
    .custom-announcement-wrapper {
      justify-content: center; /* Center everything */
    }

    .custom-announcement-group {
      justify-content: center;
      row-gap: 0.6rem;
      column-gap: 0.8rem;
    }

    .custom-announcement-right {
      display: none; /* Hide language and store location on mobile like mockup */
    }

    .custom-announcement-item {
      font-size: 1.1rem; /* Slightly scale down text for mobile */
    }
    
    .custom-announcement-icon svg {
      width: 1.4rem;
      height: 1.4rem;
    }
  }
{%- endstyle -%}

<div class="custom-announcement-bar color-{{ section.settings.color_scheme }} gradient">
  <div class="custom-announcement-wrapper">
    
    <div class="custom-announcement-group">
      {%- for block in section.blocks -%}
        <div class="custom-announcement-item" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="custom-announcement-item" style="text-decoration: none;">
          {%- endif -%}
          
          {%- if block.settings.icon != 'none' -%}
            <span class="custom-announcement-icon">
              {%- case block.settings.icon -%}
                {%- when 'shipping' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="2" y1="8" x2="6" y2="8"></line><line x1="1" y1="12" x2="5" y2="12"></line><line x1="3" y1="16" x2="7" y2="16"></line><path d="M12 2L20 6.5V15.5L12 20L4 15.5V6.5L12 2Z"></path><path d="M12 20V11"></path><path d="M12 11L20 6.5"></path><path d="M12 11L4 6.5"></path></svg>
                {%- when 'payment' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2" ry="2"></rect><line x1="2" y1="10" x2="22" y2="10"></line><path d="M16 14l2 2 4-4"></path></svg>
                {%- when 'warranty' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="M9 11l2 2 4-4"></path></svg>
              {%- endcase -%}
            </span>
          {%- endif -%}
          
          <span>{{ block.settings.text | escape }}</span>
          
          {%- if block.settings.link != blank -%}
            </a>
          {%- endif -%}
        </div>
        
        {%- unless forloop.last -%}
          <span class="custom-announcement-separator">|</span>
        {%- endunless -%}
      {%- endfor -%}
    </div>

    <div class="custom-announcement-right">
      {%- if section.settings.enable_country_selector and localization.available_countries.size >= 1 -%}
        <localization-form>
          {%- form 'localization', id: 'AnnouncementCountryForm', class: 'localization-form' -%}
            <div>
              <h2 class="visually-hidden" id="AnnouncementCountryLabel">{{ 'localization.country_label' | t }}</h2>
              {%- render 'country-localization', localPosition: 'AnnouncementCountry' -%}
            </div>
          {%- endform -%}
        </localization-form>
      {% endif %}

      {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
        <localization-form>
          {%- form 'localization', id: 'AnnouncementLanguageForm', class: 'localization-form' -%}
            <div>
              <h2 class="visually-hidden" id="AnnouncementLanguageLabel">{{ 'localization.language_label' | t }}</h2>
              {%- render 'language-localization', localPosition: 'AnnouncementLanguage' -%}
            </div>
          {%- endform -%}
        </localization-form>
      {%- endif -%}

      {%- if section.settings.store_location_label != blank -%}
        <a {% if section.settings.store_location_link != blank %}href="{{ section.settings.store_location_link }}"{% else %}href="#"{% endif %} class="custom-announcement-item">
          <span class="custom-announcement-icon">
            <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="m9.91 18.59 5.036-8.78c2.228-3.886-.525-8.777-4.942-8.777-4.385 0-7.147 4.822-4.992 8.713zM10.004 0C4.845 0 1.593 5.673 4.13 10.255l5.212 9.41a.64.64 0 0 0 1.12.009l5.358-9.342C18.445 5.755 15.202 0 10.004 0"/><path d="M13 6.796c0 1.76-1.399 3.187-3.124 3.187S6.752 8.556 6.752 6.796s1.399-3.187 3.124-3.187S13 5.036 13 6.796M9.876 8.949c1.166 0 2.11-.964 2.11-2.153s-.944-2.153-2.11-2.153-2.11.964-2.11 2.153.944 2.153 2.11 2.153"/></svg>
          </span>
          <span>{{ section.settings.store_location_label | escape }}</span>
        </a>
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "t:sections.announcement-bar.name",
  "max_blocks": 12,
  "class": "announcement-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "t:sections.announcement-bar.settings.auto_rotate.label",
      "default": false
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "t:sections.announcement-bar.settings.change_slides_speed.label",
      "default": 5
    },    
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-4"
    },  
    {
      "type": "checkbox",
      "id": "show_line_separator",
      "default": true,
      "label": "t:sections.header.settings.show_line_separator.label"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "default": false,
      "label": "t:sections.announcement-bar.settings.enable_country_selector.label"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "default": false,
      "label": "t:sections.announcement-bar.settings.enable_language_selector.label"
    },
    {
      "type": "header",
      "content": "Store Location Settings"
    },
    {
      "type": "text",
      "id": "store_location_label",
      "label": "Store Location Label",
      "default": "Store location"
    },
    {
      "type": "url",
      "id": "store_location_link",
      "label": "Store Location Link"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "t:sections.announcement-bar.blocks.announcement.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "t:sections.announcement-bar.blocks.announcement.settings.text.default",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.text.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.link.label"
        },
        {
          "type": "select",
          "id": "icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "shipping", "label": "Shipping / Box" },
            { "value": "payment", "label": "Payment / Card" },
            { "value": "warranty", "label": "Warranty / Shield" }
          ],
          "default": "none",
          "label": "Icon"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.announcement-bar.presets.name",
      "blocks": [
        {
          "type": "announcement"
        }
      ]
    }
  ]
}
{% endschema %}