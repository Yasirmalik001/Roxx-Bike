  <div class="page-width utility-bar-desktop__container">
    
    <!-- Left side announcements -->
    <div class="utility-bar-desktop__announcements">
      {%- for block in section.blocks -%}
        <div class="utility-bar-desktop__announcement" {{ block.shopify_attributes }}>
          {%- if block.settings.text != blank -%}
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="utility-bar-desktop__link">
            {%- endif -%}
            
            {%- if block.settings.icon != 'none' -%}
              <span class="utility-bar-desktop__icon">
                {%- case block.settings.icon -%}
                  {%- when 'shipping' -%}
                    <svg class="icon icon-shipping" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 1.8rem; height: 1.8rem; display: block;">
                      <line x1="2" y1="8" x2="6" y2="8"></line>
                      <line x1="1" y1="12" x2="5" y2="12"></line>
                      <line x1="3" y1="16" x2="7" y2="16"></line>
                      <path d="M12 2L20 6.5V15.5L12 20L4 15.5V6.5L12 2Z"></path>
                      <path d="M12 20V11"></path>
                      <path d="M12 11L20 6.5"></path>
                      <path d="M12 11L4 6.5"></path>
                    </svg>
                  {%- when 'payment' -%}
                    <svg class="icon icon-payment" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 1.8rem; height: 1.8rem; display: block;">
                      <rect x="2" y="5" width="20" height="14" rx="2" ry="2"></rect>
                      <line x1="2" y1="10" x2="22" y2="10"></line>
                      <path d="M16 14l2 2 4-4"></path>
                    </svg>
                  {%- when 'warranty' -%}
                    <svg class="icon icon-warranty" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 1.8rem; height: 1.8rem; display: block;">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                      <path d="M9 11l2 2 4-4"></path>
                    </svg>
                {%- endcase -%}
              </span>
            {%- endif -%}
            
            <span class="utility-bar-desktop__text">{{ block.settings.text | escape }}</span>
            
            {%- if block.settings.link != blank -%}
              </a>
            {%- endif -%}
          {%- endif -%}
        </div>
        
        {%- unless forloop.last -%}
          <span class="utility-bar-desktop__separator">|</span>
        {%- endunless -%}
      {%- endfor -%}
    </div>
    
    <!-- Right side selectors and store location link -->
    <div class="utility-bar-desktop__right">
      {%- if section.settings.enable_country_selector and localization.available_countries.size >= 1 -%}
        <localization-form>
          {%- form 'localization', id: 'AnnouncementCountryFormDesktop', class: 'localization-form' -%}
            <div>
              <h2 class="visually-hidden" id="AnnouncementCountryLabelDesktop">{{ 'localization.country_label' | t }}</h2>
              {%- render 'country-localization', localPosition: 'AnnouncementCountry' -%}
            </div>
          {%- endform -%}
        </localization-form>
      {% endif %}

      {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
        <localization-form>
          {%- form 'localization', id: 'AnnouncementLanguageFormDesktop', class: 'localization-form' -%}
            <div>
              <h2 class="visually-hidden" id="AnnouncementLanguageLabelDesktop">{{ 'localization.language_label' | t }}</h2>
              {%- render 'language-localization', localPosition: 'AnnouncementLanguage' -%}
            </div>
          {%- endform -%}
        </localization-form>
      {%- endif -%}

      {%- if section.settings.store_location_label != blank -%}
        <a 
          {% if section.settings.store_location_link != blank %}href="{{ section.settings.store_location_link }}"{% else %}href="#"{% endif %}
          class="utility-bar-desktop__store-location link link--text caption-large"
        >
          <span class="utility-bar-desktop__store-location-icon" style="display: inline-flex; align-items: center; justify-content: center;">
            <svg class="icon icon-map-pin" viewBox="0 0 20 20" fill="currentColor" style="width: 1.6rem; height: 1.6rem; display: block;">
              <path fill-rule="evenodd" d="m9.91 18.59 5.036-8.78c2.228-3.886-.525-8.777-4.942-8.777-4.385 0-7.147 4.822-4.992 8.713zM10.004 0C4.845 0 1.593 5.673 4.13 10.255l5.212 9.41a.64.64 0 0 0 1.12.009l5.358-9.342C18.445 5.755 15.202 0 10.004 0"/>
