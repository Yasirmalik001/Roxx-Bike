{%- style -%}
.section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px; padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px; }
@media screen and (min-width: 750px) { .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; } }
.our-values-header { text-align: center; margin-bottom: 3rem; }
.our-values-heading { font-size: clamp(28px, 4vw, 42px); color: inherit; margin: 0; line-height: 1.2; }
.our-values-grid { display: grid; grid-template-columns: 1fr; gap: 2rem; }
@media screen and (min-width: 750px) { .our-values-grid { grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr); } }
.our-values-card { border-radius: 24px; padding: 1.5rem; display: flex; flex-direction: column; align-items: center; text-align: center; height: 100%; box-shadow: 0 10px 30px rgba(0,0,0,0.03); }
.our-values-image-wrap { width: 100%; margin-bottom: 1.5rem; overflow: hidden; border-radius: 12px; }
.our-values-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 4/3;
}
.our-values-placeholder { width: 100%; aspect-ratio: 4 / 3; background-color: rgba(var(--color-foreground), 0.05); display: flex; align-items: center; justify-content: center; }
.our-values-placeholder svg { width: 40px; height: 40px; fill: rgba(var(--color-foreground), 0.5); }
.our-values-title { font-size: 18px; font-weight: 600; margin: 0 0 1rem 0; color: inherit; }
.our-values-text { font-size: 13px; line-height: 1.6; color: inherit; opacity: 0.9; margin: 0; }
.our-values-text p { margin: 0 0 1rem 0; }
.our-values-text p:last-child { margin: 0; }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    
    {%- if section.settings.heading != blank -%}
      <div class="our-values-header">
        <h2 class="our-values-heading">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="our-values-grid">
      {%- for block in section.blocks -%}
        <div class="our-values-card color-{{ section.settings.card_color_scheme }} gradient" {{ block.shopify_attributes }}>
          
          <div class="our-values-image-wrap">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title | escape }}" loading="lazy" class="our-values-img">
            {%- else -%}
              <div class="our-values-placeholder">
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>

          {%- if block.settings.title != blank -%}
            <p class="our-values-title">{{ block.settings.title }}</p>
          {%- endif -%}

          {%- if block.settings.text != blank -%}
            <div class="our-values-text">{{ block.settings.text }}</div>
          {%- endif -%}

        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Our Values",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Main Section Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "card_color_scheme",
      "label": "Card Color Scheme",
      "default": "scheme-2"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our values"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Desktop Columns",
      "default": 3
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value Card",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Women's Health"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Sereluna was created because there are better alternatives to disposable period products. We believe women deserve better.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Our Values",
      "blocks": [
        {
          "type": "value",
          "settings": {
            "title": "Women's Health",
            "text": "<p>Sereluna was created because there are better alternatives to disposable period products. We believe women deserve better.</p>"
          }
        },
        {
          "type": "value",
          "settings": {
            "title": "Quality",
            "text": "<p>Sereluna delivers products of top quality. We carefully select all our materials ourselves so we can maintain full control over quality.</p>"
          }
        },
        {
          "type": "value",
          "settings": {
            "title": "Sustainability",
            "text": "<p>Sustainability is at the core of how we operate. It's not just about the products we make — it's about how we run our business.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}