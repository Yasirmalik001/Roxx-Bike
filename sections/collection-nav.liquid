{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .cn-list {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 30px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .cn-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    cursor: pointer;
    color: inherit;
  }

.cn-image-box {
    width: 100%;
    height: 100%;
    background-color: rgba(var(--color-foreground), 0.05);
    border-radius: 25px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid transparent;
    transition: all 0.3s ease;
    margin-bottom: 12px;
    position: relative;
    box-sizing: border-box;
    max-height: 151px;
    max-width: 150px;
}
  .cn-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .cn-item:hover .cn-image {
    transform: scale(1.05);
  }

  .cn-droplet-icon {
    display: flex;
    justify-content: center;
    margin-bottom: 8px;
  }

  .cn-droplet-img {
    height: 20px;
    width: auto;
    object-fit: contain;
  }

  .cn-title {
    font-weight: 500;
    font-size: 14px;
    line-height: 1.4;
    text-align: center;
    color: inherit;
  }

  @media screen and (max-width: 768px) {
.cn-list {
    gap: 5px;
    position: relative;
    flex-wrap: nowrap;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scroll-padding-left: 1.5rem;
    -webkit-overflow-scrolling: touch;
    margin-bottom: 1rem;
    align-items: start;
    justify-content: center;
}
    .cn-item {
      flex: 0 0 116px;
    }
    .cn-image-box {
      max-height: 118px;
    }
  }

  @media screen and (max-width: 400px) {
    .cn-item {
      flex: 0 0 110px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="cn-container page-width">
    <div class="cn-list">
      {%- for block in section.blocks -%}
        {%- liquid
          assign is_active = false
          
          if collection.handle != blank and block.settings.collection_ref != blank
            if collection.handle == block.settings.collection_ref.handle
              assign is_active = true
            endif
          endif

          if request.path == block.settings.custom_url
             assign is_active = true
          endif
          
          assign image = block.settings.custom_image
          if image == blank and block.settings.collection_ref != blank
             assign image = block.settings.collection_ref.featured_image
          endif
          
          assign link_url = block.settings.custom_url
          if link_url == blank and block.settings.collection_ref != blank
             assign link_url = block.settings.collection_ref.url
          endif
        -%}

        <a href="{{ link_url }}" class="cn-item {% if is_active %}active{% endif %}" {{ block.shopify_attributes }}>
          <div class="cn-image-box">
            {%- if image != blank -%}
              <img 
                src="{{ image | image_url: width: 400 }}" 
                alt="{{ block.settings.title | escape }}" 
                class="cn-image"
                loading="lazy"
              >
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'cn-image' }}
            {%- endif -%}
          </div>
          
          {%- if block.settings.droplet_image != blank -%}
            <div class="cn-droplet-icon">
              {{ block.settings.droplet_image | image_url: width: 100 | image_tag: loading: 'lazy', class: 'cn-droplet-img' }}
            </div>
          {%- endif -%}

          <span class="cn-title">
            {%- if block.settings.title != blank -%}
              {{ block.settings.title }}
            {%- else -%}
              {{ block.settings.collection_ref.title }}
            {%- endif -%}
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection Navigation",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "collection_item",
      "name": "Category",
      "settings": [
        {
          "type": "header",
          "content": "Configuration"
        },
        {
          "type": "collection",
          "id": "collection_ref",
          "label": "Select Collection",
          "info": "Selection here ensures the 'Active' border works correctly."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom Title",
          "info": "Overrides the collection title"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image",
          "info": "Overrides the collection image"
        },
        {
          "type": "image_picker",
          "id": "droplet_image",
          "label": "Droplet Icon",
          "info": "Optional droplet flow icon placed above the title"
        },
        {
          "type": "url",
          "id": "custom_url",
          "label": "Custom Link (Optional)",
          "info": "Only use if not selecting a collection above."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Navigation",
      "blocks": [
        { "type": "collection_item" },
        { "type": "collection_item" },
        { "type": "collection_item" }
      ]
    }
  ]
}
{% endschema %}