{{ 'section-hero-overlay.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .custom-hero-{{ section.id }} {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: {{ section.settings.mobile_height }}px;
    background-color: #000000;
  }

  @media screen and (min-width: 750px) {
    .custom-hero-{{ section.id }} {
      min-height: {{ section.settings.desktop_height }}px;
    }
  }

  .custom-hero-{{ section.id }} .hero-background-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .custom-hero-{{ section.id }} .hero-overlay {
    position: absolute;
    inset: 0;
    background: #000000;
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 2;
  }

  .custom-hero-{{ section.id }} .hero-content-wrapper {
    position: relative;
    z-index: 3;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding: 2rem;
    max-width: 800px;
  }
{%- endstyle -%}

<div class="custom-hero-{{ section.id }} section-{{ section.id }}-padding">
  {%- if section.settings.image != blank -%}
    {{
      section.settings.image
      | image_url: width: 3840
      | image_tag:
        loading: 'lazy',
        class: 'hero-background-image',
        sizes: '100vw',
        widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
    }}
  {%- endif -%}

  <div class="hero-overlay"></div>

  <div class="hero-content-wrapper">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        
        {%- when 'icon' -%}
          <div class="hero-block-icon" {{ block.shopify_attributes }} style="--icon-width: {{ block.settings.icon_width }}px; margin-bottom: {{ block.settings.margin_bottom }}px;">
            {%- if block.settings.custom_svg != blank -%}
              <div class="icon-svg-wrapper">
                {{ block.settings.custom_svg }}
              </div>
            {%- elsif block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: block.settings.icon_width }}" alt="Icon" loading="lazy">
            {%- else -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-svg-wrapper">
                <circle cx="12" cy="12" r="3"></circle>
                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
              </svg>
            {%- endif -%}
          </div>

        {%- when 'heading' -%}
          <h2 class="hero-block-heading h1" {{ block.shopify_attributes }} style="color: {{ block.settings.color }};">
            {{ block.settings.heading | escape }}
          </h2>

        {%- when 'text' -%}
          <div class="hero-block-text" {{ block.shopify_attributes }} style="color: {{ block.settings.color }};">
            {{ block.settings.text }}
          </div>

        {%- when 'button' -%}
          {%- if block.settings.button_label != blank -%}
            <a href="{{ block.settings.button_link }}" class="button button--primary hero-block-button" {{ block.shopify_attributes }}>
              {{ block.settings.button_label | escape }}
            </a>
          {%- endif -%}

      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>

<style>
  /* Base Scoped Styles */
  .hero-block-icon {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .hero-block-icon .icon-svg-wrapper,
  .hero-block-icon img {
    width: var(--icon-width);
    max-width: 100%;
    height: auto;
    display: block;
  }
  .hero-block-icon .icon-svg-wrapper svg {
    width: 100%;
    height: auto;
  }
  .hero-block-heading {
    margin: 0;
    font-size: 3.6rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    line-height: 1.1;
  }
  .hero-block-text {
    font-size: 1.5rem;
    line-height: 1.6;
    margin: 0 auto;
    max-width: 650px;
    font-weight: 400;
  }
  .hero-block-text p {
    margin: 0;
  }
  .hero-block-button {
    margin-top: 1rem;
    min-width: 200px;
  }

  @media screen and (max-width: 749px) {
    .hero-block-heading {
      font-size: 2.8rem;
    }
    .hero-block-text {
      font-size: 1.4rem;
    }
  }
</style>

{% schema %}
{
  "name": "Overlay Banner (Blocks)",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay Opacity",
      "default": 40
    },
    {
      "type": "range",
      "id": "desktop_height",
      "min": 400,
      "max": 1000,
      "step": 20,
      "unit": "px",
      "label": "Desktop Height",
      "default": 600
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 300,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Mobile Height",
      "default": 500
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "icon",
      "name": "Icon",
      "limit": 1,
      "settings": [
        {
          "type": "html",
          "id": "custom_svg",
          "label": "Custom SVG Code",
          "info": "Paste your raw SVG code here."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Or Image fallback"
        },
        {
          "type": "range",
          "id": "icon_width",
          "min": 20,
          "max": 200,
          "step": 2,
          "unit": "px",
          "label": "Icon Width",
          "default": 64
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "min": 0,
          "max": 50,
          "step": 2,
          "unit": "px",
          "label": "Bottom Margin",
          "default": 10
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "LESS MAINTENANCE. MORE RIDING.",
          "label": "Heading"
        },
        {
          "type": "color",
          "id": "color",
          "label": "Text Color",
          "default": "#FFFFFF"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 2,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Thanks to the carbon belt drive, you get a cleaner, quieter, and more durable alternative to traditional chains — with minimal upkeep required.</p>",
          "label": "Description"
        },
        {
          "type": "color",
          "id": "color",
          "label": "Text Color",
          "default": "#FFFFFF"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label",
          "default": "Learn More",
          "label": "Button Label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Overlay Banner (Blocks)",
      "blocks": [
        {
          "type": "icon"
        },
        {
          "type": "heading"
        },
        {
          "type": "text"
        },
        {
          "type": "button"
        }
      ]
    }
  ]
}
{% endschema %}