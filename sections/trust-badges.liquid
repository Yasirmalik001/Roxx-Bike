{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .trust-badges-wrapper {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2.5rem 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .trust-badge-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: calc(50% - 0.75rem); /* 2 items per row on mobile */
  }

  .trust-badge-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    margin-bottom: 1.2rem;
  }

  .trust-badge-icon img,
  .trust-badge-icon svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
    fill: currentColor;
    color: rgb(var(--color-foreground));
  }

  .trust-badge-text {
    margin: 0;
    font-size: 1.3rem;
    font-weight: 600;
    line-height: 1.3;
    color: rgb(var(--color-foreground));
    letter-spacing: 0.04rem;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .trust-badges-wrapper {
      justify-content: space-between;
      flex-wrap: nowrap;
      gap: 2rem;
    }

    .trust-badge-item {
      width: auto;
      flex: 1 1 0; /* Distributes space evenly on desktop */
      max-width: 25rem;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <ul class="trust-badges-wrapper" role="list">
      {%- for block in section.blocks -%}
        <li class="trust-badge-item" {{ block.shopify_attributes }}>
          <div class="trust-badge-icon">
            {%- if block.settings.custom_svg != blank -%}
              {{ block.settings.custom_svg }}
            {%- elsif block.settings.image != blank -%}
              {%- assign image_width = section.settings.icon_size | times: 2 -%}
              {{ block.settings.image | image_url: width: image_width | image_tag: loading: 'lazy', alt: block.settings.title | escape }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          {%- if block.settings.title != blank -%}
            <p class="trust-badge-text">{{ block.settings.title }}</p>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>

{% schema %}
{
  "name": "Trust Badges",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 24,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Icon size",
      "default": 40
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "limit": 6,
      "settings": [
        {
          "type": "html",
          "id": "custom_svg",
          "label": "Custom SVG Code",
          "info": "Recommended for crisp icons. Paste raw SVG code here."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Fallback Image",
          "info": "Used if no SVG is provided above."
        },
        {
          "type": "inline_richtext",
          "id": "title",
          "default": "Feature Title",
          "label": "Heading"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Badges",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "title": "1-Year Warranty Included"
          }
        },
        {
          "type": "badge",
          "settings": {
            "title": "Fast 7–10 Day Delivery"
          }
        },
        {
          "type": "badge",
          "settings": {
            "title": "Interest-Free Payments"
          }
        },
        {
          "type": "badge",
          "settings": {
            "title": "Premium Quality at Fair Prices"
          }
        }
      ]
    }
  ]
}
{% endschema %}