{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .trust-badges__grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 3rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media screen and (min-width: 500px) {
    .trust-badges__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    .trust-badges__grid {
      grid-template-columns: repeat({{ section.blocks.size | at_most: 4 }}, 1fr);
      gap: 2rem;
    }
  }

  .trust-badge__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .trust-badge__icon-wrapper {
    width: 80px;
    height: 80px;
    background-color: #f7f7f7;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .trust-badge__icon-wrapper svg {
    width: 32px;
    height: 32px;
    fill: none;
    stroke: #000000;
    stroke-width: 1.2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  
  .trust-badge__icon-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 24px; /* keeps custom images sized similarly to SVGs */
  }

  .trust-badge__text {
    font-size: 1.5rem;
    color: #333333;
    margin: 0;
    font-weight: 400;
  }
{%- endstyle -%}

<div class="trust-badges section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    <ul class="trust-badges__grid">
      
      {%- for block in section.blocks -%}
        <li class="trust-badge__item" {{ block.shopify_attributes }}>
          <div class="trust-badge__icon-wrapper">
            
            {%- if block.settings.custom_svg != blank -%}
              {{ block.settings.custom_svg }}
            {%- elsif block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 160 | image_tag: loading: 'lazy' }}
            {%- else -%}
              
              {%- case forloop.index -%}
                {%- when 1 -%}
                  <svg viewBox="0 0 24 24">
                    <polygon points="12 3 20 7.5 20 16.5 12 21 4 16.5 4 7.5 12 3"></polygon>
                    <line x1="12" y1="3" x2="12" y2="21"></line>
                    <line x1="20" y1="7.5" x2="4" y2="16.5"></line>
                    <line x1="4" y1="12" x2="1.5" y2="12"></line>
                    <line x1="2.5" y1="9" x2="0.5" y2="9"></line>
                    <line x1="3" y1="15" x2="1" y2="15"></line>
                  </svg>
                {%- when 2 -%}
                  <svg viewBox="0 0 24 24">
                    <rect x="2" y="5" width="20" height="14" rx="2" ry="2"></rect>
                    <line x1="2" y1="10" x2="22" y2="10"></line>
                    <circle cx="18" cy="16" r="4" fill="#f7f7f7"></circle>
                    <polyline points="16.5 16 17.5 17 19.5 15"></polyline>
                  </svg>
                {%- when 3 -%}
                  <svg viewBox="0 0 24 24">
                    <path d="M18 16c1.1 0 2-.9 2-2V10c0-4.4-3.6-8-8-8S4 5.6 4 10v4c0 1.1.9 2 2 2h1v-7h10v7h-3"></path>
                    <path d="M15 19v1c0 1.1-.9 2-2 2h-4"></path>
                    <line x1="15" y1="18" x2="15" y2="18.01"></line>
                  </svg>
                {%- when 4 -%}
                  <svg viewBox="0 0 24 24">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                    <polyline points="9 12 11 14 15 10"></polyline>
                  </svg>
                {%- else -%}
                  <svg viewBox="0 0 24 24">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
              {%- endcase -%}

            {%- endif -%}

          </div>
          
          {%- if block.settings.text != blank -%}
            <p class="trust-badge__text">{{ block.settings.text }}</p>
          {%- endif -%}
        </li>
      {%- endfor -%}
      
    </ul>
  </div>
</div>

{% schema %}
{
  "name": "Trust Badges",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 5,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "html",
          "id": "custom_svg",
          "label": "Custom SVG Code",
          "info": "Overrides the image picker if populated."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image Fallback"
        },
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "Text",
          "default": "Feature description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Badges",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "text": "Free and Fast delivery"
          }
        },
        {
          "type": "badge",
          "settings": {
            "text": "Secure payment"
          }
        },
        {
          "type": "badge",
          "settings": {
            "text": "Strong customer service"
          }
        },
        {
          "type": "badge",
          "settings": {
            "text": "2-years warranty"
          }
        }
      ]
    }
  ]
}
{% endschema %}