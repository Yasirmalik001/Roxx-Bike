<div class="product-custom__info-card">
  {% for block in blocks %}
    {% case block.type %}
      {% when 'title' %}
        <div class="product-custom__title-block" {{ block.shopify_attributes }}>
          <h1 class="product-custom__title">{{ product.title | escape }}</h1>
        </div>

      {% when 'price' %}
        <div class="product-custom__price-row" id="price-{{ section.id }}" {{ block.shopify_attributes }}>
          <span class="product-custom__price-final">{{ product.selected_or_first_available_variant.price | money }}</span>
          {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
            <span class="product-custom__price-compare">{{ product.selected_or_first_available_variant.compare_at_price | money }}</span>
          {% endif %}
        </div>

      {% when 'installment' %}
        <div class="product-custom__installments" {{ block.shopify_attributes }}>
          <div class="product-custom__installments-icons">
            <svg viewBox="0 0 100 25" width="40" height="10"><rect width="100" height="25" fill="#FFB3C7" rx="12.5"/><text x="50" y="16" font-family="Arial" font-size="12" font-weight="bold" text-anchor="middle" fill="#000">Klarna.</text></svg>
          </div>
          <span>Pay in 3 interest-free installments</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
        </div>

      {% when 'description' %}
        <div class="product-custom__description-block" style="margin-top: 1.5rem;" {{ block.shopify_attributes }}>
          <div class="product-custom__description">{{ block.settings.text }}</div>
        </div>

      {% when 'inventory' %}
        <div class="product-custom__inventory" style="margin-top: 1.5rem;" {{ block.shopify_attributes }}>
          <div class="product-custom__inventory-dot"></div>
          <span><strong>In stock.</strong> Delivery in 4-5 days</span>
        </div>

      {% when 'buy_buttons' %}
        <div class="product-custom__buy-buttons" {{ block.shopify_attributes }}>
          <button type="button" class="product-custom__btn product-custom__btn--primary">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
            ADD TO CART
          </button>
          <button type="button" class="product-custom__btn product-custom__btn--secondary">
            BOOK A TEST RIDE
          </button>
        </div>

      {% when 'payment_icons' %}
        {% render 'product-payment-icons', block: block %}

      {% when 'accessory' %}
        {% render 'product-accessories', block: block %}

      {% when 'insurance' %}
        {% render 'product-insurance', block: block %}

      {% when 'review_avatars' %}
        {% render 'product-review-avatars', block: block %}

      {% when 'feature_icons' %}
        {% render 'product-feature-icons', block: block %}

    {% endcase %}
  {% endfor %}
</div>
