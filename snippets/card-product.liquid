{%- if card_product and card_product != empty -%}
  <style>
    .roxx-product-card {
      background-color: #F8F9FA;
      border-radius: 16px;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      position: relative;
      font-family: inherit;
      transition: box-shadow 0.3s ease;
      height: 100%;
    }

    .roxx-product-card:hover {
      box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    }

    /* Image Styling */
    .roxx-card-image-wrapper {
      position: relative;
      width: 100%;
      padding-top: 100%; /* 1:1 Aspect Ratio */
      margin-bottom: 1rem;
      display: block;
    }

    .roxx-card-image-wrapper img {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      max-width: 115%; /* Slight pop-out effect */
      max-height: 115%;
      object-fit: contain;
      mix-blend-mode: multiply; /* Removes white background from jpegs if any */
    }

    /* Title & Subtitle */
    .roxx-card-title {
      font-size: 1.6rem;
      font-weight: 800;
      color: #111111;
      margin: 0 0 0.2rem 0;
      line-height: 1.2;
      text-decoration: none;
      letter-spacing: -0.02em;
    }

    .roxx-card-subtitle {
      font-size: 0.95rem;
      color: #555555;
      margin: 0 0 1.2rem 0;
    }

    /* Specs Grid */
    .roxx-specs-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
    }

    .roxx-spec-pill {
      background-color: #FFFFFF;
      padding: 0.6rem 0.5rem;
      border-radius: 8px;
      font-size: 0.75rem;
      color: #333333;
      text-align: center;
      font-weight: 500;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* Pricing Area */
    .roxx-price-row {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
    }

    .roxx-price-current {
      font-size: 1.4rem;
      font-weight: 900;
      color: #111111;
    }

    .roxx-price-compare {
      font-size: 1.1rem;
      font-weight: 700;
      color: #A3A3A3;
      text-decoration: line-through;
    }

    .roxx-save-badge {
      background-color: #B92330;
      color: #FFFFFF;
      padding: 0.3rem 0.6rem;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    /* Buttons */
    .roxx-actions-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.8rem;
      margin-top: auto;
      margin-bottom: 1rem;
    }

    .roxx-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 12px 10px;
      border-radius: 30px;
      font-size: 0.8rem;
      font-weight: 800;
      text-transform: uppercase;
      text-decoration: none;
      cursor: pointer;
      transition: opacity 0.2s ease;
      text-align: center;
    }

    .roxx-btn:hover {
      opacity: 0.85;
    }

    .roxx-btn-primary {
      background-color: #FFD100;
      color: #000000;
      border: 1px solid #FFD100;
    }

    .roxx-btn-secondary {
      background-color: #FFFFFF;
      color: #000000;
      border: 1px solid #111111;
    }

    /* Payment Strip */
    .roxx-payment-strip {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      font-size: 0.7rem;
      color: #555555;
      font-weight: 500;
      flex-wrap: wrap;
    }

    .roxx-payment-mock {
      display: flex;
      align-items: center;
      gap: 4px;
    }
    
    .mock-klarna { background: #FFA8C2; color: #000; padding: 2px 5px; border-radius: 3px; font-weight: 800; font-size: 0.55rem; }
    .mock-ideal { background: #fff; color: #000; padding: 1px 4px; border-radius: 3px; border: 1px solid #000; font-weight: 800; font-size: 0.55rem; }
    .mock-spraypay { color: #0076B6; font-weight: 800; font-size: 0.55rem; }

  </style>

  <div class="roxx-product-card">
    <a href="{{ card_product.url }}" class="roxx-card-image-wrapper">
      {%- if card_product.featured_media -%}
        {{ card_product.featured_media | image_url: width: 800 | image_tag: loading: 'lazy', alt: card_product.title }}
      {%- else -%}
        {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </a>

    <a href="{{ card_product.url }}" style="text-decoration: none;">
      <h3 class="roxx-card-title">{{ card_product.title | escape }}</h3>
    </a>
    <p class="roxx-card-subtitle">
      {{ card_product.metafields.custom.subtitle | default: 'For easy commuting' }}
    </p>

    <div class="roxx-specs-grid">
      <div class="roxx-spec-pill" title="{{ card_product.metafields.custom.spec_1 | default: 'Endless design frame' }}">
        {{ card_product.metafields.custom.spec_1 | default: 'Endless design frame' }}
      </div>
      <div class="roxx-spec-pill" title="{{ card_product.metafields.custom.spec_2 | default: 'Range of 80-90km' }}">
        {{ card_product.metafields.custom.spec_2 | default: 'Range of 80-90km' }}
      </div>
      <div class="roxx-spec-pill" title="{{ card_product.metafields.custom.spec_3 | default: 'Speed 45-50 km/h' }}">
        {{ card_product.metafields.custom.spec_3 | default: 'Speed 45-50 km/h' }}
      </div>
      <div class="roxx-spec-pill" title="{{ card_product.metafields.custom.spec_4 | default: 'Hydraulics brakes' }}">
        {{ card_product.metafields.custom.spec_4 | default: 'Hydraulics brakes' }}
      </div>
    </div>

    <div class="roxx-price-row">
      <span class="roxx-price-current">{{ card_product.price | money }}</span>
      {%- if card_product.compare_at_price > card_product.price -%}
        <span class="roxx-price-compare">{{ card_product.compare_at_price | money }}</span>
        <span class="roxx-save-badge">
          Save {{ card_product.compare_at_price | minus: card_product.price | money }}
        </span>
      {%- endif -%}
    </div>

    <div class="roxx-actions-row">
      <a href="{{ card_product.url }}" class="roxx-btn roxx-btn-primary">SHOP NOW</a>
      <a href="/pages/contact" class="roxx-btn roxx-btn-secondary">BOOK A TEST RIDE</a>
    </div>

    <div class="roxx-payment-strip">
      <div class="roxx-payment-mock">
        <span class="mock-spraypay">SPRAYPAY</span>
        <span class="mock-ideal">iDEAL</span>
        <span class="mock-klarna">Klarna.</span>
      </div>
      <span>Pay in 3 interest-free installments</span>
    </div>
  </div>

{%- else -%}
  <style>
    /* Includes identical inline styles from above to ensure editor loads them correctly */
    .roxx-product-card { background-color: #F8F9FA; border-radius: 16px; padding: 1.5rem; display: flex; flex-direction: column; position: relative; font-family: inherit; height: 100%; }
    .roxx-card-image-wrapper { position: relative; width: 100%; padding-top: 100%; margin-bottom: 1rem; display: block; background: #eee; border-radius: 12px; }
    .roxx-card-title { font-size: 1.6rem; font-weight: 800; color: #111111; margin: 0 0 0.2rem 0; line-height: 1.2; letter-spacing: -0.02em; }
    .roxx-card-subtitle { font-size: 0.95rem; color: #555555; margin: 0 0 1.2rem 0; }
    .roxx-specs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 1.5rem; }
    .roxx-spec-pill { background-color: #FFFFFF; padding: 0.6rem 0.5rem; border-radius: 8px; font-size: 0.75rem; color: #333333; text-align: center; font-weight: 500; }
    .roxx-price-row { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 1.5rem; }
    .roxx-price-current { font-size: 1.4rem; font-weight: 900; color: #111111; }
    .roxx-price-compare { font-size: 1.1rem; font-weight: 700; color: #A3A3A3; text-decoration: line-through; }
    .roxx-save-badge { background-color: #B92330; color: #FFFFFF; padding: 0.3rem 0.6rem; border-radius: 20px; font-size: 0.75rem; font-weight: 700; }
    .roxx-actions-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; margin-top: auto; margin-bottom: 1rem; }
    .roxx-btn { display: flex; align-items: center; justify-content: center; padding: 12px 10px; border-radius: 30px; font-size: 0.8rem; font-weight: 800; text-transform: uppercase; text-decoration: none; text-align: center; }
    .roxx-btn-primary { background-color: #FFD100; color: #000000; border: 1px solid #FFD100; }
    .roxx-btn-secondary { background-color: #FFFFFF; color: #000000; border: 1px solid #111111; }
    .roxx-payment-strip { display: flex; align-items: center; justify-content: center; gap: 0.5rem; font-size: 0.7rem; color: #555555; font-weight: 500; flex-wrap: wrap; }
  </style>

  <div class="roxx-product-card">
    <div class="roxx-card-image-wrapper"></div>
    <h3 class="roxx-card-title">SL5</h3>
    <p class="roxx-card-subtitle">For easy commuting</p>
    <div class="roxx-specs-grid">
      <div class="roxx-spec-pill">Endless design frame</div>
      <div class="roxx-spec-pill">Range of 80-90km</div>
      <div class="roxx-spec-pill">Speed 45-50 km/h</div>
      <div class="roxx-spec-pill">Hydraulics brakes</div>
    </div>
    <div class="roxx-price-row">
      <span class="roxx-price-current">€ 1.599,00</span>
      <span class="roxx-price-compare">€ 2.299,00</span>
      <span class="roxx-save-badge">Save €700.00</span>
    </div>
    <div class="roxx-actions-row">
      <div class="roxx-btn roxx-btn-primary">SHOP NOW</div>
      <div class="roxx-btn roxx-btn-secondary">BOOK A TEST RIDE</div>
    </div>
    <div class="roxx-payment-strip">
      <span>SPRAYPAY iDEAL Klarna</span>
      <span>Pay in 3 interest-free installments</span>
    </div>
  </div>
{%- endif -%}