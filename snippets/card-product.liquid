{% comment %}
  Renders a product card
  Designed 1:1 based on image_3fc602.png
  Requires dynamic text from Metafields and Section/Theme settings.
{% endcomment %}

{%- unless skip_styles -%}
  {{ 'component-rating.css' | asset_url | stylesheet_tag }}
  {{ 'component-volume-pricing.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'quick-order-list.css' | asset_url | stylesheet_tag }}
  {{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

<style>
  /* ROXX Custom Design Overrides - 1:1 Match */
  .roxx-product-card {
    background-color: #F8F9FA !important;
    border-radius: 12px !important;
    padding: 24px !important;
    display: flex;
    flex-direction: column;
    position: relative;
    font-family: inherit;
    transition: box-shadow 0.3s ease;
    height: 100%;
    border: none !important;
  }
  .roxx-card-title {
    font-size: 22.4px;
    font-weight: 900;
    color: #111111;
    margin: 0 0 1.6px 0;
    line-height: 1.2;
    text-decoration: none;
    letter-spacing: -0.02em;
  }
  .roxx-card-subtitle {
    font-size: 13.6px;
    color: #555555;
    margin: 0 0 16px 0;
    font-weight: 500;
  }
  .roxx-specs-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-bottom: 19.2px;
  }
  .roxx-spec-pill {
    background-color: #FFFFFF;
    padding: 8px 8px;
    border-radius: 6px;
    font-size: 11.2px;
    color: #333333;
    text-align: center;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .roxx-price-row {
    display: flex;
    align-items: center;
    gap: 9.6px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  .roxx-price-current {
    font-size: 19.2px;
    font-weight: 900;
    color: #111111;
  }
  .roxx-price-compare {
    font-size: 16px;
    font-weight: 700;
    color: #A3A3A3;
    text-decoration: line-through;
  }
  .roxx-save-badge {
    background-color: #B22222; /* Matched dark red from image */
    color: #FFFFFF;
    padding: 4px 9.6px;
    border-radius: 20px;
    font-size: 11.2px;
    font-weight: 700;
  }
  .roxx-actions-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 9.6px;
    margin-top: auto;
    margin-bottom: 16px;
    align-items: end;
  }
  /* Buttons */
  .roxx-actions-row .quick-add__submit,
  .roxx-actions-row .roxx-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px 5px;
    border-radius: 30px !important;
    font-size: 12px;
    font-weight: 900;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.2s ease;
    text-align: center;
    min-height: 40px;
    margin: 0;
    width: 100%;
  }
  .roxx-actions-row .quick-add__submit {
    background-color: #FFD100 !important;
    color: #000000 !important;
    border: none !important;
    box-shadow: none !important;
  }
  .roxx-actions-row .quick-add__submit:hover { opacity: 0.85; }
  .roxx-actions-row .roxx-btn-secondary {
    background-color: #FFFFFF !important;
    color: #000000 !important;
    border: 1px solid #111111 !important;
  }
  .roxx-payment-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 10.4px;
    color: #555555;
    font-weight: 500;
    flex-wrap: wrap;
    margin-top: 8px;
  }
  .roxx-payment-logos {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .roxx-payment-logos img {
    height: 14px; 
    width: auto;
  }
  
  /* Hide standard card info to replace with Roxx layout */
  .roxx-product-card > .card__content { padding: 0 !important; }
</style>

{%- if card_product and card_product != empty -%}
  {%- liquid
    assign ratio = 1
    if card_product.featured_media and media_aspect_ratio == 'portrait'
      assign ratio = 0.8
    elsif card_product.featured_media and media_aspect_ratio == 'adapt'
      assign ratio = card_product.featured_media.aspect_ratio
    endif
    if ratio == 0 or ratio == null
      assign ratio = 1
    endif

    assign cp_swatch_key = swatch_option | default: 'Color' | downcase
    assign cp_found_option = null
    for option in card_product.options_with_values
      assign option_name_lower = option.name | downcase
      if option_name_lower == cp_swatch_key
        assign cp_found_option = option
        break
      endif
    endfor
    
    assign text_shop_now = settings.roxx_shop_now_text | default: 'SHOP NOW'
    assign text_test_ride = settings.roxx_test_ride_text | default: 'BOOK A TEST RIDE'
    assign link_test_ride = settings.roxx_test_ride_link | default: '/pages/contact'
    assign text_payment = settings.roxx_payment_text | default: 'Pay in 3 interest-free installments'
  -%}
  
  <div class="card-wrapper product-card-wrapper underline-links-hover roxx-product-card">
    <div
      class="
        card card--{{ settings.card_style }}
        {% if card_product.featured_media %} card--media{% else %} card--text{% endif %}
        {% if extend_height %} card--extend-height{% endif %}
        {% if horizontal_class %} card--horizontal{% endif %}
      "
      style="background: transparent; border: none; box-shadow: none;"
    >
      <div class="card-overlay-badges">
        {%- if card_product.metafields.custom.period_level != blank -%}
        <div class="card-overlay-droplet">
          {% render 'level' , count: card_product.metafields.custom.period_level.value.level %}
        </div>
      {%- endif -%}
      {%- if card_product.metafields.custom.badge != blank -%}
        <div class="card-overlay-badge">
          {{ card_product.metafields.custom.badge }}
        </div>
      {%- endif -%}
      </div>

      <div
        class="card__inner ratio"
        style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;"
      >
        {%- if card_product.featured_media -%}
          <a href="{{ card_product.url }}" class="card__media" style="display: block;">
            <div class="media media--transparent media--hover-effect">
              {% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
              <img
                srcset="
                  {%- if card_product.featured_media.width >= 165 -%}{{ card_product.featured_media | image_url: width: 165 }} 165w,{%- endif -%}
                  {%- if card_product.featured_media.width >= 360 -%}{{ card_product.featured_media | image_url: width: 360 }} 360w,{%- endif -%}
                  {%- if card_product.featured_media.width >= 533 -%}{{ card_product.featured_media | image_url: width: 533 }} 533w,{%- endif -%}
                  {%- if card_product.featured_media.width >= 720 -%}{{ card_product.featured_media | image_url: width: 720 }} 720w,{%- endif -%}
                  {%- if card_product.featured_media.width >= 940 -%}{{ card_product.featured_media | image_url: width: 940 }} 940w,{%- endif -%}
                  {{ card_product.featured_media | image_url }} {{ card_product.featured_media.width }}w
                "
                src="{{ card_product.featured_media | image_url: width: 533 }}"
                sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
                alt="{{ card_product.featured_media.alt | escape }}"
                class="motion-reduce"
                {% unless lazy_load == false %} loading="lazy"{% endunless %}
                width="{{ card_product.featured_media.width }}"
                height="{{ card_product.featured_media.height }}"
              >
              {% comment %}theme-check-enable ImgLazyLoading{% endcomment %}

              {%- if card_product.media[1] != null and show_secondary_image -%}
                <img
                  srcset="
                    {%- if card_product.media[1].width >= 165 -%}{{ card_product.media[1] | image_url: width: 165 }} 165w,{%- endif -%}
                    {%- if card_product.media[1].width >= 360 -%}{{ card_product.media[1] | image_url: width: 360 }} 360w,{%- endif -%}
                    {%- if card_product.media[1].width >= 533 -%}{{ card_product.media[1] | image_url: width: 533 }} 533w,{%- endif -%}
                    {{ card_product.media[1] | image_url }} {{ card_product.media[1].width }}w
                  "
                  src="{{ card_product.media[1] | image_url: width: 533 }}"
                  sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
                  alt="{{ card_product.media[1].alt | escape }}"
                  class="motion-reduce"
                  loading="lazy"
                  width="{{ card_product.media[1].width }}"
                  height="{{ card_product.media[1].height }}"
                >
              {%- endif -%}
            </div>
          </a>
        {%- endif -%}
      </div>
      
      <div class="card__content" style="display: flex; flex-direction: column; flex-grow: 1;">
        
        <a href="{{ card_product.url }}" style="text-decoration: none;">
          <h3 class="roxx-card-title">{{ card_product.title | escape }}</h3>
        </a>
        
        <!-- Dynamic Subtitle -->
        {% if card_product.metafields.custom.subtitle != blank %}
          <p class="roxx-card-subtitle">{{ card_product.metafields.custom.subtitle }}</p>
        {% endif %}

        <!-- Dynamic Specs Grid -->
        <div class="roxx-specs-grid">
          {% if card_product.metafields.custom.spec_1 != blank %}
            <div class="roxx-spec-pill" title="{{ card_product.metafields.custom.spec_1 }}">
              {{ card_product.metafields.custom.spec_1 }}
            </div>
          {% endif %}
          {% if card_product.metafields.custom.spec_2 != blank %}
            <div class="roxx-spec-pill" title="{{ card_product.metafields.custom.spec_2 }}">
              {{ card_product.metafields.custom.spec_2 }}
            </div>
          {% endif %}
          {% if card_product.metafields.custom.spec_3 != blank %}
            <div class="roxx-spec-pill" title="{{ card_product.metafields.custom.spec_3 }}">
              {{ card_product.metafields.custom.spec_3 }}
            </div>
          {% endif %}
          {% if card_product.metafields.custom.spec_4 != blank %}
            <div class="roxx-spec-pill" title="{{ card_product.metafields.custom.spec_4 }}">
              {{ card_product.metafields.custom.spec_4 }}
            </div>
          {% endif %}
        </div>

        <div class="roxx-price-row">
          <span class="roxx-price-current">{{ card_product.price | money }}</span>
          {%- if card_product.compare_at_price > card_product.price -%}
            <span class="roxx-price-compare">{{ card_product.compare_at_price | money }}</span>
            <span class="roxx-save-badge">
              Save {{ card_product.compare_at_price | minus: card_product.price | money }}
            </span>
          {%- endif -%}
        </div>

        {%- if show_swatches and cp_found_option and cp_found_option.values.size > 0 -%}
          <div class="card-product__swatches" role="list" style="display:inline-flex;align-items:center;gap:0.375rem;margin-bottom:1rem;">
            {%- assign cp_swatch_max = swatch_limit | default: 6 -%}
            {%- for value in cp_found_option.values limit: cp_swatch_max -%}
              {%- liquid
                assign sw_bg = ''
                if value.swatch.image
                  assign sw_img_url = value.swatch.image | image_url: width: 50
                  assign sw_bg = 'url(' | append: sw_img_url | append: ')'
                elsif value.swatch.color
                  assign sw_bg = 'rgb(' | append: value.swatch.color.rgb | append: ')'
                else
                  assign sw_bg = value | downcase
                endif
              -%}
              <span class="card-product__swatch" style="display:inline-block;width:16px;height:16px;border-radius:50%;border:1px solid rgba(0,0,0,0.12);background:{{ sw_bg }};background-size:cover;background-position:center;box-shadow:inset 0 0 0 2px #fff;font-size:0;"></span>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if show_delivery and delivery_text != blank -%}
          <div class="card__delivery" style="display:inline-flex;align-items:center;gap:0.5rem;margin-bottom:1rem;padding:0.5rem 0.75rem;background:rgba(0,0,0,0.03);border-radius:8px;font-size:0.75rem;color:rgba(31,31,31,0.78);">
            <span>{{ delivery_text }}</span>
          </div>
        {%- endif -%}

        <div class="roxx-actions-row">
          {% assign product_form_id = 'quick-add-' | append: section_id | append: card_product.id %}
          
          {% if quick_add == 'standard' %}
            <div class="quick-add no-js-hidden" style="margin: 0;">
              {%- liquid
                assign qty_rules = false
                if card_product.selected_or_first_available_variant.quantity_rule.min > 1 or card_product.selected_or_first_available_variant.quantity_rule.max != null or card_product.selected_or_first_available_variant.quantity_rule.increment > 1
                  assign qty_rules = true
                endif
              -%}
              {%- if card_product.variants_count > 1 or qty_rules -%}
                <modal-opener data-modal="#QuickAdd-{{ card_product.id }}">
                  <button
                    id="{{ product_form_id }}-submit"
                    type="submit"
                    name="add"
                    class="quick-add__submit"
                    aria-haspopup="dialog"
                    aria-labelledby="{{ product_form_id }}-submit title-{{ section_id }}-{{ card_product.id }}"
                    data-product-url="{{ card_product.url }}"
                  >
                    {{ text_shop_now }}
                    {%- render 'loading-spinner' -%}
                  </button>
                </modal-opener>
                <quick-add-modal id="QuickAdd-{{ card_product.id }}" class="quick-add-modal quick-add-modal--drawer">
                  <div role="dialog" aria-modal="true" class="quick-add-modal__content global-settings-popup" tabindex="-1">
                    <button id="ModalClose-{{ card_product.id }}" type="button" class="quick-add-modal__toggle" aria-label="{{ 'accessibility.close' | t }}">
                      {{- 'icon-close.svg' | inline_asset_content -}}
                    </button>
                    <div id="QuickAddInfo-{{ card_product.id }}" class="quick-add-modal__content-info"></div>
                  </div>
                </quick-add-modal>
              {%- else -%}
                <product-form data-section-id="{{ section.id }}">
                  {%- form 'product', card_product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                    <input type="hidden" name="id" value="{{ card_product.selected_or_first_available_variant.id }}" class="product-variant-id" {% if card_product.selected_or_first_available_variant.available == false %}disabled{% endif %}>
                    <button
                      id="{{ product_form_id }}-submit"
                      type="submit"
                      name="add"
                      class="quick-add__submit"
                      aria-haspopup="dialog"
                      aria-live="polite"
                      data-sold-out-message="true"
                      {% if card_product.selected_or_first_available_variant.available == false %}disabled{% endif %}
                    >
                      <span>
                        {%- if card_product.selected_or_first_available_variant.available -%}
                          {{ text_shop_now }}
                        {%- else -%}
                          {{ 'products.product.sold_out' | t }}
                        {%- endif -%}
                      </span>
                      <span class="sold-out-message hidden">{{ 'products.product.sold_out' | t }}</span>
                      {%- render 'loading-spinner' -%}
                    </button>
                  {%- endform -%}
                </product-form>
              {%- endif -%}
            </div>
          {% else %}
             <div style="width: 100%;">
              <a href="{{ card_product.url }}" class="quick-add__submit" style="background-color: #FFD100; color: #000; text-decoration: none;">{{ text_shop_now }}</a>
            </div>
          {% endif %}
          
          <a href="{{ link_test_ride }}" class="roxx-btn roxx-btn-secondary">{{ text_test_ride }}</a>
        </div>

        <div class="roxx-payment-strip">
          <div class="roxx-payment-logos">
            {%- if settings.roxx_payment_logo_1 != blank or settings.roxx_payment_logo_2 != blank or settings.roxx_payment_logo_3 != blank -%}
              {%- if settings.roxx_payment_logo_1 != blank -%}
                <img src="{{ settings.roxx_payment_logo_1 | image_url: height: 28 }}" alt="Payment Method 1" loading="lazy" style="height: 14px; width: auto;">
              {%- endif -%}
              {%- if settings.roxx_payment_logo_2 != blank -%}
                <img src="{{ settings.roxx_payment_logo_2 | image_url: height: 28 }}" alt="Payment Method 2" loading="lazy" style="height: 14px; width: auto;">
              {%- endif -%}
              {%- if settings.roxx_payment_logo_3 != blank -%}
                <img src="{{ settings.roxx_payment_logo_3 | image_url: height: 28 }}" alt="Payment Method 3" loading="lazy" style="height: 14px; width: auto;">
              {%- endif -%}
            {%- else -%}
<div class="roxx-payment-logos"><img src="//roxx.bike/cdn/shop/files/e28c38cf50c3b27a71073b6fc52b0f6cc99cccb9.png?height=28&amp;v=1780510808" alt="Payment Method 1" loading="lazy" style="height: 14px; width: auto;"><img src="//roxx.bike/cdn/shop/files/Group_125.svg?height=28&amp;v=1780510807" alt="Payment Method 2" loading="lazy" style="height: 14px; width: auto;"><img src="//roxx.bike/cdn/shop/files/8d4b078bbdc403275d20394187404c948d7ef9e8.png?height=28&amp;v=1780510807" alt="Payment Method 3" loading="lazy" style="height: 14px; width: auto;"></div>
            {%- endif -%}
          </div>
          <span>{{ text_payment }}</span>
        </div>

      </div>
    </div>
  </div>
{%- endif -%}