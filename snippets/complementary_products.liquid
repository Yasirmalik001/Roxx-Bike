<div class="complementary-slider-section" data-block-id="{{ block.id }}">
  <div class="slider-wrapper relative-container">
    <div class="swiper-custom-header">
      <div class="swiper-custom-heading">
        {%- if block.settings.block_heading != blank -%}
          {{ block.settings.block_heading }}
        {%- endif -%}
      </div>
      <div class="swiper-custom-controls">
        <div
          class="
            swiper-custom-prev
            {% unless block.settings.mobile_arrows %}hide-on-mobile{% endunless %}
            {% unless block.settings.desktop_arrows %}hide-on-desktop{% endunless %}
          "
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </div>
        <div
          class="
            swiper-custom-pagination
            {% unless block.settings.mobile_dots %}hide-on-mobile{% endunless %}
            {% unless block.settings.desktop_dots %}hide-on-desktop{% endunless %}
          "
        ></div>
        <div
          class="
            swiper-custom-next
            {% unless block.settings.mobile_arrows %}hide-on-mobile{% endunless %}
            {% unless block.settings.desktop_arrows %}hide-on-desktop{% endunless %}
          "
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </div>
      </div>
    </div>

    <swiper-container
      init="false"
      class="js-swiper-complementary"
      data-swiper-config='
        {
            "autoplay": {{ block.settings.enable_autoplay | default: false }},
            "mobileSlides": {{ block.settings.mobile_slides | default: 1.2 }},
            "mobileSpacing": {{ block.settings.mobile_spacing | default: 16 }},
            "desktopSlides": {{ block.settings.desktop_slides | default: 4 }},
            "desktopSpacing": {{ block.settings.desktop_spacing | default: 24 }}
        }
      '
    >
      {%- for recommended_product in product.metafields['shopify--discovery--product_recommendation'].complementary_products.value
        limit: block.settings.product_list_limit
      -%}
        <swiper-slide>
          {% render 'lx_productCard', product_obj: recommended_product %}
        </swiper-slide>
      {%- endfor -%}
    </swiper-container>
  </div>
</div>

{% comment %} Styles moved to sereluna.css {% endcomment %}

<script>
  const ComplementarySliderManager = {
    init: function () {
      const sliders = document.querySelectorAll('swiper-container.js-swiper-complementary');
      sliders.forEach((el) => this.initSingleSlider(el));
    },
    initSingleSlider: function (swiperEl) {
      if (!swiperEl || !swiperEl.dataset.swiperConfig) return;
      if (swiperEl.part && swiperEl.part.contains('initialized')) return;
      const config = JSON.parse(swiperEl.dataset.swiperConfig);
      const wrapper = swiperEl.closest('.slider-wrapper');
      if (!wrapper) return;
      const nextBtn = wrapper.querySelector('.swiper-custom-next');
      const prevBtn = wrapper.querySelector('.swiper-custom-prev');
      const paginationEl = wrapper.querySelector('.swiper-custom-pagination');
      const params = {
        slidesPerView: config.mobileSlides,
        spaceBetween: config.mobileSpacing,
        loop: false,
        breakpoints: {
          768: {
            slidesPerView: config.desktopSlides,
            spaceBetween: config.desktopSpacing,
          },
        },
      };
      if (nextBtn && prevBtn) {
        params.navigation = {
          nextEl: nextBtn,
          prevEl: prevBtn,
        };
      }
      if (paginationEl) {
        params.pagination = {
          el: paginationEl,
          clickable: true,
        };
      }
      if (config.autoplay) {
        params.autoplay = { delay: 3000, disableOnInteraction: false };
      }
      Object.assign(swiperEl, params);
      swiperEl.initialize();
    },
  };
  document.addEventListener('DOMContentLoaded', () => ComplementarySliderManager.init());
  document.addEventListener('shopify:section:load', () => ComplementarySliderManager.init());
  document.addEventListener('shopify:block:select', (e) => {
    const container = document.querySelector(
      `.complementary-slider-section[data-block-id="${e.detail.blockId}"] swiper-container`
    );
    if (container) ComplementarySliderManager.initSingleSlider(container);
  });
</script>
