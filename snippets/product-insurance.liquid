<div class="product-custom__accessories" style="margin-top: 1rem;" {{ block.shopify_attributes }}>
  <h3 class="product-custom__accessories-title">Insurance</h3>
  
  <label class="product-custom__accessory-card" for="insurance-{{ block.id }}">
    <input type="checkbox" id="insurance-{{ block.id }}" class="visually-hidden product-custom__insurance-checkbox" value="{{ block.settings.product.selected_or_first_available_variant.id }}" data-price="{{ block.settings.product.selected_or_first_available_variant.price }}">
    
    <div class="product-custom__accessory-image" style="display: flex; align-items: center; justify-content: center; width: 60px; height: 60px; font-weight: 900; color: #ffd500; font-size: 1.8rem; letter-spacing: -1px; text-transform: uppercase;">
      ROXX
    </div>
    
    <div class="product-custom__accessory-info">
      <h4 class="product-custom__accessory-title">{{ block.settings.title }}</h4>
      <p class="product-custom__accessory-price" style="font-size: 1.1rem; margin-bottom: 0.5rem; line-height: 1.3;">{{ block.settings.text }}</p>
      <a href="#" style="font-size: 1.1rem; color: #666; text-decoration: underline;">Learn more</a>
    </div>
    
    <div class="product-custom__accessory-radio">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
    </div>
  </label>
</div>
