<div class="gallery-specifications-strip" {{ block.shopify_attributes }}>
  {%- if block.settings.label_1 != blank -%}
    <div class="gallery-spec-item">
      <div class="gallery-spec-icon">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="1" y="6" width="18" height="12" rx="2" ry="2"></rect>
          <line x1="23" y1="11" x2="23" y2="13"></line>
          <line x1="9" y1="10" x2="9" y2="14"></line>
          <line x1="5" y1="12" x2="13" y2="12"></line>
        </svg>
      </div>
      <div class="gallery-spec-info">
        <span class="gallery-spec-label">{{ block.settings.label_1 | escape }}</span>
        <span class="gallery-spec-value">{{ block.settings.value_1 | escape }}</span>
      </div>
    </div>
  {%- endif -%}

  {%- if block.settings.label_2 != blank -%}
    <div class="gallery-spec-item">
      <div class="gallery-spec-icon">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M12 6v6l4 2"></path>
          <path d="M16.24 7.76a6 6 0 1 0 0 8.49"></path>
        </svg>
      </div>
      <div class="gallery-spec-info">
        <span class="gallery-spec-label">{{ block.settings.label_2 | escape }}</span>
        <span class="gallery-spec-value">{{ block.settings.value_2 | escape }}</span>
      </div>
    </div>
  {%- endif -%}

  {%- if block.settings.label_3 != blank -%}
    <div class="gallery-spec-item">
      <div class="gallery-spec-icon">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 19h16"></path>
          <path d="M4 15h16"></path>
          <path d="M4 11h16"></path>
          <path d="M4 7h16"></path>
          <path d="M12 3v18"></path>
        </svg>
      </div>
      <div class="gallery-spec-info">
        <span class="gallery-spec-label">{{ block.settings.label_3 | escape }}</span>
        <span class="gallery-spec-value">{{ block.settings.value_3 | escape }}</span>
      </div>
    </div>
  {%- endif -%}
</div>

<style>
.gallery-specifications-strip {
    display: flex;
    justify-content: space-around;
    align-items: center;
    background-color: #fcfcfc;
    /* border: 1px solid #f2f2f2; */
    border-radius: 12px;
    padding: 1.5rem;
    margin-top: 2rem;
    /* box-shadow: 0 4px 15px rgba(0,0,0,0.05); */
    box-shadow: 0px 2px 23.1px 0px #0000000D;
}
  .gallery-spec-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-align: left;
  }
  .gallery-spec-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(var(--color-foreground), 0.7);
    background-color: #f4f4f4;
    border-radius: 50%;
    width: 36px;
    height: 36px;
  }
  .gallery-spec-info {
    display: flex;
    flex-direction: column;
  }
  .gallery-spec-label {
    font-size: 1.1rem;
    color: #888;
    text-transform: capitalize;
  }
  .gallery-spec-value {
    font-size: 1.3rem;
    font-weight: 800;
    color: #000;
  }
  @media screen and (max-width: 749px) {
    .gallery-specifications-strip {
      flex-direction: column;
      gap: 1.5rem;
      align-items: flex-start;
      padding: 1.5rem 2rem;
    }
  }
</style>
