
  <div class="gallery-specifications-strip" {{ block.shopify_attributes }}>
    {%- for i in (1..3) -%}
      {%- assign label_key = 'label_' | append: i -%}
      {%- assign value_key = 'value_' | append: i -%}
      {%- assign icon_key = 'icon_' | append: i -%}
      
      {%- if block.settings[label_key] != blank -%}
        <div class="gallery-spec-item">
          <div class="gallery-spec-icon">
            {%- if block.settings[icon_key] != blank -%}
              {{ block.settings[icon_key] | image_url: width: 40 | image_tag: loading: 'lazy' }}
            {%- else -%}
              {%- if i == 1 -%}<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="6" width="18" height="12" rx="2" ry="2"></rect><line x1="23" y1="11" x2="23" y2="13"></line><line x1="9" y1="10" x2="9" y2="14"></line><line x1="5" y1="12" x2="13" y2="12"></line></svg>{% endif %}
              {%- if i == 2 -%}<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"></circle><path d="M12 6v6l4 2"></path><path d="M16.24 7.76a6 6 0 1 0 0 8.49"></path></svg>{% endif %}
              {%- if i == 3 -%}<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 19h16"></path><path d="M4 15h16"></path><path d="M4 11h16"></path><path d="M4 7h16"></path><path d="M12 3v18"></path></svg>{% endif %}
            {%- endif -%}
          </div>
          <div class="gallery-spec-info">
            <span class="gallery-spec-label">{{ block.settings[label_key] | escape }}</span>
            <span class="gallery-spec-value">{{ block.settings[value_key] | escape }}</span>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <style>
.gallery-specifications-strip {
    display: flex;
    justify-content: space-around;
    align-items: center;
    background-color: #fff;
    border-radius: 12px;
    padding: 2.5rem;
    margin-top: 2rem;
    box-shadow: 0px 2px 23.1px 0px #0000000D;
    max-width: 600px;
    margin: 0 auto;
}
    .gallery-spec-item { display: flex; align-items: center; gap: 1rem; text-align: left; }
    .gallery-spec-icon { display: flex; align-items: center; justify-content: center; }
   .gallery-spec-icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    max-width: 20px;
    border-radius: 0px !important;
}
    .gallery-spec-info { display: flex; flex-direction: column; }
    .gallery-spec-label { font-size: 1.1rem; color: #888; text-transform: capitalize; }
    .gallery-spec-value { font-size: 1.3rem; font-weight: 800; color: #000; }
    @media screen and (max-width: 749px) { .gallery-specifications-strip { flex-direction: column; gap: 1.5rem; align-items: flex-start; padding: 1.5rem 2rem; } }
  </style>