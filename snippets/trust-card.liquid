
  <div class="pdp-review-block block-{{ block.id }}" {{ block.shopify_attributes }}>
    <div class="pdp-review-container">
      
      {%- comment -%} Navigation Arrows - Top Right {%- endcomment -%}
      <div class="pdp-review-nav">
        <button class="pdp-review-prev" aria-label="Previous">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <button class="pdp-review-next" aria-label="Next">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>

      <div class="pdp-review-slider">
        {%- for i in (1..5) -%}
          {%- assign rating_key = 'rating_' | append: i -%}
          {%- assign verified_key = 'verified_' | append: i -%}
          {%- assign title_key = 'title_' | append: i -%}
          {%- assign text_key = 'text_' | append: i -%}
          {%- assign author_key = 'author_' | append: i -%}

          {%- if block.settings[title_key] != blank -%}
            <div class="pdp-review-slide">
              <div class="pdp-review-card">
                
                <div class="pdp-review-header">
                  <div class="pdp-review-stars">
                    {%- assign current_rating = block.settings[rating_key] -%}
                    {% for star in (1..5) %}
                      <svg class="pdp-star {% if star <= current_rating %}is-filled{% endif %}" viewBox="0 0 24 24">
                        <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                      </svg>
                    {% endfor %}
                  </div>
                  {% if block.settings[verified_key] %}
                    <div class="pdp-review-verified">
                      <svg viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                      <span>Verified</span>
                    </div>
                  {% endif %}
                </div>

                <div class="pdp-review-body">
                  <h4 class="pdp-review-title">{{ block.settings[title_key] }}</h4>
                  <div class="pdp-review-text">{{ block.settings[text_key] }}</div>
                </div>

                <div class="pdp-review-footer">
                  <span class="pdp-review-author">— {{ block.settings[author_key] }}</span>
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <style>
    .pdp-review-block { margin: 25px 0; width: 100%; }
    .pdp-review-container { position: relative; width: 100%; }
    
    /* Card Style */
    .pdp-review-card {
      background-color: #F9F7F2; /* Matches image beige */
      border-radius: 35px; /* High radius like image */
      padding: 35px 40px;
      position: relative;
    }

    /* Navigation */
    .pdp-review-nav {
      position: absolute;
      top: 30px;
      right: 35px;
      display: flex;
      gap: 8px;
      z-index: 5;
    }
    .pdp-review-nav button {
      background: #D8D3CC;
      border: none;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #FFF;
      padding: 0;
    }

    /* Header & Stars */
    .pdp-review-header { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; }
    .pdp-star { width: 20px; height: 20px; fill: #E0E0E0; }
    .pdp-star.is-filled { fill: #1F5E3F; } /* Dark Green */
    
    .pdp-review-verified { display: flex; align-items: center; gap: 4px; font-size: 13px; color: #666; font-style: italic; }
    .pdp-review-verified svg { width: 14px; height: 14px; }

    /* Text areas */
    .pdp-review-title { 
      font-size: 17px; 
      font-weight: 600; 
      color: #333; 
      margin: 0 0 8px 0; 
      line-height: 1.4;
    }
    .pdp-review-text { 
      font-size: 15px; 
      color: #444; 
      line-height: 1.6; 
      margin-bottom: 15px;
    }
    .pdp-review-footer { text-align: right; }
    .pdp-review-author { font-weight: 600; font-size: 15px; color: #333; }

    /* Slider Logic */
    .pdp-review-slider {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .pdp-review-slider::-webkit-scrollbar { display: none; }
    .pdp-review-slide { flex: 0 0 100%; scroll-snap-align: start; }

    @media (max-width: 600px) {
      .pdp-review-card { padding: 25px 30px; border-radius: 25px; }
      .pdp-review-nav { top: 20px; right: 25px; }
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const b = document.querySelector('.block-{{ block.id }}');
      const s = b.querySelector('.pdp-review-slider');
      b.querySelector('.pdp-review-next').onclick = () => s.scrollBy({left: s.offsetWidth, behavior: 'smooth'});
      b.querySelector('.pdp-review-prev').onclick = () => s.scrollBy({left: -s.offsetWidth, behavior: 'smooth'});
    });
  </script>