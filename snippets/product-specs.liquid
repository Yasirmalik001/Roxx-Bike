{% assign spec_blocks = blocks | where: "type", "spec" %}
{% if spec_blocks.size > 0 %}
  <div class="product-custom__specs">
    {% for block in spec_blocks %}
      <div class="product-custom__spec-item" {{ block.shopify_attributes }}>
        <div class="product-custom__spec-icon">
          {% if block.settings.icon_svg != blank %}
            {{ block.settings.icon_svg }}
          {% else %}
            <!-- Default Icon fallback -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle></svg>
          {% endif %}
        </div>
        <span class="product-custom__spec-label">{{ block.settings.label }}</span>
        <span class="product-custom__spec-value">{{ block.settings.value }}</span>
      </div>
    {% endfor %}
  </div>
{% endif %}
