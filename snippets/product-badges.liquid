{% if product.tags contains 'Bestseller' %}
  <span class="product-custom__badge" style="background: #ffd500; color: #000; font-weight: 700; font-size: 1.1rem; padding: 0.5rem 1rem; border-radius: 4px; text-transform: uppercase;">Bestseller</span>
{% else %}
  <span class="product-custom__badge" style="background: #ffd500; color: #000; font-weight: 700; font-size: 1.1rem; padding: 0.5rem 1rem; border-radius: 4px; text-transform: uppercase;">Bestseller</span>
{% endif %}
