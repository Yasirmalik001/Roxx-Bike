<div class="product-custom__avatars" {{ block.shopify_attributes }}>
  <h3 class="product-custom__avatars-title">{{ block.settings.title }}</h3>
  <div class="product-custom__avatars-row">
    {% if block.settings.image_1 != blank %}
      <div class="product-custom__avatar">
        {{ block.settings.image_1 | image_url: width: 100 | image_tag: loading: 'lazy' }}
        <div class="product-custom__avatar-icon"><svg width="8" height="8" viewBox="0 0 24 24" fill="#000"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg></div>
      </div>
    {% endif %}
    {% if block.settings.image_2 != blank %}
      <div class="product-custom__avatar">
        {{ block.settings.image_2 | image_url: width: 100 | image_tag: loading: 'lazy' }}
        <div class="product-custom__avatar-icon"><svg width="8" height="8" viewBox="0 0 24 24" fill="#000"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg></div>
      </div>
    {% endif %}
    {% if block.settings.image_3 != blank %}
      <div class="product-custom__avatar">
        {{ block.settings.image_3 | image_url: width: 100 | image_tag: loading: 'lazy' }}
        <div class="product-custom__avatar-icon"><svg width="8" height="8" viewBox="0 0 24 24" fill="#000"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg></div>
      </div>
    {% endif %}
    {% if block.settings.image_4 != blank %}
      <div class="product-custom__avatar">
        {{ block.settings.image_4 | image_url: width: 100 | image_tag: loading: 'lazy' }}
        <div class="product-custom__avatar-icon"><svg width="8" height="8" viewBox="0 0 24 24" fill="#000"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg></div>
      </div>
    {% endif %}
  </div>
</div>
