{%- style -%}
/* ==========================================
   MOBILE CSS (Default)
========================================== */
.collection-grid-item.grid__item--span-2-{{ block.id }} {
  width: calc(100% - var(--grid-desktop-horizontal-spacing) * 3 / 4);
  max-width: calc(100% - var(--grid-desktop-horizontal-spacing) * 3 / 4);
  margin-block: 20px 30px;
}
.grid__item--span-2-{{ block.id }} { grid-column: span 1; }

.promo-card-{{ block.id }} { 
  display: flex; 
  flex-direction: column; 
  border-radius: 16px; 
  overflow: hidden; 
  padding: 3rem 2rem; 
  position: relative; 
  height: 100%; 
  min-height: 550px; /* Gives the card a tall mobile look like the screenshot */
  box-sizing: border-box; 
  background-size: cover; 
  background-position: center; 
  background-repeat: no-repeat;
  text-align: center; /* Center text on mobile */
  justify-content: space-between;
  
  /* Apply Mobile Image */
  {% if block.settings.image_mobile != blank %}
    background-image: url('{{ block.settings.image_mobile | image_url: width: 800 }}');
  {% elsif block.settings.image != blank %}
    background-image: url('{{ block.settings.image | image_url: width: 800 }}');
  {% endif %}
}

.promo-content-{{ block.id }} { 
  flex: 1; 
  display: flex; 
  flex-direction: column; 
  gap: 1.5rem; 
  z-index: 2; 
  position: relative; 
  max-width: 400px;
  margin: 0 auto;
  align-items: center; /* Center contents */
}

.promo-content-{{ block.id }} .h1 { margin: 0; }
.promo-text-{{ block.id }} { font-size: 14px; line-height: 1.5; margin: 0; color: inherit; }

.promo-features-{{ block.id }} { 
  display: flex; 
  flex-direction: column; 
  gap: 0.8rem; 
  margin: auto 0 0 0; /* Pushes the list & button to the bottom on mobile */
  padding: 0; 
  list-style: none; 
  width: 100%;
}

.promo-feature-{{ block.id }} { 
  display: flex; 
  align-items: center; 
  justify-content: flex-start; /* Keeps the icons aligned left within the center block */
  gap: 10px; 
  font-size: 14px; 
  color: inherit; 
}

.promo-icon-{{ block.id }} { width: 18px; height: 18px; flex-shrink: 0; fill: none; stroke: currentColor; stroke-width: 2; }

.promo-btn-{{ block.id }} { 
  display: inline-block; 
  padding: 14px 24px; 
  background-color: #F5F2ED; 
  color: #fff; 
  text-decoration: none; 
  border-radius: 50px; 
  font-weight: 600; 
  font-size: 14px; 
  text-align: center; 
  width: 100%; /* Full width button on mobile */
  transition: opacity 0.3s; 
  margin-top: 1rem; 
}
.promo-btn-{{ block.id }}:hover { opacity: 0.85; }

/* ==========================================
   DESKTOP CSS
========================================== */
@media screen and (min-width: 750px) { 
  .grid__item--span-2-{{ block.id }} { grid-column: span 2; } 
  .collection-grid-item.grid__item--span-2-{{ block.id }} { 
    width: calc(50% - var(--grid-desktop-horizontal-spacing) * 3 / 4);
    max-width: calc(50% - var(--grid-desktop-horizontal-spacing) * 3 / 4);
    margin-block: 0px;
  }
  .promo-card-{{ block.id }} { 
    flex-direction: row; 
    align-items: center; 
    padding: 3rem; 
    min-height: auto;
    text-align: left;
    
    /* Apply Desktop Image */
    {% if block.settings.image != blank %}
      background-image: url('{{ block.settings.image | image_url: width: 1200 }}');
    {% endif %}
  }

  .promo-content-{{ block.id }} { 
    align-items: flex-start;
    margin: 0;
  }
  
  .promo-features-{{ block.id }} {
    margin: 0;
  }
  
  .promo-btn-{{ block.id }} {
    width: fit-content; /* Fit content on desktop */
  }
}
{%- endstyle -%}

<li class="grid__item collection-grid-item grid__item--span-2-{{ block.id }}">
  <div class="promo-card-{{ block.id }} color-{{ block.settings.color_scheme }} gradient" {{ block.shopify_attributes }}>
    
    <div class="promo-content-{{ block.id }}">
      {%- if block.settings.heading != blank -%}
        <h3 class="h1">{{ block.settings.heading }}</h3>
      {%- endif -%}

      {%- if block.settings.text != blank -%}
        <p class="promo-text-{{ block.id }}">{{ block.settings.text }}</p>
      {%- endif -%}

      <ul class="promo-features-{{ block.id }}">
        {%- for i in (1..3) -%}
          {%- assign feature_setting = 'feature_' | append: i -%}
          {%- if block.settings[feature_setting] != blank -%}
            <li class="promo-feature-{{ block.id }}">
              <svg class="promo-icon-{{ block.id }}" viewBox="0 0 24 24">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M22 4L12 14.01l-3-3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>{{ block.settings[feature_setting] }}</span>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>

      {%- if block.settings.button_label != blank -%}
        <a href="{{ block.settings.button_link | default: '#' }}" class="promo-btn-{{ block.id }}">
          {{ block.settings.button_label }}
        </a>
      {%- endif -%}
    </div>

  </div>
</li>