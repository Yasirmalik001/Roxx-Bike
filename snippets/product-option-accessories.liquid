<div class="product-option-accessories" {{ block.shopify_attributes }}>
  {%- if block.settings.heading != blank -%}
    <h3 class="accessory-heading">{{ block.settings.heading | escape }}</h3>
  {%- endif -%}
  
  <div class="accessories-list">
    {%- for i in (1..4) -%}
      {%- capture title_key -%}acc_title_{{ i }}{%- endcapture -%}
      {%- capture price_key -%}acc_price_{{ i }}{%- endcapture -%}
      {%- capture image_key -%}acc_image_{{ i }}{%- endcapture -%}
      
      {%- assign title_val = block.settings[title_key] -%}
      {%- assign price_val = block.settings[price_key] -%}
      {%- assign image_val = block.settings[image_key] -%}
      
      {%- if title_val != blank -%}
        <label class="accessory-card-label">
          <input type="radio" name="properties[Accessory Package]" value="{{ title_val | escape }}" class="accessory-radio-input" {% if forloop.first %}checked{% endif %}>
          <div class="accessory-card-content">
            <div class="accessory-image">
              {%- if image_val != blank -%}
                <img src="{{ image_val | image_url: width: 120 }}" alt="{{ title_val | escape }}" loading="lazy" width="40" height="40">
              {%- else -%}
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                </svg>
              {%- endif -%}
            </div>
            
            <div class="accessory-details">
              <span class="accessory-title">{{ title_val | escape }}</span>
              <span class="accessory-price">{{ price_val | escape }}</span>
            </div>
            
            <div class="accessory-radio-indicator"></div>
          </div>
        </label>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<style>
  .product-option-accessories {
    margin: 2.5rem 0;
  }
  .accessory-heading {
    font-size: 1.3rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #555;
    margin-bottom: 1.2rem;
  }
  .accessories-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .accessory-card-label {
    display: block;
    cursor: pointer;
  }
  .accessory-radio-input {
    display: none; /* Hide default radio button */
  }
  .accessory-card-content {
    display: flex;
    align-items: center;
    padding: 1.2rem 1.6rem;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    background-color: #fafafa;
    transition: all 0.2s ease;
    position: relative;
  }
  .accessory-image {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #fff;
    border-radius: 4px;
    border: 1px solid #eeeeee;
    margin-right: 1.5rem;
    overflow: hidden;
    padding: 2px;
  }
  .accessory-image img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }
  .accessory-details {
    display: flex;
    flex-direction: column;
    text-align: left;
    flex-grow: 1;
  }
  .accessory-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: #333;
    margin-bottom: 0.2rem;
  }
  .accessory-price {
    font-size: 1.2rem;
    color: #777;
    font-weight: 600;
  }
  .accessory-radio-indicator {
    width: 20px;
    height: 20px;
    border: 2px solid #ccc;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    background-color: #fff;
  }
  
  /* Sibling selectors for active state styling */
  .accessory-radio-input:checked + .accessory-card-content {
    border-color: #ffd000;
    background-color: #fffdec;
  }
  .accessory-radio-input:checked + .accessory-card-content .accessory-radio-indicator {
    border-color: #ffd000;
    background-color: #ffd000;
  }
  .accessory-radio-input:checked + .accessory-card-content .accessory-radio-indicator::after {
    content: '\2713'; /* checkmark mark */
    font-size: 1rem;
    color: #000;
    font-weight: 900;
  }
</style>
