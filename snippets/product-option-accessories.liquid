<script src="{{ 'product-accessories.js' | asset_url }}" defer="defer"></script>

<product-accessories-selector class="product-option-accessories" {{ block.shopify_attributes }}>
  {%- if block.settings.heading != blank -%}
    <h3 class="accessory-heading">{{ block.settings.heading | escape }}</h3>
  {%- endif -%}
  
  <div class="accessories-list">
    {%- for accessory_product in block.settings.accessory_products -%}
      {%- assign first_variant = accessory_product.selected_or_first_available_variant -%}
      {%- if accessory_product != blank -%}
        <label class="accessory-card-label">
          <input type="checkbox" name="accessory_items" value="{{ first_variant.id }}" class="accessory-checkbox-input">
          <div class="accessory-card-content">
            <div class="accessory-image">
              {%- if accessory_product.featured_image != blank -%}
                <img src="{{ accessory_product.featured_image | image_url: width: 120 }}" alt="{{ accessory_product.title | escape }}" loading="lazy" width="40" height="40">
              {%- else -%}
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                </svg>
              {%- endif -%}
            </div>
            
            <div class="accessory-details">
              <span class="accessory-title">{{ accessory_product.title | escape }}</span>
              <span class="accessory-price">{{ accessory_product.price | money }}</span>
            </div>
            
            <div class="accessory-radio-indicator"></div>
          </div>
        </label>
      {%- endif -%}
    {%- endfor -%}
  </div>
</product-accessories-selector>

<style>
  .product-option-accessories {
    margin: 2.5rem 0;
    display: block;
  }
  .accessory-heading {
    font-size: 1.3rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #555;
    margin-bottom: 1.2rem;
    text-align: center;
  }
  .accessories-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .accessory-card-label {
    display: block;
    cursor: pointer;
  }
  .accessory-checkbox-input {
    display: none; /* Hide default checkbox */
  }
  .accessory-card-content {
    display: flex;
    align-items: center;
    padding: 1.2rem 1.6rem;
    border: 1px solid transparent;
    border-radius: 12px;
    background-color: #fafafa;
    transition: all 0.2s ease;
    position: relative;
  }
  .accessory-image {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #fff;
    border-radius: 8px;
    border: 1px solid #eeeeee;
    margin-right: 1.5rem;
    overflow: hidden;
    padding: 2px;
  }
  .accessory-image img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }
  .accessory-details {
    display: flex;
    flex-direction: column;
    text-align: left;
    flex-grow: 1;
  }
  .accessory-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: #333;
    margin-bottom: 0.2rem;
  }
  .accessory-price {
    font-size: 1.2rem;
    color: #777;
    font-weight: 600;
  }
  .accessory-radio-indicator {
    width: 24px;
    height: 24px;
    border: 1px solid #e5e5e5;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    background-color: #fff;
  }
  
  /* Sibling selectors for active state styling */
  .accessory-checkbox-input:checked + .accessory-card-content {
    border-color: #ffd000;
  }
  .accessory-checkbox-input:checked + .accessory-card-content .accessory-radio-indicator {
    border-color: #ffd000;
    background-color: #ffd000;
  }
  .accessory-checkbox-input:checked + .accessory-card-content .accessory-radio-indicator::after {
    content: '\2713'; /* checkmark mark */
    font-size: 1.2rem;
    color: #fff;
    font-weight: 900;
  }
</style>
