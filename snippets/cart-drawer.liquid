{% comment %}
  Renders cart drawer

  Usage:
  {% render 'cart-drawer' %}
{% endcomment %}

{{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>

{% comment %} Styles moved to sereluna.css {% endcomment %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ settings.padding_top }}px;
    padding-bottom: {{ settings.padding_bottom }}px;
    background-color: {{ settings.bg_color }};
  }
  .usp-grid-settings {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30px;
  justify-content: center;
  align-items: center;
    align-items: flex-start;
  }

  .usp-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-align: center;
    gap: 8px;
  }

  .usp-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    height: {{ settings.icon_width }}px;
    margin-bottom: 5px;
  }

  .usp-icon-img {
    width: {{ settings.icon_width }}px;
    height: auto;
    object-fit: contain;
    display: block;
  }


  .usp-text h3 {
    margin: 0;
    font-size: 12px;
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: 1px;
    text-transform: capitalize;
    color: {{ settings.text_color }};
  }

  @media screen and (max-width: 767px) {
    .usp-grid-settings {
      gap: 10px;
    }

    .usp-text h3 {
      font-size: 10px;
      letter-spacing: 0.5px;
    }
  }
{%- endstyle -%}
<cart-drawer class="drawer{% if cart == empty %} is-empty{% endif %}">
  <div id="CartDrawer" class="cart-drawer">
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay"></div>
    <div class="drawer__container">
      {% if settings.upsell__container and cart != empty %}
        <div class="drawer__upsell-container">
          <div class="drawer__upsell-header">
            <h4>{{ settings.upsell__heading }}</h4>
          </div>
          <div class="drawer__upsell-wrapper">
            <div class="drawer__upsell-inner">
              <script src="{{ 'ma-quickAdd.js' | asset_url }}" defer></script>
              {% for item in settings.upsell__products %}
                {% render 'card-drawer-product', card_product: item %}
              {% endfor %}
            </div>
          </div>
          {% if settings.upsell__points %}
            <div class="drawer__upsell-footer">
              <div class="drawer__upsell-footer-inner">
                {% if settings['upsell__points-heading'] != blank %}
                  <h5>{{ settings['upsell__points-heading'] }}</h5>
                {% endif %}

                <div class="drawer__upsell-point">
                  <div class="upsell-icon">
                    {%- if settings.icon_1 != blank -%}
                      {{ settings.icon_1 | image_url: width: 50 | image_tag: loading: 'lazy' }}
                    {%- else -%}
                      <svg class="usp-icon-img" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1">
                        <circle cx="12" cy="12" r="10"></circle>
                      </svg>
                    {%- endif -%}
                  </div>
                  <span>{{ settings.title_1 | newline_to_br }}</span>
                </div>

                <div class="drawer__upsell-point">
                  <div class="upsell-icon">
                    {%- if settings.icon_2 != blank -%}
                      {{ settings.icon_2 | image_url: width: 50 | image_tag: loading: 'lazy' }}
                    {%- else -%}
                      <svg class="usp-icon-img" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                      </svg>
                    {%- endif -%}
                  </div>
                  <span>{{ settings.title_2 | newline_to_br }}</span>
                </div>

                <div class="drawer__upsell-point">
                  <div class="upsell-icon">
                    {%- if settings.icon_3 != blank -%}
                      {{ settings.icon_3 | image_url: width: 50 | image_tag: loading: 'lazy' }}
                    {%- else -%}
                      <svg class="usp-icon-img" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1">
                        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path>
                      </svg>
                    {%- endif -%}
                  </div>
                  <span>{{ settings.title_3 | newline_to_br }}</span>
                </div>
              </div>

              {% comment %} Styles moved to sereluna.css {% endcomment %}
            </div>
          {% endif %}
        </div>
      {% endif %}
      <div
        class="drawer__inner gradient color-{{ settings.cart_color_scheme }}"
        role="dialog"
        aria-modal="true"
        aria-label="{{ 'sections.cart.title' | t }}"
        tabindex="-1"
      >
        {%- if cart == empty -%}
          <div class="drawer__inner-empty">
            <div class="cart-drawer__warnings center{% if settings.cart_drawer_collection != blank %} cart-drawer__warnings--has-collection{% endif %}">
              <div class="cart-drawer__empty-content">
                <h2 class="cart__empty-text">{{ 'sections.cart.empty' | t }}</h2>
                <button
                  class="drawer__close"
                  type="button"
                  onclick="this.closest('cart-drawer').close()"
                  aria-label="{{ 'accessibility.close' | t }}"
                >
                  <span class="svg-wrapper">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M18 6L6 18M6 6l12 12" stroke="#121212" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </button>
                <a href="{{ routes.all_products_collection_url }}" class="button">
                  {{ 'general.continue_shopping' | t }}
                </a>

                {%- if shop.customer_accounts_enabled and customer == null -%}
                  <p class="cart__login-title h3">{{ 'sections.cart.login.title' | t }}</p>
                  <p class="cart__login-paragraph">
                    {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
                  </p>
                {%- endif -%}
              </div>
            </div>
            {%- if settings.cart_drawer_collection != blank -%}
              <div class="cart-drawer__collection">
                {% render 'card-collection', card_collection: settings.cart_drawer_collection, columns: 1 %}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="drawer__header">
          <h2 class="drawer__heading">Your cart</h2>
          <button
            class="drawer__close"
            type="button"
            onclick="this.closest('cart-drawer').close()"
            aria-label="{{ 'accessibility.close' | t }}"
          >
            <span class="svg-wrapper">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M18 6L6 18M6 6l12 12" stroke="#121212" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </button>
        </div>

        <cart-drawer-items
          {% if cart == empty %}
            class=" is-empty"
          {% endif %}
        >
          <form
            action="{{ routes.cart_url }}"
            id="CartDrawer-Form"
            class="cart__contents cart-drawer__form"
            method="post"
          >
            <div id="CartDrawer-CartItems" class="drawer__contents js-contents">
              {%- if cart != empty -%}
                <div class="drawer__cart-items-wrapper">
                  <table class="cart-items" role="table">
                    <thead role="rowgroup" class="visually-hidden">
                      <tr role="row">
                        <th id="CartDrawer-ColumnProductImage" role="columnheader">Image</th>
                        <th id="CartDrawer-ColumnDetails" role="columnheader">Details</th>
                      </tr>
                    </thead>

                    <tbody role="rowgroup">
                      {%- for item in cart.items -%}
                        <tr
                          id="CartDrawer-Item-{{ item.index | plus: 1 }}"
                          class="cart-item{% if item.parent_relationship.parent != null %} cart-item__nested-line{% endif %}"
                          role="row"
                        >
                          <td
                            class="cart-item__media"
                            role="cell"
                            headers="CartDrawer-ColumnProductImage"
                          >
                            {% if item.image %}
                              <a href="{{ item.url }}" class="cart-item__link" tabindex="-1" aria-hidden="true"> </a>
                              <img
                                class="cart-item__image"
                                src="{{ item.image | image_url: width: 300 }}"
                                alt="{{ item.image.alt | escape }}"
                                loading="lazy"
                                width="120"
                                height="120"
                              >
                            {% endif %}
                          </td>

                          <td class="cart-item__details" role="cell" headers="CartDrawer-ColumnProduct">
                            <a href="{{ item.url }}" class="cart-item__name full-unstyled-link">
                              {{- item.product.title | escape -}}
                            </a>

                            <div class="cart-item__rating-stars">
                              <span class="star-rating">★★★★★</span>
                              <span class="star-count">(18)</span>
                            </div>

                            <div class="cart-item__price-row">
                              {%- if item.variant.compare_at_price > item.variant.price -%}
                                {%- assign item_compare_at = item.variant.compare_at_price | times: item.quantity -%}
                                <span class="price price--sale">{{ item.final_line_price | money }}</span>
                                <s class="price price--compare">{{ item_compare_at | money }}</s>
                                {%- assign savings = item.variant.compare_at_price | minus: item.variant.price | times: 100 | divided_by: item.variant.compare_at_price | round -%}
                                <span class="price-discount-badge">{{ savings }}% OFF</span>
                              {%- else -%}
                                <span class="price price--normal">{{ item.final_line_price | money }}</span>
                              {%- endif -%}
                            </div>

                            {%- if item.product.has_only_default_variant == false or item.properties.size != 0 -%}
                              <dl class="cart-item__options">
                                {%- if item.product.has_only_default_variant == false -%}
                                  {%- for option in item.options_with_values -%}
                                    <div class="product-option">
                                      <dt>{{ option.name }}:</dt>
                                      <dd>{{ option.value }}{%- unless forloop.last %}, {% endunless %}</dd>
                                    </div>
                                  {%- endfor -%}
                                {%- endif -%}
                              </dl>
                            {%- endif -%}

                            <cart-remove-button
                              id="CartDrawer-Remove-{{ item.index | plus: 1 }}"
                              data-index="{{ item.index | plus: 1 }}"
                              class="cart-item__remove-btn"
                            >
                              <button
                                type="button"
                                class="cart-remove-button-raw"
                                aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}"
                                data-variant-id="{{ item.variant.id }}"
                              >
                                <svg class="icon icon-trash" width="16" height="18" viewBox="0 0 16 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                                  <path d="M1 4.2h14M2.4 4.2v11.2a1.4 1.4 0 001.4 1.4h8.4a1.4 1.4 0 001.4-1.4V4.2m-9.8 0V2.8a1.4 1.4 0 011.4-1.4h4.2a1.4 1.4 0 011.4 1.4v1.4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                              </button>
                            </cart-remove-button>
                          </td>

                          <td class="cart-item__quantity-hidden" style="display:none;">
                            <input
                              type="number"
                              name="updates[]"
                              value="{{ item.quantity }}"
                              data-quantity-variant-id="{{ item.variant.id }}"
                              id="Drawer-quantity-{{ item.index | plus: 1 }}"
                              data-index="{{ item.index | plus: 1 }}"
                            >
                          </td>
                        </tr>
                      {%- endfor -%}
                    </tbody>
                  </table>
                </div>
              {%- endif -%}
              <p id="CartDrawer-LiveRegionText" class="visually-hidden" role="status"></p>
              <p id="CartDrawer-LineItemStatus" class="visually-hidden" aria-hidden="true" role="status">
                {{ 'accessibility.loading' | t }}
              </p>
            </div>
            <div id="CartDrawer-CartErrors" role="alert"></div>
          </form>
        </cart-drawer-items>

        <div class="drawer__footer">
          {%- if cart != empty -%}
            <div class="cart-drawer__footer-shipping">
              <span class="shipping-icon">
                <svg width="18" height="14" viewBox="0 0 18 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M1 2.5h11v8.5H1V2.5zM12 5.5h3.5l1.8 2v3H12V5.5z" stroke="#121212" stroke-width="1.5" stroke-linejoin="round"/>
                  <circle cx="4.5" cy="11" r="1.5" fill="#121212"/>
                  <circle cx="13.5" cy="11" r="1.5" fill="#121212"/>
                </svg>
              </span>
              <span class="shipping-text">Complete your checkout now & get it by <span id="cart-drawer-delivery-date" style="font-weight:700;">28-29 March</span></span>
            </div>

            <div class="cart-drawer__totals-wrapper">
              <div class="totals-row">
                <span class="totals-label">Subtotal</span>
                <span class="totals-value">{{ cart.total_price | money }}</span>
              </div>
              <div class="totals-row totals-row--small">
                <span class="totals-label">Discounts & Taxes</span>
                <span class="totals-value">Completed at checkout</span>
              </div>
            </div>

            <div class="cart__ctas">
              <button
                type="submit"
                id="CartDrawer-Checkout"
                class="cart__checkout-button"
                name="checkout"
                form="CartDrawer-Form"
              >
                Complete Your Checkout
              </button>
            </div>

            <div class="cart-drawer__payment-badges">
              {%- for type in shop.enabled_payment_types -%}
                <div class="payment-badge-card">
                  {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                </div>
              {%- endfor -%}
            </div>

            <script>
              (function() {
                function updateDeliveryDates() {
                  const months = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
                  const today = new Date();
                  
                  const date1 = new Date(today);
                  date1.setDate(today.getDate() + 7);
                  
                  const date2 = new Date(today);
                  date2.setDate(today.getDate() + 8);
                  
                  const el = document.getElementById('cart-drawer-delivery-date');
                  if (el) {
                    let month1 = months[date1.getMonth()];
                    let month2 = months[date2.getMonth()];
                    let day1 = date1.getDate();
                    let day2 = date2.getDate();
                    
                    let newText = (month1 === month2) ? `${day1}-${day2} ${month1}` : `${day1} ${month1} - ${day2} ${month2}`;
                    if (el.innerText !== newText) {
                      el.innerText = newText;
                    }
                  }
                }
                updateDeliveryDates();
                
                const cartContainer = document.getElementById('CartDrawer');
                if (cartContainer && !window.cartDeliveryObserverAttached) {
                  window.cartDeliveryObserverAttached = true;
                  const observer = new MutationObserver(function(mutations) {
                    let shouldUpdate = false;
                    for (let m of mutations) {
                      if (m.target.id !== 'cart-drawer-delivery-date') {
                        shouldUpdate = true;
                        break;
                      }
                    }
                    if (shouldUpdate) updateDeliveryDates();
                  });
                  observer.observe(cartContainer, { childList: true, subtree: true });
                }
              })();
            </script>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</cart-drawer>
