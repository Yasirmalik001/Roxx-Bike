<script>
  // Override Dawn's default submenu behavior for accordion style
  document.addEventListener('DOMContentLoaded', function () {
    const drawer = document.querySelector('header-drawer');
    if (!drawer) return;

    // Intercept summary clicks inside the drawer to prevent Dawn's slide-over behavior
    drawer.querySelectorAll('.menu-drawer__menu > li > details > summary').forEach((summary) => {
      summary.addEventListener('click', function (e) {
        e.stopImmediatePropagation();
        const details = this.parentElement;
        const isOpen = details.hasAttribute('open');

        // Close all sibling details (accordion behavior — only one open at a time)
        details.parentElement.querySelectorAll(':scope > details[open]').forEach((sibling) => {
          if (sibling !== details) {
            sibling.removeAttribute('open');
            sibling.classList.remove('menu-opening');
          }
        });

        // Toggle current
        if (isOpen) {
          e.preventDefault();
          details.removeAttribute('open');
          details.classList.remove('menu-opening');
        } else {
          // Let native <details> open it; remove slide-over classes
          details.classList.remove('menu-opening');
          // Prevent Dawn from adding submenu-open to parent
          const parent = details.closest('.has-submenu');
          if (parent) {
            requestAnimationFrame(() => parent.classList.remove('submenu-open'));
          }
        }
      });
    });

    const closeBtn = drawer.querySelector('.sl-drawer-close-btn');
    if (closeBtn) {
      closeBtn.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        const summary = drawer.querySelector('details > summary');
        if (drawer.closeMenuDrawer) {
          drawer.closeMenuDrawer(e, summary);
        }
      });
    }
  });
</script>
