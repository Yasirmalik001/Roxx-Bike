<style>
  predictive-search {
    width: 92%;
    max-width: 1600px;
    max-height: 90vh;
    position: fixed;
    top: 5vh;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10000;
    background-color: #fff;
    display: none;
    opacity: 0;
    visibility: hidden;
    transition: 0.3s ease-out;
    border-radius: 14px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    overflow: hidden;
  }

  .ma-is-active {
    opacity: 1;
    visibility: visible;
    display: flex !important;
    flex-direction: column;
  }

  body.ma-search-open {
    overflow: hidden;
  }

  body.ma-search-open::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 9999;
    backdrop-filter: blur(2px);
    transition: 0.3s ease;
  }

  .ma-search-input-wrapper {
    width: 100%;
    height: auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 25px 50px 20px;
    flex-shrink: 0;
    background: #fafafa;
  }

  .ma-search-input-container {
    height: auto;
    position: relative;
    max-width: 1600px;
    display: flex;
    align-items: center;
    flex: 1;
    margin: 0 20px;
  }

  .ma-search-input-container input {
    width: 100%;
    height: 52px;
    border: none;
    padding: 0 55px 0 24px;
    border: 1px solid rgb(0, 0, 0);
    border-radius: 100px;
    font-size: 16px;
    transition: all 0.2s ease;
  }

  .ma-search-input-container input::placeholder {
    font-size: 14px;
    color: rgba(0, 0, 0, 0.5);
  }
  input#ma-search-input::placeholder {
    color: rgb(0, 0, 0);
    font-size: 16px;
    line-height: 32px;
  }
  .ma-search-submit-icon {
    position: absolute;
    background-color: rgba(255, 255, 255, 0);
    border: none;
    padding-inline: 10px;
    right: 5px;
    top: 50%;
    transform: translateY(-50%);
    opacity: 1;
    cursor: default;
  }

  .ma-search-submit-icon:hover {
    background-color: rgba(255, 255, 255, 0);
  }

  .ma-search-submit-icon svg {
    width: 18px;
    height: 18px;
  }
  .ma-search-clear-btn {
    padding: 0;
    position: absolute;
    right: 40px;
    background-color: rgba(255, 255, 255, 0);
    opacity: 0.5;
    border: none;
    display: none;
    cursor: pointer;
    top: 50%;
    transform: translateY(-50%);
  }

  .ma-search-clear-btn svg {
    width: 20px;
  }

  .ma-search-clear-btn:hover {
    background-color: rgba(255, 255, 255, 0);
  }

  .ma-search-input-wrapper .ma-search-logo,
  .ma-search-input-wrapper .ma-header-heading-logo-wrapper {
    display: flex;
  }

  .ma-search-input-wrapper .ma-search-logo {
    width: 12%
  }

  .ma-cart-icons-wrapper {
    display: flex;
    align-items: center;
    gap: 20px;
    width: 12%;
    justify-content: flex-end;
    padding-right: 12px;
  }
  .ma-search-close-wrapper {
    width: 100%;
    height: auto;
    top: 0;
    left: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 25px 50px 20px;
    flex-shrink: 0;
    border-bottom: 1px solid #eaeaea;
  }

  .ma-search-close-wrapper h3 {
    font-size: 16px;
    font-weight: 600;
    color: #666;
  }

  .ma-search-close-wrapper .ma-text-base {
    font-size: 14px;
  }

  .ma-search-close-btn {
    padding: 0;
    background: #f5f5f5;
    border: none;
    cursor: pointer;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.25s ease;
  }

  .ma-search-close-btn:hover {
    transform: rotate(90deg);
  }

  .ma-search-close-btn:hover svg {
    fill: #fff;
  }

  .ma-search-close-btn svg {
    width: 18px;
    height: 18px;
    transition: fill 0.25s ease;
  }

  .ma-search-dynamic-results,
  .ma-search-upsell-container {
    width: 100%;
    overflow-y: auto;
  }

  .ma-search-dynamic-results::-webkit-scrollbar,
  .ma-search-upsell-container::-webkit-scrollbar {
    width: 8px;
    background-color: #f7f7f7;
  }

  .ma-search-dynamic-results::-webkit-scrollbar-thumb,
  .ma-search-upsell-container::-webkit-scrollbar-thumb {
    width: 8px;
    background-color: #bbb;
    border-radius: 10px;
  }

  .ma-search-dynamic-results::-webkit-scrollbar-thumb:hover,
  .ma-search-upsell-container::-webkit-scrollbar-thumb:hover {
    background-color: #999;
  }

  .ma-search-dynamic-results {
    flex: 1;
    padding: 30px 50px 40px;
    display: none;
  }

  #ma-predictive-search-results {
    width: 100%;
    height: auto;
  }

  .ma-product-result-con {
    width: 100%;
    height: auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 25px;
  }

  .ma-product-result-product {
    width: 100%;
    height: auto;
    min-width: 0;
  }

  .ma-product-result-con > * {
    min-width: 0;
  }

  .ma-sugg-result-con {
    width: 100%;
    height: auto;
    padding-left: 0px;
    justify-content: center;
    margin-bottom: 25px;
    align-items: center;
    gap: 15px;
  }

  .ma-sugg-result-con h3 {
    font-size: 18px;
  }

  .ma-sugg-result-con ul {
    padding: 0;
    margin: 0;
    list-style: none;
    align-items: center;
    gap: 15px;
  }

  .ma-sugg-result-con ul li {
    list-style: none;
  }

  .ma-sugg-result-con ul li a {
    line-height: normal;
    display: block;
    text-decoration: underline;
  }

  .ma-sugg-result-con ul p {
    font-size: 16px;
    color: #000;
    margin: 10px 0;
  }

  #ma-predictive-search-products {
    font-size: 18px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25px;
  }

  #ma-predictive-search-products button {
    border: none;
    background-color: #000;
    color: #fff;
    font-size: 14px;
    border-radius: 12px;
    padding: 14px 25px;
    cursor: pointer;
    transition: 0.2s;
  }

  #ma-predictive-search-products button:hover {
    background-color: #333;
  }
  .ma-search-upsell-container {
    flex: 1;
    padding: 30px 50px 40px;
  }

  .ma-no-sugg {
    white-space: nowrap;
  }

  .ma-search-upsell-wrapper {
    width: 100%;
    height: auto;
  }

  .ma-search-upsell-product-section {
    width: 100%;
    height: auto;
    display: flex;
    justify-content: flex-start;
    flex-wrap: wrap;
    gap: 25px;
  }

  .ma-search-upsell-product-section h3 {
    font-size: 20px;
    font-weight: 600;
    width: 100%;
    text-align: left;
    margin-bottom: 10px;
  }

  .ma-search-suggestions-group {
    width: 100%;
    height: auto;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 20px;
    margin-bottom: 30px;
    flex-wrap: wrap;
  }

  .ma-search-suggestions-group h3 {
    font-size: 18px;
    font-weight: 600;
    text-align: left;
    white-space: nowrap;
    margin: 0px;
    margin-right: 10px;
  }

  .ma-search-upsell-grid {
    width: 100%;
    height: auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 25px;
  }

  .ma-search-suggestions-list {
    height: auto;
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    justify-content: flex-start;
  }

  .ma-search-upsell-item {
    width: 100%;
    height: auto;
    min-width: 0;
  }

  .ma-search-suggestions-list a {
    color: rgb(102, 102, 102);
    font-size: 15px;
    line-height: 24px;
    text-decoration: underline;
    white-space: nowrap;
    transition: 0.2s;
  }

  .ma-search-suggestions-list a:hover {
    color: rgb(0, 0, 0);
  }

  .ma-sugg-mobile {
    display: none;
  }

  #ma-search-form {
    width: 40%;
  }
  .ma-search-upsell-grid .collection-listing,
  .ma-search-upsell-grid .collection-listing .product-list,
  .ma-product-result-con .collection-listing,
  .ma-product-result-con .collection-listing .product-list {
    width: 100%;
    display: contents;
  }


  .ma-search-upsell-grid a,
  .ma-product-result-con a {
    text-decoration: none !important;
  }

  input[type="search"]::-webkit-search-decoration,
  input[type="search"]::-webkit-search-cancel-button,
  input[type="search"]::-webkit-search-results-button,
  input[type="search"]::-webkit-search-results-decoration {
    display: none;
  }

  #ma-sdp-search-btn {
    margin-right: 16px;
  }

 
  .ma-hidden-input {
    display: none !important;
  }

  @media screen and (max-width: 1600px) {
    predictive-search {
      width: 95%;
    }
  }

  @media screen and (max-width: 1400px) {
    .ma-product-result-con,
    .ma-search-upsell-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
  }

  @media screen and (max-width: 1200px) {
    predictive-search {
      max-height: 90vh;
      width: 92%;
    }

    .ma-search-upsell-item,
    .ma-product-result-product {
      width: 100%;
    }

    .ma-search-input-wrapper .ma-search-logo {
      display: none;
    }

    .ma-product-result-con,
    .ma-search-upsell-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }

    .ma-search-upsell-container {
      padding: 25px 40px 35px;
    }

    .ma-search-dynamic-results {
      padding: 0 40px 35px;
    }
  }

  @media screen and (max-width: 800px) {
    predictive-search {
      max-height: 95vh;
      width: 95%;
      border-radius: 16px;
    }

    predictive-search .ma-search-logo,
    predictive-search .ma-cart-icons-wrapper,
    .ma-sugg-result-con,
    .ma-sugg-desktop {
      display: none;
    }

    .ma-sugg-mobile {
      display: block;
    }

    .ma-search-upsell-container {
      padding: 20px 25px 30px;
    }

    .ma-search-dynamic-results {
      padding: 0 25px 30px;
    }

    .ma-search-upsell-item {
      width: 100% !important;
    }

    .ma-product-result-product {
      width: 100% !important;
    }

    .ma-search-input-wrapper {
      padding: 15px 25px;
    }

    .ma-search-close-wrapper {
      padding: 20px 25px 12px;
    }

    .ma-search-input-container,
    #ma-search-form {
      width: 100%;
    }

    .ma-search-input-container input {
      width: 100%;
      height: 48px;
      font-size: 15px;
    }

    .ma-search-upsell-product-section {
      width: 100%;
    }

    .ma-product-result-con,
    .ma-search-upsell-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 15px;
    }

    .ma-search-suggestions-group {
      width: 100%;
      padding: 0;
      margin-bottom: 20px;
      gap: 12px;
    }

    .ma-search-suggestions-list a {
      font-size: 13px;
    }

    .ma-sugg-result-con {
      width: 100%;
      padding: 0;
      margin-top: 0px;
    }

    .ma-search-dynamic-results .collection-listing {
      width: 100%;
    }

    .ma-search-upsell-container::-webkit-scrollbar,
    .ma-search-dynamic-results::-webkit-scrollbar {
      width: 4px;
    }

    .ma-search-input-container {
      margin: 0 10px;
    }

    .ma-search-close-btn {
      width: 36px;
      height: 36px;
    }

    .ma-search-close-btn svg {
      width: 16px;
      height: 16px;
    }
  }

  @media(max-width: 767px) {
    #ma-sdp-search-btn {
      margin-right: 0px;
    }
  }
</style>

<predictive-search>
  <div class="ma-search-close-wrapper">
    <div class="ma-search-popup-header">
      <h3 class="ma-text-base">Search products</h3>
    </div>
    <button type="button" class="ma-search-close-btn">
      {% render 'svg-x' %}
    </button>
  </div>
  <div class="ma-search-input-wrapper">
    <div class="ma-search-logo" logotest="">
      <a href="{{ routes.root_url }}" class="link link--text focus-inset">
        {%- if settings.logo != blank -%}
          <div class="ma-header-heading-logo-wrapper">
            {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
            {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
            {% capture sizes %}(min-width: 750px) {{ settings.logo_width }}px, 50vw{% endcapture %}
            {% capture widths %}{{ settings.logo_width }}, {{ settings.logo_width | times: 1.5 | round }}, {{ settings.logo_width | times: 2 }}{% endcapture %}
            {{
              settings.logo
              | image_url: width: 600
              | image_tag:
                class: 'header__heading-logo',
                widths: widths,
                height: logo_height,
                width: settings.logo_width,
                alt: logo_alt,
                sizes: sizes,
                preload: true
            }}
          </div>
        {%- else -%}
          <span class="h2">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>
    <form action="{{ routes.search_url }}" id="ma-search-form" method="get" role="search">
      <div class="ma-search-input-container">
        <input
          id="ma-search-input"
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="{{ 'general.search.search' | t }}..."
          role="combobox"
          aria-expanded="false"
          aria-owns="ma-predictive-search-results-container"
          aria-controls="ma-predictive-search-results-container"
          aria-haspopup="listbox"
          aria-autocomplete="list"
        >
        <input name="options[prefix]" type="hidden" value="last">
        <button type="button" class="ma-search-submit-icon">{{- 'icon-search.svg' | inline_asset_content -}}</button>
        <button type="button" class="ma-search-clear-btn"><svg viewBox="0 0 20 20" class="icon icon-close" fill="none" transform="scale(0.8)"><path fill="#000" d="M15.89 14.696l-4.734-4.734 4.717-4.717c.4-.4.4-1.03 0-1.429-.396-.396-1.028-.396-1.429 0l-4.717 4.717-4.717-4.717c-.4-.4-1.029-.4-1.429 0-.396.396-.396 1.028 0 1.429l4.717 4.717-4.717 4.717c-.4.4-.4 1.029 0 1.429.2.2.45.3.71.3.25 0 .51-.1.71-.3l4.717-4.717 4.717 4.717c.19.19.45.3.71.3.26 0 .51-.1.71-.3.4-.4.4-1.029 0-1.429z"></path></svg>
        </button>
        <input type="submit" class="ma-hidden-input" value="submit">
      </div>
    </form>
    <div class="ma-cart-icons-wrapper">
      <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart link focus-inset" id="cart-icon-bubble">
        {% if cart == empty %}
          <span class="svg-wrapper">{{ 'icon-cart-empty.svg' | inline_asset_content }}</span>
        {% else %}
          <span class="svg-wrapper">{{ 'icon-cart.svg' | inline_asset_content }}</span>
        {% endif %}
        <span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>
        {%- if cart != empty -%}
          <div class="cart-count-bubble">
            {%- if cart.item_count < 100 -%}
              <span aria-hidden="true">{{ cart.item_count }}</span>
            {%- endif -%}
            <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
          </div>
        {%- endif -%}
      </a>
    </div>
  </div>
  <div class="ma-search-upsell-container">
    <div class="ma-search-upsell-wrapper">
      <div class="ma-search-suggestions-group ma-sugg-desktop">
        <h3>Popular searches</h3>
        <div class="ma-search-suggestions-list">
          {%- if settings.text_a != blank -%}<a href="{{settings.url_a}}">{{settings.text_a}}</a>{%- endif -%}
          {%- if settings.text_b != blank -%}<a href="{{settings.url_b}}">{{settings.text_b}}</a>{%- endif -%}
          {%- if settings.text_c != blank -%}<a href="{{settings.url_c}}">{{settings.text_c}}</a>{%- endif -%}
          {%- if settings.text_d != blank -%}<a href="{{settings.url_d}}">{{settings.text_d}}</a>{%- endif -%}
          {%- if settings.text_e != blank -%}<a href="{{settings.url_e}}">{{settings.text_e}}</a>{%- endif -%}
        </div>
      </div>
      <div class="ma-search-upsell-product-section">
        <div class="ma-search-suggestions-group ma-sugg-mobile">
          <div class="ma-search-suggestions-list">
            {%- if settings.text_a != blank -%}<a href="{{settings.url_a}}">{{settings.text_a}}</a>{%- endif -%}
            {%- if settings.text_b != blank -%}<a href="{{settings.url_b}}">{{settings.text_b}}</a>{%- endif -%}
            {%- if settings.text_c != blank -%}<a href="{{settings.url_c}}">{{settings.text_c}}</a>{%- endif -%}
            {%- if settings.text_d != blank -%}<a href="{{settings.url_d}}">{{settings.text_d}}</a>{%- endif -%}
            {%- if settings.text_e != blank -%}<a href="{{settings.url_e}}">{{settings.text_e}}</a>{%- endif -%}
          </div>
        </div>
        <div class="ma-search-upsell-grid">
          {%- liquid
            if true
              assign product_limit = 20
            else
              assign product_limit = section.settings.grid | times: section.settings.rows
            endif
          -%}
          {%- assign serProducts = settings.searchPro -%}
          <div class="collection-listing" data-cc-animate="cc-fade-in-up">
            <div class="product-list product-list--per-row-{{ section.settings.grid }} product-list--image-shape-{{ settings.prod_thumb_shape }} carousel">
              {% for product in serProducts %}
                <div class="ma-search-upsell-item">
                  {% render 'card-product',
                    card_product: product,
                    media_aspect_ratio: 'square',
                    image_shape: 'default',
                    show_secondary_image: true,
                    show_vendor: false,
                    show_rating: false,
                    lazy_load: false,
                    quick_add: 'standard',
                    section_id: section.id
                  %}
                </div>
              {% endfor %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div id="ma-predictive-search-results-container" tabindex="-1" class="ma-search-dynamic-results"></div>
</predictive-search>

<script src="{{ 'ma-predictiveSearch.js' | asset_url }}" ></script>