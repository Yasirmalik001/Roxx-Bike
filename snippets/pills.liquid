
  <div class="benefit-list-wrapper block-{{ block.id }}" {{ block.shopify_attributes }}>
    
    {% if block.settings.title != blank %}
      <h3 class="benefit-list-title">{{ block.settings.title }}</h3>
    {% endif %}
    
    <div class="benefit-list-container">
      {%- for i in (1..6) -%}
        {%- assign benefit_text_key = 'benefit_' | append: i -%}
        {%- assign benefit_text = block.settings[benefit_text_key] -%}
        
        {%- if benefit_text != blank -%}
          <div class="benefit-list-item">
            <div class="benefit-icon">
              {%- if block.settings.custom_svg != blank -%}
                {{ block.settings.custom_svg }}
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              {%- endif -%}
            </div>
            <span class="benefit-text">{{ benefit_text }}</span>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <style>
    .block-{{ block.id }}.benefit-list-wrapper {
      margin: 25px 0;
      color: {{ block.settings.text_color | default: '#333333' }};
    }
    
    .block-{{ block.id }} .benefit-list-title {
      font-size: 16px;
      font-weight: 600; /* Bold title like the image */
      margin: 0 0 16px 0;
      color: inherit;
      font-family: inherit;
      line-height: 1.2;
    }
    
    .block-{{ block.id }} .benefit-list-container {
      display: flex;
      flex-direction: column; /* 1-Column layout */
      gap: 12px; /* Spacing between list items */
    }
    
    .block-{{ block.id }} .benefit-list-item {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      font-family: inherit;
      font-weight: 400; /* Regular weight for list items */
      font-size: 15px; 
      line-height: 1.4;
      white-space: normal; /* Allows text to wrap safely on mobile */
    }
    
    .block-{{ block.id }} .benefit-icon {
      width: 18px;
      height: 18px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-top: 2px; /* Aligns the icon perfectly with the text baseline */
    }
    
    .block-{{ block.id }} .benefit-icon svg {
      width: 100%;
      height: 100%;
      color: {{ block.settings.icon_color | default: '#111111' }};
    }
  </style>