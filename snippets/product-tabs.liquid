{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    font-family: var(--font-body-family);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Top Header: Tabs and Buttons */
  .custom-bike-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 4rem;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .custom-bike-tabs {
    display: flex;
    gap: 2.5rem;
  }

  .custom-tab-item {
    font-size: 1.4rem;
    font-weight: 800;
    text-transform: uppercase;
    color: rgb(var(--color-foreground));
    padding-bottom: 0.5rem;
    letter-spacing: 0.5px;
    opacity: 0.6;
    cursor: pointer;
  }

  .custom-tab-item.is-active {
    opacity: 1;
    border-bottom: 3px solid #FFD000;
  }

  .custom-bike-actions {
    display: flex;
    gap: 1.5rem;
  }

  .btn-test-ride {
    background: transparent;
    border: 1px solid #FFD100;
    border-radius: 30px;
    padding: 1.2rem 2.5rem;
    font-size: 1.3rem;
    font-weight: 800;
    text-transform: uppercase;
    color: rgb(var(--color-foreground));
    text-decoration: none;
  }

  .btn-add-cart {
    background: #FFD100;
    border: 1px solid #FFD100;
    border-radius: 30px;
    padding: 1.2rem 3rem;
    font-size: 1.3rem;
    font-weight: 800;
    text-transform: uppercase;
    color: #000000;
    text-decoration: none;
  }

  /* Main Content Layout */
  .custom-bike-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
  }

  .custom-bike-text {
    font-size: 1.6rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.85);
  }

  .custom-bike-text strong {
    color: rgb(var(--color-foreground));
    font-weight: 700;
  }

  .custom-bike-text p {
    margin-bottom: 2rem;
  }

  /* Features Grid */
  .custom-features-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    row-gap: 4rem;
    column-gap: 2rem;
  }

  .custom-feature-item {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }

  .custom-feature-icon {
    width: 28px;
    height: auto;
    color: rgb(var(--color-foreground));
  }

  .custom-feature-icon img {
    width: 100%;
    height: auto;
    display: block;
  }

  .custom-feature-label {
    font-size: 1.15rem;
    line-height: 1.3;
    color: #333333;
    max-width: 200px;
  }

  /* Mobile Responsiveness */
  @media screen and (max-width: 989px) {
    .custom-bike-content {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
  }

  @media screen and (max-width: 749px) {
    .custom-bike-header {
      flex-direction: column;
      align-items: flex-start;
    }
    
    .custom-bike-tabs {
      overflow-x: auto;
      width: 100%;
      padding-bottom: 1rem;
    }

    .custom-bike-actions {
      width: 100%;
      flex-direction: column;
    }

    .btn-test-ride, .btn-add-cart {
      width: 100%;
      text-align: center;
    }
  }
{%- endstyle -%}

<div class="page-width section-{{ section.id }}-padding" {{ section.shopify_attributes }}>
  
  <div class="custom-bike-header">
    <div class="custom-bike-tabs">
      <div class="custom-tab-item is-active">Description</div>
      <div class="custom-tab-item">Features</div>
      <div class="custom-tab-item">Specifications</div>
      <div class="custom-tab-item">Accessories</div>
      <div class="custom-tab-item">FAQ</div>
    </div>
    
    <div class="custom-bike-actions">
      <a href="{{ section.settings.btn1_link }}" class="btn-test-ride">{{ section.settings.btn1_text }}</a>
      <button type="submit" name="add" class="btn-add-cart product-form__submit">{{ section.settings.btn2_text }}</button>
    </div>
  </div>

  <div class="custom-bike-content">
    
    <div class="custom-bike-text rte">
      {{ section.settings.description }}
    </div>

    <div class="custom-features-grid">
      {%- for block in section.blocks -%}
        <div class="custom-feature-item" {{ block.shopify_attributes }}>
          <div class="custom-feature-icon">
            {%- if block.settings.icon_image != blank -%}
              <img src="{{ block.settings.icon_image | image_url: width: 64 }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="32" height="auto" style="display: block; max-width: 100%;">
            {%- else -%}
              <div style="width: 32px; height: 32px; background-color: #f4f4f4; border-radius: 4px;"></div>
            {%- endif -%}
          </div>
          <div class="custom-feature-label">{{ block.settings.title }}</div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Product Overview Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "richtext",
      "id": "description",
      "label": "Description Text",
      "default": "<p>The Joieem X represents the next generation of smart e-bikes. With a powerful yet smooth ride, <strong>up to 80-100 km of range</strong>, and intelligent app-connected features like GPS tracking and anti-theft protection, it adapts seamlessly to your everyday life.</p><p>Designed for effortless performance and minimal maintenance.</p>"
    },
    {
      "type": "text",
      "id": "btn1_text",
      "label": "Button 1 Text",
      "default": "Book a Free Test Ride"
    },
    {
      "type": "url",
      "id": "btn1_link",
      "label": "Button 1 Link"
    },
    {
      "type": "text",
      "id": "btn2_text",
      "label": "Button 2 Text",
      "default": "Add to Cart"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image"
        },
        {
          "type": "inline_richtext",
          "id": "title",
          "label": "Feature Label",
          "default": "Feature description goes here"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Overview Grid",
      "blocks": [
        { "type": "feature", "settings": { "title": "Suitable for cyclists from 160 to 200 cm" } },
        { "type": "feature", "settings": { "title": "Comfortable sitting position" } },
        { "type": "feature", "settings": { "title": "Safety features" } },
        { "type": "feature", "settings": { "title": "Step-through frame" } },
        { "type": "feature", "settings": { "title": "GPS tracking" } },
        { "type": "feature", "settings": { "title": "Mechanical brakes" } }
      ]
    }
  ]
}
{% endschema %}