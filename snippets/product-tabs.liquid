
  {%- style -%}
    /* --- Block Padding Logic --- */
    .block-padding-{{ block.id }} {
      padding-top: {{ block.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ block.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
    @media screen and (min-width: 750px) {
      .block-padding-{{ block.id }} {
        padding-top: {{ block.settings.padding_top }}px;
        padding-bottom: {{ block.settings.padding_bottom }}px;
      }
    }

    /* --- Top Header: Tabs on Left, Buttons on Right --- */
    .joieem-header-wrapper {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 5rem;
      margin-top: 3rem;
      flex-wrap: wrap;
      gap: 2rem;
    }

    .joieem-tabs-container {
      display: flex;
      gap: 3rem;
    }

    .joieem-tab-item {
      font-size: 1.4rem;
      font-weight: 800;
      text-transform: uppercase;
      color: rgb(var(--color-foreground));
      padding-bottom: 0.6rem;
      letter-spacing: 0.05em;
      cursor: pointer;
      transition: color 0.3s ease;
    }

    .joieem-tab-item.is-active {
      border-bottom: 3px solid #FFD100; 
    }

    /* --- Tab Panels CSS --- */
.joieem-text-column {
    display: flex;
    flex-direction: column;
    max-width: 700px;
}

    .joieem-tab-panel {
      display: none;
      animation: fadeIn 0.4s ease;
    }
    
    .joieem-tab-panel.is-active {
      display: block;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .joieem-actions-container {
      display: flex;
      gap: 1.5rem;
      align-items: center;
    }

    .btn-outline-custom {
      background: transparent;
      border: 2px solid #e5e5e5;
      border-radius: 30px;
      padding: 1.2rem 2.5rem;
      font-size: 1.3rem;
      font-weight: 800;
      text-transform: uppercase;
      color: rgb(var(--color-foreground));
      text-decoration: none;
      transition: all 0.3s ease;
    }

    .btn-outline-custom:hover {
      border-color: #FFD100;
    }

    .btn-solid-custom {
      background: #FFD100;
      border: 2px solid #FFD100;
      border-radius: 30px;
      padding: 1.2rem 3rem;
      font-size: 1.3rem;
      font-weight: 800;
      text-transform: uppercase;
      color: #000000;
      text-decoration: none;
      transition: opacity 0.3s ease;
    }

    .btn-solid-custom:hover {
      opacity: 0.85;
    }

    /* --- Main Content Layout --- */
    .joieem-content-grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 8rem;
      align-items: start;
    }

    .joieem-text-area {
      font-size: 1.6rem;
      line-height: 1.6;
      color: rgba(var(--color-foreground), 0.85);
    }

    .joieem-text-area strong {
      color: rgb(var(--color-foreground));
      font-weight: 700;
    }

    .joieem-text-area p {
      margin-top: 0;
      margin-bottom: 2.5rem;
    }

    .joieem-features-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      row-gap: 4.5rem;
      column-gap: 3rem;
    }

    .joieem-feature-block {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      align-items: flex-start;
    }

    .joieem-feature-icon {
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgb(var(--color-foreground));
    }

    .joieem-feature-icon img,
    .joieem-feature-icon svg {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    .joieem-feature-text {
      font-size: 1.4rem;
      line-height: 1.4;
      color: rgb(var(--color-foreground));
      max-width: 200px;
    }

    /* --- Mobile Responsiveness --- */
    @media screen and (max-width: 989px) {
      .joieem-content-grid {
        grid-template-columns: 1fr;
        gap: 5rem;
      }
    }

    @media screen and (max-width: 749px) {
      .joieem-header-wrapper {
        flex-direction: column;
        align-items: flex-start;
        gap: 2.5rem;
      }
      
      .joieem-tabs-container {
        overflow-x: auto;
        width: 100%;
        padding-bottom: 1rem;
        scrollbar-width: none;
      }
      
      .joieem-tabs-container::-webkit-scrollbar {
        display: none;
      }

      .joieem-actions-container {
        width: 100%;
        flex-direction: column;
      }

      .btn-outline-custom, .btn-solid-custom {
        width: 100%;
        text-align: center;
      }
    }
  {%- endstyle -%}

  <div class="product-block-{{ block.id }} page-width block-padding-{{ block.id }}" {{ block.shopify_attributes }}>
    
    <div class="joieem-header-wrapper">
      <div class="joieem-tabs-container">
        {%- if block.settings.tab_1 != blank -%}
          <div class="joieem-tab-item is-active" data-target="#panel-1-{{ block.id }}">{{ block.settings.tab_1 }}</div>
        {%- endif -%}
        {%- if block.settings.tab_2 != blank -%}
          <div class="joieem-tab-item" data-target="#panel-2-{{ block.id }}">{{ block.settings.tab_2 }}</div>
        {%- endif -%}
        {%- if block.settings.tab_3 != blank -%}
          <div class="joieem-tab-item" data-target="#panel-3-{{ block.id }}">{{ block.settings.tab_3 }}</div>
        {%- endif -%}
        {%- if block.settings.tab_4 != blank -%}
          <div class="joieem-tab-item" data-target="#panel-4-{{ block.id }}">{{ block.settings.tab_4 }}</div>
        {%- endif -%}
        {%- if block.settings.tab_5 != blank -%}
          <div class="joieem-tab-item" data-target="#panel-5-{{ block.id }}">{{ block.settings.tab_5 }}</div>
        {%- endif -%}
      </div>
      
      <div class="joieem-actions-container">
        {%- if block.settings.btn1_text != blank -%}
          <a href="{{ block.settings.btn1_link | default: '#' }}" class="btn-outline-custom">
            {{ block.settings.btn1_text }}
          </a>
        {%- endif -%}
        {%- if block.settings.btn2_text != blank -%}
          <button type="submit" name="add" form="{{ product_form_id }}" class="btn-solid-custom product-form__submit">
            {{ block.settings.btn2_text }}
          </button>
        {%- endif -%}
      </div>
    </div>

    <div class="joieem-content-grid">
      
      <div class="joieem-text-column">
        <div id="panel-1-{{ block.id }}" class="joieem-tab-panel is-active">
          <div class="joieem-text-area rte">
            {{ block.settings.description | default: product.description }}
          </div>
        </div>

        <div id="panel-2-{{ block.id }}" class="joieem-tab-panel">
          <div class="joieem-text-area rte">{{ block.settings.tab_2_content }}</div>
        </div>

        <div id="panel-3-{{ block.id }}" class="joieem-tab-panel">
          <div class="joieem-text-area rte">{{ block.settings.tab_3_content }}</div>
        </div>

        <div id="panel-4-{{ block.id }}" class="joieem-tab-panel">
          <div class="joieem-text-area rte">{{ block.settings.tab_4_content }}</div>
        </div>

        <div id="panel-5-{{ block.id }}" class="joieem-tab-panel">
          <div class="joieem-text-area rte">{{ block.settings.tab_5_content }}</div>
        </div>
      </div>

      <div class="joieem-features-grid">
        {%- for i in (1..6) -%}
          {%- assign img_key = 'f' | append: i | append: '_image' -%}
          {%- assign icon_key = 'f' | append: i | append: '_icon' -%}
          {%- assign title_key = 'f' | append: i | append: '_title' -%}
          
          {%- assign f_image = block.settings[img_key] -%}
          {%- assign f_icon = block.settings[icon_key] -%}
          {%- assign f_title = block.settings[title_key] -%}

          {%- if f_title != blank -%}
            <div class="joieem-feature-block">
              <div class="joieem-feature-icon">
                {%- if f_image != blank -%}
                  {{ f_image | image_url: width: 64 | image_tag: loading: 'lazy' }}
                {%- else -%}
                  {%- case f_icon -%}
                    {%- when 'cyclist' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4v16m-4-4h8M8 8h8M6 12h12"/></svg>
                    {%- when 'seat' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="7" r="3"/><path d="M12 10v10m-3-3h6"/></svg>
                    {%- when 'shield' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
                    {%- when 'frame' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 18L10 6h4l6 12M5 13h14"/></svg>
                    {%- when 'gps' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    {%- when 'brakes' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="8"/><path d="M12 8v4l3 3"/></svg>
                  {%- endcase -%}
                {%- endif -%}
              </div>
              <div class="joieem-feature-text">{{ f_title }}</div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const blockContainer = document.querySelector('.product-block-{{ block.id }}');
      if (!blockContainer) return;

      const tabs = blockContainer.querySelectorAll('.joieem-tab-item');
      const panels = blockContainer.querySelectorAll('.joieem-tab-panel');

      tabs.forEach(tab => {
        tab.addEventListener('click', function() {
          // 1. Remove active state from all tabs and panels
          tabs.forEach(t => t.classList.remove('is-active'));
          panels.forEach(p => p.classList.remove('is-active'));

          // 2. Add active state to clicked tab
          this.classList.add('is-active');

          // 3. Show target text panel
          const targetId = this.getAttribute('data-target');
          const targetPanel = blockContainer.querySelector(targetId);
          if (targetPanel) {
            targetPanel.classList.add('is-active');
          }
        });
      });
    });
  </script>