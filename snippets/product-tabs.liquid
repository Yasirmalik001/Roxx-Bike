<div class="product-tabs-section page-width" id="ProductTabs-{{ section.id }}" {{ block.shopify_attributes }}>
  <div class="product-tabs-grid">
    
    <!-- Left Column: Tab contents -->
    <div class="product-tabs-left">
      <div class="product-tabs-nav-wrapper">
        <div class="product-tabs-nav" role="tablist">
          {%- if block.settings.description != blank or product.description != blank -%}
            <button class="product-tab-btn is-active" role="tab" data-tab="tab-desc" aria-selected="true">Description</button>
          {%- endif -%}
          {%- if block.settings.features != blank -%}
            <button class="product-tab-btn" role="tab" data-tab="tab-features" aria-selected="false">Features</button>
          {%- endif -%}
          {%- if block.settings.specifications != blank -%}
            <button class="product-tab-btn" role="tab" data-tab="tab-specs" aria-selected="false">Specifications</button>
          {%- endif -%}
          {%- if block.settings.accessories != blank -%}
            <button class="product-tab-btn" role="tab" data-tab="tab-accessories" aria-selected="false">Accessories</button>
          {%- endif -%}
          {%- if block.settings.faq != blank -%}
            <button class="product-tab-btn" role="tab" data-tab="tab-faq" aria-selected="false">FAQ</button>
          {%- endif -%}
        </div>
      </div>
      
      <div class="product-tabs-content">
        {%- if block.settings.description != blank or product.description != blank -%}
          <div class="product-tab-panel is-active" id="tab-desc" role="tabpanel">
            <div class="rte">
              {{ block.settings.description | default: product.description }}
            </div>
          </div>
        {%- endif -%}
        
        {%- if block.settings.features != blank -%}
          <div class="product-tab-panel" id="tab-features" role="tabpanel">
            <div class="rte">
              {{ block.settings.features }}
            </div>
          </div>
        {%- endif -%}
        
        {%- if block.settings.specifications != blank -%}
          <div class="product-tab-panel" id="tab-specs" role="tabpanel">
            <div class="rte">
              {{ block.settings.specifications }}
            </div>
          </div>
        {%- endif -%}
        
        {%- if block.settings.accessories != blank -%}
          <div class="product-tab-panel" id="tab-accessories" role="tabpanel">
            <div class="rte">
              {{ block.settings.accessories }}
            </div>
          </div>
        {%- endif -%}
        
        {%- if block.settings.faq != blank -%}
          <div class="product-tab-panel" id="tab-faq" role="tabpanel">
            <div class="rte">
              {{ block.settings.faq }}
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
    
    <!-- Right Column: Specs Grid with Icons -->
    <div class="product-tabs-right">
      <div class="product-features-grid">
        {%- for i in (1..6) -%}
          {%- capture key -%}feature_label_{{ i }}{%- endcapture -%}
          {%- assign label_val = block.settings[key] -%}
          
          {%- if label_val != blank -%}
            <div class="feature-grid-item">
              <div class="feature-grid-icon">
                {%- case i -%}
                  {%- when 1 -%}
                    <!-- Ruler / size -->
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M5 12h14M12 5l7 7-7 7"></path>
                    </svg>
                  {%- when 2 -%}
                    <!-- Seat / Saddle -->
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M4 4h16v16H4z"></path>
                    </svg>
                  {%- when 3 -%}
                    <!-- Gear -->
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="3"></circle>
                      <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                    </svg>
                  {%- when 4 -%}
                    <!-- Chain -->
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                      <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
                    </svg>
                  {%- when 5 -%}
                    <!-- GPS -->
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                      <circle cx="12" cy="10" r="3"></circle>
                    </svg>
                  {%- when 6 -%}
                    <!-- Padlock -->
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                      <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    </svg>
                {%- endcase -%}
              </div>
              <span class="feature-grid-label">{{ label_val | escape }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

<!-- Bottom Sticky Bar -->
<div class="product-sticky-bar" id="ProductStickyBar-{{ section.id }}">
  <div class="page-width sticky-bar-inner">
    
    <div class="sticky-bar-left">
      <span class="sticky-product-title">{{ product.title | escape }}</span>
      <span class="sticky-product-price">{{ product.price | money }}</span>
    </div>
    
    <div class="sticky-bar-right">
      <button type="button" class="sticky-btn-outline" onclick="document.querySelector('.product-form__buttons .button--secondary')?.click() || alert('Book test ride')">
        Book a free test ride
      </button>
      <button type="button" class="sticky-btn-solid" onclick="document.querySelector('.product-form__buttons button[type=submit]')?.click()">
        Add to cart
      </button>
    </div>
    
  </div>
</div>

<style>
  .product-tabs-section {
    padding-top: 5rem;
    padding-bottom: 5rem;
    border-top: 1px solid #eeeeee;
    margin-top: 4rem;
  }
  .product-tabs-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 5rem;
  }
  .product-tabs-left {
    display: flex;
    flex-direction: column;
    text-align: left;
  }
  .product-tabs-nav-wrapper {
    border-bottom: 2px solid #eeeeee;
    margin-bottom: 3rem;
  }
  .product-tabs-nav {
    display: flex;
    gap: 3rem;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .product-tabs-nav::-webkit-scrollbar {
    display: none;
  }
  .product-tab-btn {
    background: none;
    border: none;
    padding: 1.5rem 0;
    font-size: 1.4rem;
    font-weight: 800;
    text-transform: uppercase;
    color: #888;
    cursor: pointer;
    position: relative;
    letter-spacing: 0.05em;
    transition: color 0.2s ease;
  }
  .product-tab-btn:hover,
  .product-tab-btn.is-active {
    color: #000;
  }
  .product-tab-btn.is-active::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 3px;
    background-color: #ffd000;
  }
  .product-tab-panel {
    display: none;
  }
  .product-tab-panel.is-active {
    display: block;
  }
  
  /* Features Grid on Right */
  .product-tabs-right {
    text-align: left;
  }
  .product-features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }
  .feature-grid-item {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }
  .feature-grid-icon {
    width: 44px;
    height: 44px;
    background-color: #f7f7f7;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #000;
  }
  .feature-grid-label {
    font-size: 1.3rem;
    font-weight: 700;
    color: #333;
    line-height: 1.4;
  }

  /* Bottom Sticky Bar Styling */
  .product-sticky-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    background-color: #ffffff;
    box-shadow: 0 -4px 15px rgba(0,0,0,0.06);
    z-index: 100;
    padding: 1.5rem 0;
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .product-sticky-bar.is-visible {
    transform: translateY(0);
  }
  .sticky-bar-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .sticky-bar-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .sticky-product-title {
    font-size: 1.5rem;
    font-weight: 800;
    text-transform: uppercase;
    color: #000;
  }
  .sticky-product-price {
    font-size: 1.3rem;
    font-weight: 700;
    color: #555;
  }
  .sticky-bar-right {
    display: flex;
    gap: 1.5rem;
  }
  .sticky-btn-outline {
    background: none;
    border: 1.5px solid #000;
    border-radius: 25px;
    padding: 1.2rem 2.5rem;
    font-size: 1.3rem;
    font-weight: 800;
    text-transform: uppercase;
    cursor: pointer;
  }
  .sticky-btn-solid {
    background-color: #ffd000;
    border: none;
    border-radius: 25px;
    padding: 1.2rem 3rem;
    font-size: 1.3rem;
    font-weight: 800;
    text-transform: uppercase;
    cursor: pointer;
    color: #000;
  }

  @media screen and (max-width: 989px) {
    .product-tabs-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
  }
  @media screen and (max-width: 749px) {
    .sticky-bar-inner {
      flex-direction: column;
      gap: 1.5rem;
      align-items: center;
    }
    .sticky-bar-left {
      align-items: center;
    }
    .sticky-bar-right {
      width: 100%;
      justify-content: center;
    }
    .sticky-btn-outline, .sticky-btn-solid {
      flex: 1;
      padding: 1rem;
      font-size: 1.2rem;
      max-width: 180px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // 1. Tab switching logic
    const tabButtons = document.querySelectorAll('.product-tab-btn');
    const tabPanels = document.querySelectorAll('.product-tab-panel');
    
    tabButtons.forEach(btn => {
      btn.addEventListener('click', function() {
        const targetId = this.dataset.tab;
        
        tabButtons.forEach(b => {
          b.classList.remove('is-active');
          b.setAttribute('aria-selected', 'false');
        });
        tabPanels.forEach(p => p.classList.remove('is-active'));
        
        this.classList.add('is-active');
        this.setAttribute('aria-selected', 'true');
        const panel = document.getElementById(targetId);
        if(panel) panel.classList.add('is-active');
      });
    });
    
    // 2. Scroll-triggered sticky bar logic
    const stickyBar = document.getElementById('ProductStickyBar-{{ section.id }}');
    const tabsSection = document.getElementById('ProductTabs-{{ section.id }}');
    
    if (stickyBar && tabsSection) {
      window.addEventListener('scroll', function() {
        const tabsOffset = tabsSection.getBoundingClientRect().top + window.scrollY;
        // Show sticky bar when user scrolls past the top of tabs section
        if (window.scrollY >= tabsOffset - 100) {
          stickyBar.classList.add('is-visible');
        } else {
          stickyBar.classList.remove('is-visible');
        }
      });
    }
  });
</script>
