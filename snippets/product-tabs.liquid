{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    font-family: var(--font-body-family);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Top Header: Tabs and Buttons */
  .custom-bike-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 4rem;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .custom-bike-tabs {
    display: flex;
    gap: 2.5rem;
  }

  .custom-tab-item {
    font-size: 1.4rem;
    font-weight: 800;
    text-transform: uppercase;
    color: rgb(var(--color-foreground));
    padding-bottom: 0.5rem;
    letter-spacing: 0.05em;
  }

  .custom-tab-item.is-active {
    border-bottom: 3px solid #FFD100; /* Exact Yellow from design */
  }

  .custom-bike-actions {
    display: flex;
    gap: 1.5rem;
  }

  .btn-test-ride {
    background: transparent;
    border: 1px solid #FFD100;
    border-radius: 30px;
    padding: 1.2rem 2.5rem;
    font-size: 1.3rem;
    font-weight: 800;
    text-transform: uppercase;
    color: rgb(var(--color-foreground));
    text-decoration: none;
  }

  .btn-add-cart {
    background: #FFD100;
    border: 1px solid #FFD100;
    border-radius: 30px;
    padding: 1.2rem 3rem;
    font-size: 1.3rem;
    font-weight: 800;
    text-transform: uppercase;
    color: #000000;
    text-decoration: none;
  }

  /* Main Content Layout */
  .custom-bike-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
  }

  .custom-bike-text {
    font-size: 1.6rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.85);
  }

  .custom-bike-text strong {
    color: rgb(var(--color-foreground));
    font-weight: 700;
  }

  .custom-bike-text p {
    margin-bottom: 2rem;
  }

  /* Features Grid */
  .custom-features-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    row-gap: 4rem;
    column-gap: 2rem;
  }

  .custom-feature-item {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .custom-feature-icon {
    width: 32px;
    height: 32px;
    color: rgb(var(--color-foreground));
  }

  .custom-feature-icon svg {
    width: 100%;
    height: 100%;
    stroke-width: 1.5;
  }

  .custom-feature-label {
    font-size: 1.4rem;
    line-height: 1.4;
    color: rgb(var(--color-foreground));
    max-width: 200px;
  }

  /* Mobile Responsiveness */
  @media screen and (max-width: 989px) {
    .custom-bike-content {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
  }

  @media screen and (max-width: 749px) {
    .custom-bike-header {
      flex-direction: column;
      align-items: flex-start;
    }
    
    .custom-bike-tabs {
      overflow-x: auto;
      width: 100%;
      padding-bottom: 1rem;
    }

    .custom-bike-actions {
      width: 100%;
      flex-direction: column;
    }

    .btn-test-ride, .btn-add-cart {
      width: 100%;
      text-align: center;
    }
  }
{%- endstyle -%}

<div class="page-width section-{{ section.id }}-padding" {{ section.shopify_attributes }}>
  
  <div class="custom-bike-header">
    <div class="custom-bike-tabs">
      <div class="custom-tab-item is-active">Description</div>
      <div class="custom-tab-item">Features</div>
      <div class="custom-tab-item">Specifications</div>
      <div class="custom-tab-item">Accessories</div>
      <div class="custom-tab-item">FAQ</div>
    </div>
    
    <div class="custom-bike-actions">
      <a href="{{ section.settings.btn1_link }}" class="btn-test-ride">{{ section.settings.btn1_text }}</a>
      <button type="submit" name="add" class="btn-add-cart product-form__submit">{{ section.settings.btn2_text }}</button>
    </div>
  </div>

  <div class="custom-bike-content">
    
    <div class="custom-bike-text rte">
      {{ section.settings.description }}
    </div>

    <div class="custom-features-grid">
      {%- for block in section.blocks -%}
        <div class="custom-feature-item" {{ block.shopify_attributes }}>
          <div class="custom-feature-icon">
            {%- if block.settings.custom_svg != blank -%}
              {{ block.settings.custom_svg }}
            {%- else -%}
              {%- case block.settings.icon -%}
                {%- when 'cyclist' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4v16m-4-4h8M8 8h8M6 12h12"/></svg>
                {%- when 'seat' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="7" r="3"/><path d="M12 10v10m-3-3h6"/></svg>
                {%- when 'shield' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
                {%- when 'frame' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M4 18L10 6h4l6 12M5 13h14"/></svg>
                {%- when 'gps' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {%- when 'brakes' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="8"/><path d="M12 8v4l3 3"/></svg>
              {%- endcase -%}
            {%- endif -%}
          </div>
          <div class="custom-feature-label">{{ block.settings.title }}</div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Product Overview Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "richtext",
      "id": "description",
      "label": "Description Text",
      "default": "<p>The Joieem X represents the next generation of smart e-bikes. With a powerful yet smooth ride, <strong>up to 80-100 km of range</strong>, and intelligent app-connected features like GPS tracking and anti-theft protection, it adapts seamlessly to your everyday life.</p><p>Designed for effortless performance and minimal maintenance.</p>"
    },
    {
      "type": "text",
      "id": "btn1_text",
      "label": "Button 1 Text",
      "default": "Book a Free Test Ride"
    },
    {
      "type": "url",
      "id": "btn1_link",
      "label": "Button 1 Link"
    },
    {
      "type": "text",
      "id": "btn2_text",
      "label": "Button 2 Text",
      "default": "Add to Cart"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "limit": 6,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Select Icon",
          "options": [
            { "value": "cyclist", "label": "Cyclist Height" },
            { "value": "seat", "label": "Comfort Seat" },
            { "value": "shield", "label": "Safety Shield" },
            { "value": "frame", "label": "Bike Frame" },
            { "value": "gps", "label": "GPS Tracking" },
            { "value": "brakes", "label": "Brakes" }
          ],
          "default": "shield"
        },
        {
          "type": "html",
          "id": "custom_svg",
          "label": "Custom SVG (Overrides default icon)"
        },
        {
          "type": "inline_richtext",
          "id": "title",
          "label": "Feature Label",
          "default": "Feature description goes here"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Overview Grid",
      "blocks": [
        { "type": "feature", "settings": { "icon": "cyclist", "title": "Suitable for cyclists from 160 to 200 cm" } },
        { "type": "feature", "settings": { "icon": "seat", "title": "Comfortable sitting position" } },
        { "type": "feature", "settings": { "icon": "shield", "title": "Safety features" } },
        { "type": "feature", "settings": { "icon": "frame", "title": "Step-through frame" } },
        { "type": "feature", "settings": { "icon": "gps", "title": "GPS tracking" } },
        { "type": "feature", "settings": { "icon": "brakes", "title": "Mechanical brakes" } }
      ]
    }
  ]
}
{% endschema %}