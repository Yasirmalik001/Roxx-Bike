{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ block.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ block.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ block.settings.padding_top }}px;
      padding-bottom: {{ block.settings.padding_bottom }}px;
    }
  }

  .product-tabs-section {
    border-top: 1px solid rgba(var(--color-foreground), 0.08);
  }

  .product-tabs-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 5rem;
  }

  .product-tabs-left {
    display: flex;
    flex-direction: column;
    text-align: left;
  }

  .product-tabs-nav-wrapper {
    border-bottom: 2px solid rgba(var(--color-foreground), 0.08);
    margin-bottom: 3rem;
  }

  .product-tabs-nav {
    display: flex;
    gap: 3rem;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .product-tabs-nav::-webkit-scrollbar {
    display: none;
  }

  .product-tab-btn {
    background: none;
    border: none;
    padding: 1.5rem 0;
    font-size: 1.4rem;
    font-family: Integral CF;
    font-weight: 600;
    font-style: Demi Bold;
    font-size: 14px;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.6);
    cursor: pointer;
    position: relative;
    letter-spacing: 0.05em;
    transition: color 0.2s ease;
  }

  .product-tab-btn:hover,
  .product-tab-btn.is-active {
    color: rgb(var(--color-foreground));
  }

  .product-tab-btn.is-active::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 3px;
    background-color: rgb(var(--color-foreground));
  }

  .product-tab-panel {
    display: none;
  }

  .product-tab-panel.is-active {
    display: block;
    animation: fadeIn 0.4s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(5px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Features Grid on Right */
  .product-tabs-right {
    text-align: left;
  }

  .product-features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }

  .feature-grid-item {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }

  .feature-grid-icon {
    width: {{ block.settings.icon_size | plus: 26 }}px;
    height: {{ block.settings.icon_size | plus: 26 }}px;
    background-color: rgba(var(--color-foreground), 0.04);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgb(var(--color-foreground));
  }

  .feature-grid-icon svg {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
  }

  .feature-grid-label {
    font-size: 1.3rem;
    font-weight: 700;
    color: rgb(var(--color-foreground));
    line-height: 1.4;
  }

  /* Bottom Sticky Bar Styling */
  .product-sticky-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    background-color: rgb(var(--color-background));
    box-shadow: 0 -4px 15px rgba(0,0,0,0.06);
    z-index: 100;
    padding: 1.5rem 0;
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    border-top: 1px solid rgba(var(--color-foreground), 0.08);
  }

  .product-sticky-bar.is-visible {
    transform: translateY(0);
  }

  .sticky-bar-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .sticky-bar-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .sticky-product-title {
    font-size: 1.5rem;
    font-weight: 800;
    text-transform: uppercase;
    color: rgb(var(--color-foreground));
  }

  .sticky-product-price {
    font-size: 1.3rem;
    font-weight: 700;
    color: rgba(var(--color-foreground), 0.75);
  }

  .sticky-bar-right {
    display: flex;
    gap: 1.5rem;
  }

  .sticky-btn-outline {
    background: transparent;
    border: 1.5px solid rgb(var(--color-foreground));
    border-radius: var(--buttons-radius, 25px);
    padding: 1.2rem 2.5rem;
    font-size: 1.3rem;
    font-weight: 800;
    text-transform: uppercase;
    cursor: pointer;
    color: rgb(var(--color-foreground));
    transition: opacity 0.2s ease;
  }

  .sticky-btn-outline:hover {
    opacity: 0.7;
  }

  .sticky-btn-solid {
    background-color: rgb(var(--color-button));
    border: none;
    border-radius: var(--buttons-radius, 25px);
    padding: 1.2rem 3rem;
    font-size: 1.3rem;
    font-weight: 800;
    text-transform: uppercase;
    cursor: pointer;
    color: rgb(var(--color-button-text));
    transition: opacity 0.2s ease;
  }

  .sticky-btn-solid:hover {
    opacity: 0.8;
  }

  @media screen and (max-width: 989px) {
    .product-tabs-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
  }

  @media screen and (max-width: 749px) {
    .sticky-bar-inner {
      flex-direction: column;
      gap: 1.5rem;
      align-items: center;
    }
    .sticky-bar-left {
      align-items: center;
    }
    .sticky-bar-right {
      width: 100%;
      justify-content: center;
    }
    .sticky-btn-outline, .sticky-btn-solid {
      flex: 1;
      padding: 1rem;
      font-size: 1.2rem;
      max-width: 180px;
    }
  }
{%- endstyle -%}

<div class="product-tabs-section color-{{ block.settings.color_scheme }} gradient section-{{ section.id }}-padding" id="ProductTabs-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="page-width">
    <div class="product-tabs-grid">
      
      <!-- Left Column: Tab contents -->
      <div class="product-tabs-left">
        <div class="product-tabs-nav-wrapper">
          <div class="product-tabs-nav" role="tablist">
            {%- if block.settings.description != blank or product.description != blank -%}
              <button class="product-tab-btn is-active" role="tab" data-tab="tab-desc" aria-selected="true">{{ block.settings.tab_1_title }}</button>
            {%- endif -%}
            {%- if block.settings.features != blank -%}
              <button class="product-tab-btn" role="tab" data-tab="tab-features" aria-selected="false">{{ block.settings.tab_2_title }}</button>
            {%- endif -%}
            {%- if block.settings.specifications != blank -%}
              <button class="product-tab-btn" role="tab" data-tab="tab-specs" aria-selected="false">{{ block.settings.tab_3_title }}</button>
            {%- endif -%}
            {%- if block.settings.accessories != blank -%}
              <button class="product-tab-btn" role="tab" data-tab="tab-accessories" aria-selected="false">{{ block.settings.tab_4_title }}</button>
            {%- endif -%}
            {%- if block.settings.faq != blank -%}
              <button class="product-tab-btn" role="tab" data-tab="tab-faq" aria-selected="false">{{ block.settings.tab_5_title }}</button>
            {%- endif -%}
          </div>
        </div>
        
        <div class="product-tabs-content">
          {%- if block.settings.description != blank or product.description != blank -%}
            <div class="product-tab-panel is-active" id="tab-desc" role="tabpanel">
              <div class="rte">
                {{ block.settings.description | default: product.description }}
              </div>
            </div>
          {%- endif -%}
          
          {%- if block.settings.features != blank -%}
            <div class="product-tab-panel" id="tab-features" role="tabpanel">
              <div class="rte">
                {{ block.settings.features }}
              </div>
            </div>
          {%- endif -%}
          
          {%- if block.settings.specifications != blank -%}
            <div class="product-tab-panel" id="tab-specs" role="tabpanel">
              <div class="rte">
                {{ block.settings.specifications }}
              </div>
            </div>
          {%- endif -%}
          
          {%- if block.settings.accessories != blank -%}
            <div class="product-tab-panel" id="tab-accessories" role="tabpanel">
              <div class="rte">
                {{ block.settings.accessories }}
              </div>
            </div>
          {%- endif -%}
          
          {%- if block.settings.faq != blank -%}
            <div class="product-tab-panel" id="tab-faq" role="tabpanel">
              <div class="rte">
                {{ block.settings.faq }}
              </div>
            </div>
          {%- endif -%}
        </div>
      </div>
      
      <!-- Right Column: Specs Grid with Icons -->
      <div class="product-tabs-right">
        <div class="product-features-grid">
          {%- for i in (1..6) -%}
            {%- capture label_key -%}feature_label_{{ i }}{%- endcapture -%}
            {%- capture icon_key -%}feature_icon_{{ i }}{%- endcapture -%}
            {%- capture svg_key -%}feature_custom_svg_{{ i }}{%- endcapture -%}
            
            {%- assign label_val = block.settings[label_key] -%}
            {%- assign icon_val = block.settings[icon_key] -%}
            {%- assign svg_val = block.settings[svg_key] -%}
            
            {%- if label_val != blank -%}
              <div class="feature-grid-item">
                <div class="feature-grid-icon">
                  {%- if svg_val != blank -%}
                    {{ svg_val }}
                  {%- else -%}
                    {%- case icon_val -%}
                      {%- when 'ruler' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
                      {%- when 'seat' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16v16H4z"></path></svg>
                      {%- when 'gear' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                      {%- when 'chain' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
                      {%- when 'gps' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                      {%- when 'padlock' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                      {%- when 'battery' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="7" width="14" height="10" rx="2" ry="2"></rect><line x1="22" y1="11" x2="22" y2="13"></line></svg>
                      {%- when 'speed' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
                    {%- endcase -%}
                  {%- endif -%}
                </div>
                <span class="feature-grid-label">{{ label_val | escape }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Bottom Sticky Bar -->
{%- if block.settings.enable_sticky_bar -%}
<div class="product-sticky-bar color-{{ block.settings.color_scheme }}" id="ProductStickyBar-{{ section.id }}">
  <div class="page-width sticky-bar-inner">
    
    <div class="sticky-bar-left">
      <span class="sticky-product-title">{{ product.title | escape }}</span>
      <span class="sticky-product-price">{{ product.price | money }}</span>
    </div>
    
    <div class="sticky-bar-right">
      {%- if block.settings.btn1_text != blank -%}
        <button type="button" class="sticky-btn-outline" onclick="{% if block.settings.btn1_link != blank %}window.location.href='{{ block.settings.btn1_link }}'{% else %}document.querySelector('.product-form__buttons .button--secondary')?.click() || alert('Action triggered'){% endif %}">
          {{ block.settings.btn1_text }}
        </button>
      {%- endif -%}
      {%- if block.settings.btn2_text != blank -%}
        <button type="button" class="sticky-btn-solid" onclick="document.querySelector('.product-form__buttons button[type=submit]')?.click()">
          {{ block.settings.btn2_text }}
        </button>
      {%- endif -%}
    </div>
    
  </div>
</div>
{%- endif -%}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // 1. Tab switching logic
    const tabSection = document.getElementById('ProductTabs-{{ section.id }}');
    if(!tabSection) return;

    const tabButtons = tabSection.querySelectorAll('.product-tab-btn');
    const tabPanels = tabSection.querySelectorAll('.product-tab-panel');
    
    tabButtons.forEach(btn => {
      btn.addEventListener('click', function() {
        const targetId = this.dataset.tab;
        
        tabButtons.forEach(b => {
          b.classList.remove('is-active');
          b.setAttribute('aria-selected', 'false');
        });
        tabPanels.forEach(p => p.classList.remove('is-active'));
        
        this.classList.add('is-active');
        this.setAttribute('aria-selected', 'true');
        const panel = tabSection.querySelector('#' + targetId);
        if(panel) panel.classList.add('is-active');
      });
    });
    
    // 2. Scroll-triggered sticky bar logic
    const stickyBar = document.getElementById('ProductStickyBar-{{ section.id }}');
    
    if (stickyBar && tabSection) {
      window.addEventListener('scroll', function() {
        const tabsOffset = tabSection.getBoundingClientRect().top + window.scrollY;
        
        if (window.scrollY >= tabsOffset - 100) {
          stickyBar.classList.add('is-visible');
        } else {
          stickyBar.classList.remove('is-visible');
        }
      });
    }
  });
</script>
