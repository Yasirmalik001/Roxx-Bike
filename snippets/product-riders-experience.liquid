
<style>
  .video-thumbnails .swiper-slide video{width:100%;height:auto;object-fit:cover;border:2px solid transparent;cursor:pointer;}
  .video-popup{position:fixed;top:0;left:0;right:0;bottom:0;margin:0 !important;inset:0;z-index:20000;display:none;justify-content:center;align-items:center;transform:none !important;background:rgba(0,0,0,0.8);width:100%;height:100%;backdrop-filter:blur(25px);}
  .swiper-wrapper-md{padding-block:10px;display:flex;align-items:center;gap:15px;margin-top:var(--video-margin-top,20px);margin-bottom:var(--video-margin-bottom,20px);flex-wrap:nowrap;overflow-x:scroll !important;overflow-y:hidden;-webkit-overflow-scrolling:touch;scroll-behavior:smooth;transform:translate3d(0,0,0);right:-100%;scrollbar-width:none;}
  .headingCustom span{z-index:2;}
.headingCustom {
    position: relative;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: start;
    font-size: .95em;
    font-family: Inter;
    font-weight: 600;
    font-style: Semi Bold;
    font-size: 12px;
    leading-trim: NONE;
    line-height: 100%;
    letter-spacing: 0%;
    text-transform: uppercase;
    color: #545453;
}
.video-thumbnails-container {
    margin-top: 50px !important;
}
  .preview-title-story{font-size:12px;line-height:16px;max-width:128px !important;font-weight:400;text-align:center;word-wrap:break-word;}
  .video-popup.active{display:flex !important;}
  body:has(.video-popup.active){overflow:hidden;height:100vh;position:fixed;width:100%;}
  body:has(.video-popup.active) header{display:none !important;}
  body:has(.video-popup.active) .MA-announcement-container{display:none !important;}
  body:has(.video-popup.active) .MA-swiper-header{display:none !important;}
  .video-popup .main-video{max-width:38%;height:100%;margin:auto;z-index:10001;}
  video.mainPopupVideoEl{height:100%;width:100%;object-fit:cover;}
  .video-popup .thumbnail-strip{position:absolute;left:40px;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;gap:10px;z-index:10001;}
  .video-popup .thumbnail-strip .swiper-slide img{width:84px;height:84px;object-fit:cover;cursor:pointer;transition:transform 0.2s;display:block;background:#ffffff45;color:transparent;}
  .video-popup .thumbnail-strip .swiper-slide-thumb-active img{border:2px solid #fff;}
  .video-popup .thumbnail-strip .swiper-button-disabled{display:none;}
  .swiper-popup-thumbs{height:300px !important;overflow:hidden;}
  .swiper-popup-thumbs .swiper-slide{height:auto;}
  .swiper-button-lock{display:block !important;opacity:1;pointer-events:auto;}
  .swiper-popup-thumbs .swiper-wrapper{flex-direction:column !important;}
  .video-popup .thumbnail-strip{width:auto;margin-left:20px;position:absolute;left:0;top:50%;display:flex;align-items:center;flex-direction:column;gap:6px;}
  .video-popup .thumbnail-strip .swiper-slide video{width:84px;height:84px;object-fit:cover;}
  #closeVideoModal{position:fixed;top:20px;left:20px;font-size:30px;color:#fff;background:none;border:none;cursor:pointer;z-index:200001;width:40px;height:40px;}
  .video-popup.active{display:flex !important;}
  .swiper-button-prev-thumb,.swiper-button-next-thumb{color:#fff;width:28px;height:28px;border-radius:50%;position:absolute;z-index:10;display:flex;justify-content:center;align-items:center;font-size:18px;cursor:pointer;}
  .swiper-button-prev-thumb{top:-50px;transform:rotate(180deg);}
  .swiper-button-next-thumb{bottom:-45px;}
  video.desktop-video-md{width:100%;height:200px;cursor:pointer;}
  .swiper-popup-thumbs .swiper-slide-active video{border:1px solid #fff;}
  .swiper-slide-md{flex:0 0 auto;display:flex;flex-direction:column;align-items:center;cursor:pointer;}
  .swiper-slide-md video{aspect-ratio:9/16;width:unset !important;margin:0 auto;overflow:hidden;height:227px;object-fit:cover;}
  .swiper-main-video button{position:absolute;top:14px;right:7px;background-color:transparent;border:1px solid transparent;border-radius:50%;cursor:pointer;display:flex;height:48px;justify-content:center;width:48px;z-index:9999;}
  .swiper-slide-md:hover video{transform:scale(1.04);transition:transform 0.18s ease-in-out;}
  .swiper-main-video .speaker-btn .mute-btn{display:none;}
  .swiper-main-video .pause-overlay{position:absolute;top:0;left:0;width:100%;height:100%;display:none;align-items:center;justify-content:center;cursor:pointer;background:rgba(0,0,0,0.2);}
  .swiper-main-video .pause-overlay svg{width:74px;height:74px;}
  .swiper-main-video .pause-overlay.show-overlay{display:flex;}
  .swiper-main-video .speaker-btn.unmuted .unmute-btn{display:none;}
  .swiper-main-video .speaker-btn.unmuted .mute-btn{display:inline-block;}
  @media screen and (max-width:1024px){
    .video-popup .main-video{max-width:100%;}
    .thumbnail-strip{display:none !important;}
  }
</style>
<div class="video-thumbnails-container">
  <div class="headingCustom">
    <span
      ><strong>{{ block.settings.Heading }}</strong></span
    >
  </div>
  <div
    class="video-thumbnails"
    style="--video-margin-top: {{ block.settings.video_margin_top }}px; --video-margin-bottom: {{ block.settings.video_margin_bottom }}px;"
  >
    <div class=" swiper-thumbs">
      <div class="swiper-wrapper-md">
        {% assign video_sources = '' %}

        {% if block.settings.use_metafields %}
          {% assign video_sources = product.metafields.custom.video_thumbnails.value %}
          {% for video in video_sources %}
            <div class="swiper-slide-md">
              {{
                video
                | video_tag:
                  autoplay: true,
                  loop: true,
                  muted: true,
                  controls: false,
                  class: 'desktop-video-md',
                  loading: lazy
              }}
            </div>
          {% endfor %}
        {% else %}
          {%- for i in (1..5) -%}
            {%- capture video_key -%}video_{{ i }}{%- endcapture -%}
            {%- capture text_key -%}video_text_{{ i }}{%- endcapture -%}
            {%- assign video_file = block.settings[video_key] -%}
            {%- assign video_text = block.settings[text_key] -%}
            {%- if video_file != blank -%}
              <div class="swiper-slide-md">
                {{
                  video_file
                  | video_tag:
                    autoplay: true,
                    loop: true,
                    muted: true,
                    controls: false,
                    class: 'desktop-video-md',
                    loading: lazy
                }}
              </div>
            {%- endif -%}
          {%- endfor -%}
        {% endif %}
      </div>
    </div>
  </div>

  <div class="video-popup" id="videoModal">
    <div class="close-btn" id="closeVideoModal">
      <svg width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
